{
  "name": "vscode-aiir",
  "displayName": "AIIR",
  "description": "AIIR Language Extension",
  "version": "0.0.14",
  "publisher": "llvm-vs-code-extensions",
  "homepage": "https://aiir.llvm.org/",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "LLVM",
    "AIIR",
    "PDLL",
    "TableGen",
    "tblgen",
    "tablegen"
  ],
  "activationEvents": [
    "onFileSystem:aiir.bytecode-aiir",
    "onCustomEditor:aiir.bytecode",
    "onLanguage:aiir",
    "onLanguage:pdll",
    "onLanguage:tablegen"
  ],
  "main": "./out/extension",
  "scripts": {
    "vscode:prepublish": "tsc -p ./",
    "compile": "tsc -watch -p ./",
    "format": "clang-format -i --glob=\"{src,test}/*.ts\"",
    "package": "vsce package",
    "publish": "vsce publish",
    "publish-openvsx": "ovsx publish --baseImagesUrl https://raw.githubusercontent.com/llvm/vscode-aiir/main/",
    "git-clang-format": "git-clang-format"
  },
  "dependencies": {
    "base64-js": "^1.5.1",
    "chokidar": "3.5.2",
    "minimatch": "^3.0.5",
    "semver": "^7.5.2",
    "vscode-languageclient": "^8.0.2-next.5"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^25.0.3",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.7.1",
    "clang-format": "^1.8.0",
    "ovsx": "^0.10.7",
    "typescript": "^4.9.5",
    "vscode-test": "^1.3.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/llvm/vscode-aiir.git"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "aiir.bytecode",
        "displayName": "AIIR Bytecode",
        "priority": "default",
        "selector": [
          {
            "filenamePattern": "*.aiirbc"
          }
        ]
      }
    ],
    "languages": [
      {
        "id": "aiir",
        "aliases": [
          "AIIR",
          "aiir"
        ],
        "extensions": [
          ".aiir",
          ".aiirbc"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "aiir-injection"
      },
      {
        "id": "pdll",
        "aliases": [
          "PDLL",
          "pdll"
        ],
        "extensions": [
          ".pdll"
        ],
        "configuration": "./pdll-language-configuration.json"
      },
      {
        "id": "tablegen",
        "aliases": [
          "TableGen",
          "tblgen"
        ],
        "extensions": [
          ".td"
        ],
        "configuration": "./tablegen-language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "aiir",
        "scopeName": "source.aiir",
        "path": "./grammar.json"
      },
      {
        "language": "aiir-injection",
        "scopeName": "markdown.aiir.codeblock",
        "path": "markdown-grammar.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.aiir": "aiir",
          "meta.embedded.block.pdll": "pdll",
          "meta.embedded.block.tablegen": "tablegen"
        }
      },
      {
        "scopeName": "source.cpp.aiir",
        "path": "./cpp-grammar.json",
        "injectTo": [
          "source.cpp"
        ],
        "embeddedLanguages": {
          "source.aiir": "aiir"
        }
      },
      {
        "language": "pdll",
        "scopeName": "source.pdll",
        "path": "./pdll-grammar.json"
      },
      {
        "language": "tablegen",
        "scopeName": "source.tablegen",
        "path": "./tablegen-grammar.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "AIIR",
      "properties": {
        "aiir.server_path": {
          "scope": "resource",
          "type": "string",
          "description": "The file path of the aiir-lsp-server executable."
        },
        "aiir.aiir_additional_server_args": {
          "scope": "resource",
          "type": "array",
          "description": "A list of additional arguments for aiir-lsp-server executable. E.g. --log=verbose."
        },
        "aiir.pdll_server_path": {
          "scope": "resource",
          "type": "string",
          "description": "The file path of the aiir-pdll-lsp-server executable."
        },
        "aiir.pdll_compilation_databases": {
          "scope": "resource",
          "type": "array",
          "description": "A list of `pdll_compile_commands.yml` database files containing information about .pdll files processed by the server."
        },
        "aiir.pdll_additional_server_args": {
          "scope": "resource",
          "type": "array",
          "description": "A list of additional arguments for pdll-lsp-server executable. E.g. --log=verbose."
        },
        "aiir.tablegen_server_path": {
          "scope": "resource",
          "type": "string",
          "description": "The file path of the tblgen-lsp-server executable."
        },
        "aiir.tablegen_compilation_databases": {
          "scope": "resource",
          "type": "array",
          "description": "A list of `tablegen_compile_commands.yml` database files containing information about .td files processed by the server."
        },
        "aiir.tablegen_additional_server_args": {
          "scope": "resource",
          "type": "array",
          "description": "A list of additional arguments for tblgen-lsp-server executable. E.g. --log=verbose."
        },
        "aiir.onSettingsChanged": {
          "type": "string",
          "default": "prompt",
          "description": "Action taken when a setting change requires a server restart to take effect.",
          "enum": [
            "prompt",
            "restart",
            "ignore"
          ],
          "enumDescriptions": [
            "Prompt the user for restarting the server",
            "Automatically restart the server",
            "Do nothing"
          ]
        }
      }
    },
    "commands": [
      {
        "command": "aiir.restart",
        "title": "aiir: Restart language server"
      },
      {
        "command": "aiir.viewPDLLOutput",
        "title": "aiir-pdll: View PDLL output"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "aiir.viewPDLLOutput",
          "group": "z_commands",
          "when": "editorLangId == pdll"
        }
      ]
    }
  }
}
