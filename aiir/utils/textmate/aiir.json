{
  "name": "AIIR",
  "fileTypes": [
    "aiir"
  ],
  "patterns": [
    {
      "include": "#comment"
    },
    {
      "include": "#string"
    },
    {
      "include": "#top_level_entity"
    }
  ],
  "repository": {
    "comment": {
      "match": "\/\/.*$",
      "name": "comment.line.double-slash.aiir"
    },
    "number": {
      "patterns": [
        {
          "match": "(\\W)?([0-9]+\\.[0-9]*)([eE][+-]?[0-9]+)?",
          "name": "constant.numeric.aiir"
        },
        {
          "match": "([\\W])?(0x[0-9a-zA-Z]+)",
          "captures": {
            "2": {
              "name": "constant.numeric.aiir"
            }
          }
        },
        {
          "match": "([\\Wx])?([0-9]+)",
          "captures": {
            "2": {
              "name": "constant.numeric.aiir"
            }
          }
        }
      ]
    },
    "string": {
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.aiir"
        }
      },
      "patterns": [
        {
          "match": "\\\\[nt\"]",
          "name": "constant.character.escape.aiir"
        }
      ],
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.aiir"
        }
      },
      "name": "string.quoted.double.aiir"
    },
    "top_level_entity": {
      "patterns": [
        {
          "include": "#attribute_alias_def"
        },
        {
          "include": "#type_alias_def"
        },
        {
          "include": "#operation_body"
        }
      ]
    },
    "attribute_alias_def": {
      "match": "^\\s*(\\#\\w+)\\b\\s+\\=",
      "captures": {
        "1": {
          "name": "constant.language.aiir"
        }
      }
    },
    "type_alias_def": {
      "match": "^\\s*(\\!\\w+)\\b\\s+\\=",
      "captures": {
        "1": {
          "name": "entity.name.type.aiir"
        }
      }
    },
    "operation": {
      "patterns": [
        {
          "match": "^\\s*(\\%[\\%\\w\\:\\,\\s]+)\\s+\\=\\s+([\\w\\.\\$\\-]+)\\b",
          "captures": {
            "1": {
              "patterns": [
                {
                  "include": "#ssa_value"
                }
              ]
            },
            "2": {
              "name": "variable.other.enummember.aiir"
            }
          }
        },
        {
          "match": "^\\s*([\\w\\.\\$\\-]+)\\b(?=[^\\<\\:])",
          "name": "variable.other.enummember.aiir"
        }
      ]
    },
    "operation_body": {
      "patterns": [
        {
          "include": "#operation"
        },
        {
          "include": "#region_body_or_attr_dict"
        },
        {
          "include": "#comment"
        },
        {
          "include": "#ssa_value"
        },
        {
          "include": "#block"
        },
        {
          "include": "#attribute_value"
        },
        {
          "include": "#bare_identifier"
        }
      ]
    },
    "region_body_or_attr_dict": {
      "patterns": [
        {
          "begin": "\\{\\s*(?=\\%|\\/|\\^)",
          "patterns": [
            {
              "include": "#operation_body"
            }
          ],
          "end": "\\}"
        },
        {
          "begin": "\\{\\s*(?=[^\\}]*$)",
          "patterns": [
            {
              "include": "#operation_body"
            }
          ],
          "end": "\\}"
        },
        {
          "begin": "\\{\\s*(?=\\%)",
          "patterns": [
            {
              "include": "#operation_body"
            }
          ],
          "end": "\\}"
        },
        {
          "begin": "\\{\\s*(?=.*$)",
          "patterns": [
            {
              "include": "#attribute_dictionary_body"
            }
          ],
          "end": "\\}"
        }
      ]
    },
    "attribute_value": {
      "patterns": [
        {
          "include": "#string"
        },
        {
          "include": "#comment"
        },
        {
          "include": "#number"
        },
        {
          "match": "\\b(false|true|unit)\\b",
          "name": "constant.language.aiir"
        },
        {
          "begin": "\\b(affine_map|affine_set)\\s*(\\<)",
          "beginCaptures": {
            "1": {
              "name": "constant.language.aiir"
            },
            "2": {
              "name": "punctuation.bracket.angle.begin.aiir"
            }
          },
          "patterns": [
            {
              "match": "\\b(ceildiv|floordiv|mod|symbol)\\b",
              "name": "entity.name.function.aiir"
            },
            {
              "match": "\\b([\\w\\.\\$\\-]+)\\b",
              "name": "variable.aiir"
            },
            {
              "include": "#number"
            }
          ],
          "end": "\\)(\\>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.bracket.angle.end.aiir"
            }
          }
        },
        {
          "begin": "\\b(dense|opaque|sparse)\\s*(\\<)",
          "beginCaptures": {
            "1": {
              "name": "constant.language.aiir"
            },
            "2": {
              "name": "punctuation.bracket.angle.begin.aiir"
            }
          },
          "patterns": [
            {
              "include": "#attribute_value"
            }
          ],
          "end": "(\\>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.bracket.angle.end.aiir"
            }
          }
        },
        {
          "begin": "\\[",
          "patterns": [
            {
              "include": "#attribute_value"
            },
            {
              "include": "#operation_body"
            }
          ],
          "end": "\\]"
        },
        {
          "begin": "\\{",
          "patterns": [
            {
              "include": "#attribute_dictionary_body"
            }
          ],
          "end": "\\}"
        },
        {
          "match": "(\\@[\\w+\\$\\-\\.]*)",
          "name": "entity.name.function.aiir"
        },
        {
          "begin": "(\\#[\\w\\$\\-\\.]+)(\\<)",
          "beginCaptures": {
            "1": {
              "name": "constant.language.aiir"
            },
            "2": {
              "name": "punctuation.bracket.angle.begin.aiir"
            }
          },
          "patterns": [
            {
              "include": "#attribute_value"
            },
            {
              "match": "\\-\\>|\\>\\="
            },
            {
              "include": "#bare_identifier"
            }
          ],
          "end": "(\\>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.bracket.angle.end.aiir"
            }
          }
        },
        {
          "match": "\\#[\\w\\$\\-\\.]+\\b",
          "name": "constant.language.aiir"
        },
        {
          "include": "#type_value"
        },
        {
          "begin": "(\\<)",
          "beginCaptures": {
            "1": {
              "name": "punctuation.bracket.angle.begin.aiir"
            }
          },
          "patterns": [
            {
              "include": "#attribute_value"
            },
            {
              "include": "#bare_identifier"
            }
          ],
          "end": "(\\>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.bracket.angle.end.aiir"
            }
          }
        }
      ]
    },
    "attribute_dictionary_body": {
      "patterns": [
        {
          "include": "#comment"
        },
        {
          "include": "#string"
        },
        {
          "include": "#attribute_value"
        },
        {
          "match": "(\\%)?\\b([\\w\\.\\-\\$\\:0-9]+)\\b\\s*(?=\\=|\\,|\\})",
          "name": "variable.other.aiir"
        }
      ]
    },
    "type_value": {
      "patterns": [
        {
          "begin": "(\\![\\w\\$\\-\\.]+)(\\<)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.type.aiir"
            },
            "2": {
              "name": "punctuation.bracket.angle.begin.aiir"
            }
          },
          "patterns": [
            {
              "include": "#attribute_value"
            },
            {
              "match": "\\-\\>|\\>\\=",
              "name": "punctuation.other.aiir"
            },
            {
              "include": "#bare_identifier"
            }
          ],
          "end": "(\\>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.bracket.angle.end.aiir"
            }
          }
        },
        {
          "match": "\\![\\w\\$\\-\\.]+\\b",
          "name": "entity.name.type.aiir"
        },
        {
          "begin": "(complex|memref|tensor|tuple|vector)(\\<)",
          "beginCaptures": {
            "1": {
              "name": "entity.name.type.aiir"
            },
            "2": {
              "name": "punctuation.bracket.angle.begin.aiir"
            }
          },
          "patterns": [
            {
              "match": "[\\?x0-9\\[\\]]+",
              "captures": {
                "0": {
                  "patterns": [
                    {
                      "include": "#number"
                    }
                  ]
                }
              }
            },
            {
              "include": "#attribute_value"
            },
            {
              "match": "\\-\\>|\\>\\=",
              "name": "punctuation.other.aiir"
            },
            {
              "include": "#bare_identifier"
            }
          ],
          "end": "(\\>)",
          "endCaptures": {
            "1": {
              "name": "punctuation.bracket.angle.end.aiir"
            }
          }
        },
        {
          "match": "bf16|f16|f32|f64|f80|f128|index|none|(u|s)?i[0-9]+",
          "name": "entity.name.type.aiir"
        }
      ]
    },
    "bare_identifier": {
      "match": "\\b([\\w\\.\\$\\-]+)\\b",
      "name": "keyword.other.aiir"
    },
    "ssa_value": {
      "match": "\\%[\\w\\.\\$\\:\\#]+",
      "name": "variable.other.aiir"
    },
    "block": {
      "match": "\\^[\\w\\d_$\\.-]+",
      "name": "keyword.control.aiir"
    }
  },
  "scopeName": "source.aiir"
}