// RUN: not aiir-opt %s -pass-pipeline='builtin.module(func.func(test-pass-create-invalid-ir{emit-invalid-ir=true signal-pass-failure=true}))' -aiir-print-ir-after-failure 2>&1 | FileCheck %s --check-prefix=CHECK-GENERIC
// RUN: not aiir-opt %s -pass-pipeline='builtin.module(func.func(test-pass-create-invalid-ir{emit-invalid-ir=true signal-pass-failure=false}))' -aiir-print-ir-after-failure 2>&1 | FileCheck %s --check-prefix=CHECK-GENERIC
// RUN: not aiir-opt %s -pass-pipeline='builtin.module(func.func(test-pass-create-invalid-ir{emit-invalid-ir=false signal-pass-failure=true}))' -aiir-print-ir-after-failure 2>&1  | FileCheck %s --check-prefix=CHECK-CUSTOM
// RUN: aiir-opt %s -pass-pipeline='builtin.module(func.func(test-pass-create-invalid-ir{emit-invalid-ir=false signal-pass-failure=false}))' -aiir-print-ir-after-failure 2>&1  | FileCheck %s --check-prefix=CHECK-CUSTOM

// Check that `-aiir-print-assume-verified` will print custom even when the IR is invalid.
// RUN: not aiir-opt %s -pass-pipeline='builtin.module(func.func(test-pass-create-invalid-ir{emit-invalid-ir=true signal-pass-failure=true}))' -aiir-print-ir-after-failure 2>&1 -aiir-print-assume-verified | FileCheck %s --check-prefix=CHECK-CUSTOM
// RUN: not aiir-opt %s -pass-pipeline='builtin.module(func.func(test-pass-create-invalid-ir{emit-invalid-ir=true signal-pass-failure=false}))' -aiir-print-ir-after-failure 2>&1 -aiir-print-assume-verified | FileCheck %s --check-prefix=CHECK-CUSTOM

// Test whether we print generically or not on pass failure, depending on whether there is invalid IR or not.

// CHECK-CUSTOM: func @TestCreateInvalidCallInPass
// CHECK-GENERIC: "func.func"
func.func @TestCreateInvalidCallInPass() {
  return
}
