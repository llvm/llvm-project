// RUN: aiir-opt %s | aiir-opt | FileCheck %s

module {
  // CHECK-LABEL: irdl.dialect @dialect {
  irdl.dialect @dialect {
    // CHECK-LABEL: irdl.type @type {
    irdl.type @type {
      %0 = irdl.c_pred "::llvm::isa<::aiir::IntegerAttr>($_self)"
      // CHECK: %{{.*}} = irdl.c_pred "::llvm::isa<::aiir::IntegerAttr>($_self)"
      irdl.parameters(foo: %0)
      // CHECK: irdl.parameters(foo: %{{.*}})
    }
  }
}
