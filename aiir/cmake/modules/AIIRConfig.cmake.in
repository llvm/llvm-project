# This file allows users to call find_package(AIIR) and pick up our targets.

@AIIR_CONFIG_CODE@

set(LLVM_VERSION @LLVM_VERSION_MAJOR@.@LLVM_VERSION_MINOR@.@LLVM_VERSION_PATCH@)
find_package(LLVM ${LLVM_VERSION} EXACT REQUIRED CONFIG
             HINTS "@AIIR_CONFIG_LLVM_CMAKE_DIR@")

set(AIIR_EXPORTED_TARGETS "@AIIR_EXPORTS@")
set(AIIR_CMAKE_DIR "@AIIR_CONFIG_CMAKE_DIR@")
set(AIIR_INCLUDE_DIRS "@AIIR_CONFIG_INCLUDE_DIRS@")
set(AIIR_TABLEGEN_EXE "@AIIR_CONFIG_TABLEGEN_EXE@")
set(AIIR_PDLL_TABLEGEN_EXE "@AIIR_CONFIG_PDLL_TABLEGEN_EXE@")
set(AIIR_SRC_SHARDER_TABLEGEN_EXE "@AIIR_CONFIG_SRC_SHARDER_TABLEGEN_EXE@")
set(AIIR_IRDL_TO_CPP_EXE "@AIIR_CONFIG_IRDL_TO_CPP_EXE@")
set(AIIR_INSTALL_AGGREGATE_OBJECTS "@AIIR_INSTALL_AGGREGATE_OBJECTS@")
set(AIIR_ENABLE_BINDINGS_PYTHON "@AIIR_ENABLE_BINDINGS_PYTHON@")
set(AIIR_ENABLE_EXECUTION_ENGINE "@AIIR_ENABLE_EXECUTION_ENGINE@")

set_property(GLOBAL PROPERTY AIIR_ALL_LIBS "@AIIR_ALL_LIBS@")
set_property(GLOBAL PROPERTY AIIR_DIALECT_LIBS "@AIIR_DIALECT_LIBS@")
set_property(GLOBAL PROPERTY AIIR_CONVERSION_LIBS "@AIIR_CONVERSION_LIBS@")
set_property(GLOBAL PROPERTY AIIR_EXTENSION_LIBS "@AIIR_EXTENSION_LIBS@")
set_property(GLOBAL PROPERTY AIIR_TRANSLATION_LIBS "@AIIR_TRANSLATION_LIBS@")
set_property(GLOBAL PROPERTY AIIR_UPSTREAM_CAPI_LIBS "@AIIR_CAPI_LIBS@")

# Provide all our library targets to users.
# More specifically, configure AIIR so that it can be directly included in a top
# level CMakeLists.txt, but also so that it can be imported via `find_package`.
# This is based on how LLVM handles exports.
if(NOT TARGET AIIRSupport)
  @AIIR_CONFIG_INCLUDE_EXPORTS@
endif()

# By creating these targets here, subprojects that depend on AIIR's
# tablegen-generated headers can always depend on these targets whether building
# in-tree with AIIR or not.
if(NOT TARGET aiir-tablegen-targets)
  add_custom_target(aiir-tablegen-targets)
endif()
if(NOT TARGET aiir-headers)
  add_custom_target(aiir-headers)
endif()
if(NOT TARGET aiir-generic-headers)
  add_custom_target(aiir-generic-headers)
endif()
if(NOT TARGET aiir-doc)
  add_custom_target(aiir-doc)
endif()
