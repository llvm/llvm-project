REQUIRES: ld.lld

# Show that DTLTO input file serialization interacts correctly with the
# ThinLTO cache.
#
# To handle bitcode inputs that are not in individual files on disk, such as
# members of non-thin archives, DTLTO serializes such input bitcode to a
# temporary individual file on disk. This serialization should only be
# performed if the backend compilation is required. A backend compilation is
# only required if there is a miss in the ThinLTO cache for that module, or a
# module is imported by a module that has missed in the ThinLTO cache.
#
# Test DTLTO input serialization across three cases:
#   1. None of the backend compilations hit in the ThinLTO cache.
#   2. All of the backend compilations hit in the ThinLTO cache.
#   3. Some backend compilations hit in the ThinLTO cache and some miss.

RUN: rm -rf %t && split-file %s %t && cd %t

RUN: %clang --target=x86_64-linux-gnu -O2 -flto=thin -c t1.c t2.c
RUN: llvm-ar rcs t1.a t1.o
RUN: llvm-ar rcs t2.a t2.o

RUN: mkdir cache.dir

DEFINE: %{link} =  \
DEFINE:    %clang --target=x86_64-linux-gnu -fuse-ld=lld -shared -nostdlib \
DEFINE:     -O2 -flto=thin \
DEFINE:     -fthinlto-distributor=%python \
DEFINE:     -Xthinlto-distributor=%llvm_src_root/utils/dtlto/local.py \
DEFINE:     -Wl,--thinlto-cache-dir=cache.dir \
DEFINE:     -Wl,--save-temps

# 1. None of the backend compilations hit in the ThinLTO cache.
#
# Both t1.o and t2.o require backend compilation, so both should be serialized.
# Each backend compilation should produce:
#   * a native object
#   * a thinlto.bc file
#   * a serialized temporary bitcode file (an extracted archive member)
RUN: mkdir none
RUN: %{link} -Wl,--whole-archive t1.a t2.a -o none/t.elf
RUN: ls none | sort | FileCheck %s --check-prefixes=JSON,ELF,NONE
JSON: {{^}}t.[[#PID:]].dist-file.json{{$}}
ELF: {{^}}t.elf.resolution.txt{{$}}
NONE-NEXT: {{^}}t1.a(t1.o at [[#T1_OFFSET:]]).1.[[#%X,HEXPID:]].1.[[#PID]].native.o{{$}}
NONE-NEXT: {{^}}t1.a(t1.o at [[#T1_OFFSET]]).1.[[#%X,HEXPID]].1.[[#PID]].native.o.thinlto.bc{{$}}
NONE-NEXT: {{^}}t1.a(t1.o at [[#T1_OFFSET]]).1.[[#%X,HEXPID]].o{{$}}
NONE-NEXT: {{^}}t2.a(t2.o at [[#T2_OFFSET:]]).2.[[#%X,HEXPID]].2.[[#PID]].native.o{{$}}
NONE-NEXT: {{^}}t2.a(t2.o at [[#T2_OFFSET]]).2.[[#%X,HEXPID]].2.[[#PID]].native.o.thinlto.bc{{$}}
NONE-NEXT: {{^}}t2.a(t2.o at [[#T2_OFFSET]]).2.[[#%X,HEXPID]].o{{$}}
NONE-NOT: {{.}}

# 2. All of the backend compilations hit in the ThinLTO cache.
#
# Both t1.o and t2.o are satisfied from the ThinLTO cache. No backend
# compilation runs, so there should be no .native.o files, no .thinlto.bc files,
# and no serialized archive-member bitcode files.
RUN: mkdir all
RUN: %{link} -Wl,--whole-archive t1.a t2.a -o all/t.elf
RUN: ls all | sort | FileCheck %s --check-prefixes=ELF,ALL
ALL-NOT: {{.}}

# 3. Some backend compilations hit in the ThinLTO cache and some miss.
#
# t1.o and t2.o are cached, but the new t3.o misses the cache and imports from
# t1.o:
#   * t3.o must be compiled and serialized
#   * cached t1.o must be serialized because t3.o imports from it.
#   * cached t2.o should not be serialized or compiled.
RUN: %clang --target=x86_64-linux-gnu -O2 -flto=thin -c t3.c
RUN: llvm-ar rcs t3.a t3.o
RUN: mkdir some
RUN: %{link} -Wl,--whole-archive t1.a t2.a t3.a -o some/t.elf
RUN: ls some | sort | FileCheck %s --check-prefixes=JSON,ELF,SOME
SOME-NEXT: {{^}}t1.a(t1.o at [[#T1_OFFSET:]]).1.[[#%X,HEXPID:]].o{{$}}
SOME-NEXT: {{^}}t3.a(t3.o at [[#T3_OFFSET:]]).3.[[#%X,HEXPID]].3.[[#PID]].native.o{{$}}
SOME-NEXT: {{^}}t3.a(t3.o at [[#T3_OFFSET]]).3.[[#%X,HEXPID]].3.[[#PID]].native.o.thinlto.bc{{$}}
SOME-NEXT: {{^}}t3.a(t3.o at [[#T3_OFFSET]]).3.[[#%X,HEXPID]].o{{$}}
SOME-NOT: {{.}}

#--- t1.c
__attribute__((retain)) int t1(int x) { return x; }

#--- t2.c
extern int t1(int);
__attribute__((retain)) int t2(int x) { return t1(x) + x; }

#--- t3.c
extern int t1(int);
__attribute__((retain)) int t3(int x) { return t1(x) + x; }
