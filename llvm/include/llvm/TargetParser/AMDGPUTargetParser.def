R600_GPU      ("cayman",  GK_CAYMAN,  FEATURE_FMA)
R600_GPU      ("turks",   GK_TURKS,   FEATURE_NONE)

#undef R600_GPU
#undef R600_GPU_ALIAS

#ifndef AMDGCN_GPU
#define AMDGCN_GPU(NAME, ENUM, ISAVERSION, FEATURES)
#endif

#ifndef AMDGCN_GPU_ALIAS
#define AMDGCN_GPU_ALIAS(NAME, ENUM)
#endif

