# RUN: yaml2obj %s -o %t
# RUN: llvm-nm %t | count 0
# RUN: llvm-nm --special-syms %t | FileCheck %s \
# RUN:   --implicit-check-not=file_sym --implicit-check-not=.text

## --special-syms should show mapping symbols but not STT_FILE or STT_SECTION.
# CHECK:     00000000 t $d.1
# CHECK:     00000000 t $t.1

!ELF
FileHeader:
  Class:           ELFCLASS32
  Data:            ELFDATA2LSB
  Type:            ET_REL
  Machine:         EM_CSKY
Sections:
  - Name:            .text
    Type:            SHT_PROGBITS
    Flags:           [ SHF_ALLOC, SHF_EXECINSTR ]
    AddressAlign:    0x4
Symbols:
  - Name:     ""
    Type:     STT_SECTION
    Section:  .text
  - Name:     file_sym
    Type:     STT_FILE
    Index:    SHN_ABS
  - Name:     $d.1
    Section:  .text
  - Name:     $t.1
    Section:  .text
