# REQUIRES: host-byteorder-little-endian

# RUN: rm -rf %t && split-file %s %t
# RUN: mkdir -p %t/tmp
# RUN: yaml2obj %t/a.yaml -o %t/tmp/a.o
# RUN: yaml2obj %t/b.yaml -o %t/tmp/b.o
# RUN: sed -e "s|DIR|%/t|g" %t/debug.map.in > %t/debug.map

# RUN: dsymutil --linker classic -y %t/debug.map -o %t/classic.dSYM
# RUN: llvm-objdump --section-headers %t/classic.dSYM/Contents/Resources/DWARF/debug.map | FileCheck %s --check-prefix=SIZE
# RUN: llvm-readobj --sections %t/classic.dSYM/Contents/Resources/DWARF/debug.map | FileCheck %s --check-prefix=SEG
# RUN: llvm-objdump -s --section=__probes --section=__probe_descs %t/classic.dSYM/Contents/Resources/DWARF/debug.map | FileCheck %s --check-prefix=DATA

# RUN: dsymutil --linker parallel -y %t/debug.map -o %t/parallel.dSYM
# RUN: llvm-objdump --section-headers %t/parallel.dSYM/Contents/Resources/DWARF/debug.map | FileCheck %s --check-prefix=SIZE
# RUN: llvm-readobj --sections %t/parallel.dSYM/Contents/Resources/DWARF/debug.map | FileCheck %s --check-prefix=SEG
# RUN: llvm-objdump -s --section=__probes --section=__probe_descs %t/parallel.dSYM/Contents/Resources/DWARF/debug.map | FileCheck %s --check-prefix=DATA

# SEG:      Name: __probe_descs
# SEG-NEXT: Segment: __LLVM
# SEG:      Name: __probes
# SEG-NEXT: Segment: __LLVM

# SIZE: __probe_descs 00000024
# SIZE: __probes      00000040

# DATA:      Contents of section __LLVM,__probe_descs:
# DATA-NEXT: {{[0-9a-f]+}} 0cc175b9 c0f1b6a8 94da52e8 10000000
# DATA-NEXT: {{[0-9a-f]+}} 016192eb 5ffee6ae 2fec94da 52e81000
# DATA-NEXT: {{[0-9a-f]+}} 00000162
# DATA:      Contents of section __LLVM,__probes:
# DATA-NEXT: {{[0-9a-f]+}} 0cc175b9 c0f1b6a8 05000020 5c855e09
# DATA-NEXT: {{[0-9a-f]+}} 4bdf284e 01800c02 80140380 0c048008
# DATA-NEXT: {{[0-9a-f]+}} 92eb5ffe e6ae2fec 05000020 c716fb29
# DATA-NEXT: {{[0-9a-f]+}} 298ad96a 01800c02 80140380 0c048008

#--- debug.map.in
---
triple:          'arm64-apple-darwin'
objects:
  - filename: DIR/tmp/a.o
    symbols:         []
  - filename: DIR/tmp/b.o
    symbols:         []
...

#--- a.yaml
--- !mach-o
FileHeader:
