        size:            18
        offset:          0x264
        align:           0
        reloff:          0x0
        nreloc:          0
        flags:           0x12000000
        reserved1:       0x0
        reserved2:       0x0
        reserved3:       0x0
        content:         0CC175B9C0F1B6A894DA52E8100000000161
      - sectname:        __compact_unwind
        segname:         __LD
        addr:            0x50
        size:            32
        offset:          0x278
        align:           3
        reloff:          0x2B8
        nreloc:          1
        flags:           0x2000000
        reserved1:       0x0
        reserved2:       0x0
        reserved3:       0x0
        content:         00000000000000003C0000000010000200000000000000000000000000000000
        relocations:
          - address:         0x0
            symbolnum:       1
