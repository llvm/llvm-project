  - cmd:             LC_BUILD_VERSION
    cmdsize:         24
    platform:        1
    minos:           1703936
    sdk:             1704960
    ntools:          0
  - cmd:             LC_SYMTAB
    cmdsize:         24
    symoff:          704
    nsyms:           5
    stroff:          784
    strsize:         32
  - cmd:             LC_DYSYMTAB
    cmdsize:         80
    ilocalsym:       0
    nlocalsym:       4
    iextdefsym:      4
    nextdefsym:      1
    iundefsym:       5
    nundefsym:       0
    tocoff:          0
    ntoc:            0
    modtaboff:       0
    nmodtab:         0
    extrefsymoff:    0
    nextrefsyms:     0
    indirectsymoff:  0
    nindirectsyms:   0
    extreloff:       0
    nextrel:         0
    locreloff:       0
    nlocrel:         0
LinkEditData:
