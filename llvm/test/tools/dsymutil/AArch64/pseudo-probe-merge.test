      n_type:          0xE
      n_sect:          1
      n_desc:          0
      n_value:         0
    - n_strx:          16
      n_type:          0xE
      n_sect:          2
      n_desc:          0
      n_value:         60
    - n_strx:          10
      n_type:          0xE
      n_sect:          3
      n_desc:          0
      n_value:         80
    - n_strx:          4
      n_type:          0xE
      n_sect:          4
      n_desc:          0
      n_value:         112
    - n_strx:          1
      n_type:          0xF
      n_sect:          1
      n_desc:          0
      n_value:         0
  StringTable:
