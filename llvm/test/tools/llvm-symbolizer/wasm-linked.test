## To generate the corresponding WASM executable, run:
##
## cat <<'EOF' > test.c
## int main() {
##     return 42;
## }
## EOF
## clang -g -O0 --target=wasm32-unknown-unknown test.c -c -o test.o
## wasm-ld test.o -o wasm-linked.wasm --no-entry --export=main

# RUN: llvm-symbolizer -e %p/Inputs/wasm-linked.wasm -f 0x66 | FileCheck %s

# CHECK: __original_main
# CHECK-NEXT: {{.*}}test.c:1:0
