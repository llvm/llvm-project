RUN: printf '\2\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\0\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\130\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\10\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\110\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\130\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\150\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\0\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\0\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\2\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\067\265\035\031\112\165\023\344' >> %t.past.profraw
RUN: printf '\02\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\110\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\150\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\130\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\0\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\0\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\2\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\0\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\067\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\101\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\5\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\6\0\0\0\0\0\0\0' >> %t.past.profraw
RUN: printf '\3\0bar\0\0\0' >> %t.past.profraw
RUN: not llvm-profdata merge -o /dev/null %t.past.profraw 2>&1 | FileCheck %s --check-prefix=PAST
PAST: malformed instrumentation profile data: uniform counter offset 16 is greater than the maximum uniform counter offset 15
PAST: error: no profile can be merged

// UniformCounterPtr leaves only one uniform counter, but NumCounters is two.
