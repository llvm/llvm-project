            Form:      DW_FORM_data1
      - Tag:      DW_TAG_enumerator
        Children: DW_CHILDREN_no
        Attributes:
          - Attribute: DW_AT_name
            Form:      DW_FORM_string
          - Attribute: DW_AT_const_value
            Form:      DW_FORM_data1
      - Tag:      DW_TAG_base_type
        Children: DW_CHILDREN_no
        Attributes:
          - Attribute: DW_AT_name
            Form:      DW_FORM_string
          - Attribute: DW_AT_encoding
            Form:      DW_FORM_data1
          - Attribute: DW_AT_byte_size
            Form:      DW_FORM_data1
  debug_info:
    - Version:  5
      UnitType: DW_UT_compile
      Entries:
        - AbbrCode: 1
          Values:
            - CStr: test.c
            - Value: 0x0001
        - AbbrCode: 2
          Values:
            - CStr: Color
            - Value: 0x00000038
            - Value: 0x04
        - AbbrCode: 3
          Values:
            - CStr: Red
            - Value: 0x00
        - AbbrCode: 3
          Values:
            - CStr: Green
            - Value: 0x01
        - AbbrCode: 3
          Values:
            - CStr: Blue
            - Value: 0x02
        - AbbrCode: 0
        - AbbrCode: 4
          Values:
            - CStr: unsigned int
            - Value: 0x07
            - Value: 0x04
        - AbbrCode: 0

