## Check exporting DXContainer with the designated option.
# RUN: llvm-pdbutil yaml2pdb %s --pdb=%t.pdb
# RUN: llvm-pdbutil export --dxcontainer --out=%t.cso %t.pdb
# RUN: obj2yaml %t.cso > %t.yaml
# RUN: FileCheck -input-file=%t.yaml %s --check-prefix=CHECK-YAML

## Check missing option errors.
# RUN: not llvm-pdbutil export --out=%t.cso %t.pdb 2>&1 \
# RUN:   | FileCheck %s --check-prefix=CHECK-NOOPTS
# CHECK-NOOPTS: either --stream or --dxcontainer must be specified!

## Check DXContainer missing error.
# RUN: not llvm-pdbutil export --dxcontainer --out=%t.cso %p/Inputs/ClassLayoutTest.pdb 2>&1 \
# RUN:   | FileCheck %s --check-prefix=CHECK-NODXC
# CHECK-NODXC: DirectX Container is not present

