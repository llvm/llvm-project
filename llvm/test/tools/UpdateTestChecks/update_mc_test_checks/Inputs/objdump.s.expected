// NOTE: Assertions have been autogenerated by utils/update_mc_test_checks.py UTC_ARGS: --use-same-for-encoding
// RUN: llvm-mc -triple=riscv32 -mattr=+f -defsym=RV64=0 --show-encoding --show-inst %s | FileCheck --check-prefixes=CHECK,CHECK-ASM,CHECK-32,CHECK-ASM-32 %s
// RUN: llvm-mc -triple=riscv64 -mattr=+f -defsym=RV64=1 --show-encoding --show-inst %s | FileCheck --check-prefixes=CHECK,CHECK-ASM,CHECK-64,CHECK-ASM-64 %s
// RUN: llvm-mc -filetype=obj -triple=riscv32 -mattr=+f -defsym=RV64=0 < %s | llvm-objdump --mattr=-f -d - | FileCheck %s --check-prefixes=CHECK,CHECK-OBJ,CHECK-32,CHECK-OBJ-32
// RUN: llvm-mc -filetype=obj -triple=riscv64 -mattr=+f -defsym=RV64=1 < %s | llvm-objdump --mattr=-f -d - | FileCheck %s --check-prefixes=CHECK,CHECK-OBJ,CHECK-64,CHECK-OBJ-64

/// Check that identical instructions across assembly and disassembly are merged under CHECK
add a0, a0, a1
// CHECK: add	a0, a0, a1
// CHECK-ASM-SAME: # encoding: [0x33,0x05,0xb5,0x00]
// CHECK-ASM-NEXT: # <MCInst #[[#MCINST1:]] ADD{{$}}
// CHECK-ASM-NEXT: #  <MCOperand Reg:X10>
// CHECK-ASM-NEXT: #  <MCOperand Reg:X10>
// CHECK-ASM-NEXT: #  <MCOperand Reg:X11>>

/// Check target-specific instructions that differ completely depending on the mode
.if RV64
ld a0, 0(a1)
// CHECK-64: ld	a0, 0(a1)
// CHECK-ASM-64-SAME: # encoding: [0x03,0xb5,0x05,0x00]
// CHECK-ASM-64-NEXT: # <MCInst #[[#MCINST2:]] LD{{$}}
// CHECK-ASM-64-NEXT: #  <MCOperand Reg:X10>
// CHECK-ASM-64-NEXT: #  <MCOperand Reg:X11>
// CHECK-ASM-64-NEXT: #  <MCOperand Imm:0>>
.else
lw a0, 0(a1)
// CHECK-32: lw	a0, 0(a1)
// CHECK-ASM-32-SAME: # encoding: [0x03,0xa5,0x05,0x00]
// CHECK-ASM-32-NEXT: # <MCInst #[[#MCINST3:]] LW{{$}}
// CHECK-ASM-32-NEXT: #  <MCOperand Reg:X10>
// CHECK-ASM-32-NEXT: #  <MCOperand Reg:X11>
// CHECK-ASM-32-NEXT: #  <MCOperand Imm:0>>
.endif

/// Check instructions that have target-specific preprocessor immediate values depending on the mode
addi a0, a0, RV64
// CHECK-32: mv	a0, a0
// CHECK-64: addi	a0, a0, 1
// CHECK-ASM-32-SAME: # encoding: [0x13,0x05,0x05,0x00]
// CHECK-ASM-64-SAME: # encoding: [0x13,0x05,0x15,0x00]
// CHECK-ASM: # <MCInst #[[#MCINST4:]] ADDI{{$}}
// CHECK-ASM-NEXT: #  <MCOperand Reg:X10>
// CHECK-ASM-NEXT: #  <MCOperand Reg:X10>
// CHECK-ASM-32-NEXT: #  <MCOperand Imm:0>>
// CHECK-ASM-64-NEXT: #  <MCOperand Imm:1>>

/// Check disassembly of an invalid instruction mapping to <unknown> (we disable F for llvm-objdump output)
fadd.s fa0, fa0, fa1
// CHECK-ASM: fadd.s	fa0, fa0, fa1
// CHECK-OBJ: <unknown>
// CHECK-ASM-SAME: # encoding: [0x53,0x75,0xb5,0x00]
// CHECK-ASM-NEXT: # <MCInst #[[#MCINST5:]] FADD_S{{$}}
// CHECK-ASM-NEXT: #  <MCOperand Reg:F10_F>
// CHECK-ASM-NEXT: #  <MCOperand Reg:F10_F>
// CHECK-ASM-NEXT: #  <MCOperand Reg:F11_F>
// CHECK-ASM-NEXT: #  <MCOperand Imm:7>>
