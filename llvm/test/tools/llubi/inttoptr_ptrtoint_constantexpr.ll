@g = global i32 0
@gp = global i64 ptrtoint (ptr @g to i64)
@g2 = global i32 0

define void @main() {
  ; noncacheable
  %alloc1 = alloca i32
  %alloc2 = alloca i32
  %exposed1 = ptrtoint ptr %alloc1 to i64
  %exposed2 = ptrtoint ptr %alloc2 to i64
  %diff = sub i64 %exposed2, %exposed1
  %p1 = getelementptr i8, ptr inttoptr (i64 36 to ptr), i64 0
  store i32 0, ptr %p1
  %p2 = getelementptr i8, ptr inttoptr (i64 36 to ptr), i64 %diff
  ; inttoptr (i64 36 to ptr) is not cached so we can still access %alloc2
  store i32 0, ptr %p2

  ; ptrtoint/inttoptr of vector/poison
  %ptrtoint_vec = add <2 x i64> ptrtoint (<2 x ptr> insertelement (<2 x ptr> poison, ptr @g2, i64 sub (i64 28, i64 ptrtoaddr (ptr @g2 to i64))) to <2 x i64>), zeroinitializer
  %inttoptr_vec = getelementptr i8, <2 x ptr> inttoptr (<2 x i64> insertelement (<2 x i64> poison, i64 4, i64 sub (i64 28, i64 ptrtoaddr (ptr @g2 to i64))) to <2 x ptr>), i64 0

  ; exposed via globals
  %pi = load i64, ptr @gp
  %p = inttoptr i64 %pi to ptr
  store i32 0, ptr %p
  ret void
}
