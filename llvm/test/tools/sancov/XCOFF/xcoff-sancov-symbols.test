## This test verifies sancov tools correctly identify the prefix for XCOFF binaries.

# REQUIRES: powerpc-registered-target

# RUN: yaml2obj %s -o %t.o
# RUN: sancov -print-coverage-pcs %t.o

--- !XCOFF
FileHeader:
  MagicNumber: 0x01DF
Sections:
  - Name: .text
    Flags: [ STYP_TEXT ]
    SectionData: "60000000"
Symbols:
  - Name: .__sanitizer_cov_trace_pc_guard
    Value: 0x1000
    Section: .text
    Type: 0x0
    StorageClass: C_EXT
    NumberOfAuxEntries: 1
    AuxEntries:
      - Type: AUX_CSECT
        SectionOrLength: 0
        SymbolAlignmentAndType: 0x01
        StorageMappingClass: XMC_PR
