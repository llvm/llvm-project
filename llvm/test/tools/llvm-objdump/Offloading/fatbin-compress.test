## Test that --offloading with a compressed fatbin works correctly

# REQUIRES: target={{x86_64-.*-linux.*}}
# REQUIRES: amdgpu-registered-target
# REQUIRES: zstd
# RUN: yaml2obj %s -o %t.elf
# RUN: llvm-objdump --offloading %t.elf 
# RUN: llvm-objdump -d %t.elf.0.hip-amdgcn-hsa-amdhsa--gfx942 | FileCheck %s 

# CHECK:         s_load_dwordx2 s[0:1], s[0:1], 0x0
# CHECK-NEXT:    v_mov_b32_e32 v0, 0
# CHECK-NEXT:    v_mov_b32_e32 v1, 0x40240000
# CHECK-NEXT:    v_mov_b32_e32 v2, 0
# CHECK-NEXT:    s_waitcnt lgkmcnt(0)
# CHECK-NEXT:    s_load_dwordx2 s[2:3], s[0:1], 0x0
# CHECK-NEXT:    s_waitcnt lgkmcnt(0)
# CHECK-NEXT:    v_add_f64 v[0:1], s[2:3], v[0:1]
# CHECK-NEXT:    global_store_dwordx2 v2, v[0:1], s[0:1]
# CHECK-NEXT:    s_endpgm

--- !ELF
FileHeader:
  Class:           ELFCLASS64
  Data:            ELFDATA2LSB
  Type:            ET_EXEC
  Machine:         EM_X86_64
  Entry:           0x202730
ProgramHeaders:
  - Type:            PT_PHDR
    Flags:           [ PF_R ]
    VAddr:           0x200040
    Align:           0x8
    Offset:          0x40
  - Type:            PT_GNU_STACK
    Flags:           [ PF_W, PF_R ]
    Align:           0x0
    Offset:          0x0
Sections:
  - Name:            .hip_fatbin
    Type:            SHT_PROGBITS
    Flags:           [ SHF_ALLOC ]
    Address:         0x201000
    AddressAlign:    0x1000
    Content:         
  - Name:            .hipFatBinSegment
    Type:            SHT_PROGBITS
    Flags:           [ SHF_ALLOC ]
    Address:         0x201578
    AddressAlign:    0x8
    Content:         '465049480100000000102000000000000000000000000000'
...
