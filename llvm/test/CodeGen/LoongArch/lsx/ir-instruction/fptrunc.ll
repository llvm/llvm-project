  %lo = shufflevector <4 x double> %x, <4 x double> poison,
                    <2 x i32> <i32 0, i32 1>
  %hi = shufflevector <4 x double> %x, <4 x double> poison,
                    <2 x i32> <i32 2, i32 3>

  %r0 = fptrunc <2 x double> %lo to <2 x float>
  %r1 = fptrunc <2 x double> %hi to <2 x float>

