define void @fptrunc_concat_bitcast(ptr %res, ptr %a0) nounwind {
; CHECK-LABEL: fptrunc_concat_bitcast:
; CHECK:       # %bb.0: # %entry
; CHECK-NEXT:    xvld $xr0, $a1, 0
; CHECK-NEXT:    xvld $xr1, $a1, 32
; CHECK-NEXT:    xvfcvt.s.d $xr0, $xr1, $xr0
