; LA32-NEXT:    beq $a2, $zero, .LBB19_2
; LA32-NEXT:  # %bb.1: # %then
; LA32-NEXT:    b callee_musttail_cross_bb
; LA32-NEXT:  .LBB19_2: # %else
; LA32-NEXT:    move $a0, $zero
; LA32-NEXT:    ret
;
; LA64-LABEL: caller_musttail_cross_bb:
