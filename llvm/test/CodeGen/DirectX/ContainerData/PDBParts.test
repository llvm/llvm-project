RUN: rm -rf %t && mkdir %t
RUN: llc %S/Inputs/SourceInfo.ll --filetype=obj -o %t.dxbc --dx-pdb-file=%t/parts.pdb
RUN: llvm-pdbutil dump --streams --dxcontainer %t/parts.pdb | FileCheck %s --check-prefix=PDB

# Check that debug-related container parts are emitted into companion PDB file.
PDB:              PartCount: 5
PDB-NEXT:         Parts:
PDB-NEXT:           ILDB |
PDB-NEXT:           HASH |
PDB-NEXT:           ILDN |
PDB-NEXT:           SRCI |
PDB-NEXT:           VERS |
