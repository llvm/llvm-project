RUN: rm -rf %t && mkdir %t
RUN: llc %S/Inputs/SourceInfo.ll --filetype=obj -o - --dx-Fd=%t/ofile.pdb | obj2yaml | FileCheck %s
RUN: test -f %t/ofile.pdb

CHECK:       - Name:            ILDN
CHECK:         DebugName:
CHECK-NEXT:      Flags:           0
CHECK-NEXT:      NameLength:      {{.*}}
CHECK-NEXT:      DebugName:       {{.*[/\]+}}ofile.pdb
