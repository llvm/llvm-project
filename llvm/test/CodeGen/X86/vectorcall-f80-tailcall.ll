; Verify that tail calls to vectorcall functions with two x86_fp80 arguments
; pass arguments in the correct stack order (X at lower address, Y above).

declare x86_vectorcallcc x86_fp80 @tailcall_f80_callee(x86_fp80, x86_fp80)

define dso_local x86_vectorcallcc x86_fp80 @tailcall_f80_swap_args(x86_fp80 %Y, x86_fp80 %X) {
; CHECK-LABEL: tailcall_f80_swap_args@@24:
; CHECK:       # %bb.0:
; CHECK-DAG:   fldt 40(%esp)
; CHECK-DAG:   fldt 28(%esp)
; CHECK-DAG:   fstpt (%esp)
; CHECK-DAG:   fstpt 12(%esp)
; CHECK-NOT:   xmm
; CHECK:       calll tailcall_f80_callee@@24
entry:
  %ret = tail call x86_vectorcallcc x86_fp80 @tailcall_f80_callee(x86_fp80 %X, x86_fp80 %Y)
  ret x86_fp80 %ret
}

define dso_local x86_vectorcallcc x86_fp80 @tailcall_f80_passthrough(x86_fp80 %X, x86_fp80 %Y) {
; CHECK-LABEL: tailcall_f80_passthrough@@24:
; CHECK:       jmp tailcall_f80_callee@@24
entry:
  %ret = tail call x86_vectorcallcc x86_fp80 @tailcall_f80_callee(x86_fp80 %X, x86_fp80 %Y)
  ret x86_fp80 %ret
}
