# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py
# RUN: llc -mtriple x86_64 -run-pass=X86-postlegalizer-combiner -verify-machineinstrs %s -o - | FileCheck %s
# RUN: llc -mtriple x86_64 -passes=x86-postlegalizer-combiner-pass -verify-machineinstrs %s -o - | FileCheck %s

---
name:            shift_of_zero
alignment:       4
legalized:       true
liveins:
  - { reg: '$eax' }
body:             |
  bb.1.entry:
    liveins: $rax

    ; CHECK-LABEL: name: shift_of_zero
    ; CHECK: liveins: $rax
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: %a:_(s64) = COPY $rax
    ; CHECK-NEXT: $rax = COPY %a(s64)
    ; CHECK-NEXT: RET implicit $rax
    %a:_(s64) = COPY $rax
    %b:_(s64) = G_CONSTANT i64 0
    %res:_(s64) = G_LSHR %a, %b
    $rax = COPY %res(s64)
    RET implicit $rax

...
