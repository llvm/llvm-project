    ; AVX-NEXT: RET 0, implicit [[VINSERTF128rri1]](<8 x s32>)
    %1:_(s32) = COPY $edi
    %2:_(s32) = COPY $esi
    %3:_(s32) = COPY $edx
    %4:_(s32) = COPY $ecx
    %5:_(s32) = G_FCONSTANT float 1.0
    %6:_(s32) = G_FCONSTANT float 1.25
    %7:_(s32) = G_FCONSTANT float 1.5
    %8:_(s32) = G_FCONSTANT float 1.75
    %0:_(<8 x s32>) = G_BUILD_VECTOR %1:_(s32), %2:_(s32), %3:_(s32), %4:_(s32), %5:_(s32), %6:_(s32), %7:_(s32), %8:_(s32)
    RET 0, implicit %0
