...
---
name:            right_ident_lshr
tracksRegLiveness: true
body:             |
  bb.1.entry:
    liveins: $eax
    ; Fold (x lshr 0) -> x
    ; CHECK-LABEL: name: right_ident_lshr
    ; CHECK: liveins: $eax
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: %x:_(s32) = COPY $eax
    ; CHECK-NEXT: $eax = COPY %x(s32)
    ; CHECK-NEXT: RET implicit $eax
