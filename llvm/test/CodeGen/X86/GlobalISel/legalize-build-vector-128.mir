    ; SSE41-NEXT: [[PINSRQrri1:%[0-9]+]]:_(<2 x s64>) = PINSRQrri [[PINSRQrri]](<2 x s64>), [[C]](s64), 1
    ; SSE41-NEXT: RET 0, implicit [[PINSRQrri1]](<2 x s64>)
    %1:_(s64) = COPY $rdi
    %2:_(s64) = G_FCONSTANT double 1.0
    %0:_(<2 x s64>) = G_BUILD_VECTOR %1:_(s64), %2:_(s64)
    RET 0, implicit %0
...
