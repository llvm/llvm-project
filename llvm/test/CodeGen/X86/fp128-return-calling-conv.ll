; WIN-LABEL: ret_ccc:
; WIN:       # %bb.0:
; WIN-NEXT:    movq %rcx, %rax
; WIN-NEXT:    movaps (%rdx), %xmm0
; WIN-NEXT:    movaps %xmm0, (%rcx)
; WIN-NEXT:    retq
;
; LINUX-LABEL: ret_ccc:
; LINUX:       # %bb.0:
; LINUX-NEXT:    movaps (%rdi), %xmm0
; LINUX-NEXT:    retq
