; Verify that i128 ctlz uses LZCNT's CF output to avoid a redundant TEST.
; The high half is computed last. CMOVB selects based on CF directly.
; Note: X86 (32-bit) splits the i128 into 4 i32 chunks and cannot use the
; CF->CMOV optimization; it emits branches as expected.
define i64 @lzcnt128(ptr %p) nounwind {
; X32-LABEL: lzcnt128:
; X32:       # %bb.0:
; X32-NEXT:    lzcntq (%edi), %rcx
; X32-NEXT:    addq $64, %rcx
; X32-NEXT:    lzcntq 8(%edi), %rax
; X32-NOT:     testq
; X32-NEXT:    cmovbq %rcx, %rax
; X32-NEXT:    retq
;
; X64-LABEL: lzcnt128:
; X64:       # %bb.0:
; X64-NEXT:    lzcntq (%rdi), %rcx
; X64-NEXT:    addq $64, %rcx
; X64-NEXT:    lzcntq 8(%rdi), %rax
; X64-NOT:     testq
; X64-NEXT:    cmovbq %rcx, %rax
; X64-NEXT:    retq
;
  %a = load i128, ptr %p, align 8
  %cnt = tail call i128 @llvm.ctlz.i128(i128 %a, i1 true)
  %res = trunc i128 %cnt to i64
  ret i64 %res
}

