; NOTE: Assertions have been autogenerated by utils/update_llc_test_checks.py UTC_ARGS: --filter "^\t(#|movl\t)" --version 4
; RUN: llc -mtriple=x86_64-unknown-linux-gnu -O2 < %s | FileCheck %s

; Test that MayFoldRegister is set for "+rm" (tied read-write) constraints.
; When all 15 GPRs are claimed by explicit register constraints in the same asm
; block, the RA must fold the "+rm" operand to memory.  Without MayFoldRegister
; being set for tied outputs, the slow path in getConstraintPreferences filters
; out 'm' (gcc compat: "matching constraints can only be registers"), leaving no
; viable allocation and likely causing a crash or suboptimal spill cascade.

; A single "+rm" where all 15 GPRs are simultaneously claimed by explicit
; output constraints -- the tied output MUST go to memory.
define dso_local i32 @test_plus_rm_all_regs_taken(i32 %x) local_unnamed_addr {
; CHECK-LABEL: test_plus_rm_all_regs_taken:
; CHECK:    #APP
; CHECK:    # +rm: all regs taken
; CHECK:    # {{-?[0-9]+}}(%rsp)
; CHECK:    #NO_APP
entry:
  %0 = call { i32, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64 } asm sideeffect "# +rm: all regs taken\0A\09# $0", "=rm,={rax},={rcx},={rdx},={rsi},={rdi},={rbx},={rbp},={r8},={r9},={r10},={r11},={r12},={r13},={r14},={r15},0,~{dirflag},~{fpsr},~{flags}"(i32 %x)
  %asmresult = extractvalue { i32, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64, i64 } %0, 0
  ret i32 %asmresult
}
