; RUN: opt < %s -O2 | llc -mtriple=x86_64-unknown-linux-gnu | FileCheck %s --check-prefixes=X64
; RUN: opt < %s -O2 | llc -mtriple=i686-unknown-linux-gnu | FileCheck %s --check-prefixes=X86

; Regression tests for single bit atomics instruction codegen
define i1 @or_check_bit0(ptr %v) nounwind {
; X64-LABEL: or_check_bit0:
; X64:       # %bb.0:
; X64-NEXT:    lock btsl $0, (%rdi)
; X64-NEXT:    setb %al
; X64-NEXT:    retq
;
; X86-LABEL: or_check_bit0:
; X86:       # %bb.0:
; X86-NEXT:    movl {{[0-9]+}}(%esp), %eax
; X86-NEXT:    lock btsl $0, (%eax)
; X86-NEXT:    setb %al
; X86-NEXT:    retl
  %call = atomicrmw or ptr %v, i32 1 seq_cst, align 4
  %and = and i32 %call, 1
  %cmp = icmp eq i32 %and, 1
  ret i1 %cmp
}

