# RUN: llc -mtriple=x86_64-- -mcpu=haswell -run-pass machine-scheduler \
# RUN:   -verify-machineinstrs %s -o - -debug-only=machine-scheduler 2>&1 \
# RUN:   | FileCheck %s
# REQUIRES: asserts

# Test that artificial dependencies from a physical register def to ExitSU
# (created when the register is live-out to a successor block) have latency 0.
#
# In addPhysRegDataDeps(), when UseOpIdx < 0 (live-out physreg to ExitSU),
# an SDep::Artificial dependency is created. Previously, ImplicitPseudoUse
# was not set to true in this path, causing computeOperandLatency() to be
# called with an invalid (negative) use operand index, which returned a
# non-zero latency. The fix sets ImplicitPseudoUse = true so the latency
# is correctly set to 0.

# CHECK-LABEL: physreg_liveout_artificial_dep_zero_latency
# The defining instruction should have an artificial dep to ExitSU with
# latency 0, not the instruction's default def latency.
# CHECK:       SU(1):   $eax = MOV32ri 42
# CHECK:         Successors:
# CHECK:           ExitSU: Ord  Latency=0 Artificial

---
name: physreg_liveout_artificial_dep_zero_latency
tracksRegLiveness: true
body: |
  bb.0:
    successors: %bb.1

    $ecx = MOV32ri 0
    $eax = MOV32ri 42

  bb.1:
    liveins: $eax
    RET 0, $eax
...
