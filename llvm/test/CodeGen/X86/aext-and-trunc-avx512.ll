; NOTE: Assertions have been autogenerated by utils/update_llc_test_checks.py UTC_ARGS: --version 6
; RUN: llc < %s -mtriple=x86_64-unknown-linux-gnu -mattr=+avx512f,+avx512bw,+popcnt | FileCheck %s

; Test (zext (and (trunc x) C)) -> (and x C) fold with AVX512 mask registers.
; Ensures "andb $7, %al; movzbl %al, %eax" is folded to "andl $7, %eax".

define i8 @ctpop_aext_i3_v3i1(ptr %p) {
; CHECK-LABEL: ctpop_aext_i3_v3i1:
; CHECK:       # %bb.0:
; CHECK-NEXT:    vmovd {{.*#+}} xmm0 = mem[0],zero,zero,zero
; CHECK-NEXT:    vpbroadcastb {{.*#+}} xmm1 = [61,61,61,61,61,61,61,61,61,61,61,61,61,61,61,61]
; CHECK-NEXT:    vpcmpneqb %zmm1, %zmm0, %k0
; CHECK-NEXT:    kmovd %k0, %eax
; CHECK-NEXT:    andl $7, %eax
; CHECK-NEXT:    popcntl %eax, %eax
; CHECK-NEXT:    # kill: def $al killed $al killed $eax
; CHECK-NEXT:    vzeroupper
; CHECK-NEXT:    retq
  %v = load <3 x i8>, ptr %p
  %cmp = icmp ne <3 x i8> %v, splat (i8 61)
  %bc = bitcast <3 x i1> %cmp to i3
  %ct = call i3 @llvm.ctpop.i3(i3 %bc)
  %ext = zext i3 %ct to i8
  ret i8 %ext
}
