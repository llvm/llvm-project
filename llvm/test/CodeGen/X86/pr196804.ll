entry:
  %b_init = load i32, ptr @b, align 4
  %f_val = load i32, ptr @f, align 4
  %f_is_zero = icmp eq i32 %f_val, 0
  br label %loop

loop:
  %iter = phi i32 [ 0, %entry ], [ %iter_next, %loop ]
  %b_phi = phi i32 [ %b_init, %entry ], [ %new_b, %loop ]
  %div = sdiv i32 -1, %b_phi
  store volatile i32 %div, ptr @sink, align 4
  %b_ne_m1 = icmp ne i32 %b_phi, -1
  %zext_cmp = zext i1 %b_ne_m1 to i8
  %xor_cmp = xor i8 %zext_cmp, -1
  %o = select i1 %f_is_zero, i8 %xor_cmp, i8 -2
  %o.fr = freeze i8 %o
  %not_o = xor i8 %o.fr, -1
  %zext_not_o = zext nneg i8 %not_o to i32
  %notsub = add i8 %o.fr, -1
  %cmp_urem = icmp ult i8 %notsub, -2
  %urem_neg = xor i8 %o.fr, -1
  %srem_result = select i1 %cmp_urem, i8 -1, i8 %urem_neg
  %srem_ext = sext i8 %srem_result to i32
  %mul = mul nuw nsw i32 %zext_not_o, %srem_ext
  %mul_ne_zero = icmp ne i32 %mul, 0
  %o_ne_m1 = icmp ne i8 %o.fr, -1
  %cond = and i1 %mul_ne_zero, %o_ne_m1
  %fb_xor = xor i32 %f_val, %b_phi
  %fb_low = and i32 %fb_xor, 1
  %j = select i1 %cond, i32 %fb_low, i32 0
  %j_zero = icmp eq i32 %j, 0
  %new_b = select i1 %j_zero, i32 0, i32 %b_phi
  store i32 %new_b, ptr @b, align 4
  %iter_next = add i32 %iter, 1
  %done = icmp eq i32 %iter_next, 2
