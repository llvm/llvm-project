# RUN: llc -mtriple=x86_64-unknown-linux -run-pass=livevars,phi-node-elimination \
# RUN:   -verify-machineinstrs -o /dev/null %s

# Test that PHI Elimination correctly clears LiveVariables AliveBlocks for
# registers defined by IMPLICIT_DEF when used as PHI sources. The source
# register %2 is live-through bb.2 to reach the PHI in bb.3. Without the fix,
# MachineVerifier reports:
#   "LiveVariables: Block should not be in AliveBlocks"

---
name: phi_elim_undef_source
tracksRegLiveness: true
body: |
  bb.0:
    successors: %bb.1, %bb.4

    %0:gr32 = MOV32r0 implicit-def dead $eflags
    TEST32rr %0, %0, implicit-def $eflags
    JCC_1 %bb.4, 4, implicit $eflags
    JMP_1 %bb.1

  bb.1:
    successors: %bb.2

    %1:vr128 = IMPLICIT_DEF
    JMP_1 %bb.2

  bb.2:
    successors: %bb.3

    JMP_1 %bb.3

  bb.3:
    %3:vr128 = PHI %1, %bb.2, %2, %bb.4
    $xmm0 = COPY %3
    RET 0, implicit $xmm0

  bb.4:
    successors: %bb.3

    %2:vr128 = V_SET0
    JMP_1 %bb.3
...
