; PR175802 - shuffle simplifies to all undef/zero
define <16 x i32> @PR175802() {
; CHECK-LABEL: PR175802:
; CHECK:       # %bb.0:
; CHECK-NEXT:    retq
  %avg = tail call <8 x i16> @llvm.x86.sse2.pavg.w(<8 x i16> undef, <8 x i16> undef)
  %src = bitcast <8 x i16> %avg to <4 x i32>
  %shift = shufflevector <4 x i32> %src, <4 x i32> zeroinitializer, <4 x i32> <i32 poison, i32 2, i32 poison, i32 poison>
  %add = add <4 x i32> %shift, %src
  %res = shufflevector <4 x i32> %add, <4 x i32> zeroinitializer, <16 x i32> <i32 1, i32 1, i32 1, i32 1, i32 1, i32 1, i32 1, i32 1, i32 poison, i32 poison, i32 poison, i32 poison, i32 poison, i32 poison, i32 poison, i32 poison>
  ret <16 x i32> %res
}
