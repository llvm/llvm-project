  define fastcc void @fold_with_physical_reg(i64 %arg1) "target-features"="+ndd" {
    %alloc = alloca i8, i64 %arg1, align 16
    ret void
  }
...
---
name:            fold_with_physical_reg
alignment:       1
tracksRegLiveness: true
noPhis:          true
isSSA:           false
frameInfo:
