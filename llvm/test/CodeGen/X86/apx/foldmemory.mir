  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $rdi, $rsi, $rdx, $ecx

    %5:gr32 = COPY $ecx
    %4:gr64 = COPY $rdx
    %3:gr64 = COPY $rsi
    %2:gr64 = COPY $rdi
    %8:gr64 = LEA64r %3, 1, $noreg, 15, $noreg
