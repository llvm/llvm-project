; CHECK-WO-SSE4-NEXT:    pxor %xmm3, %xmm3
; CHECK-WO-SSE4-NEXT:    pcmpgtb %xmm1, %xmm3
; CHECK-WO-SSE4-NEXT:    movdqa %xmm3, %xmm4
; CHECK-WO-SSE4-NEXT:    pandn %xmm0, %xmm4
