; RUN: llc < %s -mtriple=aarch64-linux-gnu | FileCheck %s --check-prefixes=SPLIT
; RUN: llc < %s -mtriple=aarch64-linux-gnu -aarch64-br-merging-cbz-tbnz-bias=0 | FileCheck %s --check-prefixes=MERGE

; When one side of a merged branch condition would lower to a single CBZ/CBNZ or
; TBZ/TBNZ compare-and-branch, getJumpConditionMergingParams withdraws the CCMP
; merging discount so the fused branch is kept (and the expensive RHS is
; short-circuited) instead of folded into a CMP/CCMP chain. The second RUN line
; disables the carve-out (bias=0) and recovers the merged CCMP form.

declare void @sink_a()
declare void @sink_b()

