; MERGE-NEXT:    b sink_a
; MERGE-NEXT:  .LBB0_2: // %fall
; MERGE-NEXT:    b sink_b
entry:
  %c0 = icmp eq ptr %p, null
  %a1 = add i32 %x, %y
  %a2 = mul i32 %a1, %z
