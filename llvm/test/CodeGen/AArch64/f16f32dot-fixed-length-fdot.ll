; CHECK-EXPAND-NEXT:    fadd v0.2s, v0.2s, v1.2s
; CHECK-EXPAND-NEXT:    ext v1.16b, v1.16b, v1.16b, #8
; CHECK-EXPAND-NEXT:    fadd v0.2s, v1.2s, v0.2s
