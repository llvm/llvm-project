; CHECK-FMLAL-NEXT:    fmlal v0.2s, v1.2h, v2.2h
; CHECK-FMLAL-NEXT:    fmlal2 v0.2s, v1.2h, v2.2h
; CHECK-FMLAL-NEXT:    ret
;
; CHECK-FDOT-LABEL: fixed_fdot:
; CHECK-FDOT:       // %bb.0: // %entry
; CHECK-FDOT-NEXT:    fdot v0.2s, v1.4h, v2.4h
; CHECK-FDOT-NEXT:    ret
entry:
