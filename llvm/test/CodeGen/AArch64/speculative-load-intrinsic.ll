; CHECK:       // %bb.0:
; CHECK-NEXT:    ldr z0, [x0]
; CHECK-NEXT:    ret
  %load = call <vscale x 4 x i32> (ptr, ...) @llvm.speculative.load.nxv4i32.p0(ptr align 16 %ptr, i64 8)
  ret <vscale x 4 x i32> %load
}

define <vscale x 2 x double> @speculative_load_nxv2f64(ptr %ptr) {
