; CHECK-NEXT:    mov z16.d, #0xffffffffffff0003
; CHECK-NEXT:    movi v0.2d, #0000000000000000
; CHECK-NEXT:    mov z6.d, x9
; CHECK-NEXT:    movi v1.2d, #0000000000000000
