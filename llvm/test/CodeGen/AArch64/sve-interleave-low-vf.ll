; CHECK-NEXT:    movi v2.2d, #0000000000000000
; CHECK-NEXT:    movi v3.2d, #0000000000000000
; CHECK-NEXT:    cnth x9
; CHECK-NEXT:    add z4.d, z7.d, z4.d
; CHECK-NEXT:    add z5.d, z7.d, z5.d
