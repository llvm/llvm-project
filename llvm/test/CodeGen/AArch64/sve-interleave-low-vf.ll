; CHECK-NEXT:    // =>This Inner Loop Header: Depth=1
; CHECK-NEXT:    ld1h { z16.h }, p0/z, [x0, x8, lsl #1]
; CHECK-NEXT:    add x8, x8, x9
; CHECK-NEXT:    cmp x8, x2
; CHECK-NEXT:    tbl z17.h, { z16.h }, z4.h
; CHECK-NEXT:    tbl z18.h, { z16.h }, z5.h
; CHECK-NEXT:    tbl z19.h, { z16.h }, z6.h
; CHECK-NEXT:    tbl z16.h, { z16.h }, z7.h
