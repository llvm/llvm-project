# Overlapping X4 tuple with no permutation: copies must be emitted in reverse dependency order.
---
name:            form_transposed_reg_tuple_x4_overlap
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $z17, $z19, $z20, $z21
    ; CHECK-LABEL: name: form_transposed_reg_tuple_x4_overlap
    ; CHECK: liveins: $z17, $z19, $z20, $z21
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: $z22 = ORR_ZZZ $z21, $z21
    ; CHECK-NEXT: $z21 = ORR_ZZZ $z20, $z20
    ; CHECK-NEXT: $z20 = ORR_ZZZ $z19, $z19
    ; CHECK-NEXT: $z19 = ORR_ZZZ $z17, $z17
    ; CHECK-NEXT: RET undef $lr, implicit killed $z19, implicit killed $z20, implicit killed $z21, implicit killed $z22
    $z19_z20_z21_z22 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO $z17, $z19, $z20, $z21
    RET_ReallyLR implicit killed $z19, implicit killed $z20, implicit killed $z21, implicit killed $z22
...

# Mixed X4 case: independent copies first, then swap the remaining 2-cycle.
---
name:            form_transposed_reg_tuple_x4_contains_swap
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $z17, $z18, $z19, $z20
    ; CHECK-LABEL: name: form_transposed_reg_tuple_x4_contains_swap
    ; CHECK: liveins: $z17, $z18, $z19, $z20
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: $z22 = ORR_ZZZ $z18, $z18
    ; CHECK-NEXT: $z21 = ORR_ZZZ $z17, $z17
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z20
    ; CHECK-NEXT: $z20 = EOR_ZZZ $z20, $z19
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z20
    ; CHECK-NEXT: RET undef $lr, implicit killed $z19, implicit killed $z20, implicit killed $z21, implicit killed $z22
    $z19_z20_z21_z22 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO $z20, $z19, $z17, $z18
    RET_ReallyLR implicit killed $z19, implicit killed $z20, implicit killed $z21, implicit killed $z22
...

# Pure X4 permutation: expand into a sequence of swaps over the cycle.
---
name:            form_transposed_reg_tuple_x4_rotate
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $z19, $z20, $z21, $z22
    ; CHECK-LABEL: name: form_transposed_reg_tuple_x4_rotate
    ; CHECK: liveins: $z19, $z20, $z21, $z22
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z22
    ; CHECK-NEXT: $z22 = EOR_ZZZ $z22, $z19
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z22
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z21
    ; CHECK-NEXT: $z21 = EOR_ZZZ $z21, $z19
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z21
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z20
    ; CHECK-NEXT: $z20 = EOR_ZZZ $z20, $z19
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z20
    ; CHECK-NEXT: RET undef $lr, implicit killed $z19, implicit killed $z20, implicit killed $z21, implicit killed $z22
    $z19_z20_z21_z22 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO $z20, $z21, $z22, $z19
    RET_ReallyLR implicit killed $z19, implicit killed $z20, implicit killed $z21, implicit killed $z22
...

# Non-contiguous remaining 2-cycle after removing an identity and an external copy.
---
name:            form_transposed_reg_tuple_x4_noncontiguous_2cycle
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $z18, $z19, $z20, $z21
    ; CHECK-LABEL: name: form_transposed_reg_tuple_x4_noncontiguous_2cycle
    ; CHECK: liveins: $z18, $z19, $z20, $z21
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: $z22 = ORR_ZZZ $z18, $z18
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z21
    ; CHECK-NEXT: $z21 = EOR_ZZZ $z21, $z19
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z21
    ; CHECK-NEXT: RET undef $lr, implicit killed $z19, implicit killed $z20, implicit killed $z21, implicit killed $z22
    $z19_z20_z21_z22 = FORM_TRANSPOSED_REG_TUPLE_X4_PSEUDO $z21, $z20, $z19, $z18
    RET_ReallyLR implicit killed $z19, implicit killed $z20, implicit killed $z21, implicit killed $z22
...

