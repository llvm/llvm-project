# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py UTC_ARGS: --version 6
# RUN: llc -mtriple=aarch64-linux-gnu -mattr=+sme2 -run-pass=aarch64-expand-pseudo -verify-machineinstrs %s -o - | FileCheck %s

# Post-RA tests for FORM_TRANSPOSED_REG_TUPLE_*_PSEUDO expansion.
#
# This test covers unlikely cases that ideally we'll never encounter in
# practice, but still need to handle for correctness.
#
# Ideally, we should make it impossible for the register allocator to pick cases
# with costly expansions (i.e., those that require swaps).


# Naive copy lowering would clobber $z19 before $z20 is formed.
---
name:            form_transposed_reg_tuple_x2_overlap
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $z17, $z19
    ; CHECK-LABEL: name: form_transposed_reg_tuple_x2_overlap
    ; CHECK: liveins: $z17, $z19
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: $z20 = ORR_ZZZ $z19, $z19
    ; CHECK-NEXT: $z19 = ORR_ZZZ $z17, $z17
    ; CHECK-NEXT: RET undef $lr, implicit killed $z19, implicit killed $z20
    $z19_z20 = FORM_TRANSPOSED_REG_TUPLE_X2_PSEUDO $z17, $z19
    RET_ReallyLR implicit killed $z19, implicit killed $z20
...

# Pure X2 permutation: this must use the fallback swap sequence.
---
name:            form_transposed_reg_tuple_x2_swap
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $z19, $z20
    ; CHECK-LABEL: name: form_transposed_reg_tuple_x2_swap
    ; CHECK: liveins: $z19, $z20
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z20
    ; CHECK-NEXT: $z20 = EOR_ZZZ $z20, $z19
    ; CHECK-NEXT: $z19 = EOR_ZZZ $z19, $z20
    ; CHECK-NEXT: RET undef $lr, implicit killed $z19, implicit killed $z20
    $z19_z20 = FORM_TRANSPOSED_REG_TUPLE_X2_PSEUDO $z20, $z19
    RET_ReallyLR implicit killed $z19, implicit killed $z20
...
# Pure X2 permutation: this must use the fallback swap sequence (z31_z0).
---
name:            form_transposed_reg_tuple_x2_swap_reg_wrap
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $z0, $z31
    ; CHECK-LABEL: name: form_transposed_reg_tuple_x2_swap_reg_wrap
    ; CHECK: liveins: $z0, $z31
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: $z31 = EOR_ZZZ $z31, $z0
    ; CHECK-NEXT: $z0 = EOR_ZZZ $z0, $z31
    ; CHECK-NEXT: $z31 = EOR_ZZZ $z31, $z0
    ; CHECK-NEXT: RET undef $lr, implicit killed $z31, implicit killed $z0
    $z31_z0 = FORM_TRANSPOSED_REG_TUPLE_X2_PSEUDO $z0, $z31
    RET_ReallyLR implicit killed $z31, implicit killed $z0
...
