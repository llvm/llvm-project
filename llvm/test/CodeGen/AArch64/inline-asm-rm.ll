; NOTE: Assertions have been autogenerated by utils/update_llc_test_checks.py UTC_ARGS: --version 6
; Test rm constraints on AArch64 under both ISel frameworks.
; At -O0, AArch64 defaults to GlobalISel; InlineAsmPrepare routes to the
; memory path so the output lands in a stack slot in both frameworks.
; At -O2, SelectionDAG chooses the register path; the RA places the result
; directly in a register.
;
; Both ISel frameworks produce identical O0 output: InlineAsmPrepare routes to
; the memory path before either framework sees the IR, so no GlobalISel-specific
; changes are needed for rm-constraint support.
; RUN: llc -mtriple=aarch64-unknown-linux-gnu -O0 --global-isel < %s \
; RUN:     | FileCheck --check-prefix=O0 %s
; RUN: llc -mtriple=aarch64-unknown-linux-gnu -O0 --global-isel=false --fast-isel=false < %s \
; RUN:     | FileCheck --check-prefix=O0 %s
; RUN: llc -mtriple=aarch64-unknown-linux-gnu -O2 < %s \
; RUN:     | FileCheck --check-prefix=O2 %s

; At -O0 (both GlobalISel and SelectionDAG) InlineAsmPrepare selects the
; memory path, so the output is written indirectly through a stack slot.
; At -O2, InlineAsmPrepare selects the register path; the output comes back
; in a register.
define i64 @test_rm_output() {
; O0-LABEL: test_rm_output:
; O0:       // %bb.0: // %entry
; O0-NEXT:    sub sp, sp, #16
; O0-NEXT:    .cfi_def_cfa_offset 16
; O0-NEXT:    add x8, sp, #8
; O0-NEXT:    //APP
; O0-NEXT:    // [x8]
; O0-NEXT:    //NO_APP
; O0-NEXT:    ldr x0, [sp, #8]
; O0-NEXT:    add sp, sp, #16
; O0-NEXT:    ret
;
; O2-LABEL: test_rm_output:
; O2:       // %bb.0: // %entry
; O2-NEXT:    sub sp, sp, #16
; O2-NEXT:    .cfi_def_cfa_offset 16
; O2-NEXT:    //APP
; O2-NEXT:    // x0
; O2-NEXT:    //NO_APP
; O2-NEXT:    add sp, sp, #16
; O2-NEXT:    ret
entry:
  %out = alloca i64, align 8
  callbr void @llvm.asm.constraint.br()
      to label %asm.pref.reg [label %asm.pref.mem]

asm.pref.reg:
  %0 = tail call i64 asm "# $0", "=rm"()
  br label %asm.merge

asm.pref.mem:
  call void asm "# $0", "=*rm"(ptr elementtype(i64) %out)
  %1 = load i64, ptr %out, align 8
  br label %asm.merge

asm.merge:
  %2 = phi i64 [ %0, %asm.pref.reg ], [ %1, %asm.pref.mem ]
  ret i64 %2
}

declare void @llvm.asm.constraint.br()
