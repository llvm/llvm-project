; LE-NEXT:    ldrb w19, [x0]
; LE-NEXT:    and w0, w20, #0x3
; LE-NEXT:    bl _use.i8
; LE-NEXT:    bfi w19, w20, #8, #2
; LE-NEXT:    ldp x29, x30, [sp, #16] ; 16-byte Folded Reload
; LE-NEXT:    mov w0, w19
; LE-NEXT:    ldp x20, x19, [sp], #32 ; 16-byte Folded Reload
; LE-NEXT:    ret
;
; BE-LABEL: negative_multiuse_and:
; BE:       // %bb.0:
; BE-NEXT:    str x30, [sp, #-32]! // 8-byte Folded Spill
; BE-NEXT:    stp x20, x19, [sp, #16] // 16-byte Folded Spill
; BE-NEXT:    .cfi_def_cfa_offset 32
; BE-NEXT:    .cfi_offset w19, -8
; BE-NEXT:    .cfi_offset w20, -16
; BE-NEXT:    .cfi_offset w30, -32
; BE-NEXT:    ldrb w20, [x0, #1]
; BE-NEXT:    ldrb w19, [x0]
; BE-NEXT:    and w0, w20, #0x3
; BE-NEXT:    bl use.i8
; BE-NEXT:    bfi w19, w20, #8, #2
; BE-NEXT:    mov w0, w19
; BE-NEXT:    ldp x20, x19, [sp, #16] // 16-byte Folded Reload
; BE-NEXT:    ldr x30, [sp], #32 // 8-byte Folded Reload
