; RUN: llc -mtriple=aarch64-apple-macosx < %s | FileCheck %s --check-prefix=LE
; RUN: llc -mtriple=aarch64_be-unknown < %s | FileCheck %s --check-prefix=BE

; Test that consecutive byte loads combined via OR with AND masks on individual
; loads are folded into a single wider load + mask at the DAG level.
; This is the pattern from manual bitfield extraction code.
; https://github.com/llvm/llvm-project/issues/191193

; --- Positive tests (should fold to wide load + mask) ---

; High byte masked.
define i16 @load_2_bytes_high_masked(ptr %p) {
; LE-LABEL: load_2_bytes_high_masked:
; LE:       ; %bb.0:
; LE-NEXT:    ldrh w8, [x0]
; LE-NEXT:    and w0, w8, #0x3ff
; LE-NEXT:    ret
;
; BE-LABEL: load_2_bytes_high_masked:
; BE:       // %bb.0:
; BE-NEXT:    ldrh w8, [x0]
; BE-NEXT:    rev w8, w8
; BE-NEXT:    ubfx w0, w8, #16, #10
; BE-NEXT:    ret
  %p1 = getelementptr inbounds i8, ptr %p, i64 1
  %lo = load i8, ptr %p, align 1
  %hi = load i8, ptr %p1, align 1
  %hi.m = and i8 %hi, 3
  %lo.ext = zext i8 %lo to i16
  %hi.ext = zext i8 %hi.m to i16
  %hi.shift = shl i16 %hi.ext, 8
  %result = or i16 %hi.shift, %lo.ext
  ret i16 %result
}

