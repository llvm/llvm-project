; SIGNED-ZEROS-NEXT:    ret
    %res = fptosi <vscale x 4 x float> %in to <vscale x 4 x i32>
    %res2 = sitofp <vscale x 4 x i32> %res to <vscale x 4 x float>
    ret <vscale x 4 x float> %res2
}

