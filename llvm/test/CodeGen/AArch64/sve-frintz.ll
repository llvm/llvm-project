; CHECK-NEXT:    ptrue p0.s
; CHECK-NEXT:    frintz z0.s, p0/m, z0.s
; CHECK-NEXT:    ret
;
; SIGNED-ZEROS-LABEL: frintz_f32_i32_f32:
; SIGNED-ZEROS:       // %bb.0:
; SIGNED-ZEROS-NEXT:    ptrue p0.s
; SIGNED-ZEROS-NEXT:    fcvtzs z0.s, p0/m, z0.s
