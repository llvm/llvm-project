# CHECK:       name:            [[ADD_FUNC]]
# CHECK:       early-clobber $sp = STRXpre $lr, $sp, -16
# CHECK-NEXT:  BL @callee
# CHECK-NEXT:  $x15 = ADDXri $sp, 64, 0
# CHECK-NEXT:  $x15 = ADDXri $sp, 64, 0
# CHECK-NEXT:  early-clobber $sp, $lr = LDRXpost $sp, 16
# CHECK-NEXT:  RET $lr

# CHECK:       name:            [[SUB_FUNC]]
# CHECK:       early-clobber $sp = STRXpre $lr, $sp, -16
# CHECK-NEXT:  BL @callee
# CHECK-NEXT:  $x15 = SUBXri $sp, 32, 0
# CHECK-NEXT:  $x15 = SUBXri $sp, 32, 0
# CHECK-NEXT:  early-clobber $sp, $lr = LDRXpost $sp, 16
