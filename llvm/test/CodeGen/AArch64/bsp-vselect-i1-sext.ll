; CHECK-BE-NEXT:    xtn v2.4h, v4.4s
; CHECK-BE-NEXT:    xtn v0.4h, v0.4s
; CHECK-BE-NEXT:    mvn v3.16b, v3.16b
; CHECK-BE-NEXT:    xtn v1.4h, v1.4s
; CHECK-BE-NEXT:    xtn v3.4h, v3.4s
; CHECK-BE-NEXT:    bif v0.8b, v2.8b, v1.8b
