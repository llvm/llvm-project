; CHECK-BE-LABEL: bsp_const_mask:
; CHECK-BE:       // %bb.0: // %entry
; CHECK-BE-NEXT:    movi d2, #0x00ffff0000ffff
; CHECK-BE-NEXT:    rev64 v1.4h, v1.4h
; CHECK-BE-NEXT:    rev64 v0.4h, v0.4h
; CHECK-BE-NEXT:    bif v0.8b, v1.8b, v2.8b
; CHECK-BE-NEXT:    rev64 v0.4h, v0.4h
; CHECK-BE-NEXT:    ret
entry:
  %m = and <4 x i16> %b, <i16 -1, i16 0, i16 -1, i16 0>
  %n = and <4 x i16> %c, <i16 0, i16 -1, i16 0, i16 -1>
  %r = or <4 x i16> %m, %n
