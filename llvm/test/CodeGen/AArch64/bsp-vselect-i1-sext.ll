; CHECK-BE-NEXT:    and v2.16b, v0.16b, v1.16b
; CHECK-BE-NEXT:    fcmeq v3.4s, v0.4s, v1.4s
; CHECK-BE-NEXT:    cmgt v4.4s, v1.4s, v0.4s
