    $x14 = LDRXui $x22, 14
    $x15 = LDRXui $x22, 15
    $x16 = LDRXui $x22, 16
    $x17 = LDRXui $x22, 17
    $x18 = LDRXui $x22, 18
    $x19 = LDRXui $x22, 19
