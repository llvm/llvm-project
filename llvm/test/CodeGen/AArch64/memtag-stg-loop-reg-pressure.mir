    $lr = LDRXui $x22, 29
    $fp = LDRXui $x22, 30

    ST2Gi $sp, %stack.1, 0 :: (store (s256))
    ST2Gi $sp, %stack.2, 0 :: (store (s256))
    ST2Gi $sp, %stack.3, 0 :: (store (s256))
