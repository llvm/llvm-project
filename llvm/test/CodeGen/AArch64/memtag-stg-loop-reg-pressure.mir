  - { id: 40, size: 8, alignment: 8 }
body:             |
  bb.0.entry:
    liveins: $x22

    ; Load all registers from memory
    $x0 = LDRXui $x22, 0
    $x1 = LDRXui $x22, 1
    $x2 = LDRXui $x22, 2
    $x3 = LDRXui $x22, 3
    $x4 = LDRXui $x22, 4
    $x5 = LDRXui $x22, 5
    $x6 = LDRXui $x22, 6
    $x7 = LDRXui $x22, 7
