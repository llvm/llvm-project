name: no_fuse_positive_shift_orrwrs
tracksRegLiveness: true
isSSA: false
noVRegs: true
body: |
  bb.0:
    successors: %bb.1, %bb.2
    liveins: $w0, $w1, $w2
    $w0 = ORRWrs $w0, $w1, 12
    $w3 = ORRWri $w2, 4096
    CBNZW $w0, %bb.2
  bb.1:
    RET undef $lr
  bb.2:
    RET undef $lr
...

