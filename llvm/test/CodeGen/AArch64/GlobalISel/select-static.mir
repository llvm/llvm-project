    %2(s64) = COPY $x0
    %3(s32) = G_ICMP intpred(uge), %2, %2
    $w0 = COPY %3

    %4(p0) = COPY $x0
    %5(s32) = G_ICMP intpred(ne), %4, %4
    $w0 = COPY %5
...

