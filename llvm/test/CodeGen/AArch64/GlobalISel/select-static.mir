  ; CHECK-NEXT:   $s0 = COPY [[PHI]]
  ; CHECK-NEXT:   RET_ReallyLR implicit $s0
  bb.0:
    liveins: $s0, $w0
    successors: %bb.1
    %0(s32) = COPY $s0
    %3:gpr(s32) = COPY $w0

  bb.1:
    successors: %bb.1, %bb.2
    %2(s32) = PHI %0, %bb.0, %2, %bb.1
    G_BRCOND %3, %bb.1

  bb.2:
    $s0 = COPY %2
    RET_ReallyLR implicit $s0
...

