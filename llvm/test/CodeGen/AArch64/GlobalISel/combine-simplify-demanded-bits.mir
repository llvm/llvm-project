    ; FULL-NEXT: RET_ReallyLR implicit $w0
    %0:_(s32) = COPY $w0
    %amt:_(s32) = G_CONSTANT i32 8
    %ashr:_(s32) = G_ASHR %0, %amt
    %lowmask:_(s32) = G_CONSTANT i32 65535
    %and:_(s32) = G_AND %ashr, %lowmask
    $w0 = COPY %and(s32)
    RET_ReallyLR implicit $w0
...
