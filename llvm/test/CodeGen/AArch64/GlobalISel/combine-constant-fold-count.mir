# Negative test: non-constant source should not be folded.
name:            ctlz_nonconstant
body:             |
  bb.0:
    liveins: $w0
    ; CHECK-LABEL: name: ctlz_nonconstant
    ; CHECK: liveins: $w0
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: %a:_(s32) = COPY $w0
    ; CHECK-NEXT: %res:_(s32) = G_CTLZ %a(s32)
    ; CHECK-NEXT: $w0 = COPY %res(s32)
    ; CHECK-NEXT: RET_ReallyLR implicit $w0
    %a:_(s32) = COPY $w0
    %res:_(s32) = G_CTLZ %a
    $w0 = COPY %res(s32)
    RET_ReallyLR implicit $w0
...
