name:            ctlz_s32
body:             |
  bb.0:
    ; CHECK-LABEL: name: ctlz_s32
    ; CHECK: %res:_(s32) = G_CONSTANT i32 28
    ; CHECK-NEXT: $w0 = COPY %res(s32)
    ; CHECK-NEXT: RET_ReallyLR implicit $w0
    %a:_(s32) = G_CONSTANT i32 8
    %res:_(s32) = G_CTLZ %a
    $w0 = COPY %res(s32)
    RET_ReallyLR implicit $w0
...
