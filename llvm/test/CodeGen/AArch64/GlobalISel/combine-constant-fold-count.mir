    ; CHECK-NEXT: [[C3:%[0-9]+]]:_(s32) = G_CONSTANT i32 28
    ; CHECK-NEXT: %res:_(<4 x s32>) = G_BUILD_VECTOR [[C]](s32), [[C1]](s32), [[C2]](s32), [[C3]](s32)
    ; CHECK-NEXT: $q0 = COPY %res(<4 x s32>)
    ; CHECK-NEXT: RET_ReallyLR implicit $q0
    %c0:_(s32) = G_CONSTANT i32 1
    %c1:_(s32) = G_CONSTANT i32 2
    %c2:_(s32) = G_CONSTANT i32 4
    %c3:_(s32) = G_CONSTANT i32 8
    %v:_(<4 x s32>) = G_BUILD_VECTOR %c0, %c1, %c2, %c3
    %res:_(<4 x s32>) = G_CTLZ %v
    $q0 = COPY %res(<4 x s32>)
    RET_ReallyLR implicit $q0
...
