    %0:_(<3 x i1>) = G_TRUNC %4(<3 x i8>)
    %5:_(<3 x i1>) = G_OR %0, %0
    %7:_(<3 x i8>) = G_ANYEXT %5(<3 x i1>)
    %8:_(i8), %9:_(i8), %10:_(i8) = G_UNMERGE_VALUES %7(<3 x i8>)
