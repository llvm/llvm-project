name:            srem_pos_pow2_s32
body:             |
  bb.1:
    liveins: $w0

    ; CHECK-LABEL: name: srem_pos_pow2_s32
    ; CHECK: liveins: $w0
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:_(s32) = COPY $w0
    ; CHECK-NEXT: [[C:%[0-9]+]]:_(s32) = G_CONSTANT i32 -2147483647
