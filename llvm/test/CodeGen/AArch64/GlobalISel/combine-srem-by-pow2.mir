    ; CHECK-NEXT: %c0:_(s32) = G_CONSTANT i32 4
    ; CHECK-NEXT: %c1:_(s32) = G_CONSTANT i32 -8
    ; CHECK-NEXT: %c2:_(s32) = G_CONSTANT i32 16
    ; CHECK-NEXT: %c3:_(s32) = G_CONSTANT i32 -1
    ; CHECK-NEXT: [[BUILD_VECTOR:%[0-9]+]]:_(<4 x s32>) = G_BUILD_VECTOR %c0(s32), %c1(s32), %c2(s32), %c3(s32)
    ; CHECK-NEXT: [[C:%[0-9]+]]:_(s32) = G_CONSTANT i32 -2147483647
    ; CHECK-NEXT: [[C1:%[0-9]+]]:_(s32) = G_CONSTANT i32 1
    ; CHECK-NEXT: [[C2:%[0-9]+]]:_(s32) = G_CONSTANT i32 2147483647
    ; CHECK-NEXT: [[C3:%[0-9]+]]:_(s32) = G_CONSTANT i32 2
    ; CHECK-NEXT: [[C4:%[0-9]+]]:_(s32) = G_CONSTANT i32 3
    ; CHECK-NEXT: [[C5:%[0-9]+]]:_(s32) = G_CONSTANT i32 0
    ; CHECK-NEXT: [[BUILD_VECTOR1:%[0-9]+]]:_(<4 x s32>) = G_BUILD_VECTOR [[C]](s32), [[C2]](s32), [[C]](s32), [[C5]](s32)
    ; CHECK-NEXT: [[BUILD_VECTOR2:%[0-9]+]]:_(<4 x s32>) = G_BUILD_VECTOR [[C1]](s32), %c3(s32), [[C1]](s32), %c3(s32)
    ; CHECK-NEXT: [[BUILD_VECTOR3:%[0-9]+]]:_(<4 x s32>) = G_BUILD_VECTOR [[C1]](s32), [[C3]](s32), [[C4]](s32), [[C5]](s32)
    ; CHECK-NEXT: [[BUILD_VECTOR4:%[0-9]+]]:_(<4 x s32>) = G_BUILD_VECTOR %c3(s32), %c3(s32), %c3(s32), [[C5]](s32)
    ; CHECK-NEXT: [[SMULH:%[0-9]+]]:_(<4 x s32>) = G_SMULH [[COPY]], [[BUILD_VECTOR1]]
    ; CHECK-NEXT: [[MUL:%[0-9]+]]:_(<4 x s32>) = G_MUL [[COPY]], [[BUILD_VECTOR2]]
    ; CHECK-NEXT: [[ADD:%[0-9]+]]:_(<4 x s32>) = G_ADD [[SMULH]], [[MUL]]
    ; CHECK-NEXT: [[ASHR:%[0-9]+]]:_(<4 x s32>) = G_ASHR [[ADD]], [[BUILD_VECTOR3]](<4 x s32>)
    ; CHECK-NEXT: [[C6:%[0-9]+]]:_(s32) = G_CONSTANT i32 31
    ; CHECK-NEXT: [[BUILD_VECTOR5:%[0-9]+]]:_(<4 x s32>) = G_BUILD_VECTOR [[C6]](s32), [[C6]](s32), [[C6]](s32), [[C6]](s32)
    ; CHECK-NEXT: [[LSHR:%[0-9]+]]:_(<4 x s32>) = G_LSHR [[ASHR]], [[BUILD_VECTOR5]](<4 x s32>)
    ; CHECK-NEXT: [[AND:%[0-9]+]]:_(<4 x s32>) = G_AND [[LSHR]], [[BUILD_VECTOR4]]
    ; CHECK-NEXT: [[ADD1:%[0-9]+]]:_(<4 x s32>) = G_ADD [[ASHR]], [[AND]]
    ; CHECK-NEXT: [[MUL1:%[0-9]+]]:_(<4 x s32>) = G_MUL [[ADD1]], [[BUILD_VECTOR]]
    ; CHECK-NEXT: [[SUB:%[0-9]+]]:_(<4 x s32>) = G_SUB [[COPY]], [[MUL1]]
    ; CHECK-NEXT: $q0 = COPY [[SUB]](<4 x s32>)
    ; CHECK-NEXT: RET_ReallyLR implicit $q0
    %0:_(<4 x s32>) = COPY $q0
    %c0:_(s32) = G_CONSTANT i32 4
    %c1:_(s32) = G_CONSTANT i32 -8
    %c2:_(s32) = G_CONSTANT i32 16
    %c3:_(s32) = G_CONSTANT i32 -1
    %1:_(<4 x s32>) = G_BUILD_VECTOR %c0, %c1, %c2, %c3
    %2:_(<4 x s32>) = G_SREM %0, %1
    $q0 = COPY %2(<4 x s32>)
    RET_ReallyLR implicit $q0

