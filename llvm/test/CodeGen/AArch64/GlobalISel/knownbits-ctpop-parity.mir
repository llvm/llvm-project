# RUN: llc -mtriple=aarch64 -passes="print<gisel-value-tracking>" %s -filetype=null 2>&1 | FileCheck %s

--- |
  declare i32 @llvm.ctpop.i32(i32)
  declare i64 @llvm.ctpop.i64(i64)

  define i32 @parity(i32 %x) {
  entry:
    %0 = call i32 @llvm.ctpop.i32(i32 %x)
    %1 = and i32 %0, 1
    ret i32 %1
  }

  define i1 @parity_bool(i32 %x) {
  entry:
    %0 = call i32 @llvm.ctpop.i32(i32 %x)
    %1 = and i32 %0, 1
    %2 = icmp ne i32 %1, 0
    ret i1 %2
  }

  define i32 @parity_const() {
  entry:
    %0 = call i32 @llvm.ctpop.i32(i32 5)
    %1 = and i32 %0, 1
    ret i32 %1
  }

...

# CHECK-LABEL: name: @parity
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:00000000000000000000000000?????? SignBits:26
# CHECK-NEXT: %2:_ KnownBits:00000000000000000000000000000001 SignBits:31
# CHECK-NEXT: %3:_ KnownBits:0000000000000000000000000000000? SignBits:32

---
name:            parity
body:             |
  bb.1.entry:
    liveins: $w0

    %0:_(i32) = COPY $w0
    %1:_(i32) = G_CTPOP %0(i32)
    %2:_(i32) = G_CONSTANT i32 1
    %3:_(i32) = G_AND %1, %2

    $w0 = COPY %3(i32)
    RET_ReallyLR implicit $w0
...

# CHECK-LABEL: name: @parity_bool
# CHECK-NEXT: %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT: %1:_ KnownBits:00000000000000000000000000?????? SignBits:26
# CHECK-NEXT: %2:_ KnownBits:00000000000000000000000000000001 SignBits:31
# CHECK-NEXT: %3:_ KnownBits:0000000000000000000000000000000? SignBits:32
# CHECK-NEXT: %4:_ KnownBits:00000000000000000000000000000000 SignBits:32
# CHECK-NEXT: %5:_ KnownBits:? SignBits:1
# CHECK-NEXT: %6:_ KnownBits:0000000? SignBits:7
# CHECK-NEXT: %7:_ KnownBits:????????????????????????0000000? SignBits:1

---
name:            parity_bool
body:             |
  bb.1.entry:
    liveins: $w0

    %0:_(i32) = COPY $w0
    %1:_(i32) = G_CTPOP %0(i32)
    %2:_(i32) = G_CONSTANT i32 1
    %3:_(i32) = G_AND %1, %2
    %4:_(i32) = G_CONSTANT i32 0
    %5:_(i1) = G_ICMP intpred(ne), %3(i32), %4
    %6:_(i8) = G_ZEXT %5(i1)
    %7:_(i32) = G_ANYEXT %6(i8)

    $w0 = COPY %7(i32)
    RET_ReallyLR implicit $w0
...

# CHECK-LABEL: name: @parity_const
# CHECK-NEXT: %0:_ KnownBits:00000000000000000000000000000000 SignBits:32

---
name:            parity_const
body:             |
  bb.1.entry:

    %0:_(i32) = G_CONSTANT i32 0

    $w0 = COPY %0(i32)
    RET_ReallyLR implicit $w0
...
