# CHECK-LABEL: name: @numsignbits_srem_negative
# CHECK-NEXT:  %0:_ KnownBits:???????????????????????????????? SignBits:1
# CHECK-NEXT:  %1:_ KnownBits:11111111111111111111111111111000 SignBits:29
# CHECK-NEXT:  %2:_ KnownBits:???????????????????????????????? SignBits:1

---
name: numsignbits_srem_negative
body: |
  bb.1:
    liveins: $w0

    %0:_(s32) = COPY $w0
    %1:_(s32) = G_CONSTANT i32 -8
    %2:_(s32) = G_SREM %0, %1
    $w0 = COPY %2(s32)
    RET_ReallyLR implicit $w0
...

