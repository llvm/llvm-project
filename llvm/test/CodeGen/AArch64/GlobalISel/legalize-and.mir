---
name:            test_scalar_and_small
body:             |
  bb.0.entry:
    ; CHECK-LABEL: name: test_scalar_and_small
    ; CHECK: [[COPY:%[0-9]+]]:_(i64) = COPY $x0
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:_(i64) = COPY $x1
    ; CHECK-NEXT: [[TRUNC:%[0-9]+]]:_(i32) = G_TRUNC [[COPY]](i64)
    ; CHECK-NEXT: [[TRUNC1:%[0-9]+]]:_(i32) = G_TRUNC [[COPY1]](i64)
    ; CHECK-NEXT: [[AND:%[0-9]+]]:_(i32) = G_AND [[TRUNC]], [[TRUNC1]]
    ; CHECK-NEXT: $w0 = COPY [[AND]](i32)
    ; CHECK-NEXT: $x0 = COPY [[COPY]](i64)
    %0:_(i64) = COPY $x0
    %1:_(i64) = COPY $x1
    %2:_(i8) = G_TRUNC %0(i64)
    %3:_(i8) = G_TRUNC %1(i64)
    %4:_(i8) = G_AND %2, %3
    %6:_(i32) = G_ANYEXT %4(i8)
    $w0 = COPY %6(i32)
    %5:_(i64) = G_ANYEXT %2(i8)
    $x0 = COPY %5(i64)

...
