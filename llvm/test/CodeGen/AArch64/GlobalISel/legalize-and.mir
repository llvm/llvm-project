    liveins: $b0, $b1, $b2

    ; CHECK-LABEL: name: and_v3s1
    ; CHECK: liveins: $b0, $b1, $b2
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:_(i8) = COPY $b0
