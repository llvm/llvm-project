name:            test_vector_xor_v16s16
body:             |
  bb.0.entry:
    ; CHECK-LABEL: name: test_vector_xor_v16s16
    ; CHECK: [[COPY:%[0-9]+]]:_(<8 x i16>) = COPY $q0
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:_(<8 x i16>) = COPY $q1
    ; CHECK-NEXT: [[XOR:%[0-9]+]]:_(<8 x i16>) = G_XOR [[COPY]], [[COPY]]
    ; CHECK-NEXT: [[XOR1:%[0-9]+]]:_(<8 x i16>) = G_XOR [[COPY1]], [[COPY1]]
    ; CHECK-NEXT: $q0 = COPY [[XOR]](<8 x i16>)
    ; CHECK-NEXT: $q1 = COPY [[XOR1]](<8 x i16>)
    %1:_(<8 x i16>) = COPY $q0
    %2:_(<8 x i16>) = COPY $q1
    %0:_(<16 x i16>) = G_CONCAT_VECTORS %1(<8 x i16>), %2(<8 x i16>)
    %3:_(<16 x i16>) = G_XOR %0, %0
    %4:_(<8 x i16>), %5:_(<8 x i16>) = G_UNMERGE_VALUES %3(<16 x i16>)
    $q0 = COPY %4(<8 x i16>)
    $q1 = COPY %5(<8 x i16>)

...
