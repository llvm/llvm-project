---
name:            test_scalar_xor_small
body:             |
  bb.0.entry:
    ; CHECK-LABEL: name: test_scalar_xor_small
    ; CHECK: [[COPY:%[0-9]+]]:_(i64) = COPY $x0
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:_(i64) = COPY $x1
    ; CHECK-NEXT: [[TRUNC:%[0-9]+]]:_(i32) = G_TRUNC [[COPY]](i64)
    ; CHECK-NEXT: [[TRUNC1:%[0-9]+]]:_(i32) = G_TRUNC [[COPY1]](i64)
    ; CHECK-NEXT: [[XOR:%[0-9]+]]:_(i32) = G_XOR [[TRUNC]], [[TRUNC1]]
    ; CHECK-NEXT: [[ANYEXT:%[0-9]+]]:_(i64) = G_ANYEXT [[XOR]](i32)
    ; CHECK-NEXT: $x0 = COPY [[ANYEXT]](i64)
    %0:_(i64) = COPY $x0
    %1:_(i64) = COPY $x1
    %2:_(i8) = G_TRUNC %0(i64)
    %3:_(i8) = G_TRUNC %1(i64)
    %4:_(i8) = G_XOR %2, %3
    %5:_(i64) = G_ANYEXT %4(i8)
    $x0 = COPY %5(i64)

...
