  %max = call i64 @llvm.smax.i64(i64 %a, i64 %sub1)
  %sub2 = sub i64 0, %max
  %mul = mul i64 %max, %sub2
  ret i64 %mul
}

; 0 - umax(a, 0 - a)  ->  umin(a, 0 - a)
define i64 @ASubUMax(i64 %a) {
