    ; CHECK: $d0 = COPY [[CLZv8i8_]]
    ; CHECK: RET_ReallyLR implicit $d0
    %0:fpr(<8 x i8>) = COPY $d0
    %1:fpr(<8 x i8>) = G_CTLZ %0(<8 x i8>)
    $d0 = COPY %1(<8 x i8>)
    RET_ReallyLR implicit $d0

...
