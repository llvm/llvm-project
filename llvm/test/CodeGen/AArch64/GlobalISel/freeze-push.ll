; NOTE: Assertions have been autogenerated by utils/update_llc_test_checks.py
; RUN: llc -mtriple=arm64-apple-macosx -global-isel < %s | FileCheck %s

; In the combine rule
;
;    // Convert freeze(Op(Op0, NonPoisonOps...)) to Op(freeze(Op0), NonPoisonOps...)
;    // when Op0 is not guaranteed non-poison
;    def push_freeze_to_prevent_poison_from_propagating ...
;
; Don't push the `freeze` if `freeze(Op0)` is illegal and we've already ; run
; the legalizer.
;
; On AArch64, in the functions below, `freeze`s would be pushed all the way to
; the `load`, which would then cause the crash:
;
;    LLVM ERROR: instruction is not legal: %14:_(i128) = G_FREEZE %0:_ (in function: _0)

define <4 x i32> @_0() {
; CHECK-LABEL: _0:
; CHECK:       ; %bb.0: ; %entry
; CHECK-NEXT:    mov x8, xzr
; CHECK-NEXT:    ldr q0, [x8]
; CHECK-NEXT:    fmov x8, d0
; CHECK-NEXT:    fmov s0, w8
; CHECK-NEXT:    mov.s v0[1], wzr
; CHECK-NEXT:    mov.s v0[2], wzr
; CHECK-NEXT:    mov.s v0[3], wzr
; CHECK-NEXT:    ret
entry:
  %0 = load i128, ptr null, align 16
  %1 = freeze i128 %0
  %2 = insertelement <4 x i128> zeroinitializer, i128 %1, i64 0
  %3 = trunc <4 x i128> %2 to <4 x i32>
  ret <4 x i32> %3
}

