    %0:_(p0) = COPY $x0
    %1:_(i128) = G_LOAD %0(p0) :: (load (i128) from %ir.0)
    %2:_(i128) = G_FREEZE %1
    %3:_(i32) = G_TRUNC %2(i128)
    $w0 = COPY %3(i32)
    RET_ReallyLR implicit $w0
