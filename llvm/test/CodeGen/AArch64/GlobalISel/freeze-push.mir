# RUN: llc -mtriple=arm64-apple-macosx -global-isel -run-pass=aarch64-postlegalizer-combiner %s -o - | FileCheck %s
--- |
  ; ModuleID = 'llvm/test/CodeGen/AArch64/GlobalISel/freeze-push.mir'
  source_filename = "llvm/test/CodeGen/AArch64/GlobalISel/freeze-push.mir"
  target datalayout = "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-n32:64-S128-Fn32"

  define i32 @_0(ptr %0) {
  entry:
    %1 = load i128, ptr %0, align 16
    %2 = freeze i128 %1
    %3 = trunc i128 %2 to i32
    ret i32 %3
  }
...
---
name:            _0
legalized:       true
body:             |
  bb.0.entry:
    liveins: $x0
    ; CHECK-LABEL: name: _0
    ; CHECK: liveins: $x0
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:_(p0) = COPY $x0
    ; CHECK-NEXT: [[LOAD:%[0-9]+]]:_(i128) = G_LOAD [[COPY]](p0) :: (load (i128) from %ir.0)
    ; CHECK-NEXT: [[TRUNC:%[0-9]+]]:_(i64) = G_TRUNC [[LOAD]](i128)
    ; CHECK-NEXT: [[FREEZE:%[0-9]+]]:_(i64) = G_FREEZE [[TRUNC]]
    ; CHECK-NEXT: [[TRUNC1:%[0-9]+]]:_(i32) = G_TRUNC [[FREEZE]](i64)
    ; CHECK-NEXT: $w0 = COPY [[TRUNC1]](i32)
    ; CHECK-NEXT: RET_ReallyLR implicit $w0
    %0:_(p0) = COPY $x0
    %1:_(i128) = G_LOAD %0(p0) :: (load (i128) from %ir.0)
    %4:_(i64), %5:_(i64) = G_UNMERGE_VALUES %1(i128)
    %6:_(i64) = G_FREEZE %4
    %3:_(i32) = G_TRUNC %6(i64)
    $w0 = COPY %3(i32)
    RET_ReallyLR implicit $w0
...
