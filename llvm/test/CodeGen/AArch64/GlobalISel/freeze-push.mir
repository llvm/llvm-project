name:            freeze_illegal_push
legalized:       true
body:             |
  bb.0.entry:
    liveins: $x0
    ; CHECK-LABEL: name: freeze_illegal_push
    ; CHECK: liveins: $x0
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:_(p0) = COPY $x0
