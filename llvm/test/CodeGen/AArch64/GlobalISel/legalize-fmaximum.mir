    ; FP16-NEXT: $h0 = COPY %legalize_me(f16)
    ; FP16-NEXT: RET_ReallyLR implicit $h0
    ;
    ; NO-FP16-LABEL: name: s16_legal_with_full_fp16
    ; NO-FP16: liveins: $h0, $h1
    ; NO-FP16-NEXT: {{  $}}
    ; NO-FP16-NEXT: %a:_(f16) = COPY $h0
    ; NO-FP16-NEXT: %b:_(f16) = COPY $h1
