  ; CHECK-NEXT: %or:_ KnownBits:??????????????????????????????1? SignBits:1
  ; CHECK-NEXT: %inreg1:_ KnownBits:11111111111111111111111111111111 SignBits:32
  ; CHECK-NEXT: %copy_inreg1:_ KnownBits:11111111111111111111111111111111 SignBits:32
