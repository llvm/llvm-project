    %tmp1:_(<2 x s8>) = G_AND %unknown, %mask2_splat
    %val1:_(<2 x s8>) = G_OR %tmp1, %mask3_splat
    %smin:_(<2 x s8>) = G_SMIN %val0, %val1
    %copy_smin:_(<2 x s8>) = COPY %smin
...
