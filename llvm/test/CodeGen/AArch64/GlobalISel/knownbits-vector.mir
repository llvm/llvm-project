name:            TestVectorInvalidQueries
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $x0
  ; CHECK-LABEL: name: @TestVectorInvalidQueries
  ; CHECK-NEXT: %src:_ KnownBits:???????????????????????????????? SignBits:1
  ; CHECK-NEXT: %thirty2:_ KnownBits:00000000000000000000000000100000 SignBits:26
  ; CHECK-NEXT: %thirty2_splat:_ KnownBits:00000000000000000000000000100000 SignBits:26
  ; CHECK-NEXT: %equalSized:_ KnownBits:00000000000000000000000000000000 SignBits:32
  ; CHECK-NEXT: %copy1:_ KnownBits:00000000000000000000000000000000 SignBits:32
  ; CHECK-NEXT: %thirty3:_ KnownBits:00000000000000000000000000100001 SignBits:26
  ; CHECK-NEXT: %thirty3_splat:_ KnownBits:00000000000000000000000000100001 SignBits:26
  ; CHECK-NEXT: %biggerSized:_ KnownBits:00000000000000000000000000000000 SignBits:32
  ; CHECK-NEXT: %copy2:_ KnownBits:00000000000000000000000000000000 SignBits:32
    %src:_(<2 x s32>) = COPY $x0
    %thirty2:_(s32) = G_CONSTANT i32 32
    %thirty2_splat:_(<2 x s32>) = G_BUILD_VECTOR %thirty2:_(s32), %thirty2:_(s32)
    %equalSized:_(<2 x s32>) = G_SHL %src, %thirty2_splat
    %copy1:_(<2 x s32>) = COPY %equalSized
    %thirty3:_(s32) = G_CONSTANT i32 33
    %thirty3_splat:_(<2 x s32>) = G_BUILD_VECTOR %thirty3:_(s32), %thirty3:_(s32)
    %biggerSized:_(<2 x s32>) = G_SHL %src, %thirty3_splat
    %copy2:_(<2 x s32>) = COPY %biggerSized
...
