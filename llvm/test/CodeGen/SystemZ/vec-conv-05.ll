; CHECK-NEXT:    vst %v3, 1024(%r1,%r2)
; CHECK-NEXT:    la %r1, 16(%r1)
; CHECK-NEXT:    cgijlh %r1, 0, .LBB24_1
; CHECK-NEXT:  # %bb.2: # %exit
; CHECK-NEXT:    br %r14
entry:
 %n.vec = add i64 128, 128
 br label %vector.body

vector.body:                                      ; preds = %vector.body, %vector.ph
  %lsr.iv145 = phi i64 [ %lsr.iv.next146, %vector.body ], [ 0, %entry ]
  %lsr.iv143 = phi i64 [ %lsr.iv.next144, %vector.body ], [ %n.vec, %entry ]
  %scevgep148 = getelementptr i8, ptr %Arr, i64 %lsr.iv145
  %scevgep147 = getelementptr i8, ptr %Arr2, i64 %lsr.iv145
  %wide.load = load <4 x float>, ptr %scevgep147, align 4
  %64 = fmul <4 x float> %wide.load, splat (float 2.550000e+02)
  %65 = fptoui <4 x float> %64 to <4 x i8>
  %interleaved.vec = shufflevector <4 x i8> %65, <4 x i8> splat (i8 -1), <16 x i32> <i32 0, i32 0, i32 0, i32 4, i32 1, i32 1, i32 1, i32 5, i32 2, i32 2, i32 2, i32 6, i32 3, i32 3, i32 3, i32 7>
  store <16 x i8> %interleaved.vec, ptr %scevgep148, align 1
  %lsr.iv.next144 = add i64 %lsr.iv143, -4
  %lsr.iv.next146 = add i64 %lsr.iv145, 16
  %66 = icmp eq i64 %lsr.iv.next144, 0
  br i1 %66, label %exit, label %vector.body

exit:
  ret void
}
