# RUN: llc -o - %s -mtriple=s390x-linux-gnu -mcpu=z16 -verify-machineinstrs \
# RUN:   -run-pass=machine-scheduler -debug-only=machine-scheduler 2>&1\
# RUN:   | FileCheck %s

# Schedule the NRK that defines the compare source low to help comparison
# elimination.
# CHECK:      ********** MI Scheduling **********
# CHECK-NEXT: fun:%bb.0
# CHECK:      ********** MI Scheduling **********
# CHECK-NEXT: fun:%bb.1
# CHECK:      Queue BotQ.A: 0 1
# CHECK-NEXT:   Cand SU(0) FIRST
# CHECK-NEXT: Pick Bot WEAK       [pre-RA]
# CHECK-NEXT: Scheduling SU(0) %4:gr32bit = NRK %1:gr32bit, %0:gr32bit, impl
# CHECK:      *** Final schedule for %bb.1 ***
# CHECK-NEXT: SU(1):   %3:addr32bit = OILMux %3:addr32bit(tied-def 0), 1, implicit-def dead $cc
# CHECK-NEXT: SU(0):   %4:gr32bit = NRK %1:gr32bit, %0:gr32bit, implicit-def dead $cc
# CHECK-NEXT: SU(2):   %5:gr32bit = SLLK %2:gr32bit, %3:addr32bit, 0
# CHECK-NEXT: SU(3):   CHIMux %4:gr32bit, 0, implicit-def $cc
---
name:            fun
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $r2l, $r3l
  
    %0:gr32bit = COPY $r3l
    %1:gr32bit = COPY $r2l
    %2:gr32bit = LHIMux 1
    %3:addr32bit = LHIMux 1
  
  bb.1:
    %4:gr32bit = NRK %1, %0, implicit-def dead $cc
    %3:addr32bit = OILMux %3, 1, implicit-def dead $cc
    %5:gr32bit = SLLK %2, %3, 0
    CHIMux %4, 0, implicit-def $cc
    %5:gr32bit = LOCHIMux %5, 0, 14, 8, implicit killed $cc
    Return
...
