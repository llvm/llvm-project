; Commuted operand order: zext on the left
define i32 @add_zext_setne_zero_commuted(i32 %x, i32 %z) {
; CHECK-LABEL: add_zext_setne_zero_commuted:
; CHECK:       @ %bb.0:
; CHECK-NEXT:    rsbs r1, r1, #0
; CHECK-NEXT:    sbcs r1, r1
; CHECK-NEXT:    subs r0, r0, r1
; CHECK-NEXT:    bx lr
  %cmp = icmp ne i32 %z, 0
  %ext = zext i1 %cmp to i32
  %result = add i32 %ext, %x
  ret i32 %result
}

; Negative test: multi-use of zext should not be combined
define i32 @add_zext_setne_zero_multiuse(i32 %x, i32 %z) {
; CHECK-LABEL: add_zext_setne_zero_multiuse:
; CHECK:       @ %bb.0:
; CHECK-NEXT:    subs r2, r1, #1
; CHECK-NEXT:    sbcs r1, r2
; CHECK-NEXT:    adds r0, r0, r1
; CHECK-NEXT:    adds r0, r0, r1
; CHECK-NEXT:    bx lr
  %cmp = icmp ne i32 %z, 0
  %ext = zext i1 %cmp to i32
  %result = add i32 %x, %ext
  %result2 = add i32 %result, %ext
  ret i32 %result2
}

; Negative test: multi-use of setcc should not be combined
define i32 @add_zext_setne_zero_multiuse_cmp(i32 %x, i32 %z) {
; CHECK-LABEL: add_zext_setne_zero_multiuse_cmp:
; CHECK:       @ %bb.0:
; CHECK-NEXT:    bx lr
  %cmp = icmp ne i32 %z, 0
  %ext = zext i1 %cmp to i32
  %ext2 = sext i1 %cmp to i32
  %result = add i32 %x, %ext
  %result2 = add i32 %result, %ext2
  ret i32 %result2
}

