; NOTE: Assertions have been autogenerated by utils/update_llc_test_checks.py
; RUN: llc -mtriple=avr -mcpu=attiny85 < %s | FileCheck %s

; Test mul-by-constant expansion for AVR without hardware multiply.
; attiny85 has no MUL instruction.

define i8 @mul_i8_by_3(i8 %a) nounwind {
; CHECK-LABEL: mul_i8_by_3:
; CHECK:       ; %bb.0:
; CHECK-NEXT:    ldi r22, 3
; CHECK-NEXT:    rcall __mulqi3
; CHECK-NEXT:    ret
  %1 = mul i8 %a, 3
  ret i8 %1
}

