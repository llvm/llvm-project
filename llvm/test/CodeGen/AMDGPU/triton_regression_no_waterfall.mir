    %0:sreg_32 = COPY $sgpr7
    %1:sreg_32 = COPY $sgpr8
    %2:vgpr_32 = nofpexcept V_CVT_U32_F32_e64 0, %1, 0, 0, implicit $mode, implicit $exec
    %3:sreg_32 = COPY %2
