  %gep3 = getelementptr inbounds [8 x float], ptr addrspace(5) %arrayidx, i32 0, i32 3
  store float 4.0, ptr addrspace(5) %gep3, align 4

  %gep4 = getelementptr inbounds [8 x float], ptr addrspace(5) %arrayidx, i32 0, i32 4
  store float 5.0, ptr addrspace(5) %gep4, align 16
