; CHECK-NEXT:    ret void
;
entry:
  %accumulators = alloca [4 x [1 x [8 x float]]], align 32, addrspace(5)
  %arrayidx = getelementptr inbounds [4 x [1 x [8 x float]]], ptr addrspace(5) %accumulators, i32 0, i32 %idx, i32 0

  ; Individual float stores that should be vectorized
  store float 1.0, ptr addrspace(5) %arrayidx, align 16
  %gep1 = getelementptr inbounds [8 x float], ptr addrspace(5) %arrayidx, i32 0, i32 1
  store float 2.0, ptr addrspace(5) %gep1, align 4
  %gep2 = getelementptr inbounds [8 x float], ptr addrspace(5) %arrayidx, i32 0, i32 2
