; CHECK-NEXT:    [[GEP5:%.*]] = getelementptr inbounds [8 x float], ptr addrspace(5) [[ARRAYIDX]], i32 0, i32 5
; CHECK-NEXT:    [[TMP6:%.*]] = getelementptr i8, ptr addrspace(5) [[ARRAYIDX]], i64 20
