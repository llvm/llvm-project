name: test_mmo_merge1
body: |
  bb.0:
    ; CHECK-LABEL: name: test_mmo_merge1
    ; CHECK: BUNDLE implicit-def %0, implicit %1:vgpr_32, implicit $exec :: (store (s32) into @foo, addrspace 3) {
