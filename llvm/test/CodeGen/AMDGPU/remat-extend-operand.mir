#--- Positive: same-block extension enables remat ---
---
name: test_extend_same_block
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $vgpr0, $vgpr1


    ; CHECK-LABEL: name: test_extend_same_block
    ; CHECK: liveins: $vgpr0, $vgpr1
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: S_NOP 0, implicit renamable $vgpr1
    ; CHECK-NEXT: S_NOP 0, implicit renamable $vgpr0
    ; CHECK-NEXT: S_NOP 0, implicit renamable $vgpr0
    ; CHECK-NEXT: renamable $vgpr0 = V_ADD_U32_e64 killed $vgpr1, killed $vgpr0, 0, implicit $exec
    ; CHECK-NEXT: S_NOP 0, implicit killed renamable $vgpr0
    ; CHECK-NEXT: S_ENDPGM 0
    %0:vgpr_32 = COPY $vgpr0
    %1:vgpr_32 = COPY $vgpr1
    %2:vgpr_32 = V_ADD_U32_e64 %1, %0, 0, implicit $exec

    S_NOP 0, implicit %1

    S_NOP 0, implicit %0
    S_NOP 0, implicit %0
    S_NOP 0, implicit %2
    S_ENDPGM 0
...

