    ; CHECK: [[S_MOV_B32_:%[0-9]+]]:sgpr_32 = S_MOV_B32 0, implicit $exec
    ; CHECK-NEXT: undef [[COPY:%[0-9]+]].sub0:sreg_64 = COPY [[S_MOV_B32_]]
    ; CHECK-NEXT: [[COPY:%[0-9]+]].sub1:sreg_64 = IMPLICIT_DEF
    ;
    ; LIS-LABEL: name: regsequence-undef-subreg-without-use
    ; LIS: [[S_MOV_B32_:%[0-9]+]]:sgpr_32 = S_MOV_B32 0, implicit $exec
    ; LIS-NEXT: undef [[COPY:%[0-9]+]].sub0:sreg_64 = COPY [[S_MOV_B32_]]
    ; LIS-NEXT: dead [[COPY:%[0-9]+]].sub1:sreg_64 = IMPLICIT_DEF
    %0:sgpr_32 = S_MOV_B32  0, implicit $exec

    %1:sreg_64 = REG_SEQUENCE %0, %subreg.sub0, undef %2:sgpr_32, %subreg.sub1
...

---
name:      regsequence-undef-subreg-full-reg-use
noPhis:          true
body:             |
  bb.0:



    ; CHECK-LABEL: name: regsequence-undef-subreg-full-reg-use
    ; CHECK: [[S_MOV_B32_:%[0-9]+]]:sgpr_32 = S_MOV_B32 0, implicit $exec
    ; CHECK-NEXT: undef [[COPY:%[0-9]+]].sub0:sreg_64 = COPY [[S_MOV_B32_]]
    ; CHECK-NEXT: [[COPY:%[0-9]+]].sub1:sreg_64 = IMPLICIT_DEF
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:vreg_64 = COPY [[COPY]], implicit $exec
    ;
    ; LIS-LABEL: name: regsequence-undef-subreg-full-reg-use
    ; LIS: [[S_MOV_B32_:%[0-9]+]]:sgpr_32 = S_MOV_B32 0, implicit $exec
    ; LIS-NEXT: undef [[COPY:%[0-9]+]].sub0:sreg_64 = COPY [[S_MOV_B32_]]
    ; LIS-NEXT: [[COPY:%[0-9]+]].sub1:sreg_64 = IMPLICIT_DEF
    ; LIS-NEXT: dead [[COPY1:%[0-9]+]]:vreg_64 = COPY [[COPY]], implicit $exec
    %0:sgpr_32 = S_MOV_B32  0, implicit $exec

    %1:sreg_64 = REG_SEQUENCE %0, %subreg.sub0, undef %2:sgpr_32, %subreg.sub1
    %3:vreg_64 = COPY %1, implicit $exec
...
