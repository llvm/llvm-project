---
name: rcp_s32_vs
legalized: true
regBankSelected: true
tracksRegLiveness: true

body: |
  bb.0:
    liveins: $sgpr0

    ; CHECK-LABEL: name: rcp_s32_vs
    ; CHECK: liveins: $sgpr0
