    ; CHECK-NEXT: [[COPY:%[0-9]+]]:sreg_32 = COPY $sgpr0
    ; CHECK-NEXT: [[V_RCP_F32_e64_:%[0-9]+]]:vgpr_32 = nofpexcept V_RCP_F32_e64 0, [[COPY]], 0, 0, implicit $mode, implicit $exec
    ; CHECK-NEXT: S_ENDPGM 0, implicit [[V_RCP_F32_e64_]]
    %0:sgpr(i32) = COPY $sgpr0
    %2:sgpr(f32) = G_BITCAST %0(i32)
    %1:vgpr(f32) = G_INTRINSIC intrinsic(@llvm.amdgcn.rcp), %2(f32)
    %3:vgpr(i32) = G_BITCAST %1(f32)
    S_ENDPGM 0, implicit %3(i32)
...

