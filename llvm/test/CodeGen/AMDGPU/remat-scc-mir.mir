# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py UTC_ARGS: --version 6
# RUN: llc -mtriple=amdgcn -mcpu=gfx900 --stress-regalloc=2 -run-pass=greedy -o - %s | FileCheck %s

# Test that SOP2 instructions with dead SCC are rematerialized under register pressure

---
name: test_remat_s_add_i32
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $sgpr0

    ; CHECK-LABEL: name: test_remat_s_add_i32
    ; CHECK: liveins: $sgpr0
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:sreg_32 = COPY $sgpr0
    ; CHECK-NEXT: S_NOP 0, implicit-def $sgpr1
    ; CHECK-NEXT: [[S_ADD_I32_:%[0-9]+]]:sreg_32 = S_ADD_I32 [[COPY]], [[COPY]], implicit-def dead $scc
    ; CHECK-NEXT: S_ENDPGM 0, implicit [[COPY]], implicit [[S_ADD_I32_]]
    %0:sreg_32 = COPY $sgpr0


    %1:sreg_32 = S_ADD_I32 %0, %0, implicit-def dead $scc


    S_NOP 0, implicit-def $sgpr1


    S_ENDPGM 0, implicit %0, implicit %1
...
