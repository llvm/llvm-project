; P0-GFX9_4-GISEL-NEXT:    s_waitcnt vmcnt(0) expcnt(0) lgkmcnt(0)
; P0-GFX9_4-GISEL-NEXT:    v_fma_f32 v4, v2, v3, v4
; P0-GFX9_4-GISEL-NEXT:    v_fmac_f32_e32 v4, v0, v1
