# RUN: llc -mtriple=amdgcn -mcpu=gfx90a -mattr=-vgpr-align2 -passes="post-ra-pseudos,si-merge-vgpr-copies" -verify-machineinstrs -o - %s | FileCheck -check-prefixes=GCN,GFX90A-NO-ALIGN %s
# RUN: llc -mtriple=amdgcn -mcpu=gfx90a                     -passes="post-ra-pseudos,si-merge-vgpr-copies" -verify-machineinstrs -o - %s | FileCheck -check-prefixes=GCN,GFX90A-ALIGN    %s
# RUN: llc -mtriple=amdgcn -mcpu=gfx942 -mattr=-vgpr-align2 -passes="post-ra-pseudos,si-merge-vgpr-copies" -verify-machineinstrs -o - %s | FileCheck -check-prefixes=GCN,GFX942-NO-ALIGN %s
# RUN: llc -mtriple=amdgcn -mcpu=gfx942                     -passes="post-ra-pseudos,si-merge-vgpr-copies" -verify-machineinstrs -o - %s | FileCheck -check-prefixes=GCN,GFX942-ALIGN    %s

# Check that merging of 32-bit copies can be done for odd-aligned VGPR registers
# if the target supports it.
# All targets that currently enable this pass (hasPkMovB32 or hasMovB64) also
# require even-aligned VGPR pairs (needsAlignedVGPRs). The -vgpr-align2 flag
# is used here to synthesize a target where the pass runs without the alignment
# requirement, exercising the conditional alignment check.

---
name:            test_odd_aligned_src
tracksRegLiveness: true
body:             |
  bb.0:
    liveins: $vgpr4, $vgpr5
    ; NO-ALIGN-LABEL: name: test_odd_aligned_src
    ; NO-ALIGN: liveins: $vgpr4, $vgpr5
    ; NO-ALIGN-NEXT: {{  $}}
    ; NO-ALIGN-NEXT: $vgpr1_vgpr2 = COPY $vgpr4_vgpr5, implicit $exec
    ; NO-ALIGN-NEXT: S_ENDPGM 0, implicit $vgpr1, implicit $vgpr2
    ; ALIGN-LABEL: name: test_odd_aligned_src
    ; ALIGN: liveins: $vgpr4, $vgpr5
    ; ALIGN-NEXT: {{  $}}
    ; ALIGN-NEXT: $vgpr1 = COPY $vgpr4
    ; ALIGN-NEXT: $vgpr2 = COPY $vgpr5
    ; ALIGN-NEXT: S_ENDPGM 0, implicit $vgpr1, implicit $vgpr2
    ; GFX90A-NO-ALIGN-LABEL: name: test_odd_aligned_src
    ; GFX90A-NO-ALIGN: liveins: $vgpr4, $vgpr5
    ; GFX90A-NO-ALIGN-NEXT: {{  $}}
    ; GFX90A-NO-ALIGN-NEXT: $vgpr1_vgpr2 = V_PK_MOV_B32 8, $vgpr4_vgpr5, 12, $vgpr4_vgpr5, 0, 0, 0, 0, 0, implicit $exec, implicit $vgpr4_vgpr5
    ; GFX90A-NO-ALIGN-NEXT: S_ENDPGM 0, implicit $vgpr1, implicit $vgpr2
    ;
    ; GFX90A-ALIGN-LABEL: name: test_odd_aligned_src
    ; GFX90A-ALIGN: liveins: $vgpr4, $vgpr5
    ; GFX90A-ALIGN-NEXT: {{  $}}
    ; GFX90A-ALIGN-NEXT: $vgpr1 = V_MOV_B32_e32 $vgpr4, implicit $exec
    ; GFX90A-ALIGN-NEXT: $vgpr2 = V_MOV_B32_e32 $vgpr5, implicit $exec
    ; GFX90A-ALIGN-NEXT: S_ENDPGM 0, implicit $vgpr1, implicit $vgpr2
    ;
    ; GFX942-NO-ALIGN-LABEL: name: test_odd_aligned_src
    ; GFX942-NO-ALIGN: liveins: $vgpr4, $vgpr5
    ; GFX942-NO-ALIGN-NEXT: {{  $}}
    ; GFX942-NO-ALIGN-NEXT: $vgpr1_vgpr2 = V_MOV_B64_e32 $vgpr4_vgpr5, implicit $exec
    ; GFX942-NO-ALIGN-NEXT: S_ENDPGM 0, implicit $vgpr1, implicit $vgpr2
    ;
    ; GFX942-ALIGN-LABEL: name: test_odd_aligned_src
    ; GFX942-ALIGN: liveins: $vgpr4, $vgpr5
    ; GFX942-ALIGN-NEXT: {{  $}}
    ; GFX942-ALIGN-NEXT: $vgpr1 = V_MOV_B32_e32 $vgpr4, implicit $exec
    ; GFX942-ALIGN-NEXT: $vgpr2 = V_MOV_B32_e32 $vgpr5, implicit $exec
    ; GFX942-ALIGN-NEXT: S_ENDPGM 0, implicit $vgpr1, implicit $vgpr2
    $vgpr1 = COPY $vgpr4
    $vgpr2 = COPY $vgpr5
    S_ENDPGM 0, implicit $vgpr1, implicit $vgpr2
...

