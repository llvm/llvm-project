# RUN: not llc -mtriple=amdgcn -mcpu=gfx900 -run-pass=si-fold-operands -o - %s 2>&1 | FileCheck %s
# XFAIL: *
# CHECK: Assertion `isVirtual() && "Not a virtual register"' failed

# TODO: Fix SIFoldOperands to handle REG_SEQUENCE with physical register inputs.

---
name: regseq_with_phys_source_crash
tracksRegLiveness: true
body: |
  bb.0:
    liveins: $vgpr0, $vgpr2

    %0:vgpr_32 = V_MOV_B32_e32 1, implicit $exec
    %1:vreg_64 = REG_SEQUENCE $vgpr0, %subreg.sub0, %0, %subreg.sub1
    %2:vgpr_32 = V_ADD_CO_U32_e32 %1.sub0, $vgpr2, implicit-def $vcc, implicit $exec
    S_ENDPGM 0, implicit %2

...
