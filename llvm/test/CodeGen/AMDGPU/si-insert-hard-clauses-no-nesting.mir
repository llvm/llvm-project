      S_CLAUSE 1
      $sgpr2 = S_LOAD_DWORD_IMM $sgpr0_sgpr1, 0, 0
      KILL undef renamable $sgpr0
      $sgpr3 = S_LOAD_DWORD_IMM $sgpr0_sgpr1, 4, 0
    }
    S_ENDPGM 0
