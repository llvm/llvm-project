    ; CHECK-NEXT:   KILL undef renamable $sgpr0
    ; CHECK-NEXT:   $sgpr3 = S_LOAD_DWORD_IMM $sgpr0_sgpr1, 4, 0
    ; CHECK-NEXT: }
    ; CHECK-NEXT: S_ENDPGM 0
