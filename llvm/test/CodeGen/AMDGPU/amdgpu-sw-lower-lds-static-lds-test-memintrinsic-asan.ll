; Test to check that memset/memcpy/memmove on LDS pointers are lowered to the
; global memory buffer that backs the lowered LDS, rather than left targeting
; the LDS address space.

@lds_1 = internal addrspace(3) global [16 x i8] poison, align 4
@lds_2 = internal addrspace(3) global [16 x i8] poison, align 4

