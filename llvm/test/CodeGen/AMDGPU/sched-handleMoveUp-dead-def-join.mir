    %19:sreg_32 = S_AND_B32 %18, 6, implicit-def dead $scc
    %20:sreg_32 = nuw nsw S_ADD_I32 %19, %16, implicit-def dead $scc
    S_CMP_GT_I32 %6, 7, implicit-def $scc
