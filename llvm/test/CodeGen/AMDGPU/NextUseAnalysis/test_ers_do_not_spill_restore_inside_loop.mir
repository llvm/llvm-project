# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.graphics.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.graphics.json --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.compute.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.compute.json --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.compute.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.compute.json --check-prefix=CHECK-CP-JSON %s

--- |
  define amdgpu_ps void @test(ptr addrspace(1) %p1, ptr addrspace(1) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10, $vgpr11, $vgpr12, $vgpr13
  
    %0:vgpr_32 = COPY $vgpr13
    %1:vgpr_32 = COPY $vgpr12
    %2:vgpr_32 = COPY $vgpr11
    %3:vgpr_32 = COPY $vgpr10
    %4:vgpr_32 = COPY $vgpr9
    %5:vgpr_32 = COPY $vgpr8
    %6:vgpr_32 = COPY $vgpr7
    %7:vgpr_32 = COPY $vgpr6
    %8:vgpr_32 = COPY $vgpr5
    %9:vgpr_32 = COPY $vgpr4
    %10:vgpr_32 = COPY $vgpr3
    %11:vgpr_32 = COPY $vgpr2
    %12:vgpr_32 = COPY $vgpr1
    %13:vgpr_32 = COPY $vgpr0
    %14:vreg_64 = REG_SEQUENCE %5, %subreg.sub0, %4, %subreg.sub1
    %15:vreg_64 = REG_SEQUENCE %7, %subreg.sub0, %6, %subreg.sub1
    %16:vreg_64 = REG_SEQUENCE %9, %subreg.sub0, %8, %subreg.sub1
    %17:vreg_64 = REG_SEQUENCE %11, %subreg.sub0, %10, %subreg.sub1
    %18:vreg_64 = REG_SEQUENCE %13, %subreg.sub0, %12, %subreg.sub1
    %19:vgpr_32 = V_AND_B32_e64 1, %3, implicit $exec
    %20:sreg_32 = V_CMP_NE_U32_e64 1, %19, implicit $exec
    %21:vgpr_32 = GLOBAL_LOAD_UBYTE %18, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %22:vgpr_32 = GLOBAL_LOAD_UBYTE %18, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %23:vgpr_32 = V_LSHL_OR_B32_e64 %22, 8, %21, implicit $exec
    %24:vgpr_32 = GLOBAL_LOAD_UBYTE %18, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %25:vgpr_32 = GLOBAL_LOAD_UBYTE %18, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %26:vgpr_32 = V_LSHL_OR_B32_e64 %25, 8, %24, implicit $exec
    %27:vgpr_32 = V_LSHL_OR_B32_e64 %26, 16, %23, implicit $exec
    %28:vgpr_32 = V_MOV_B32_e32 10, implicit $exec
    %29:sreg_32 = S_MOV_B32 0
    %30:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
  
  bb.1:
    successors: %bb.4(0x40000000), %bb.2(0x40000000)
  
    %31:sreg_32 = PHI %29, %bb.0, %32, %bb.5
    %33:vgpr_32 = PHI %30, %bb.0, %34, %bb.5
    %35:vgpr_32 = PHI %28, %bb.0, %36, %bb.5
    %37:vgpr_32 = PHI %27, %bb.0, %38, %bb.5
    %39:sreg_32 = S_MOV_B32 -1
    %40:sreg_32 = SI_IF %20, %bb.2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.2:
    successors: %bb.3(0x40000000), %bb.5(0x40000000)
  
    %41:sreg_32 = PHI %39, %bb.1, %42, %bb.4
    %43:vgpr_32 = PHI undef %44:vgpr_32, %bb.1, %45, %bb.4
    %46:vgpr_32 = PHI undef %44:vgpr_32, %bb.1, %47, %bb.4
    %48:vgpr_32 = PHI undef %44:vgpr_32, %bb.1, %49, %bb.4
    %50:vgpr_32 = PHI %35, %bb.1, undef %51:vgpr_32, %bb.4
    %52:vgpr_32 = PHI %33, %bb.1, undef %53:vgpr_32, %bb.4
    %54:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
    %55:sreg_32 = SI_ELSE %40, %bb.5, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.3:
    successors: %bb.5(0x80000000)
  
    %56:vgpr_32 = V_SUB_U32_e64 %27, %50, 0, implicit $exec
    %57:vgpr_32 = V_ADD_U32_e64 1, %52, 0, implicit $exec
    %58:sreg_32 = V_CMP_GE_U32_e64 %57, %2, implicit $exec
    %59:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
    %60:sreg_32 = S_ANDN2_B32 %41, $exec_lo, implicit-def dead $scc
    %61:sreg_32 = S_AND_B32 %58, $exec_lo, implicit-def dead $scc
    %62:sreg_32 = S_OR_B32 %60, %61, implicit-def dead $scc
    S_BRANCH %bb.5
  
  bb.4:
    successors: %bb.2(0x80000000)
  
    %47:vgpr_32 = GLOBAL_LOAD_DWORD %17, 0, 0, implicit $exec :: (load (s32) from %ir.p2, addrspace 1)
    %45:vgpr_32 = V_ADD_U32_e64 1, %35, 0, implicit $exec
    %49:vgpr_32 = V_ADD_U32_e64 %47, %45, 0, implicit $exec
    %63:sreg_32 = V_CMP_GE_U32_e64 %45, %1, implicit $exec
    %42:sreg_32 = S_ORN2_B32 %63, $exec_lo, implicit-def dead $scc
    S_BRANCH %bb.2
  
  bb.5:
    successors: %bb.6(0x04000000), %bb.1(0x7c000000)
  
    %64:sreg_32 = PHI %41, %bb.2, %62, %bb.3
    %36:vgpr_32 = PHI %43, %bb.2, %59, %bb.3
    %34:vgpr_32 = PHI %54, %bb.2, %57, %bb.3
    %65:vgpr_32 = PHI %46, %bb.2, %27, %bb.3
    %38:vgpr_32 = PHI %48, %bb.2, %56, %bb.3
    SI_END_CF %55, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %32:sreg_32 = SI_IF_BREAK %64, %31, implicit-def dead $scc
    SI_LOOP %32, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.6
  
  bb.6:
    successors: %bb.7(0x80000000)
  
    SI_END_CF %32, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %66:vgpr_32 = V_MUL_LO_U32_e64 %38, %27, implicit $exec
    GLOBAL_STORE_DWORD %16, %66, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %67:sreg_32 = S_MOV_B32 0
  
  bb.7:
    successors: %bb.8(0x04000000), %bb.7(0x7c000000)
  
    %68:sreg_32 = PHI %67, %bb.6, %69, %bb.7
    %70:sreg_32 = PHI %67, %bb.6, %71, %bb.7
    %72:vgpr_32 = PHI %38, %bb.6, %27, %bb.7
    %71:sreg_32 = S_ADD_I32 %70, 2, implicit-def dead $scc
    %73:sreg_32 = V_CMP_GE_U32_e64 %71, %0, implicit $exec
    %69:sreg_32 = SI_IF_BREAK %73, %68, implicit-def dead $scc
    %74:vgpr_32 = COPY %71, implicit $exec
    SI_LOOP %69, %bb.7, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.8
  
  bb.8:
    SI_END_CF %69, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %75:vgpr_32 = V_ADD_U32_e64 %72, %74, 0, implicit $exec
    %76:vgpr_32 = V_ADD_U32_e64 %75, %38, 0, implicit $exec
    %77:vgpr_32 = V_ADD3_U32_e64 %76, %66, %75, implicit $exec
    %78:vgpr_32 = V_ADD3_U32_e64 %27, %77, 100, implicit $exec
    %79:vgpr_32 = V_MUL_LO_U32_e64 %78, %72, implicit $exec
    %80:vgpr_32 = V_SUB_U32_e64 %76, %65, 0, implicit $exec
    %81:vgpr_32 = V_MUL_LO_U32_e64 %79, %80, implicit $exec
    %82:vgpr_32 = GLOBAL_LOAD_DWORD %15, 0, 0, implicit $exec :: (load (s32) from %ir.p4, addrspace 1)
    %83:vgpr_32 = V_MUL_LO_U32_e64 %81, %82, implicit $exec
    %84:vgpr_32 = V_SUB_U32_e64 %76, %82, 0, implicit $exec
    %85:vgpr_32 = GLOBAL_LOAD_DWORD %14, 0, 0, implicit $exec :: (load (s32) from %ir.p5, addrspace 1)
    %86:vgpr_32 = V_SUB_U32_e64 %84, %85, 0, implicit $exec
    %87:vgpr_32 = V_ADD3_U32_e64 %83, %86, %37, implicit $exec
    GLOBAL_STORE_DWORD %15, %87, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    GLOBAL_STORE_DWORD %14, %66, 0, 0, implicit $exec :: (store (s32) into %ir.p5, addrspace 1)
    S_ENDPGM 0
...


