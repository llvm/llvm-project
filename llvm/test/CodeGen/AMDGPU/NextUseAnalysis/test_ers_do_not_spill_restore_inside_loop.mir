# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s
--- |
  define amdgpu_ps void @test(ptr addrspace(1) %p1, ptr addrspace(1) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10, $vgpr11, $vgpr12, $vgpr13
  
    %51:vgpr_32 = COPY $vgpr13
    %50:vgpr_32 = COPY $vgpr12
    %49:vgpr_32 = COPY $vgpr11
    %48:vgpr_32 = COPY $vgpr10
    %47:vgpr_32 = COPY $vgpr9
    %46:vgpr_32 = COPY $vgpr8
    %45:vgpr_32 = COPY $vgpr7
    %44:vgpr_32 = COPY $vgpr6
    %43:vgpr_32 = COPY $vgpr5
    %42:vgpr_32 = COPY $vgpr4
    %41:vgpr_32 = COPY $vgpr3
    %40:vgpr_32 = COPY $vgpr2
    %39:vgpr_32 = COPY $vgpr1
    %38:vgpr_32 = COPY $vgpr0
    %119:vreg_64 = REG_SEQUENCE %46, %subreg.sub0, %47, %subreg.sub1
    %118:vreg_64 = REG_SEQUENCE %44, %subreg.sub0, %45, %subreg.sub1
    %117:vreg_64 = REG_SEQUENCE %42, %subreg.sub0, %43, %subreg.sub1
    %116:vreg_64 = REG_SEQUENCE %40, %subreg.sub0, %41, %subreg.sub1
    %115:vreg_64 = REG_SEQUENCE %38, %subreg.sub0, %39, %subreg.sub1
    %63:vgpr_32 = V_AND_B32_e64 1, %48, implicit $exec
    %64:sreg_32 = V_CMP_NE_U32_e64 1, %63, implicit $exec
    %65:vgpr_32 = GLOBAL_LOAD_UBYTE %115, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %67:vgpr_32 = GLOBAL_LOAD_UBYTE %115, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %70:vgpr_32 = V_LSHL_OR_B32_e64 %67, 8, %65, implicit $exec
    %71:vgpr_32 = GLOBAL_LOAD_UBYTE %115, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %73:vgpr_32 = GLOBAL_LOAD_UBYTE %115, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %75:vgpr_32 = V_LSHL_OR_B32_e64 %73, 8, %71, implicit $exec
    %1:vgpr_32 = V_LSHL_OR_B32_e64 %75, 16, %70, implicit $exec
    %57:vgpr_32 = V_MOV_B32_e32 10, implicit $exec
    %56:sreg_32 = S_MOV_B32 0
    %120:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
  
  bb.1:
    successors: %bb.4(0x40000000), %bb.2(0x40000000)
  
    %2:sreg_32 = PHI %56, %bb.0, %24, %bb.5
    %3:vgpr_32 = PHI %120, %bb.0, %20, %bb.5
    %4:vgpr_32 = PHI %57, %bb.0, %19, %bb.5
    %5:vgpr_32 = PHI %1, %bb.0, %22, %bb.5
    %79:sreg_32 = S_MOV_B32 -1
    %6:sreg_32 = SI_IF %64, %bb.2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.2:
    successors: %bb.3(0x40000000), %bb.5(0x40000000)
  
    %10:sreg_32 = PHI %79, %bb.1, %122, %bb.4
    %7:vgpr_32 = PHI undef %77:vgpr_32, %bb.1, %16, %bb.4
    %8:vgpr_32 = PHI undef %77:vgpr_32, %bb.1, %15, %bb.4
    %9:vgpr_32 = PHI undef %77:vgpr_32, %bb.1, %17, %bb.4
    %128:vgpr_32 = PHI %4, %bb.1, undef %129:vgpr_32, %bb.4
    %130:vgpr_32 = PHI %3, %bb.1, undef %131:vgpr_32, %bb.4
    %83:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
    %11:sreg_32 = SI_ELSE %6, %bb.5, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.3:
    successors: %bb.5(0x80000000)
  
    %12:vgpr_32 = V_SUB_U32_e64 %1, %128, 0, implicit $exec
    %13:vgpr_32 = V_ADD_U32_e64 1, %130, 0, implicit $exec
    %86:sreg_32 = V_CMP_GE_U32_e64 %13, %49, implicit $exec
    %84:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
    %125:sreg_32 = S_ANDN2_B32 %10, $exec_lo, implicit-def dead $scc
    %126:sreg_32 = S_AND_B32 %86, $exec_lo, implicit-def dead $scc
    %124:sreg_32 = S_OR_B32 %125, %126, implicit-def dead $scc
    S_BRANCH %bb.5
  
  bb.4:
    successors: %bb.2(0x80000000)
  
    %15:vgpr_32 = GLOBAL_LOAD_DWORD %116, 0, 0, implicit $exec :: (load (s32) from %ir.p2, addrspace 1)
    %16:vgpr_32 = V_ADD_U32_e64 1, %4, 0, implicit $exec
    %17:vgpr_32 = V_ADD_U32_e64 %15, %16, 0, implicit $exec
    %82:sreg_32 = V_CMP_GE_U32_e64 %16, %50, implicit $exec
    %122:sreg_32 = S_ORN2_B32 %82, $exec_lo, implicit-def dead $scc
    S_BRANCH %bb.2
  
  bb.5:
    successors: %bb.6(0x04000000), %bb.1(0x7c000000)
  
    %23:sreg_32 = PHI %10, %bb.2, %124, %bb.3
    %19:vgpr_32 = PHI %7, %bb.2, %84, %bb.3
    %20:vgpr_32 = PHI %83, %bb.2, %13, %bb.3
    %21:vgpr_32 = PHI %8, %bb.2, %1, %bb.3
    %22:vgpr_32 = PHI %9, %bb.2, %12, %bb.3
    SI_END_CF %11, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %24:sreg_32 = SI_IF_BREAK %23, %2, implicit-def dead $scc
    SI_LOOP %24, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.6
  
  bb.6:
    successors: %bb.7(0x80000000)
  
    SI_END_CF %24, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %29:vgpr_32 = V_MUL_LO_U32_e64 %22, %1, implicit $exec
    GLOBAL_STORE_DWORD %117, %29, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %88:sreg_32 = S_MOV_B32 0
  
  bb.7:
    successors: %bb.8(0x04000000), %bb.7(0x7c000000)
  
    %30:sreg_32 = PHI %88, %bb.6, %34, %bb.7
    %31:sreg_32 = PHI %88, %bb.6, %33, %bb.7
    %32:vgpr_32 = PHI %22, %bb.6, %1, %bb.7
    %33:sreg_32 = S_ADD_I32 %31, 2, implicit-def dead $scc
    %90:sreg_32 = V_CMP_GE_U32_e64 %33, %51, implicit $exec
    %34:sreg_32 = SI_IF_BREAK %90, %30, implicit-def dead $scc
    %121:vgpr_32 = COPY %33, implicit $exec
    SI_LOOP %34, %bb.7, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.8
  
  bb.8:
    SI_END_CF %34, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %91:vgpr_32 = V_ADD_U32_e64 %32, %121, 0, implicit $exec
    %92:vgpr_32 = V_ADD_U32_e64 %91, %22, 0, implicit $exec
    %93:vgpr_32 = V_ADD3_U32_e64 %92, %29, %91, implicit $exec
    %95:vgpr_32 = V_ADD3_U32_e64 %1, %93, 100, implicit $exec
    %96:vgpr_32 = V_MUL_LO_U32_e64 %95, %32, implicit $exec
    %97:vgpr_32 = V_SUB_U32_e64 %92, %21, 0, implicit $exec
    %98:vgpr_32 = V_MUL_LO_U32_e64 %96, %97, implicit $exec
    %99:vgpr_32 = GLOBAL_LOAD_DWORD %118, 0, 0, implicit $exec :: (load (s32) from %ir.p4, addrspace 1)
    %100:vgpr_32 = V_MUL_LO_U32_e64 %98, %99, implicit $exec
    %101:vgpr_32 = V_SUB_U32_e64 %92, %99, 0, implicit $exec
    %102:vgpr_32 = GLOBAL_LOAD_DWORD %119, 0, 0, implicit $exec :: (load (s32) from %ir.p5, addrspace 1)
    %103:vgpr_32 = V_SUB_U32_e64 %101, %102, 0, implicit $exec
    %104:vgpr_32 = V_ADD3_U32_e64 %100, %103, %5, implicit $exec
    GLOBAL_STORE_DWORD %118, %104, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    GLOBAL_STORE_DWORD %119, %29, 0, 0, implicit $exec :: (store (s32) into %ir.p5, addrspace 1)
    S_ENDPGM 0
...

