# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# MIR CFG:
#
#           bb.0
#               |
#       bb.1.header<---+
#          /        |        |
#bb.4.latch2  |        |
#          \        |        |
#           bb.2        |
#           /       |        |
#bb.3.latch1  |        |
#           \       |        |
#           bb.5-------+
#               |
#            bb.6
#               |
#           bb.7<------+
#               |            |
#               +------------+
#               |
#           bb.8
#

--- |
  define amdgpu_ps i32 @test7(ptr addrspace(1) %p1, ptr addrspace(1) %p2, ptr addrspace(1) %p3) {
  ret i32 0
  }
...

---
name:            test7
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9
  
    %0:vgpr_32 = COPY $vgpr9
    %1:vgpr_32 = COPY $vgpr8
    %2:vgpr_32 = COPY $vgpr7
    %3:vgpr_32 = COPY $vgpr6
    %4:vgpr_32 = COPY $vgpr5
    %5:vgpr_32 = COPY $vgpr4
    %6:vgpr_32 = COPY $vgpr3
    %7:vgpr_32 = COPY $vgpr2
    %8:vgpr_32 = COPY $vgpr1
    %9:vgpr_32 = COPY $vgpr0
    %10:vreg_64 = REG_SEQUENCE %5, %subreg.sub0, %4, %subreg.sub1
    %11:vreg_64 = REG_SEQUENCE %7, %subreg.sub0, %6, %subreg.sub1
    %12:vreg_64 = REG_SEQUENCE %9, %subreg.sub0, %8, %subreg.sub1
    %13:vgpr_32 = V_AND_B32_e64 1, %3, implicit $exec
    %14:sreg_32 = V_CMP_NE_U32_e64 1, %13, implicit $exec
    %15:vgpr_32 = GLOBAL_LOAD_UBYTE %12, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %16:vgpr_32 = GLOBAL_LOAD_UBYTE %12, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %17:vgpr_32 = V_LSHL_OR_B32_e64 %16, 8, %15, implicit $exec
    %18:vgpr_32 = GLOBAL_LOAD_UBYTE %12, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %19:vgpr_32 = GLOBAL_LOAD_UBYTE %12, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %20:vgpr_32 = V_LSHL_OR_B32_e64 %19, 8, %18, implicit $exec
    %21:vgpr_32 = V_LSHL_OR_B32_e64 %20, 16, %17, implicit $exec
    %22:vgpr_32 = V_MOV_B32_e32 10, implicit $exec
    %23:sreg_32 = S_MOV_B32 0
    %24:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
  
  bb.1:
    successors: %bb.4(0x40000000), %bb.2(0x40000000)
  
    %25:sreg_32 = PHI %23, %bb.0, %26, %bb.5
    %27:vgpr_32 = PHI %24, %bb.0, %28, %bb.5
    %29:vgpr_32 = PHI %22, %bb.0, %30, %bb.5
    %31:vgpr_32 = PHI %21, %bb.0, %32, %bb.5
    %33:sreg_32 = S_MOV_B32 -1
    %34:sreg_32 = SI_IF %14, %bb.2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.2:
    successors: %bb.3(0x40000000), %bb.5(0x40000000)
  
    %35:sreg_32 = PHI %33, %bb.1, %36, %bb.4
    %37:vgpr_32 = PHI undef %38:vgpr_32, %bb.1, %39, %bb.4
    %40:vgpr_32 = PHI undef %38:vgpr_32, %bb.1, %41, %bb.4
    %42:vgpr_32 = PHI undef %38:vgpr_32, %bb.1, %43, %bb.4
    %44:vgpr_32 = PHI undef %38:vgpr_32, %bb.1, %45, %bb.4
    %46:vgpr_32 = PHI %29, %bb.1, undef %47:vgpr_32, %bb.4
    %48:vgpr_32 = PHI %27, %bb.1, undef %49:vgpr_32, %bb.4
    %50:sreg_32 = SI_ELSE %34, %bb.5, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.3:
    successors: %bb.5(0x80000000)
  
    %51:vgpr_32 = V_SUB_U32_e64 %21, %46, 0, implicit $exec
    %52:vgpr_32 = V_ADD_U32_e64 1, %48, 0, implicit $exec
    %53:sreg_32 = V_CMP_GE_U32_e64 %52, %2, implicit $exec
    %54:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
    %55:sreg_32 = S_ANDN2_B32 %35, $exec_lo, implicit-def dead $scc
    %56:sreg_32 = S_AND_B32 %53, $exec_lo, implicit-def dead $scc
    %57:sreg_32 = S_OR_B32 %55, %56, implicit-def dead $scc
    S_BRANCH %bb.5
  
  bb.4:
    successors: %bb.2(0x80000000)
  
    %43:vgpr_32 = GLOBAL_LOAD_DWORD %11, 0, 0, implicit $exec :: (load (s32) from %ir.p2, addrspace 1)
    %39:vgpr_32 = V_ADD_U32_e64 1, %29, 0, implicit $exec
    %45:vgpr_32 = V_ADD_U32_e64 %43, %39, 0, implicit $exec
    %58:sreg_32 = V_CMP_GE_U32_e64 %39, %1, implicit $exec
    %41:vgpr_32 = V_MOV_B32_e32 0, implicit $exec
    %36:sreg_32 = S_ORN2_B32 %58, $exec_lo, implicit-def dead $scc
    S_BRANCH %bb.2
  
  bb.5:
    successors: %bb.6(0x04000000), %bb.1(0x7c000000)
  
    %59:sreg_32 = PHI %35, %bb.2, %57, %bb.3
    %30:vgpr_32 = PHI %37, %bb.2, %54, %bb.3
    %28:vgpr_32 = PHI %40, %bb.2, %52, %bb.3
    %60:vgpr_32 = PHI %42, %bb.2, %21, %bb.3
    %32:vgpr_32 = PHI %44, %bb.2, %51, %bb.3
    SI_END_CF %50, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %26:sreg_32 = SI_IF_BREAK %59, %25, implicit-def dead $scc
    SI_LOOP %26, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.6
  
  bb.6:
    successors: %bb.7(0x80000000)
  
    SI_END_CF %26, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %61:vgpr_32 = V_MUL_LO_U32_e64 %32, %31, implicit $exec
    GLOBAL_STORE_DWORD %10, %61, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %62:sreg_32 = S_MOV_B32 0
  
  bb.7:
    successors: %bb.8(0x04000000), %bb.7(0x7c000000)
  
    %63:sreg_32 = PHI %62, %bb.6, %64, %bb.7
    %65:sreg_32 = PHI %62, %bb.6, %66, %bb.7
    %67:vgpr_32 = PHI %32, %bb.6, %31, %bb.7
    %66:sreg_32 = S_ADD_I32 %65, 2, implicit-def dead $scc
    %68:sreg_32 = V_CMP_GE_U32_e64 %66, %0, implicit $exec
    %64:sreg_32 = SI_IF_BREAK %68, %63, implicit-def dead $scc
    %69:vgpr_32 = COPY %66, implicit $exec
    SI_LOOP %64, %bb.7, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.8
  
  bb.8:
    SI_END_CF %64, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %70:vgpr_32 = V_ADD3_U32_e64 %67, %69, %32, implicit $exec
    %71:vgpr_32 = V_ADD3_U32_e64 %70, %61, %60, implicit $exec
    %72:vgpr_32 = V_ADD3_U32_e64 %21, %71, 100, implicit $exec
    %73:sreg_32_xm0 = V_READFIRSTLANE_B32 %72, implicit $exec
    $sgpr0 = COPY %73
    SI_RETURN_TO_EPILOG killed $sgpr0
...
---


