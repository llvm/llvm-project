# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

--- |
  define amdgpu_ps void @test(ptr addrspace(1) %gep.le, ptr addrspace(1) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10
  
    %0:vgpr_32 = COPY $vgpr10
    %1:vgpr_32 = COPY $vgpr9
    %2:vgpr_32 = COPY $vgpr8
    %3:vgpr_32 = COPY $vgpr7
    %4:vgpr_32 = COPY $vgpr6
    %5:vgpr_32 = COPY $vgpr5
    %6:vgpr_32 = COPY $vgpr4
    %7:vgpr_32 = COPY $vgpr3
    %8:vgpr_32 = COPY $vgpr2
    %9:vgpr_32 = COPY $vgpr1
    %10:vgpr_32 = COPY $vgpr0
    %11:vreg_64 = REG_SEQUENCE %2, %subreg.sub0, %1, %subreg.sub1
    %12:vreg_64 = REG_SEQUENCE %4, %subreg.sub0, %3, %subreg.sub1
    %13:vreg_64 = REG_SEQUENCE %6, %subreg.sub0, %5, %subreg.sub1
    %14:vreg_64 = REG_SEQUENCE %10, %subreg.sub0, %9, %subreg.sub1
    %15:vreg_64 = REG_SEQUENCE %8, %subreg.sub0, %7, %subreg.sub1
    %16:vgpr_32 = GLOBAL_LOAD_DWORD %15, 0, 0, implicit $exec :: (load (s32) from %ir.p2, addrspace 1)
    GLOBAL_STORE_DWORD %15, %0, 0, 0, implicit $exec :: (store (s32) into %ir.p2, addrspace 1)
    %17:sreg_32 = S_MOV_B32 -1
    %18:sreg_32 = S_MOV_B32 0
  
  bb.1:
    successors: %bb.2(0x04000000), %bb.1(0x7c000000)
  
    %19:sreg_32 = PHI %18, %bb.0, %20, %bb.1
    %21:sreg_32 = PHI %17, %bb.0, %22, %bb.1
    %22:sreg_32 = S_ADD_I32 %21, 1, implicit-def dead $scc
    %23:sreg_32 = S_ADD_I32 %21, 2, implicit-def dead $scc
    %24:sreg_32 = V_CMP_GE_U32_e64 %23, %16, implicit $exec
    %20:sreg_32 = SI_IF_BREAK %24, %19, implicit-def dead $scc
    %25:vgpr_32 = COPY %22, implicit $exec
    %26:vgpr_32 = COPY %23, implicit $exec
    SI_LOOP %20, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    SI_END_CF %20, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %27:vgpr_32 = V_ASHRREV_I32_e64 31, %25, implicit $exec
    %28:vreg_64 = REG_SEQUENCE %25, %subreg.sub0, %27, %subreg.sub1
    %29:vreg_64 = nsw V_LSHLREV_B64_pseudo_e64 2, %28, implicit $exec
    %30:vgpr_32, %31:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %14.sub0, %29.sub0, 0, implicit $exec
    %32:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %14.sub1, %29.sub1, %31, 0, implicit $exec
    %33:vreg_64 = REG_SEQUENCE %30, %subreg.sub0, %32, %subreg.sub1
    %34:vgpr_32 = GLOBAL_LOAD_UBYTE %33, 0, 0, implicit $exec :: (load (s8) from %ir.gep.le, addrspace 1)
    %35:vgpr_32 = GLOBAL_LOAD_UBYTE %33, 1, 0, implicit $exec :: (load (s8) from %ir.gep.le + 1, addrspace 1)
    %36:vgpr_32 = V_LSHL_OR_B32_e64 %35, 8, %34, implicit $exec
    %37:vgpr_32 = GLOBAL_LOAD_UBYTE %33, 2, 0, implicit $exec :: (load (s8) from %ir.gep.le + 2, addrspace 1)
    %38:vgpr_32 = GLOBAL_LOAD_UBYTE %33, 3, 0, implicit $exec :: (load (s8) from %ir.gep.le + 3, addrspace 1)
    %39:vgpr_32 = V_LSHL_OR_B32_e64 %38, 8, %37, implicit $exec
    %40:vgpr_32 = V_LSHL_OR_B32_e64 %39, 16, %36, implicit $exec
    %41:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 0, 0, implicit $exec :: (load (s8) from %ir.p3, addrspace 1)
    %42:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 1, 0, implicit $exec :: (load (s8) from %ir.p3 + 1, addrspace 1)
    %43:vgpr_32 = V_LSHL_OR_B32_e64 %42, 8, %41, implicit $exec
    %44:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 2, 0, implicit $exec :: (load (s8) from %ir.p3 + 2, addrspace 1)
    %45:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 3, 0, implicit $exec :: (load (s8) from %ir.p3 + 3, addrspace 1)
    %46:vgpr_32 = V_LSHL_OR_B32_e64 %45, 8, %44, implicit $exec
    %47:vgpr_32 = V_LSHL_OR_B32_e64 %46, 16, %43, implicit $exec
    %48:vgpr_32 = GLOBAL_LOAD_DWORD %12, 0, 0, implicit $exec :: (load (s32) from %ir.p4, addrspace 1)
    %49:vgpr_32 = V_ADD_U32_e64 %48, %26, 0, implicit $exec
    %50:vgpr_32 = V_MUL_LO_U32_e64 %48, %49, implicit $exec
    GLOBAL_STORE_DWORD %13, %50, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %51:vgpr_32 = V_SUB_U32_e64 %50, %49, 0, implicit $exec
    %52:vgpr_32 = V_MUL_LO_U32_e64 %51, %0, implicit $exec
    GLOBAL_STORE_DWORD %12, %52, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    %53:vgpr_32 = V_MUL_LO_U32_e64 %16, %47, implicit $exec
    %54:vgpr_32 = V_ADD3_U32_e64 %40, %25, %53, implicit $exec
    GLOBAL_STORE_DWORD %11, %54, 0, 0, implicit $exec :: (store (s32) into %ir.p5, addrspace 1)
    S_ENDPGM 0
...


