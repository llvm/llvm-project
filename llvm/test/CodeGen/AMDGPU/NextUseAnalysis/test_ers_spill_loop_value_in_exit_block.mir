# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s
--- |
  define amdgpu_ps void @test(ptr addrspace(1) %gep.le, ptr addrspace(1) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10
  
    %19:vgpr_32 = COPY $vgpr10
    %18:vgpr_32 = COPY $vgpr9
    %17:vgpr_32 = COPY $vgpr8
    %16:vgpr_32 = COPY $vgpr7
    %15:vgpr_32 = COPY $vgpr6
    %14:vgpr_32 = COPY $vgpr5
    %13:vgpr_32 = COPY $vgpr4
    %12:vgpr_32 = COPY $vgpr3
    %11:vgpr_32 = COPY $vgpr2
    %10:vgpr_32 = COPY $vgpr1
    %9:vgpr_32 = COPY $vgpr0
    %79:vreg_64 = REG_SEQUENCE %17, %subreg.sub0, %18, %subreg.sub1
    %78:vreg_64 = REG_SEQUENCE %15, %subreg.sub0, %16, %subreg.sub1
    %77:vreg_64 = REG_SEQUENCE %13, %subreg.sub0, %14, %subreg.sub1
    %76:vreg_64 = REG_SEQUENCE %9, %subreg.sub0, %10, %subreg.sub1
    %75:vreg_64 = REG_SEQUENCE %11, %subreg.sub0, %12, %subreg.sub1
    %0:vgpr_32 = GLOBAL_LOAD_DWORD %75, 0, 0, implicit $exec :: (load (s32) from %ir.p2, addrspace 1)
    GLOBAL_STORE_DWORD %75, %19, 0, 0, implicit $exec :: (store (s32) into %ir.p2, addrspace 1)
    %25:sreg_32 = S_MOV_B32 -1
    %24:sreg_32 = S_MOV_B32 0
  
  bb.1:
    successors: %bb.2(0x04000000), %bb.1(0x7c000000)
  
    %1:sreg_32 = PHI %24, %bb.0, %5, %bb.1
    %2:sreg_32 = PHI %25, %bb.0, %3, %bb.1
    %3:sreg_32 = S_ADD_I32 %2, 1, implicit-def dead $scc
    %4:sreg_32 = S_ADD_I32 %2, 2, implicit-def dead $scc
    %35:sreg_32 = V_CMP_GE_U32_e64 %4, %0, implicit $exec
    %5:sreg_32 = SI_IF_BREAK %35, %1, implicit-def dead $scc
    %80:vgpr_32 = COPY %3, implicit $exec
    %81:vgpr_32 = COPY %4, implicit $exec
    SI_LOOP %5, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    SI_END_CF %5, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %36:vgpr_32 = V_ASHRREV_I32_e64 31, %80, implicit $exec
    %38:vreg_64 = REG_SEQUENCE %80, %subreg.sub0, %36, %subreg.sub1
    %40:vreg_64 = nsw V_LSHLREV_B64_pseudo_e64 2, %38, implicit $exec
    %82:vgpr_32, %84:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %76.sub0, %40.sub0, 0, implicit $exec
    %83:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %76.sub1, %40.sub1, %84, 0, implicit $exec
    %41:vreg_64 = REG_SEQUENCE %82, %subreg.sub0, %83, %subreg.sub1
    %42:vgpr_32 = GLOBAL_LOAD_UBYTE %41, 0, 0, implicit $exec :: (load (s8) from %ir.gep.le, addrspace 1)
    %43:vgpr_32 = GLOBAL_LOAD_UBYTE %41, 1, 0, implicit $exec :: (load (s8) from %ir.gep.le + 1, addrspace 1)
    %45:vgpr_32 = V_LSHL_OR_B32_e64 %43, 8, %42, implicit $exec
    %46:vgpr_32 = GLOBAL_LOAD_UBYTE %41, 2, 0, implicit $exec :: (load (s8) from %ir.gep.le + 2, addrspace 1)
    %47:vgpr_32 = GLOBAL_LOAD_UBYTE %41, 3, 0, implicit $exec :: (load (s8) from %ir.gep.le + 3, addrspace 1)
    %48:vgpr_32 = V_LSHL_OR_B32_e64 %47, 8, %46, implicit $exec
    %50:vgpr_32 = V_LSHL_OR_B32_e64 %48, 16, %45, implicit $exec
    %51:vgpr_32 = GLOBAL_LOAD_UBYTE %77, 0, 0, implicit $exec :: (load (s8) from %ir.p3, addrspace 1)
    %52:vgpr_32 = GLOBAL_LOAD_UBYTE %77, 1, 0, implicit $exec :: (load (s8) from %ir.p3 + 1, addrspace 1)
    %53:vgpr_32 = V_LSHL_OR_B32_e64 %52, 8, %51, implicit $exec
    %54:vgpr_32 = GLOBAL_LOAD_UBYTE %77, 2, 0, implicit $exec :: (load (s8) from %ir.p3 + 2, addrspace 1)
    %55:vgpr_32 = GLOBAL_LOAD_UBYTE %77, 3, 0, implicit $exec :: (load (s8) from %ir.p3 + 3, addrspace 1)
    %56:vgpr_32 = V_LSHL_OR_B32_e64 %55, 8, %54, implicit $exec
    %57:vgpr_32 = V_LSHL_OR_B32_e64 %56, 16, %53, implicit $exec
    %58:vgpr_32 = GLOBAL_LOAD_DWORD %78, 0, 0, implicit $exec :: (load (s32) from %ir.p4, addrspace 1)
    %59:vgpr_32 = V_ADD_U32_e64 %58, %81, 0, implicit $exec
    %60:vgpr_32 = V_MUL_LO_U32_e64 %58, %59, implicit $exec
    GLOBAL_STORE_DWORD %77, %60, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %61:vgpr_32 = V_SUB_U32_e64 %60, %59, 0, implicit $exec
    %62:vgpr_32 = V_MUL_LO_U32_e64 %61, %19, implicit $exec
    GLOBAL_STORE_DWORD %78, %62, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    %63:vgpr_32 = V_MUL_LO_U32_e64 %0, %57, implicit $exec
    %64:vgpr_32 = V_ADD3_U32_e64 %50, %80, %63, implicit $exec
    GLOBAL_STORE_DWORD %79, %64, 0, 0, implicit $exec :: (store (s32) into %ir.p5, addrspace 1)
    S_ENDPGM 0
...

