# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s
--- |
  define amdgpu_ps i64 @test(ptr addrspace(1) %gep3, ptr addrspace(1) %gep4) {
  ret i64 0
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.3(0x40000000), %bb.1(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3
  
    %9:vgpr_32 = COPY $vgpr3
    %8:vgpr_32 = COPY $vgpr2
    %7:vgpr_32 = COPY $vgpr1
    %6:vgpr_32 = COPY $vgpr0
    %13:vgpr_32 = V_AND_B32_e64 1, %6, implicit $exec
    %14:sreg_32 = V_CMP_NE_U32_e64 1, %13, implicit $exec
    %0:sreg_32 = SI_IF %14, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.1:
    successors: %bb.2(0x40000000), %bb.4(0x40000000)
  
    %1:vreg_64 = PHI undef %11:vreg_64, %bb.0, %4, %bb.3
    %56:vgpr_32 = PHI %7, %bb.0, undef %57:vgpr_32, %bb.3
    %58:vgpr_32 = PHI %8, %bb.0, undef %59:vgpr_32, %bb.3
    %60:vgpr_32 = PHI %9, %bb.0, undef %61:vgpr_32, %bb.3
    %2:sreg_32 = SI_ELSE %0, %bb.4, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    successors: %bb.4(0x80000000)
  
    %32:vreg_64 = DS_READ2_B32_gfx9 %56, 6, 7, 0, implicit $exec :: (load (s64) from %ir.gep3, align 4, addrspace 3)
    %40:vgpr_32, %42:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %32.sub0, %58, 0, implicit $exec
    %41:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %32.sub1, %60, %42, 0, implicit $exec
    %3:vreg_64 = REG_SEQUENCE %40, %subreg.sub0, %41, %subreg.sub1
    S_BRANCH %bb.4
  
  bb.3:
    successors: %bb.1(0x80000000)
  
    %15:vgpr_32 = DS_READ_U8_gfx9 %7, 32, 0, implicit $exec :: (load (s8) from %ir.gep4, addrspace 3)
    %16:vgpr_32 = DS_READ_U8_gfx9 %7, 33, 0, implicit $exec :: (load (s8) from %ir.gep4 + 1, addrspace 3)
    %17:vgpr_32 = DS_READ_U8_gfx9 %7, 34, 0, implicit $exec :: (load (s8) from %ir.gep4 + 2, addrspace 3)
    %18:vgpr_32 = DS_READ_U8_gfx9 %7, 35, 0, implicit $exec :: (load (s8) from %ir.gep4 + 3, addrspace 3)
    %19:vgpr_32 = DS_READ_U8_gfx9 %7, 36, 0, implicit $exec :: (load (s8) from %ir.gep4 + 4, addrspace 3)
    %20:vgpr_32 = DS_READ_U8_gfx9 %7, 37, 0, implicit $exec :: (load (s8) from %ir.gep4 + 5, addrspace 3)
    %21:vgpr_32 = DS_READ_U8_gfx9 %7, 38, 0, implicit $exec :: (load (s8) from %ir.gep4 + 6, addrspace 3)
    %22:vgpr_32 = DS_READ_U8_gfx9 %7, 39, 0, implicit $exec :: (load (s8) from %ir.gep4 + 7, addrspace 3)
    %24:vgpr_32 = V_LSHL_OR_B32_e64 %20, 8, %19, implicit $exec
    %25:vgpr_32 = V_LSHL_OR_B32_e64 %22, 8, %21, implicit $exec
    %27:vgpr_32 = V_LSHL_OR_B32_e64 %25, 16, %24, implicit $exec
    %28:vgpr_32 = V_LSHL_OR_B32_e64 %16, 8, %15, implicit $exec
    %29:vgpr_32 = V_LSHL_OR_B32_e64 %18, 8, %17, implicit $exec
    %30:vgpr_32 = V_LSHL_OR_B32_e64 %29, 16, %28, implicit $exec
    %48:vgpr_32, %50:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %30, %8, 0, implicit $exec
    %49:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %27, %9, %50, 0, implicit $exec
    %4:vreg_64 = REG_SEQUENCE %48, %subreg.sub0, %49, %subreg.sub1
    S_BRANCH %bb.1
  
  bb.4:
    %5:vreg_64 = PHI %1, %bb.1, %3, %bb.2
    SI_END_CF %2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %34:sreg_32_xm0 = V_READFIRSTLANE_B32 %5.sub0, implicit $exec
    %36:sreg_32_xm0 = V_READFIRSTLANE_B32 %5.sub1, implicit $exec
    $sgpr0 = COPY %34
    $sgpr1 = COPY %36
    SI_RETURN_TO_EPILOG killed $sgpr0, killed $sgpr1
...

