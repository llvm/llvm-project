# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

--- |
  define amdgpu_ps i64 @test(ptr addrspace(1) %gep3, ptr addrspace(1) %gep4) {
  ret i64 0
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.3(0x40000000), %bb.1(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3
  
    %0:vgpr_32 = COPY $vgpr3
    %1:vgpr_32 = COPY $vgpr2
    %2:vgpr_32 = COPY $vgpr1
    %3:vgpr_32 = COPY $vgpr0
    %4:vgpr_32 = V_AND_B32_e64 1, %3, implicit $exec
    %5:sreg_32 = V_CMP_NE_U32_e64 1, %4, implicit $exec
    %6:sreg_32 = SI_IF %5, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.1:
    successors: %bb.2(0x40000000), %bb.4(0x40000000)
  
    %7:vreg_64 = PHI undef %8:vreg_64, %bb.0, %9, %bb.3
    %10:vgpr_32 = PHI %2, %bb.0, undef %11:vgpr_32, %bb.3
    %12:vgpr_32 = PHI %1, %bb.0, undef %13:vgpr_32, %bb.3
    %14:vgpr_32 = PHI %0, %bb.0, undef %15:vgpr_32, %bb.3
    %16:sreg_32 = SI_ELSE %6, %bb.4, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    successors: %bb.4(0x80000000)
  
    %17:vreg_64 = DS_READ2_B32_gfx9 %10, 6, 7, 0, implicit $exec :: (load (s64) from %ir.gep3, align 4, addrspace 3)
    %18:vgpr_32, %19:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %17.sub0, %12, 0, implicit $exec
    %20:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %17.sub1, %14, %19, 0, implicit $exec
    %21:vreg_64 = REG_SEQUENCE %18, %subreg.sub0, %20, %subreg.sub1
    S_BRANCH %bb.4
  
  bb.3:
    successors: %bb.1(0x80000000)
  
    %22:vgpr_32 = DS_READ_U8_gfx9 %2, 32, 0, implicit $exec :: (load (s8) from %ir.gep4, addrspace 3)
    %23:vgpr_32 = DS_READ_U8_gfx9 %2, 33, 0, implicit $exec :: (load (s8) from %ir.gep4 + 1, addrspace 3)
    %24:vgpr_32 = DS_READ_U8_gfx9 %2, 34, 0, implicit $exec :: (load (s8) from %ir.gep4 + 2, addrspace 3)
    %25:vgpr_32 = DS_READ_U8_gfx9 %2, 35, 0, implicit $exec :: (load (s8) from %ir.gep4 + 3, addrspace 3)
    %26:vgpr_32 = DS_READ_U8_gfx9 %2, 36, 0, implicit $exec :: (load (s8) from %ir.gep4 + 4, addrspace 3)
    %27:vgpr_32 = DS_READ_U8_gfx9 %2, 37, 0, implicit $exec :: (load (s8) from %ir.gep4 + 5, addrspace 3)
    %28:vgpr_32 = DS_READ_U8_gfx9 %2, 38, 0, implicit $exec :: (load (s8) from %ir.gep4 + 6, addrspace 3)
    %29:vgpr_32 = DS_READ_U8_gfx9 %2, 39, 0, implicit $exec :: (load (s8) from %ir.gep4 + 7, addrspace 3)
    %30:vgpr_32 = V_LSHL_OR_B32_e64 %27, 8, %26, implicit $exec
    %31:vgpr_32 = V_LSHL_OR_B32_e64 %29, 8, %28, implicit $exec
    %32:vgpr_32 = V_LSHL_OR_B32_e64 %31, 16, %30, implicit $exec
    %33:vgpr_32 = V_LSHL_OR_B32_e64 %23, 8, %22, implicit $exec
    %34:vgpr_32 = V_LSHL_OR_B32_e64 %25, 8, %24, implicit $exec
    %35:vgpr_32 = V_LSHL_OR_B32_e64 %34, 16, %33, implicit $exec
    %36:vgpr_32, %37:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %35, %1, 0, implicit $exec
    %38:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %32, %0, %37, 0, implicit $exec
    %9:vreg_64 = REG_SEQUENCE %36, %subreg.sub0, %38, %subreg.sub1
    S_BRANCH %bb.1
  
  bb.4:
    %39:vreg_64 = PHI %7, %bb.1, %21, %bb.2
    SI_END_CF %16, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %40:sreg_32_xm0 = V_READFIRSTLANE_B32 %39.sub0, implicit $exec
    %41:sreg_32_xm0 = V_READFIRSTLANE_B32 %39.sub1, implicit $exec
    $sgpr0 = COPY %40
    $sgpr1 = COPY %41
    SI_RETURN_TO_EPILOG killed $sgpr0, killed $sgpr1
...


