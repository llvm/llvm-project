    %24:vreg_64 = REG_SEQUENCE %18, %subreg.sub0, %17, %subreg.sub1
    %25:vreg_64 = REG_SEQUENCE %2, %subreg.sub0, %1, %subreg.sub1
    %26:vreg_64 = REG_SEQUENCE %4, %subreg.sub0, %3, %subreg.sub1
    %27:vreg_64 = REG_SEQUENCE %8, %subreg.sub0, %7, %subreg.sub1
