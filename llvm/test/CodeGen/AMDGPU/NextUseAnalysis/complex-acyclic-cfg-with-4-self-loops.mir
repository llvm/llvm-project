    %22:vreg_64 = REG_SEQUENCE %16, %subreg.sub0, %15, %subreg.sub1
    %23:vgpr_32 = GLOBAL_LOAD_UBYTE %22, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %24:vgpr_32 = GLOBAL_LOAD_UBYTE %22, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %25:vgpr_32 = V_LSHL_OR_B32_e64 %24, 8, %23, implicit $exec
