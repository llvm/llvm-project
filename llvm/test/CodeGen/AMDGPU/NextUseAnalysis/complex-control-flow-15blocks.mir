    %40:vgpr_32 = PHI %28, %bb.2, undef %41:vgpr_32, %bb.5
    %42:sreg_32 = SI_ELSE killed %37, %bb.6, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.4:
    successors: %bb.6(0x80000000)
  
    %43:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %17, killed %40, 1000, 0, implicit $exec
    %44:vgpr_32 = COPY killed %43.sub0
    S_BRANCH %bb.6
  
  bb.5:
    successors: %bb.3(0x80000000)
  
