    %95:vgpr_32 = V_ADD_U32_e64 killed %36, killed %94, 0, implicit $exec
    %96:sreg_32_xm0 = V_READFIRSTLANE_B32 killed %95, implicit $exec
    $sgpr0 = COPY killed %96
    SI_RETURN_TO_EPILOG killed $sgpr0
...
