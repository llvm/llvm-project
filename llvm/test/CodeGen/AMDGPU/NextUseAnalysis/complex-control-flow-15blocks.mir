    %59:sreg_32 = S_AND_B32 killed %7, killed %9, implicit-def dead $scc
    %60:sreg_32 = S_XOR_B32 killed %59, -1, implicit-def dead $scc
    %61:sreg_32 = SI_IF killed %60, %bb.9, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.11
  
  bb.9:
    successors: %bb.10(0x40000000), %bb.13(0x40000000)
  
    %62:vgpr_32 = PHI undef %63:vgpr_32, %bb.8, %70, %bb.11
    %64:vgpr_32 = PHI %54, %bb.8, undef %65:vgpr_32, %bb.11
    %66:vgpr_32 = PHI %56, %bb.8, undef %67:vgpr_32, %bb.11
    %68:sreg_32 = SI_ELSE killed %61, %bb.13, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.10
  
  bb.10:
    successors: %bb.13(0x80000000)
  
    %69:vgpr_32 = V_ADD_U32_e64 killed %64, killed %66, 0, implicit $exec
    S_BRANCH %bb.13
  
  bb.11:
    successors: %bb.9(0x80000000)
  
    %70:vgpr_32 = V_MUL_LO_U32_e64 killed %54, killed %56, implicit $exec
    S_BRANCH %bb.9
  
  bb.12:
    successors: %bb.7(0x80000000)
  
    %71:vgpr_32 = V_SUB_U32_e64 killed %47, killed %48, 0, implicit $exec
    %72:vgpr_32 = V_MUL_LO_U32_e64 killed %71, killed %35, implicit $exec
    %73:vgpr_32 = V_CVT_F32_U32_e64 %17, 0, 0, implicit $mode, implicit $exec
    %74:vgpr_32 = nofpexcept V_RCP_IFLAG_F32_e64 0, killed %73, 0, 0, implicit $mode, implicit $exec
    %75:vgpr_32 = nnan ninf nsz arcp contract afn reassoc nofpexcept V_MUL_F32_e64 0, 1333788670, 0, killed %74, 0, 0, implicit $mode, implicit $exec
    %76:vgpr_32 = nofpexcept V_CVT_U32_F32_e64 0, killed %75, 0, 0, implicit $mode, implicit $exec
    %77:vgpr_32 = V_SUB_U32_e64 0, %17, 0, implicit $exec
    %78:vgpr_32 = V_MUL_LO_U32_e64 killed %77, %76, implicit $exec
    %79:vgpr_32 = V_MUL_HI_U32_e64 %76, killed %78, implicit $exec
    %80:vgpr_32 = V_ADD_U32_e64 killed %76, killed %79, 0, implicit $exec
    %81:vgpr_32 = V_MUL_HI_U32_e64 %72, killed %80, implicit $exec
    %82:vgpr_32 = V_MUL_LO_U32_e64 %81, %17, implicit $exec
