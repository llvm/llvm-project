    %84:sreg_32_xm0_xexec = V_CMP_GE_U32_e64 %83, %17, implicit $exec
    %85:vgpr_32 = V_ADD_U32_e64 1, %81, 0, implicit $exec
    %86:vgpr_32 = V_CNDMASK_B32_e64 0, killed %81, 0, killed %85, %84, implicit $exec
    %87:vgpr_32 = V_SUB_U32_e64 %83, %17, 0, implicit $exec
    %88:vgpr_32 = V_CNDMASK_B32_e64 0, killed %83, 0, killed %87, killed %84, implicit $exec
    %89:sreg_32_xm0_xexec = V_CMP_GE_U32_e64 killed %88, killed %17, implicit $exec
    %90:vgpr_32 = V_ADD_U32_e64 1, %86, 0, implicit $exec
    %91:vgpr_32 = V_CNDMASK_B32_e64 0, killed %86, 0, killed %90, killed %89, implicit $exec
    %92:vgpr_32 = V_ADD_U32_e64 killed %91, killed %24, 0, implicit $exec
