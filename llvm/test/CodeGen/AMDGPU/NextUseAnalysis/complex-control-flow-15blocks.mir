    %47:vgpr_32 = DS_READ_B32_gfx9 killed %2, 12, 0, implicit $exec :: (load (s32) from %ir.gep2, align 8, addrspace 3)
    %48:vgpr_32 = V_ADD_U32_e64 %47, killed %46, 0, implicit $exec
    %49:sreg_32 = S_XOR_B32 %7, %9, implicit-def dead $scc
    %50:sreg_32 = S_XOR_B32 killed %49, -1, implicit-def dead $scc
    %51:sreg_32 = SI_IF killed %50, %bb.7, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.12
  
  bb.7:
    successors: %bb.8(0x40000000), %bb.14(0x40000000)
  
    %52:vgpr_32 = PHI undef %53:vgpr_32, %bb.6, %92, %bb.12
    %54:vgpr_32 = PHI %24, %bb.6, undef %55:vgpr_32, %bb.12
    %56:vgpr_32 = PHI %48, %bb.6, undef %57:vgpr_32, %bb.12
    %58:sreg_32 = SI_ELSE killed %51, %bb.14, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.8
  
  bb.8:
