    %175:sreg_32 = SI_IF_BREAK killed %174, killed %30, implicit-def dead $scc
    SI_LOOP %175, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.19
  
  bb.19:
    SI_END_CF killed %175, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %176:vgpr_32 = V_ADD_U32_e64 killed %158, killed %46, 0, implicit $exec
    %177:sreg_32_xm0 = V_READFIRSTLANE_B32 killed %176, implicit $exec
    $sgpr0 = COPY killed %177
    SI_RETURN_TO_EPILOG killed $sgpr0
...
