--- |
  define amdgpu_ps i32 @test13(ptr addrspace(1) %gep1, ptr addrspace(1) %gep2, ptr addrspace(1) %gep3, ptr addrspace(1) %gep4, ptr addrspace(1) %gep5, ptr addrspace(1) %p1, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret i32 0
  }
...

