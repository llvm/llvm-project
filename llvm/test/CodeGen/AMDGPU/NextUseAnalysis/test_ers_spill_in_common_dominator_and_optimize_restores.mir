# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

--- |
  @array1 = global [5 x i32] zeroinitializer, align 4
  @array2 = global [5 x i32] zeroinitializer, align 4
  @array3 = global [5 x i32] zeroinitializer, align 4
  @array4 = global [5 x i32] zeroinitializer, align 4
  
  define amdgpu_ps void @test(ptr addrspace(1) %gep1, ptr addrspace(1) %p1, ptr addrspace(3) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x40000000), %bb.2(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10, $vgpr11
  
    %0:vgpr_32 = COPY $vgpr11
    %1:vgpr_32 = COPY $vgpr10
    %2:vgpr_32 = COPY $vgpr9
    %3:vgpr_32 = COPY $vgpr8
    %4:vgpr_32 = COPY $vgpr7
    %5:vgpr_32 = COPY $vgpr6
    %6:vgpr_32 = COPY $vgpr5
    %7:vgpr_32 = COPY $vgpr4
    %8:vgpr_32 = COPY $vgpr3
    %9:vgpr_32 = COPY $vgpr2
    %10:vgpr_32 = COPY $vgpr1
    %11:vgpr_32 = COPY $vgpr0
    %12:vreg_64 = REG_SEQUENCE %3, %subreg.sub0, %2, %subreg.sub1
    %13:vreg_64 = REG_SEQUENCE %5, %subreg.sub0, %4, %subreg.sub1
    %14:vreg_64 = REG_SEQUENCE %7, %subreg.sub0, %6, %subreg.sub1
    %15:vreg_64 = REG_SEQUENCE %11, %subreg.sub0, %10, %subreg.sub1
    %16:vgpr_32 = V_AND_B32_e64 1, %8, implicit $exec
    %17:sreg_32 = V_CMP_EQ_U32_e64 1, %16, implicit $exec
    %18:vgpr_32 = GLOBAL_LOAD_UBYTE %15, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %19:vgpr_32 = GLOBAL_LOAD_UBYTE %15, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %20:vgpr_32 = V_LSHL_OR_B32_e64 %19, 8, %18, implicit $exec
    %21:vgpr_32 = GLOBAL_LOAD_UBYTE %15, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %22:vgpr_32 = GLOBAL_LOAD_UBYTE %15, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %23:vgpr_32 = V_LSHL_OR_B32_e64 %22, 8, %21, implicit $exec
    %24:vgpr_32 = V_LSHL_OR_B32_e64 %23, 16, %20, implicit $exec
    %25:vgpr_32 = GLOBAL_LOAD_UBYTE %15, 12, 0, implicit $exec :: (load (s8) from %ir.gep1, addrspace 1)
    %26:vgpr_32 = GLOBAL_LOAD_UBYTE %15, 13, 0, implicit $exec :: (load (s8) from %ir.gep1 + 1, addrspace 1)
    %27:vgpr_32 = V_LSHL_OR_B32_e64 %26, 8, %25, implicit $exec
    %28:vgpr_32 = GLOBAL_LOAD_UBYTE %15, 14, 0, implicit $exec :: (load (s8) from %ir.gep1 + 2, addrspace 1)
    %29:vgpr_32 = GLOBAL_LOAD_UBYTE %15, 15, 0, implicit $exec :: (load (s8) from %ir.gep1 + 3, addrspace 1)
    %30:vgpr_32 = V_LSHL_OR_B32_e64 %29, 8, %28, implicit $exec
    %31:vgpr_32 = V_LSHL_OR_B32_e64 %30, 16, %27, implicit $exec
    %32:vreg_128 = GLOBAL_LOAD_DWORDX4 %14, 16, 0, implicit $exec :: (load (s128) from %ir.p3 + 16, align 4, addrspace 1)
    %33:vreg_128 = GLOBAL_LOAD_DWORDX4 %14, 0, 0, implicit $exec :: (load (s128) from %ir.p3, align 4, addrspace 1)
    %34:vgpr_32 = V_ADD_U32_e64 %33.sub0, %24, 0, implicit $exec
    GLOBAL_STORE_DWORD %14, %34, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %35:vgpr_32 = V_ADD_U32_e64 %34, %24, 0, implicit $exec
    %36:sreg_64 = SI_PC_ADD_REL_OFFSET target-flags(amdgpu-gotprel32-lo) @array1, target-flags(amdgpu-gotprel32-hi) @array1, implicit-def dead $scc
    %37:sreg_64_xexec = S_LOAD_DWORDX2_IMM %36, 0, 0 :: (dereferenceable invariant load (s64) from got, addrspace 4)
    %38:vreg_64 = COPY %37
    %39:vgpr_32 = FLAT_LOAD_DWORD %38, 20, 0, implicit $exec, implicit $flat_scr :: (load (s32) from `ptr getelementptr inbounds nuw (i8, ptr @array1, i64 20)`)
    %40:sreg_64 = SI_PC_ADD_REL_OFFSET target-flags(amdgpu-gotprel32-lo) @array3, target-flags(amdgpu-gotprel32-hi) @array3, implicit-def dead $scc
    %41:sreg_64_xexec = S_LOAD_DWORDX2_IMM %40, 0, 0 :: (dereferenceable invariant load (s64) from got, addrspace 4)
    %42:vreg_64 = COPY %41
    FLAT_STORE_DWORD %42, %39, 4, 0, implicit $exec, implicit $flat_scr :: (store (s32) into `ptr getelementptr inbounds nuw (i8, ptr @array3, i64 4)`)
    %43:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 20, 0, implicit $exec :: (load (s8) from %ir.p4 + 20, addrspace 1)
    %44:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 21, 0, implicit $exec :: (load (s8) from %ir.p4 + 21, addrspace 1)
    %45:vgpr_32 = V_LSHL_OR_B32_e64 %44, 8, %43, implicit $exec
    %46:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 22, 0, implicit $exec :: (load (s8) from %ir.p4 + 22, addrspace 1)
    %47:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 23, 0, implicit $exec :: (load (s8) from %ir.p4 + 23, addrspace 1)
    %48:vgpr_32 = V_LSHL_OR_B32_e64 %47, 8, %46, implicit $exec
    %49:vgpr_32 = V_LSHL_OR_B32_e64 %48, 16, %45, implicit $exec
    %50:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 12, 0, implicit $exec :: (load (s8) from %ir.p4 + 12, addrspace 1)
    %51:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 13, 0, implicit $exec :: (load (s8) from %ir.p4 + 13, addrspace 1)
    %52:vgpr_32 = V_LSHL_OR_B32_e64 %51, 8, %50, implicit $exec
    %53:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 14, 0, implicit $exec :: (load (s8) from %ir.p4 + 14, addrspace 1)
    %54:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 15, 0, implicit $exec :: (load (s8) from %ir.p4 + 15, addrspace 1)
    %55:vgpr_32 = V_LSHL_OR_B32_e64 %54, 8, %53, implicit $exec
    %56:vgpr_32 = V_LSHL_OR_B32_e64 %55, 16, %52, implicit $exec
    %57:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 0, 0, implicit $exec :: (load (s8) from %ir.p4, addrspace 1)
    %58:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 1, 0, implicit $exec :: (load (s8) from %ir.p4 + 1, addrspace 1)
    %59:vgpr_32 = V_LSHL_OR_B32_e64 %58, 8, %57, implicit $exec
    %60:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 2, 0, implicit $exec :: (load (s8) from %ir.p4 + 2, addrspace 1)
    %61:vgpr_32 = GLOBAL_LOAD_UBYTE %13, 3, 0, implicit $exec :: (load (s8) from %ir.p4 + 3, addrspace 1)
    %62:vgpr_32 = V_LSHL_OR_B32_e64 %61, 8, %60, implicit $exec
    %63:vgpr_32 = V_LSHL_OR_B32_e64 %62, 16, %59, implicit $exec
    %64:vgpr_32 = V_ADD_U32_e64 %63, %34, 0, implicit $exec
    GLOBAL_STORE_DWORD %13, %64, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    %65:sreg_32 = SI_IF %17, %bb.2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.1
  
  bb.1:
    successors: %bb.2(0x80000000)
  
    %66:vgpr_32 = DS_READ_U8_gfx9 %9, 0, 0, implicit $exec :: (load (s8) from %ir.p2, addrspace 3)
    %67:vgpr_32 = DS_READ_U8_gfx9 %9, 1, 0, implicit $exec :: (load (s8) from %ir.p2 + 1, addrspace 3)
    %68:vgpr_32 = DS_READ_U8_gfx9 %9, 2, 0, implicit $exec :: (load (s8) from %ir.p2 + 2, addrspace 3)
    %69:vgpr_32 = DS_READ_U8_gfx9 %9, 3, 0, implicit $exec :: (load (s8) from %ir.p2 + 3, addrspace 3)
    %70:vgpr_32 = V_LSHL_OR_B32_e64 %67, 8, %66, implicit $exec
    %71:vgpr_32 = V_LSHL_OR_B32_e64 %69, 8, %68, implicit $exec
    %72:vgpr_32 = V_LSHL_OR_B32_e64 %71, 16, %70, implicit $exec
    %73:vreg_64 = COPY %37
    %74:vgpr_32 = FLAT_LOAD_DWORD %73, 28, 0, implicit $exec, implicit $flat_scr :: (load (s32) from `ptr getelementptr inbounds nuw (i8, ptr @array1, i64 28)`)
    %75:sreg_64 = SI_PC_ADD_REL_OFFSET target-flags(amdgpu-gotprel32-lo) @array2, target-flags(amdgpu-gotprel32-hi) @array2, implicit-def dead $scc
    %76:sreg_64_xexec = S_LOAD_DWORDX2_IMM %75, 0, 0 :: (dereferenceable invariant load (s64) from got, addrspace 4)
    %77:vreg_64 = COPY %76
    FLAT_STORE_DWORD %77, %74, 68, 0, implicit $exec, implicit $flat_scr :: (store (s32) into `ptr getelementptr inbounds nuw (i8, ptr @array2, i64 68)`)
    %78:sreg_64 = SI_PC_ADD_REL_OFFSET target-flags(amdgpu-gotprel32-lo) @array4, target-flags(amdgpu-gotprel32-hi) @array4, implicit-def dead $scc
    %79:sreg_64_xexec = S_LOAD_DWORDX2_IMM %78, 0, 0 :: (dereferenceable invariant load (s64) from got, addrspace 4)
    %80:vreg_64 = COPY %79
    %81:vgpr_32 = FLAT_LOAD_DWORD %80, 20, 0, implicit $exec, implicit $flat_scr :: (load (s32) from `ptr getelementptr inbounds nuw (i8, ptr @array4, i64 20)`)
    %82:vreg_64 = COPY %41
    FLAT_STORE_DWORD %82, %81, 60, 0, implicit $exec, implicit $flat_scr :: (store (s32) into `ptr getelementptr inbounds nuw (i8, ptr @array3, i64 60)`)
    %83:vgpr_32 = FLAT_LOAD_DWORD %82, 84, 0, implicit $exec, implicit $flat_scr :: (load (s32) from `ptr getelementptr inbounds nuw (i8, ptr @array3, i64 84)`)
    %84:vgpr_32 = FLAT_LOAD_DWORD %82, 0, 0, implicit $exec, implicit $flat_scr :: (dereferenceable load (s32) from @array3)
    %85:vgpr_32 = FLAT_LOAD_DWORD %73, 0, 0, implicit $exec, implicit $flat_scr :: (dereferenceable load (s32) from @array1)
    %86:vgpr_32 = FLAT_LOAD_DWORD %77, 0, 0, implicit $exec, implicit $flat_scr :: (dereferenceable load (s32) from @array2)
    %87:vgpr_32 = FLAT_LOAD_DWORD %80, 0, 0, implicit $exec, implicit $flat_scr :: (dereferenceable load (s32) from @array4)
    %88:vgpr_32 = V_MUL_LO_U32_e64 %86, %87, implicit $exec
    %89:vreg_64 = REG_SEQUENCE %88, %subreg.sub0, undef %90:vgpr_32, %subreg.sub1
    %91:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %84, %85, %89, 0, implicit $exec
    %92:vgpr_32 = COPY %91.sub0
    %93:vgpr_32 = COPY %33.sub1
    %94:vgpr_32 = COPY %33.sub2
    %95:vgpr_32 = COPY %32.sub2
    %96:vgpr_32 = COPY %32.sub3
  
  bb.2:
    %97:vgpr_32 = PHI %24, %bb.0, %74, %bb.1
    %98:vgpr_32 = PHI %39, %bb.0, %81, %bb.1
    %99:vgpr_32 = PHI %39, %bb.0, %83, %bb.1
    %100:vgpr_32 = PHI %39, %bb.0, %84, %bb.1
    %101:vgpr_32 = PHI %39, %bb.0, %85, %bb.1
    %102:vgpr_32 = PHI %39, %bb.0, %86, %bb.1
    %103:vgpr_32 = PHI %39, %bb.0, %87, %bb.1
    %104:vgpr_32 = PHI %39, %bb.0, %92, %bb.1
    %105:vgpr_32 = PHI %39, %bb.0, %93, %bb.1
    %106:vgpr_32 = PHI %39, %bb.0, %94, %bb.1
    %107:vgpr_32 = PHI %39, %bb.0, %95, %bb.1
    %108:vgpr_32 = PHI %39, %bb.0, %96, %bb.1
    %109:vgpr_32 = PHI %31, %bb.0, %24, %bb.1
    %110:vgpr_32 = PHI %39, %bb.0, %1, %bb.1
    %111:vgpr_32 = PHI %35, %bb.0, %72, %bb.1
    SI_END_CF %65, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %112:vgpr_32 = V_ADD_U32_e64 %97, %56, 0, implicit $exec
    %113:vgpr_32 = V_MUL_LO_U32_e64 %112, %49, implicit $exec
    %114:vgpr_32 = V_SUB_U32_e64 %113, %39, 0, implicit $exec
    %115:vgpr_32 = V_SUB_U32_e64 %114, %98, 0, implicit $exec
    %116:vgpr_32 = V_ADD_U32_e64 %115, %99, 0, implicit $exec
    %117:vgpr_32 = V_SUB_U32_e64 %116, %34, 0, implicit $exec
    %118:vgpr_32 = V_MUL_LO_U32_e64 %117, %100, implicit $exec
    %119:vgpr_32 = V_MUL_LO_U32_e64 %118, %101, implicit $exec
    %120:vgpr_32 = V_SUB_U32_e64 %119, %102, 0, implicit $exec
    %121:vgpr_32 = V_ADD_U32_e64 %120, %103, 0, implicit $exec
    %122:vgpr_32 = V_MUL_LO_U32_e64 %121, %104, implicit $exec
    %123:vgpr_32 = V_ADD3_U32_e64 %122, %105, %106, implicit $exec
    %124:vgpr_32 = V_SUB_U32_e64 %123, %107, 0, implicit $exec
    %125:vgpr_32 = V_SUB_U32_e64 %124, %108, 0, implicit $exec
    %126:vgpr_32 = V_MUL_LO_U32_e64 %125, %109, implicit $exec
    %127:vreg_64 = REG_SEQUENCE %111, %subreg.sub0, undef %128:vgpr_32, %subreg.sub1
    %129:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %126, %110, %127, 0, implicit $exec
    %130:vgpr_32 = V_SUB_U32_e64 %129.sub0, %0, 0, implicit $exec
    GLOBAL_STORE_SHORT_D16_HI %12, %130, 2, 0, implicit $exec :: (store (s16) into %ir.p5 + 2, addrspace 1)
    GLOBAL_STORE_SHORT %12, %130, 0, 0, implicit $exec :: (store (s16) into %ir.p5, addrspace 1)
    S_ENDPGM 0
...


# CHECK-CP-JSON:      {
# CHECK-CP-JSON-NEXT:  "next-use-analysis": {
# CHECK-CP-JSON-NEXT:    "furthest-distances": {
# CHECK-CP-JSON-NEXT:      "bb.0": [
# CHECK-CP-JSON-NEXT:        {
# CHECK-CP-JSON-NEXT:          "instr": "%0:vgpr_32 = COPY $vgpr11",
# CHECK-CP-JSON-NEXT:          "id": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "head-len": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "tail-len": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "distances": {},
# CHECK-CP-JSON-NEXT:          "furthest": {},
# CHECK-CP-JSON-NEXT:          "furthest-subreg": {}
# CHECK-CP-JSON-NEXT:        },
# CHECK-CP-JSON-NEXT:        {
# CHECK-CP-JSON-NEXT:          "instr": "%1:vgpr_32 = COPY $vgpr10",
# CHECK-CP-JSON-NEXT:          "id": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "head-len": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "tail-len": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "distances": {
# CHECK-CP-JSON-DAG:             "%0": 87
# CHECK-CP-JSON:               },
# CHECK-CP-JSON-NEXT:          "furthest": {
# CHECK-CP-JSON-DAG:             "register": "%0",
# CHECK-CP-JSON-DAG:             "use": "{{[^"]+}}",
# CHECK-CP-JSON-DAG:             "use-mi": "{{[^"]+}}",
# CHECK-CP-JSON-DAG:             "distance": 87
# CHECK-CP-JSON:               },
# CHECK-CP-JSON-NEXT:          "furthest-subreg": {
# CHECK-CP-JSON-DAG:             "register": "%0",
# CHECK-CP-JSON-DAG:             "use": "{{[^"]+}}",
# CHECK-CP-JSON-DAG:             "use-mi": "{{[^"]+}}",
# CHECK-CP-JSON-DAG:             "distance": 87
# CHECK-CP-JSON:               }
# CHECK-CP-JSON-NEXT:        },
# CHECK-CP-JSON-NEXT:        {
