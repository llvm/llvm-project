# CHECK-CP-JSON-DAG:             "register": "%1",
# CHECK-CP-JSON-DAG:             "use": "{{[^"]+}}",
# CHECK-CP-JSON-DAG:             "use-mi": "{{[^"]+}}",
# CHECK-CP-JSON-DAG:             "distance": 97
# CHECK-CP-JSON:               },
