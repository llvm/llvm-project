# CHECK-CP-JSON-NEXT:          "id": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "head-len": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "tail-len": {{[0-9]+}},
# CHECK-CP-JSON-NEXT:          "distances": {
# CHECK-CP-JSON-DAG:             "%0": 86
# CHECK-CP-JSON-DAG:             "%1": 99
# CHECK-CP-JSON:               },
# CHECK-CP-JSON-NEXT:          "furthest": {
