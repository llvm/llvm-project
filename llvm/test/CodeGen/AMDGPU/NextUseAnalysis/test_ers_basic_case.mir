# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s
--- |
  define amdgpu_ps i64 @test(ptr addrspace(3) %p1, ptr addrspace(3) %p2) {
  ret i64 0
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.3(0x40000000), %bb.1(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4
  
    %10:vgpr_32 = COPY $vgpr4
    %9:vgpr_32 = COPY $vgpr3
    %8:vgpr_32 = COPY $vgpr2
    %7:vgpr_32 = COPY $vgpr1
    %6:vgpr_32 = COPY $vgpr0
    %14:vgpr_32 = V_AND_B32_e64 1, %8, implicit $exec
    %15:sreg_32 = V_CMP_NE_U32_e64 1, %14, implicit $exec
    %0:sreg_32 = SI_IF %15, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.1:
    successors: %bb.2(0x40000000), %bb.4(0x40000000)
  
    %1:vreg_64 = PHI undef %12:vreg_64, %bb.0, %4, %bb.3
    %66:vgpr_32 = PHI %6, %bb.0, undef %67:vgpr_32, %bb.3
    %2:sreg_32 = SI_ELSE %0, %bb.4, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    successors: %bb.4(0x80000000)
  
    %33:vgpr_32 = DS_READ_U8_gfx9 %66, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 3)
    %34:vgpr_32 = DS_READ_U8_gfx9 %66, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 3)
    %35:vgpr_32 = DS_READ_U8_gfx9 %66, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 3)
    %36:vgpr_32 = DS_READ_U8_gfx9 %66, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 3)
    %37:vgpr_32 = DS_READ_U8_gfx9 %66, 4, 0, implicit $exec :: (load (s8) from %ir.p1 + 4, addrspace 3)
    %38:vgpr_32 = DS_READ_U8_gfx9 %66, 5, 0, implicit $exec :: (load (s8) from %ir.p1 + 5, addrspace 3)
    %39:vgpr_32 = DS_READ_U8_gfx9 %66, 6, 0, implicit $exec :: (load (s8) from %ir.p1 + 6, addrspace 3)
    %40:vgpr_32 = DS_READ_U8_gfx9 %66, 7, 0, implicit $exec :: (load (s8) from %ir.p1 + 7, addrspace 3)
    %42:vgpr_32 = V_LSHL_OR_B32_e64 %38, 8, %37, implicit $exec
    %43:vgpr_32 = V_LSHL_OR_B32_e64 %40, 8, %39, implicit $exec
    %45:vgpr_32 = V_LSHL_OR_B32_e64 %43, 16, %42, implicit $exec
    %46:vgpr_32 = V_LSHL_OR_B32_e64 %34, 8, %33, implicit $exec
    %47:vgpr_32 = V_LSHL_OR_B32_e64 %36, 8, %35, implicit $exec
    %48:vgpr_32 = V_LSHL_OR_B32_e64 %47, 16, %46, implicit $exec
    %49:vreg_64 = REG_SEQUENCE %48, %subreg.sub0, %45, %subreg.sub1
    %3:vreg_64 = COPY %49
    S_BRANCH %bb.4
  
  bb.3:
    successors: %bb.1(0x80000000)
  
    %16:vgpr_32 = DS_READ_U8_gfx9 %7, 0, 0, implicit $exec :: (load (s8) from %ir.p2, addrspace 3)
    %17:vgpr_32 = DS_READ_U8_gfx9 %7, 1, 0, implicit $exec :: (load (s8) from %ir.p2 + 1, addrspace 3)
    %18:vgpr_32 = DS_READ_U8_gfx9 %7, 2, 0, implicit $exec :: (load (s8) from %ir.p2 + 2, addrspace 3)
    %19:vgpr_32 = DS_READ_U8_gfx9 %7, 3, 0, implicit $exec :: (load (s8) from %ir.p2 + 3, addrspace 3)
    %20:vgpr_32 = DS_READ_U8_gfx9 %7, 4, 0, implicit $exec :: (load (s8) from %ir.p2 + 4, addrspace 3)
    %21:vgpr_32 = DS_READ_U8_gfx9 %7, 5, 0, implicit $exec :: (load (s8) from %ir.p2 + 5, addrspace 3)
    %22:vgpr_32 = DS_READ_U8_gfx9 %7, 6, 0, implicit $exec :: (load (s8) from %ir.p2 + 6, addrspace 3)
    %23:vgpr_32 = DS_READ_U8_gfx9 %7, 7, 0, implicit $exec :: (load (s8) from %ir.p2 + 7, addrspace 3)
    %25:vgpr_32 = V_LSHL_OR_B32_e64 %21, 8, %20, implicit $exec
    %26:vgpr_32 = V_LSHL_OR_B32_e64 %23, 8, %22, implicit $exec
    %28:vgpr_32 = V_LSHL_OR_B32_e64 %26, 16, %25, implicit $exec
    %29:vgpr_32 = V_LSHL_OR_B32_e64 %17, 8, %16, implicit $exec
    %30:vgpr_32 = V_LSHL_OR_B32_e64 %19, 8, %18, implicit $exec
    %31:vgpr_32 = V_LSHL_OR_B32_e64 %30, 16, %29, implicit $exec
    %32:vreg_64 = REG_SEQUENCE %31, %subreg.sub0, %28, %subreg.sub1
    %4:vreg_64 = COPY %32
    S_BRANCH %bb.1
  
  bb.4:
    %5:vreg_64 = PHI %1, %bb.1, %3, %bb.2
    SI_END_CF %2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %58:vgpr_32, %60:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %5.sub0, %9, 0, implicit $exec
    %59:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %5.sub1, %10, %60, 0, implicit $exec
    %53:sreg_32_xm0 = V_READFIRSTLANE_B32 %58, implicit $exec
    %54:sreg_32_xm0 = V_READFIRSTLANE_B32 %59, implicit $exec
    $sgpr0 = COPY %53
    $sgpr1 = COPY %54
    SI_RETURN_TO_EPILOG killed $sgpr0, killed $sgpr1
...

