
# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s
--- |
  define amdgpu_ps i64 @test2(ptr addrspace(1) %gep2, ptr addrspace(1) %gep3, ptr addrspace(1) %gep4, ptr addrspace(3) %p) {
  ret i64 0
  }
...
---
name:            test2
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.3(0x40000000), %bb.8(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3
  
    %0:vgpr_32 = COPY killed $vgpr3
    %1:vgpr_32 = COPY killed $vgpr2
    %2:vgpr_32 = COPY killed $vgpr1
    %3:vgpr_32 = COPY killed $vgpr0
    %4:vgpr_32 = V_AND_B32_e64 1, killed %3, implicit $exec
    %5:sreg_32 = V_CMP_NE_U32_e64 1, killed %4, implicit $exec
    %6:sreg_32 = S_MOV_B32 0
    %7:sreg_32 = SI_IF %5, %bb.8, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.1:
    successors: %bb.8(0x80000000)
  
    %8:sreg_32 = PHI %28, %bb.3, %73, %bb.9
    %9:vreg_64 = PHI undef %10:vreg_64, %bb.3, %72, %bb.9
    %11:vreg_64 = PHI %27, %bb.3, undef %12:vreg_64, %bb.9
    SI_END_CF killed %29, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %13:sreg_32 = S_AND_B32 killed %8, $exec_lo, implicit-def dead $scc
    %14:sreg_32 = COPY killed %13
    S_BRANCH %bb.8
  
  bb.2:
    successors: %bb.6(0x80000000)
  
    %15:vgpr_32 = DS_READ_U16_gfx9 %2, 0, 0, implicit $exec :: (load (s16) from %ir.p, addrspace 3)
    %16:vgpr_32 = DS_READ_U16_gfx9 %2, 2, 0, implicit $exec :: (load (s16) from %ir.p + 2, addrspace 3)
    %17:vgpr_32 = DS_READ_U16_gfx9 %2, 4, 0, implicit $exec :: (load (s16) from %ir.p + 4, addrspace 3)
    %18:vgpr_32 = DS_READ_U16_gfx9 %2, 6, 0, implicit $exec :: (load (s16) from %ir.p + 6, addrspace 3)
    %19:vgpr_32 = V_LSHL_OR_B32_e64 killed %18, 16, killed %17, implicit $exec
    %20:vgpr_32 = V_LSHL_OR_B32_e64 killed %16, 16, killed %15, implicit $exec
    %21:vreg_64 = REG_SEQUENCE killed %20, %subreg.sub0, killed %19, %subreg.sub1
    %22:vreg_64 = COPY killed %21
    %23:sreg_32 = COPY $exec_lo
    %24:sreg_32 = S_ANDN2_B32 killed %50, $exec_lo, implicit-def dead $scc
    %25:sreg_32 = S_AND_B32 killed %5, $exec_lo, implicit-def dead $scc
    %26:sreg_32 = S_OR_B32 killed %24, killed %25, implicit-def dead $scc
    S_BRANCH %bb.6
  
  bb.3:
    successors: %bb.9(0x40000000), %bb.1(0x40000000)
  
    %27:vreg_64 = DS_READ_B64_gfx9 %2, 8, 0, implicit $exec :: (load (s64) from %ir.gep2, addrspace 3)
    %28:sreg_32 = S_MOV_B32 -1
    %29:sreg_32 = SI_IF %5, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.9
  
  bb.4:
    successors: %bb.5(0x40000000), %bb.10(0x40000000)
  
    %30:sreg_32 = PHI %39, %bb.6, %49, %bb.7
    %31:vreg_64 = PHI %40, %bb.6, %47, %bb.7
    SI_END_CF killed %43, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %32:sreg_32 = SI_IF killed %30, %bb.10, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.5
  
  bb.5:
    successors: %bb.10(0x80000000)
  
    %33:vreg_64 = DS_READ2_B32_gfx9 killed %2, 6, 7, 0, implicit $exec :: (load (s64) from %ir.gep3, align 4, addrspace 3)
    %34:vgpr_32, %35:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %33.sub0, killed %1, 0, implicit $exec
    %36:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 killed %33.sub1, killed %0, killed %35, 0, implicit $exec
    %37:vreg_64 = REG_SEQUENCE killed %34, %subreg.sub0, killed %36, %subreg.sub1
    S_BRANCH %bb.10
  
  bb.6:
    successors: %bb.7(0x40000000), %bb.4(0x40000000)
  
    %38:sreg_32 = PHI %50, %bb.8, %26, %bb.2
    %39:sreg_32 = PHI %6, %bb.8, %23, %bb.2
    %40:vreg_64 = PHI %51, %bb.8, undef %41:vreg_64, %bb.2
    %42:vreg_64 = PHI %53, %bb.8, %22, %bb.2
    SI_END_CF killed %54, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %43:sreg_32 = SI_IF killed %38, %bb.4, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.7
  
  bb.7:
    successors: %bb.4(0x80000000)
  
    %44:vgpr_32, %45:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %42.sub0, %1, 0, implicit $exec
    %46:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 killed %42.sub1, %0, killed %45, 0, implicit $exec
    %47:vreg_64 = REG_SEQUENCE killed %44, %subreg.sub0, killed %46, %subreg.sub1
    %48:sreg_32 = S_ANDN2_B32 killed %39, $exec_lo, implicit-def dead $scc
    %49:sreg_32 = COPY killed %48
    S_BRANCH %bb.4
  
  bb.8:
    successors: %bb.2(0x40000000), %bb.6(0x40000000)
  
    %50:sreg_32 = PHI %6, %bb.0, %14, %bb.1
    %51:vreg_64 = PHI undef %52:vreg_64, %bb.0, %9, %bb.1
    %53:vreg_64 = PHI undef %52:vreg_64, %bb.0, %11, %bb.1
    %54:sreg_32 = SI_ELSE killed %7, %bb.6, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.9:
    successors: %bb.1(0x80000000)
  
    %55:vgpr_32 = DS_READ_U8_gfx9 %2, 32, 0, implicit $exec :: (load (s8) from %ir.gep4, addrspace 3)
    %56:vgpr_32 = DS_READ_U8_gfx9 %2, 33, 0, implicit $exec :: (load (s8) from %ir.gep4 + 1, addrspace 3)
    %57:vgpr_32 = DS_READ_U8_gfx9 %2, 34, 0, implicit $exec :: (load (s8) from %ir.gep4 + 2, addrspace 3)
    %58:vgpr_32 = DS_READ_U8_gfx9 %2, 35, 0, implicit $exec :: (load (s8) from %ir.gep4 + 3, addrspace 3)
    %59:vgpr_32 = DS_READ_U8_gfx9 %2, 36, 0, implicit $exec :: (load (s8) from %ir.gep4 + 4, addrspace 3)
    %60:vgpr_32 = DS_READ_U8_gfx9 %2, 37, 0, implicit $exec :: (load (s8) from %ir.gep4 + 5, addrspace 3)
    %61:vgpr_32 = DS_READ_U8_gfx9 %2, 38, 0, implicit $exec :: (load (s8) from %ir.gep4 + 6, addrspace 3)
    %62:vgpr_32 = DS_READ_U8_gfx9 %2, 39, 0, implicit $exec :: (load (s8) from %ir.gep4 + 7, addrspace 3)
    %63:vgpr_32 = V_LSHL_OR_B32_e64 killed %60, 8, killed %59, implicit $exec
    %64:vgpr_32 = V_LSHL_OR_B32_e64 killed %62, 8, killed %61, implicit $exec
    %65:vgpr_32 = V_LSHL_OR_B32_e64 killed %64, 16, killed %63, implicit $exec
    %66:vgpr_32 = V_LSHL_OR_B32_e64 killed %56, 8, killed %55, implicit $exec
    %67:vgpr_32 = V_LSHL_OR_B32_e64 killed %58, 8, killed %57, implicit $exec
    %68:vgpr_32 = V_LSHL_OR_B32_e64 killed %67, 16, killed %66, implicit $exec
    %69:vgpr_32, %70:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 killed %68, %1, 0, implicit $exec
    %71:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 killed %65, %0, killed %70, 0, implicit $exec
    %72:vreg_64 = REG_SEQUENCE killed %69, %subreg.sub0, killed %71, %subreg.sub1
    %73:sreg_32 = S_XOR_B32 $exec_lo, -1, implicit-def dead $scc
    S_BRANCH %bb.1
  
  bb.10:
    %74:vreg_64 = PHI %31, %bb.4, %37, %bb.5
    SI_END_CF killed %32, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %75:sreg_32_xm0 = V_READFIRSTLANE_B32 %74.sub0, implicit $exec
    %76:sreg_32_xm0 = V_READFIRSTLANE_B32 killed %74.sub1, implicit $exec
    $sgpr0 = COPY killed %75
    $sgpr1 = COPY killed %76
    SI_RETURN_TO_EPILOG killed $sgpr0, killed $sgpr1
...
---



