# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# 
# MIR CFG:
#
#             bb.0
#                 |
#         bb.1.header<-----+
#                 |              |
#         bb.2.header<--+  |
#               /    \        |  |
#            bb.3   bb.6  |  |
#               \    /        |  |
#              bb.4      |  |
#               /    |        |  |
#  bb.5.latch1 |        |  |
#               \    |        |  |
#             bb.7------+  |
#                 |              |
#          bb.8.latch------+
#                 |
#             bb.9
#

--- |
  define amdgpu_ps i32 @test10(ptr addrspace(1) %gep1, ptr addrspace(1) %gep2, ptr addrspace(1) %p1, ptr addrspace(1) %p3) {
  ret i32 0
  }
...

---
name:            test10
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7
  
    %0:vgpr_32 = COPY $vgpr7
    %1:vgpr_32 = COPY $vgpr6
    %2:vgpr_32 = COPY $vgpr5
    %3:vgpr_32 = COPY $vgpr4
    %4:vgpr_32 = COPY $vgpr3
    %5:vgpr_32 = COPY $vgpr2
    %6:vgpr_32 = COPY $vgpr1
    %7:vgpr_32 = COPY $vgpr0
    %8:vreg_64 = REG_SEQUENCE %3, %subreg.sub0, %2, %subreg.sub1
    %9:vreg_64 = REG_SEQUENCE %5, %subreg.sub0, %4, %subreg.sub1
    %10:vreg_64 = REG_SEQUENCE %7, %subreg.sub0, %6, %subreg.sub1
    %11:vgpr_32 = GLOBAL_LOAD_UBYTE %10, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %12:vgpr_32 = GLOBAL_LOAD_UBYTE %10, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %13:vgpr_32 = V_LSHL_OR_B32_e64 %12, 8, %11, implicit $exec
    %14:vgpr_32 = GLOBAL_LOAD_UBYTE %10, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %15:vgpr_32 = GLOBAL_LOAD_UBYTE %10, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %16:vgpr_32 = V_LSHL_OR_B32_e64 %15, 8, %14, implicit $exec
    %17:vgpr_32 = V_LSHL_OR_B32_e64 %16, 16, %13, implicit $exec
    %18:sreg_32 = S_MOV_B32 0
  
  bb.1:
    successors: %bb.2(0x80000000)
  
    %19:sreg_32 = PHI %18, %bb.0, %20, %bb.7
    %21:sreg_32 = PHI %18, %bb.0, %22, %bb.7
    %23:vgpr_32 = PHI %17, %bb.0, %24, %bb.7
    %25:vgpr_32 = V_MOV_B32_e32 100, implicit $exec
    %26:vgpr_32 = V_MUL_LO_U32_e64 100, %23, implicit $exec
    GLOBAL_STORE_DWORD %8, %26, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
  
  bb.2:
    successors: %bb.5(0x40000000), %bb.3(0x40000000)
  
    %27:sreg_32 = PHI %18, %bb.1, %28, %bb.6
    %29:sreg_32 = PHI %18, %bb.1, %30, %bb.6
    %24:vgpr_32 = PHI %25, %bb.1, %31, %bb.6
    %32:sreg_32 = S_MOV_B32 -1
    %33:sreg_32 = S_MOV_B32 -1
    S_CMP_GE_U32 %29, %21, implicit-def $scc
    %34:sgpr_32 = V_READFIRSTLANE_B32 undef %35:vgpr_32, implicit $exec
    S_CBRANCH_SCC1 %bb.5, implicit killed $scc
    S_BRANCH %bb.3
  
  bb.3:
    successors: %bb.4(0x40000000), %bb.6(0x40000000)
  
    %36:sreg_32 = PHI %32, %bb.2, %37, %bb.5
    %38:vgpr_32 = PHI undef %35:vgpr_32, %bb.2, %39, %bb.5
    %40:sreg_32 = PHI %34, %bb.2, %41, %bb.5
    %42:sreg_32_xm0_xexec = PHI %33, %bb.2, %43, %bb.5
    %44:vgpr_32 = V_CNDMASK_B32_e64 0, 0, 0, 1, %42, implicit $exec
    %45:sreg_32_xm0_xexec = V_CMP_NE_U32_e64 1, %44, implicit $exec
    $vcc_lo = S_AND_B32 $exec_lo, %45, implicit-def dead $scc
    S_CBRANCH_VCCNZ %bb.6, implicit killed $vcc_lo, implicit $vcc
    S_BRANCH %bb.4
  
  bb.4:
    successors: %bb.6(0x80000000)
  
    %46:sreg_32_xm0 = S_ASHR_I32 %29, 31, implicit-def dead $scc
    %47:sreg_64 = REG_SEQUENCE %29, %subreg.sub0, %46, %subreg.sub1
    %48:sreg_64 = nsw S_LSHL_B64 %47, 3, implicit-def dead $scc
    %49:vgpr_32, %50:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %9.sub0, %48.sub0, 0, implicit $exec
    %51:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %48.sub1, %9.sub1, %50, 0, implicit $exec
    %52:vreg_64 = REG_SEQUENCE %49, %subreg.sub0, %51, %subreg.sub1
    %53:vgpr_32 = GLOBAL_LOAD_UBYTE %52, 0, 0, implicit $exec :: (load (s8) from %ir.gep1, addrspace 1)
    %54:vgpr_32 = GLOBAL_LOAD_UBYTE %52, 1, 0, implicit $exec :: (load (s8) from %ir.gep1 + 1, addrspace 1)
    %55:vgpr_32 = V_LSHL_OR_B32_e64 %54, 8, %53, implicit $exec
    %56:vgpr_32 = GLOBAL_LOAD_UBYTE %52, 2, 0, implicit $exec :: (load (s8) from %ir.gep1 + 2, addrspace 1)
    %57:vgpr_32 = GLOBAL_LOAD_UBYTE %52, 3, 0, implicit $exec :: (load (s8) from %ir.gep1 + 3, addrspace 1)
    %58:vgpr_32 = V_LSHL_OR_B32_e64 %57, 8, %56, implicit $exec
    %59:vgpr_32 = V_LSHL_OR_B32_e64 %58, 16, %55, implicit $exec
    %60:vgpr_32 = V_ADD_U32_e64 %21, %59, 0, implicit $exec
    %61:sreg_32 = S_ADD_I32 %29, 1, implicit-def dead $scc
    %62:sreg_32 = V_CMP_GE_U32_e64 %61, %0, implicit $exec
    %63:sreg_32 = S_ANDN2_B32 %36, $exec_lo, implicit-def dead $scc
    %64:sreg_32 = S_AND_B32 %62, $exec_lo, implicit-def dead $scc
    %65:sreg_32 = S_OR_B32 %63, %64, implicit-def dead $scc
    S_BRANCH %bb.6
  
  bb.5:
    successors: %bb.3(0x80000000)
  
    %66:sreg_32 = S_SUB_I32 %29, %21, implicit-def dead $scc
    %67:sreg_32_xm0 = S_ASHR_I32 %66, 31, implicit-def dead $scc
    %68:sreg_64 = REG_SEQUENCE %66, %subreg.sub0, %67, %subreg.sub1
    %69:sreg_64 = nsw S_LSHL_B64 %68, 3, implicit-def dead $scc
    %70:vgpr_32, %71:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %10.sub0, %69.sub0, 0, implicit $exec
    %72:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %69.sub1, %10.sub1, %71, 0, implicit $exec
    %73:vreg_64 = REG_SEQUENCE %70, %subreg.sub0, %72, %subreg.sub1
    %74:vgpr_32 = GLOBAL_LOAD_UBYTE %73, 0, 0, implicit $exec :: (load (s8) from %ir.gep2, addrspace 1)
    %75:vgpr_32 = GLOBAL_LOAD_UBYTE %73, 1, 0, implicit $exec :: (load (s8) from %ir.gep2 + 1, addrspace 1)
    %76:vgpr_32 = V_LSHL_OR_B32_e64 %75, 8, %74, implicit $exec
    %77:vgpr_32 = GLOBAL_LOAD_UBYTE %73, 2, 0, implicit $exec :: (load (s8) from %ir.gep2 + 2, addrspace 1)
    %78:vgpr_32 = GLOBAL_LOAD_UBYTE %73, 3, 0, implicit $exec :: (load (s8) from %ir.gep2 + 3, addrspace 1)
    %79:vgpr_32 = V_LSHL_OR_B32_e64 %78, 8, %77, implicit $exec
    %80:vgpr_32 = V_LSHL_OR_B32_e64 %79, 16, %76, implicit $exec
    %39:vgpr_32 = V_SUBREV_U32_e64 %29, %80, 0, implicit $exec
    %41:sreg_32 = S_ADD_I32 %29, 2, implicit-def dead $scc
    %81:sreg_32 = V_CMP_GE_U32_e64 %41, %0, implicit $exec
    %43:sreg_32 = S_MOV_B32 0
    %37:sreg_32 = S_ORN2_B32 %81, $exec_lo, implicit-def dead $scc
    S_BRANCH %bb.3
  
  bb.6:
    successors: %bb.7(0x04000000), %bb.2(0x7c000000)
  
    %82:sreg_32 = PHI %36, %bb.3, %65, %bb.4
    %31:vgpr_32 = PHI %38, %bb.3, %60, %bb.4
    %30:sreg_32 = PHI %40, %bb.3, %61, %bb.4
    %28:sreg_32 = SI_IF_BREAK %82, %27, implicit-def dead $scc
    SI_LOOP %28, %bb.2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.7
  
  bb.7:
    successors: %bb.8(0x04000000), %bb.1(0x7c000000)
  
    SI_END_CF %28, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %22:sreg_32 = S_ADD_I32 %21, 1, implicit-def dead $scc
    %83:sreg_32 = V_CMP_GE_U32_e64 %22, %1, implicit $exec
    %20:sreg_32 = SI_IF_BREAK %83, %19, implicit-def dead $scc
    %84:vgpr_32 = COPY %22, implicit $exec
    SI_LOOP %20, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.8
  
  bb.8:
    SI_END_CF %20, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %85:vgpr_32 = V_ADD3_U32_e64 %23, %84, %17, implicit $exec
    %86:vgpr_32 = V_ADD3_U32_e64 %85, %26, 100, implicit $exec
    %87:sreg_32_xm0 = V_READFIRSTLANE_B32 %86, implicit $exec
    $sgpr0 = COPY %87
    SI_RETURN_TO_EPILOG killed $sgpr0
...
---


