    GLOBAL_STORE_DWORD %19, %51, 0, 0, implicit $exec :: (store (s32) into %ir.p8, addrspace 1)
    S_BRANCH %bb.4
  
  bb.3:
    successors: %bb.1(0x80000000)
  
    %53:vgpr_32 = DS_READ_U8_gfx9 %16, 0, 0, implicit $exec :: (load (s8) from %ir.p2, addrspace 3)
    %54:vgpr_32 = DS_READ_U8_gfx9 %16, 1, 0, implicit $exec :: (load (s8) from %ir.p2 + 1, addrspace 3)
