# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

--- |
  @array2 = global [5 x i32] zeroinitializer, align 4
  @array3 = global [5 x i32] zeroinitializer, align 4
  @array4 = global [5 x i32] zeroinitializer, align 4
  @array5 = global [5 x i32] zeroinitializer, align 4
  @array6 = global [5 x i32] zeroinitializer, align 4
  @array7 = global [5 x i32] zeroinitializer, align 4
  @array8 = global [5 x i32] zeroinitializer, align 4
  @array9 = global [5 x i32] zeroinitializer, align 4
  
  define amdgpu_ps void @test(ptr addrspace(1) %gep1, ptr addrspace(1) %p1, ptr addrspace(1) %p10, ptr addrspace(3) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5, ptr addrspace(1) %p6, ptr addrspace(1) %p7, ptr addrspace(1) %p8, ptr addrspace(1) %p9) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.3(0x40000000), %bb.1(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10, $vgpr11, $vgpr12, $vgpr13, $vgpr14, $vgpr15, $vgpr16, $vgpr17, $vgpr18
  
    %0:vgpr_32 = COPY $vgpr18
    %1:vgpr_32 = COPY $vgpr17
    %2:vgpr_32 = COPY $vgpr16
    %3:vgpr_32 = COPY $vgpr15
    %4:vgpr_32 = COPY $vgpr14
    %5:vgpr_32 = COPY $vgpr13
    %6:vgpr_32 = COPY $vgpr12
    %7:vgpr_32 = COPY $vgpr11
    %8:vgpr_32 = COPY $vgpr10
    %9:vgpr_32 = COPY $vgpr9
    %10:vgpr_32 = COPY $vgpr8
    %11:vgpr_32 = COPY $vgpr7
    %12:vgpr_32 = COPY $vgpr6
    %13:vgpr_32 = COPY $vgpr5
    %14:vgpr_32 = COPY $vgpr4
    %15:vgpr_32 = COPY $vgpr3
    %16:vgpr_32 = COPY $vgpr2
    %17:vgpr_32 = COPY $vgpr1
    %18:vgpr_32 = COPY $vgpr0
    %19:vreg_64 = REG_SEQUENCE %5, %subreg.sub0, %4, %subreg.sub1
    %20:vreg_64 = REG_SEQUENCE %18, %subreg.sub0, %17, %subreg.sub1
    %21:vreg_64 = REG_SEQUENCE %11, %subreg.sub0, %10, %subreg.sub1
    %22:vreg_64 = REG_SEQUENCE %13, %subreg.sub0, %12, %subreg.sub1
    %23:vgpr_32 = GLOBAL_LOAD_USHORT %22, 0, 0, implicit $exec :: (load (s16) from %ir.p4, addrspace 1)
    %24:vgpr_32 = GLOBAL_LOAD_USHORT %22, 2, 0, implicit $exec :: (load (s16) from %ir.p4 + 2, addrspace 1)
    %25:vgpr_32 = V_LSHL_OR_B32_e64 %24, 16, %23, implicit $exec
    %26:vgpr_32 = GLOBAL_LOAD_DWORD %21, 0, 0, implicit $exec :: (load (s32) from %ir.p5, align 8, addrspace 1)
    %27:vgpr_32 = GLOBAL_LOAD_DWORD %20, 0, 0, implicit $exec :: (load (s32) from %ir.p1, addrspace 1)
    %28:vgpr_32 = GLOBAL_LOAD_UBYTE %20, 12, 0, implicit $exec :: (load (s8) from %ir.gep1, addrspace 1)
    %29:vgpr_32 = GLOBAL_LOAD_UBYTE %20, 13, 0, implicit $exec :: (load (s8) from %ir.gep1 + 1, addrspace 1)
    %30:vgpr_32 = V_LSHL_OR_B32_e64 %29, 8, %28, implicit $exec
    %31:vgpr_32 = GLOBAL_LOAD_UBYTE %20, 14, 0, implicit $exec :: (load (s8) from %ir.gep1 + 2, addrspace 1)
    %32:vgpr_32 = GLOBAL_LOAD_UBYTE %20, 15, 0, implicit $exec :: (load (s8) from %ir.gep1 + 3, addrspace 1)
    %33:vgpr_32 = V_LSHL_OR_B32_e64 %32, 8, %31, implicit $exec
    %34:vgpr_32 = V_ADD_U32_e64 %25, %26, 0, implicit $exec
    GLOBAL_STORE_DWORD %20, %34, 0, 0, implicit $exec :: (store (s32) into %ir.p1, addrspace 1)
    %35:sreg_32 = V_CMP_LT_U32_e64 %26, %34, implicit $exec
    %36:sreg_32 = SI_IF %35, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.1:
    successors: %bb.2(0x40000000), %bb.4(0x40000000)
  
    %37:vgpr_32 = PHI undef %38:vgpr_32, %bb.0, %39, %bb.3
    %40:vgpr_32 = PHI undef %38:vgpr_32, %bb.0, %41, %bb.3
    %42:vgpr_32 = PHI undef %38:vgpr_32, %bb.0, %43, %bb.3
    %44:vreg_64 = REG_SEQUENCE %15, %subreg.sub0, %14, %subreg.sub1
    %45:vgpr_32 = V_LSHL_OR_B32_e64 %33, 16, %30, implicit $exec
    %46:sreg_32 = SI_ELSE %36, %bb.4, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
