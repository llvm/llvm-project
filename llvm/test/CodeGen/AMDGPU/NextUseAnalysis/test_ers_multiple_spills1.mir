    %67:vgpr_32 = GLOBAL_LOAD_UBYTE %19, 9, 0, implicit $exec :: (load (s8) from %ir.p8 + 9, addrspace 1)
    %68:vgpr_32 = V_LSHL_OR_B32_e64 %67, 8, %66, implicit $exec
