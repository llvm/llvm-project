# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s
--- |
  @array2 = global [5 x i32] zeroinitializer, align 4
  @array3 = global [5 x i32] zeroinitializer, align 4
  @array4 = global [5 x i32] zeroinitializer, align 4
  @array5 = global [5 x i32] zeroinitializer, align 4
  @array6 = global [5 x i32] zeroinitializer, align 4
  @array7 = global [5 x i32] zeroinitializer, align 4
  @array8 = global [5 x i32] zeroinitializer, align 4
  @array9 = global [5 x i32] zeroinitializer, align 4
  
  define amdgpu_ps void @test(ptr addrspace(1) %gep1, ptr addrspace(1) %p1, ptr addrspace(1) %p10, ptr addrspace(3) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5, ptr addrspace(1) %p6, ptr addrspace(1) %p7, ptr addrspace(1) %p8, ptr addrspace(1) %p9) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.3(0x40000000), %bb.1(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10, $vgpr11, $vgpr12, $vgpr13, $vgpr14, $vgpr15, $vgpr16, $vgpr17, $vgpr18
  
