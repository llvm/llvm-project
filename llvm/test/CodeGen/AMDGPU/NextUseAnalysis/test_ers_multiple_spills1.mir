    %5:vgpr_32 = PHI undef %63:vgpr_32, %bb.0, %13, %bb.3
    %6:vgpr_32 = PHI undef %63:vgpr_32, %bb.0, %12, %bb.3
    %7:vgpr_32 = PHI undef %63:vgpr_32, %bb.0, %14, %bb.3
