    %70:vgpr_32 = GLOBAL_LOAD_UBYTE %19, 11, 0, implicit $exec :: (load (s8) from %ir.p8 + 11, addrspace 1)
    %71:vgpr_32 = V_LSHL_OR_B32_e64 %70, 8, %69, implicit $exec
    %39:vgpr_32 = V_LSHL_OR_B32_e64 %71, 16, %68, implicit $exec
    %72:vreg_64 = REG_SEQUENCE %39, %subreg.sub0, undef %73:vgpr_32, %subreg.sub1
    %74:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %59, %41, %72, 0, implicit $exec
    %43:vgpr_32 = V_SUB_U32_e64 %74.sub0, %27, 0, implicit $exec
    S_BRANCH %bb.1
  
  bb.4:
    successors: %bb.7(0x40000000), %bb.5(0x40000000)
  
    %75:vgpr_32 = PHI %42, %bb.1, %49, %bb.2
    %76:vgpr_32 = PHI %34, %bb.1, %49, %bb.2
    %77:vgpr_32 = PHI %40, %bb.1, %50, %bb.2
    %78:vgpr_32 = PHI %37, %bb.1, %48, %bb.2
    SI_END_CF %46, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %79:vreg_64 = REG_SEQUENCE %25, %subreg.sub0, undef %80:vgpr_32, %subreg.sub1
    %81:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %75, %27, %79, 0, implicit $exec
    %82:vreg_64 = REG_SEQUENCE %76, %subreg.sub0, undef %83:vgpr_32, %subreg.sub1
    %84:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %81.sub0, %34, %82, 0, implicit $exec
