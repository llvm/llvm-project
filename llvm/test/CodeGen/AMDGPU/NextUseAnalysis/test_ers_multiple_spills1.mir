    %450:vreg_64 = REG_SEQUENCE %42, %subreg.sub0, %43, %subreg.sub1
    %449:vreg_64 = REG_SEQUENCE %40, %subreg.sub0, %41, %subreg.sub1
    %73:vgpr_32 = GLOBAL_LOAD_USHORT %449, 0, 0, implicit $exec :: (load (s16) from %ir.p4, addrspace 1)
    %75:vgpr_32 = GLOBAL_LOAD_USHORT %449, 2, 0, implicit $exec :: (load (s16) from %ir.p4 + 2, addrspace 1)
    %0:vgpr_32 = V_LSHL_OR_B32_e64 %75, 16, %73, implicit $exec
