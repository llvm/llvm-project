# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s
--- |
  define amdgpu_ps i32 @test(ptr addrspace(1) %p1, ptr addrspace(1) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret i32 0
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10, $vgpr11
  
    %45:vgpr_32 = COPY $vgpr11
    %44:vgpr_32 = COPY $vgpr10
    %43:vgpr_32 = COPY $vgpr9
    %42:vgpr_32 = COPY $vgpr8
    %41:vgpr_32 = COPY $vgpr7
    %40:vgpr_32 = COPY $vgpr6
    %39:vgpr_32 = COPY $vgpr5
    %38:vgpr_32 = COPY $vgpr4
    %37:vgpr_32 = COPY $vgpr3
    %36:vgpr_32 = COPY $vgpr2
    %35:vgpr_32 = COPY $vgpr1
    %34:vgpr_32 = COPY $vgpr0
    %124:vreg_64 = REG_SEQUENCE %42, %subreg.sub0, %43, %subreg.sub1
    %123:vreg_64 = REG_SEQUENCE %40, %subreg.sub0, %41, %subreg.sub1
    %122:vreg_64 = REG_SEQUENCE %38, %subreg.sub0, %39, %subreg.sub1
    %121:vreg_64 = REG_SEQUENCE %36, %subreg.sub0, %37, %subreg.sub1
    %120:vreg_64 = REG_SEQUENCE %34, %subreg.sub0, %35, %subreg.sub1
    %56:vgpr_32 = GLOBAL_LOAD_UBYTE %120, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %58:vgpr_32 = GLOBAL_LOAD_UBYTE %120, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %61:vgpr_32 = V_LSHL_OR_B32_e64 %58, 8, %56, implicit $exec
    %62:vgpr_32 = GLOBAL_LOAD_UBYTE %120, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %64:vgpr_32 = GLOBAL_LOAD_UBYTE %120, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %66:vgpr_32 = V_LSHL_OR_B32_e64 %64, 8, %62, implicit $exec
    %0:vgpr_32 = V_LSHL_OR_B32_e64 %66, 16, %61, implicit $exec
    %50:sreg_32 = S_MOV_B32 0
  
  bb.1:
    successors: %bb.2(0x80000000)
  
    %1:sreg_32 = PHI %50, %bb.0, %28, %bb.5
    %2:sreg_32 = PHI %50, %bb.0, %27, %bb.5
    %3:vgpr_32 = PHI %0, %bb.0, %26, %bb.5
    %69:vgpr_32 = V_MOV_B32_e32 13, implicit $exec
  
  bb.2:
    successors: %bb.3(0x80000000)
  
    %4:sreg_32 = PHI %50, %bb.1, %19, %bb.4
    %5:sreg_32 = PHI %50, %bb.1, %18, %bb.4
    %6:vgpr_32 = PHI %69, %bb.1, %17, %bb.4
    %71:vgpr_32 = GLOBAL_LOAD_UBYTE %121, 0, 0, implicit $exec :: (load (s8) from %ir.p2, addrspace 1)
    %72:vgpr_32 = GLOBAL_LOAD_UBYTE %121, 1, 0, implicit $exec :: (load (s8) from %ir.p2 + 1, addrspace 1)
    %74:vgpr_32 = V_LSHL_OR_B32_e64 %72, 8, %71, implicit $exec
    %75:vgpr_32 = GLOBAL_LOAD_UBYTE %121, 2, 0, implicit $exec :: (load (s8) from %ir.p2 + 2, addrspace 1)
    %76:vgpr_32 = GLOBAL_LOAD_UBYTE %121, 3, 0, implicit $exec :: (load (s8) from %ir.p2 + 3, addrspace 1)
    %77:vgpr_32 = V_LSHL_OR_B32_e64 %76, 8, %75, implicit $exec
    %7:vgpr_32 = V_LSHL_OR_B32_e64 %77, 16, %74, implicit $exec
    %79:vgpr_32 = V_ADD_U32_e64 %5, %7, 0, implicit $exec
    GLOBAL_STORE_BYTE_D16_HI %123, %79, 2, 0, implicit $exec :: (store (s8) into %ir.p4 + 2, addrspace 1)
    GLOBAL_STORE_BYTE %123, %79, 0, 0, implicit $exec :: (store (s8) into %ir.p4, addrspace 1)
    %81:vgpr_32 = V_LSHRREV_B32_e64 24, %79, implicit $exec
    GLOBAL_STORE_BYTE %123, %81, 3, 0, implicit $exec :: (store (s8) into %ir.p4 + 3, addrspace 1)
    %82:vgpr_32 = V_LSHRREV_B32_e64 8, %79, implicit $exec
    GLOBAL_STORE_BYTE %123, %82, 1, 0, implicit $exec :: (store (s8) into %ir.p4 + 1, addrspace 1)
    %70:sreg_32 = S_MOV_B32 0
  
  bb.3:
    successors: %bb.4(0x04000000), %bb.3(0x7c000000)
  
    %8:sreg_32 = PHI %70, %bb.2, %12, %bb.3
    %9:sreg_32 = PHI %70, %bb.2, %10, %bb.3
    %10:sreg_32 = S_ADD_I32 %9, 3, implicit-def dead $scc
    %84:vgpr_32 = GLOBAL_LOAD_UBYTE %122, 0, 0, implicit $exec :: (load (s8) from %ir.p3, addrspace 1)
    %85:vgpr_32 = GLOBAL_LOAD_UBYTE %122, 1, 0, implicit $exec :: (load (s8) from %ir.p3 + 1, addrspace 1)
    %87:vgpr_32 = V_LSHL_OR_B32_e64 %85, 8, %84, implicit $exec
    %88:vgpr_32 = GLOBAL_LOAD_UBYTE %122, 2, 0, implicit $exec :: (load (s8) from %ir.p3 + 2, addrspace 1)
    %89:vgpr_32 = GLOBAL_LOAD_UBYTE %122, 3, 0, implicit $exec :: (load (s8) from %ir.p3 + 3, addrspace 1)
    %90:vgpr_32 = V_LSHL_OR_B32_e64 %89, 8, %88, implicit $exec
    %11:vgpr_32 = V_LSHL_OR_B32_e64 %90, 16, %87, implicit $exec
    %92:vgpr_32 = V_ADD_U32_e64 %10, %11, 0, implicit $exec
    GLOBAL_STORE_BYTE_D16_HI %124, %92, 2, 0, implicit $exec :: (store (s8) into %ir.p5 + 2, addrspace 1)
    GLOBAL_STORE_BYTE %124, %92, 0, 0, implicit $exec :: (store (s8) into %ir.p5, addrspace 1)
    %94:vgpr_32 = V_LSHRREV_B32_e64 24, %92, implicit $exec
    GLOBAL_STORE_BYTE %124, %94, 3, 0, implicit $exec :: (store (s8) into %ir.p5 + 3, addrspace 1)
    %95:vgpr_32 = V_LSHRREV_B32_e64 8, %92, implicit $exec
    GLOBAL_STORE_BYTE %124, %95, 1, 0, implicit $exec :: (store (s8) into %ir.p5 + 1, addrspace 1)
    %96:sreg_32 = V_CMP_GE_U32_e64 %10, %44, implicit $exec
    %12:sreg_32 = SI_IF_BREAK %96, %8, implicit-def dead $scc
    %125:vgpr_32 = COPY %10, implicit $exec
    SI_LOOP %12, %bb.3, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.4:
    successors: %bb.5(0x04000000), %bb.2(0x7c000000)
  
    SI_END_CF %12, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %16:vgpr_32 = V_ADD_U32_e64 %11, %125, 0, implicit $exec
    %17:vgpr_32 = V_MUL_LO_U32_e64 %3, %16, implicit $exec
    %18:sreg_32 = S_ADD_I32 %5, 2, implicit-def dead $scc
    %98:sreg_32 = V_CMP_GE_U32_e64 %18, %45, implicit $exec
    %19:sreg_32 = SI_IF_BREAK %98, %4, implicit-def dead $scc
    SI_LOOP %19, %bb.2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.5
  
  bb.5:
    successors: %bb.6(0x04000000), %bb.1(0x7c000000)
  
    SI_END_CF %19, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %26:vgpr_32 = V_SUB_U32_e64 %7, %125, 0, implicit $exec
    %27:sreg_32 = S_ADD_I32 %2, 1, implicit-def dead $scc
    %100:sreg_32 = V_CMP_GE_U32_e64 %27, %44, implicit $exec
    %28:sreg_32 = SI_IF_BREAK %100, %1, implicit-def dead $scc
    SI_LOOP %28, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.6
  
  bb.6:
    SI_END_CF %28, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %102:vgpr_32 = V_MAX_U32_e64 1, %44, implicit $exec
    %103:vgpr_32 = V_ADD_U32_e64 %102, %0, 0, implicit $exec
    %104:vgpr_32 = V_ADD3_U32_e64 %6, %3, %16, implicit $exec
    %105:vgpr_32 = V_ADD_U32_e64 %16, %17, 0, implicit $exec
    %106:vgpr_32 = V_ADD3_U32_e64 %105, %104, %6, implicit $exec
    %108:vgpr_32 = V_ADD3_U32_e64 %103, %106, -1, implicit $exec
    %109:sreg_32_xm0 = V_READFIRSTLANE_B32 %108, implicit $exec
    $sgpr0 = COPY %109
    SI_RETURN_TO_EPILOG killed $sgpr0
...

