# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

--- |
  define amdgpu_ps i32 @test(ptr addrspace(1) %gep1, ptr addrspace(1) %gep2, ptr addrspace(1) %p1, ptr addrspace(3) %p2) {
  ret i32 0
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x40000000), %bb.2(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4
  
    %0:vgpr_32 = COPY $vgpr4
    %1:vgpr_32 = COPY $vgpr3
    %2:vgpr_32 = COPY $vgpr2
    %3:vgpr_32 = COPY $vgpr1
    %4:vgpr_32 = COPY $vgpr0
    %5:vreg_64 = REG_SEQUENCE %4, %subreg.sub0, %3, %subreg.sub1
    %6:vgpr_32 = V_AND_B32_e64 1, %1, implicit $exec
    %7:sreg_32 = V_CMP_EQ_U32_e64 1, %6, implicit $exec
    %8:vgpr_32 = V_AND_B32_e64 1, %0, implicit $exec
    %9:sreg_32 = V_CMP_EQ_U32_e64 1, %8, implicit $exec
    %10:sreg_32 = S_XOR_B32 %9, -1, implicit-def dead $scc
    %11:vgpr_32 = GLOBAL_LOAD_UBYTE %5, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %12:vgpr_32 = GLOBAL_LOAD_UBYTE %5, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %13:vgpr_32 = V_LSHL_OR_B32_e64 %12, 8, %11, implicit $exec
    %14:vgpr_32 = GLOBAL_LOAD_UBYTE %5, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %15:vgpr_32 = GLOBAL_LOAD_UBYTE %5, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %16:vgpr_32 = V_LSHL_OR_B32_e64 %15, 8, %14, implicit $exec
    %17:vgpr_32 = V_LSHL_OR_B32_e64 %16, 16, %13, implicit $exec
    %18:vgpr_32 = GLOBAL_LOAD_UBYTE %5, 12, 0, implicit $exec :: (load (s8) from %ir.gep1, addrspace 1)
    %19:vgpr_32 = GLOBAL_LOAD_UBYTE %5, 13, 0, implicit $exec :: (load (s8) from %ir.gep1 + 1, addrspace 1)
    %20:vgpr_32 = GLOBAL_LOAD_UBYTE %5, 14, 0, implicit $exec :: (load (s8) from %ir.gep1 + 2, addrspace 1)
    %21:vgpr_32 = GLOBAL_LOAD_UBYTE %5, 15, 0, implicit $exec :: (load (s8) from %ir.gep1 + 3, addrspace 1)
    %22:vgpr_32 = V_ADD_U32_e64 100, %17, 0, implicit $exec
    %23:sreg_32 = SI_IF %7, %bb.2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.1
  
  bb.1:
    successors: %bb.2(0x80000000)
  
    %24:vgpr_32 = V_MOV_B32_e32 100, implicit $exec
  
  bb.2:
    successors: %bb.5(0x40000000), %bb.3(0x40000000)
  
    %25:vgpr_32 = PHI %22, %bb.0, %24, %bb.1
    SI_END_CF %23, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %26:vgpr_32 = DS_READ_U8_gfx9 %2, 0, 0, implicit $exec :: (load (s8) from %ir.p2, addrspace 3)
    %27:vgpr_32 = DS_READ_U8_gfx9 %2, 1, 0, implicit $exec :: (load (s8) from %ir.p2 + 1, addrspace 3)
    %28:vgpr_32 = DS_READ_U8_gfx9 %2, 2, 0, implicit $exec :: (load (s8) from %ir.p2 + 2, addrspace 3)
    %29:vgpr_32 = DS_READ_U8_gfx9 %2, 3, 0, implicit $exec :: (load (s8) from %ir.p2 + 3, addrspace 3)
    %30:vgpr_32 = V_LSHL_OR_B32_e64 %27, 8, %26, implicit $exec
    %31:vgpr_32 = V_LSHL_OR_B32_e64 %29, 8, %28, implicit $exec
    %32:vgpr_32 = V_LSHL_OR_B32_e64 %31, 16, %30, implicit $exec
    %33:sreg_32 = SI_IF %10, %bb.3, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.5
  
  bb.3:
    successors: %bb.4(0x40000000), %bb.6(0x40000000)
  
    %34:vgpr_32 = PHI undef %35:vgpr_32, %bb.2, %36, %bb.5
    %37:vgpr_32 = PHI %25, %bb.2, undef %38:vgpr_32, %bb.5
    %39:vgpr_32 = V_LSHL_OR_B32_e64 %19, 8, %18, implicit $exec
    %40:vgpr_32 = V_LSHL_OR_B32_e64 %21, 8, %20, implicit $exec
    %41:sreg_32 = SI_ELSE %33, %bb.6, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.4:
    successors: %bb.6(0x80000000)
  
    %42:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %17, %37, 1000, 0, implicit $exec
    %43:vgpr_32 = COPY %42.sub0
    S_BRANCH %bb.6
  
  bb.5:
    successors: %bb.3(0x80000000)
  
    %36:vgpr_32 = V_ADD_U32_e64 %22, %32, 0, implicit $exec
    S_BRANCH %bb.3
  
  bb.6:
    successors: %bb.12(0x40000000), %bb.7(0x40000000)
  
    %44:vgpr_32 = PHI %34, %bb.3, %43, %bb.4
    SI_END_CF %41, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %45:vgpr_32 = V_LSHL_OR_B32_e64 %40, 16, %39, implicit $exec
    %46:vgpr_32 = DS_READ_B32_gfx9 %2, 12, 0, implicit $exec :: (load (s32) from %ir.gep2, align 8, addrspace 3)
    %47:vgpr_32 = V_ADD_U32_e64 %46, %44, 0, implicit $exec
    %48:sreg_32 = S_XOR_B32 %7, %9, implicit-def dead $scc
    %49:sreg_32 = S_XOR_B32 %48, -1, implicit-def dead $scc
    %50:sreg_32 = SI_IF %49, %bb.7, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.12
  
  bb.7:
    successors: %bb.8(0x40000000), %bb.14(0x40000000)
  
    %51:vgpr_32 = PHI undef %52:vgpr_32, %bb.6, %53, %bb.12
    %54:vgpr_32 = PHI %45, %bb.6, undef %55:vgpr_32, %bb.12
    %56:vgpr_32 = PHI %47, %bb.6, undef %57:vgpr_32, %bb.12
    %58:sreg_32 = SI_ELSE %50, %bb.14, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.8
  
  bb.8:
    successors: %bb.11(0x40000000), %bb.9(0x40000000)
  
    %59:sreg_32 = S_AND_B32 %7, %9, implicit-def dead $scc
    %60:sreg_32 = S_XOR_B32 %59, -1, implicit-def dead $scc
    %61:sreg_32 = SI_IF %60, %bb.9, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.11
  
  bb.9:
    successors: %bb.10(0x40000000), %bb.13(0x40000000)
  
    %62:vgpr_32 = PHI undef %63:vgpr_32, %bb.8, %64, %bb.11
    %65:vgpr_32 = PHI %54, %bb.8, undef %66:vgpr_32, %bb.11
    %67:vgpr_32 = PHI %56, %bb.8, undef %68:vgpr_32, %bb.11
    %69:sreg_32 = SI_ELSE %61, %bb.13, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.10
  
  bb.10:
    successors: %bb.13(0x80000000)
  
    %70:vgpr_32 = V_ADD_U32_e64 %65, %67, 0, implicit $exec
    S_BRANCH %bb.13
  
  bb.11:
    successors: %bb.9(0x80000000)
  
    %64:vgpr_32 = V_MUL_LO_U32_e64 %54, %56, implicit $exec
    S_BRANCH %bb.9
  
  bb.12:
    successors: %bb.7(0x80000000)
  
    %71:vgpr_32 = V_SUB_U32_e64 %46, %47, 0, implicit $exec
    %72:vgpr_32 = V_MUL_LO_U32_e64 %71, %32, implicit $exec
    %73:vgpr_32 = V_CVT_F32_U32_e64 %17, 0, 0, implicit $mode, implicit $exec
    %74:vgpr_32 = nofpexcept V_RCP_IFLAG_F32_e64 0, %73, 0, 0, implicit $mode, implicit $exec
    %75:vgpr_32 = nnan ninf nsz arcp contract afn reassoc nofpexcept V_MUL_F32_e64 0, 1333788670, 0, %74, 0, 0, implicit $mode, implicit $exec
    %76:vgpr_32 = nofpexcept V_CVT_U32_F32_e64 0, %75, 0, 0, implicit $mode, implicit $exec
    %77:vgpr_32 = V_SUB_U32_e64 0, %17, 0, implicit $exec
    %78:vgpr_32 = V_MUL_LO_U32_e64 %77, %76, implicit $exec
    %79:vgpr_32 = V_MUL_HI_U32_e64 %76, %78, implicit $exec
    %80:vgpr_32 = V_ADD_U32_e64 %76, %79, 0, implicit $exec
    %81:vgpr_32 = V_MUL_HI_U32_e64 %72, %80, implicit $exec
    %82:vgpr_32 = V_MUL_LO_U32_e64 %81, %17, implicit $exec
    %83:vgpr_32 = V_SUB_U32_e64 %72, %82, 0, implicit $exec
    %84:sreg_32_xm0_xexec = V_CMP_GE_U32_e64 %83, %17, implicit $exec
    %85:vgpr_32 = V_ADD_U32_e64 1, %81, 0, implicit $exec
    %86:vgpr_32 = V_CNDMASK_B32_e64 0, %81, 0, %85, %84, implicit $exec
    %87:vgpr_32 = V_SUB_U32_e64 %83, %17, 0, implicit $exec
    %88:vgpr_32 = V_CNDMASK_B32_e64 0, %83, 0, %87, %84, implicit $exec
    %89:sreg_32_xm0_xexec = V_CMP_GE_U32_e64 %88, %17, implicit $exec
    %90:vgpr_32 = V_ADD_U32_e64 1, %86, 0, implicit $exec
    %91:vgpr_32 = V_CNDMASK_B32_e64 0, %86, 0, %90, %89, implicit $exec
    %53:vgpr_32 = V_ADD_U32_e64 %91, %45, 0, implicit $exec
    S_BRANCH %bb.7
  
  bb.13:
    successors: %bb.14(0x80000000)
  
    %92:vgpr_32 = PHI %62, %bb.9, %70, %bb.10
    SI_END_CF %69, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
  
  bb.14:
    %93:vgpr_32 = PHI %51, %bb.7, %92, %bb.13
    SI_END_CF %58, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %94:vgpr_32 = V_ADD3_U32_e64 %32, %93, 100, implicit $exec
    %95:sreg_32_xm0 = V_READFIRSTLANE_B32 %94, implicit $exec
    $sgpr0 = COPY %95
    SI_RETURN_TO_EPILOG killed $sgpr0
...


