--- |
  define amdgpu_ps i32 @test(ptr addrspace(1) %gep1, ptr addrspace(1) %gep2, ptr addrspace(1) %p1, ptr addrspace(3) %p2) {
  ret i32 0
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x40000000), %bb.2(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4
  
    %30:vgpr_32 = COPY $vgpr4
    %29:vgpr_32 = COPY $vgpr3
    %28:vgpr_32 = COPY $vgpr2
    %27:vgpr_32 = COPY $vgpr1
    %26:vgpr_32 = COPY $vgpr0
    %117:vreg_64 = REG_SEQUENCE %26, %subreg.sub0, %27, %subreg.sub1
    %34:vgpr_32 = V_AND_B32_e64 1, %29, implicit $exec
    %35:sreg_32 = V_CMP_EQ_U32_e64 1, %34, implicit $exec
    %36:vgpr_32 = V_AND_B32_e64 1, %30, implicit $exec
    %37:sreg_32 = V_CMP_EQ_U32_e64 1, %36, implicit $exec
    %39:sreg_32 = S_XOR_B32 %37, -1, implicit-def dead $scc
    %40:vgpr_32 = GLOBAL_LOAD_UBYTE %117, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %42:vgpr_32 = GLOBAL_LOAD_UBYTE %117, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %45:vgpr_32 = V_LSHL_OR_B32_e64 %42, 8, %40, implicit $exec
    %46:vgpr_32 = GLOBAL_LOAD_UBYTE %117, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %48:vgpr_32 = GLOBAL_LOAD_UBYTE %117, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %50:vgpr_32 = V_LSHL_OR_B32_e64 %48, 8, %46, implicit $exec
    %1:vgpr_32 = V_LSHL_OR_B32_e64 %50, 16, %45, implicit $exec
    %52:vgpr_32 = GLOBAL_LOAD_UBYTE %117, 12, 0, implicit $exec :: (load (s8) from %ir.gep1, addrspace 1)
    %54:vgpr_32 = GLOBAL_LOAD_UBYTE %117, 13, 0, implicit $exec :: (load (s8) from %ir.gep1 + 1, addrspace 1)
    %57:vgpr_32 = GLOBAL_LOAD_UBYTE %117, 14, 0, implicit $exec :: (load (s8) from %ir.gep1 + 2, addrspace 1)
    %59:vgpr_32 = GLOBAL_LOAD_UBYTE %117, 15, 0, implicit $exec :: (load (s8) from %ir.gep1 + 3, addrspace 1)
    %3:vgpr_32 = V_ADD_U32_e64 100, %1, 0, implicit $exec
    %4:sreg_32 = SI_IF %35, %bb.2, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.1
  
  bb.1:
    successors: %bb.2(0x80000000)
  
    %63:vgpr_32 = V_MOV_B32_e32 100, implicit $exec
  
  bb.2:
    successors: %bb.5(0x40000000), %bb.3(0x40000000)
  
    %5:vgpr_32 = PHI %3, %bb.0, %63, %bb.1
    SI_END_CF %4, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %65:vgpr_32 = DS_READ_U8_gfx9 %28, 0, 0, implicit $exec :: (load (s8) from %ir.p2, addrspace 3)
    %66:vgpr_32 = DS_READ_U8_gfx9 %28, 1, 0, implicit $exec :: (load (s8) from %ir.p2 + 1, addrspace 3)
    %67:vgpr_32 = DS_READ_U8_gfx9 %28, 2, 0, implicit $exec :: (load (s8) from %ir.p2 + 2, addrspace 3)
    %68:vgpr_32 = DS_READ_U8_gfx9 %28, 3, 0, implicit $exec :: (load (s8) from %ir.p2 + 3, addrspace 3)
    %70:vgpr_32 = V_LSHL_OR_B32_e64 %66, 8, %65, implicit $exec
    %71:vgpr_32 = V_LSHL_OR_B32_e64 %68, 8, %67, implicit $exec
    %6:vgpr_32 = V_LSHL_OR_B32_e64 %71, 16, %70, implicit $exec
    %7:sreg_32 = SI_IF %39, %bb.3, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.5
  
  bb.3:
    successors: %bb.4(0x40000000), %bb.6(0x40000000)
  
    %8:vgpr_32 = PHI undef %64:vgpr_32, %bb.2, %11, %bb.5
    %118:vgpr_32 = PHI %5, %bb.2, undef %119:vgpr_32, %bb.5
    %56:vgpr_32 = V_LSHL_OR_B32_e64 %54, 8, %52, implicit $exec
    %61:vgpr_32 = V_LSHL_OR_B32_e64 %59, 8, %57, implicit $exec
    %9:sreg_32 = SI_ELSE %7, %bb.6, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.4:
    successors: %bb.6(0x80000000)
  
    %74:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %1, %118, 1000, 0, implicit $exec
    %10:vgpr_32 = COPY %74.sub0
    S_BRANCH %bb.6
  
  bb.5:
    successors: %bb.3(0x80000000)
  
    %11:vgpr_32 = V_ADD_U32_e64 %3, %6, 0, implicit $exec
    S_BRANCH %bb.3
  
  bb.6:
    successors: %bb.12(0x40000000), %bb.7(0x40000000)
  
    %12:vgpr_32 = PHI %8, %bb.3, %10, %bb.4
    SI_END_CF %9, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %2:vgpr_32 = V_LSHL_OR_B32_e64 %61, 16, %56, implicit $exec
    %13:vgpr_32 = DS_READ_B32_gfx9 %28, 12, 0, implicit $exec :: (load (s32) from %ir.gep2, align 8, addrspace 3)
    %14:vgpr_32 = V_ADD_U32_e64 %13, %12, 0, implicit $exec
    %77:sreg_32 = S_XOR_B32 %35, %37, implicit-def dead $scc
    %81:sreg_32 = S_XOR_B32 %77, -1, implicit-def dead $scc
    %15:sreg_32 = SI_IF %81, %bb.7, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.12
  
  bb.7:
    successors: %bb.8(0x40000000), %bb.14(0x40000000)
  
    %16:vgpr_32 = PHI undef %76:vgpr_32, %bb.6, %23, %bb.12
    %120:vgpr_32 = PHI %2, %bb.6, undef %121:vgpr_32, %bb.12
    %122:vgpr_32 = PHI %14, %bb.6, undef %123:vgpr_32, %bb.12
    %17:sreg_32 = SI_ELSE %15, %bb.14, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.8
  
  bb.8:
    successors: %bb.11(0x40000000), %bb.9(0x40000000)
  
    %107:sreg_32 = S_AND_B32 %35, %37, implicit-def dead $scc
    %111:sreg_32 = S_XOR_B32 %107, -1, implicit-def dead $scc
    %18:sreg_32 = SI_IF %111, %bb.9, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.11
  
  bb.9:
    successors: %bb.10(0x40000000), %bb.13(0x40000000)
  
    %19:vgpr_32 = PHI undef %106:vgpr_32, %bb.8, %22, %bb.11
    %124:vgpr_32 = PHI %120, %bb.8, undef %125:vgpr_32, %bb.11
    %126:vgpr_32 = PHI %122, %bb.8, undef %127:vgpr_32, %bb.11
    %20:sreg_32 = SI_ELSE %18, %bb.13, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.10
  
  bb.10:
    successors: %bb.13(0x80000000)
  
    %21:vgpr_32 = V_ADD_U32_e64 %124, %126, 0, implicit $exec
    S_BRANCH %bb.13
  
  bb.11:
    successors: %bb.9(0x80000000)
  
    %22:vgpr_32 = V_MUL_LO_U32_e64 %120, %122, implicit $exec
    S_BRANCH %bb.9
  
  bb.12:
    successors: %bb.7(0x80000000)
  
    %82:vgpr_32 = V_SUB_U32_e64 %13, %14, 0, implicit $exec
    %83:vgpr_32 = V_MUL_LO_U32_e64 %82, %6, implicit $exec
    %84:vgpr_32 = V_CVT_F32_U32_e64 %1, 0, 0, implicit $mode, implicit $exec
    %85:vgpr_32 = nofpexcept V_RCP_IFLAG_F32_e64 0, %84, 0, 0, implicit $mode, implicit $exec
    %87:vgpr_32 = nnan ninf nsz arcp contract afn reassoc nofpexcept V_MUL_F32_e64 0, 1333788670, 0, %85, 0, 0, implicit $mode, implicit $exec
    %88:vgpr_32 = nofpexcept V_CVT_U32_F32_e64 0, %87, 0, 0, implicit $mode, implicit $exec
    %90:vgpr_32 = V_SUB_U32_e64 0, %1, 0, implicit $exec
    %91:vgpr_32 = V_MUL_LO_U32_e64 %90, %88, implicit $exec
    %92:vgpr_32 = V_MUL_HI_U32_e64 %88, %91, implicit $exec
    %93:vgpr_32 = V_ADD_U32_e64 %88, %92, 0, implicit $exec
    %94:vgpr_32 = V_MUL_HI_U32_e64 %83, %93, implicit $exec
    %95:vgpr_32 = V_MUL_LO_U32_e64 %94, %1, implicit $exec
    %96:vgpr_32 = V_SUB_U32_e64 %83, %95, 0, implicit $exec
    %97:sreg_32_xm0_xexec = V_CMP_GE_U32_e64 %96, %1, implicit $exec
    %99:vgpr_32 = V_ADD_U32_e64 1, %94, 0, implicit $exec
    %100:vgpr_32 = V_CNDMASK_B32_e64 0, %94, 0, %99, %97, implicit $exec
    %101:vgpr_32 = V_SUB_U32_e64 %96, %1, 0, implicit $exec
    %102:vgpr_32 = V_CNDMASK_B32_e64 0, %96, 0, %101, %97, implicit $exec
    %103:sreg_32_xm0_xexec = V_CMP_GE_U32_e64 %102, %1, implicit $exec
    %104:vgpr_32 = V_ADD_U32_e64 1, %100, 0, implicit $exec
    %105:vgpr_32 = V_CNDMASK_B32_e64 0, %100, 0, %104, %103, implicit $exec
    %23:vgpr_32 = V_ADD_U32_e64 %105, %2, 0, implicit $exec
    S_BRANCH %bb.7
  
  bb.13:
    successors: %bb.14(0x80000000)
  
    %24:vgpr_32 = PHI %19, %bb.9, %21, %bb.10
    SI_END_CF %20, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
  
  bb.14:
    %25:vgpr_32 = PHI %16, %bb.7, %24, %bb.13
    SI_END_CF %17, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %113:vgpr_32 = V_ADD3_U32_e64 %6, %25, 100, implicit $exec
    %114:sreg_32_xm0 = V_READFIRSTLANE_B32 %113, implicit $exec
    $sgpr0 = COPY %114
    SI_RETURN_TO_EPILOG killed $sgpr0
...

