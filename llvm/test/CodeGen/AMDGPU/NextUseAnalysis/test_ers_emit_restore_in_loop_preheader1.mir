# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

--- |
  define amdgpu_ps void @test(ptr addrspace(1) %gep, ptr addrspace(1) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10
  
    %0:vgpr_32 = COPY $vgpr10
    %1:vgpr_32 = COPY $vgpr9
    %2:vgpr_32 = COPY $vgpr8
    %3:vgpr_32 = COPY $vgpr7
    %4:vgpr_32 = COPY $vgpr6
    %5:vgpr_32 = COPY $vgpr5
    %6:vgpr_32 = COPY $vgpr4
    %7:vgpr_32 = COPY $vgpr3
    %8:vgpr_32 = COPY $vgpr2
    %9:vgpr_32 = COPY $vgpr1
    %10:vgpr_32 = COPY $vgpr0
    %11:vreg_64 = REG_SEQUENCE %2, %subreg.sub0, %1, %subreg.sub1
    %12:vreg_64 = REG_SEQUENCE %10, %subreg.sub0, %9, %subreg.sub1
    %13:vreg_64 = REG_SEQUENCE %4, %subreg.sub0, %3, %subreg.sub1
    %14:vreg_64 = REG_SEQUENCE %6, %subreg.sub0, %5, %subreg.sub1
    %15:vreg_64 = REG_SEQUENCE %8, %subreg.sub0, %7, %subreg.sub1
    %16:vgpr_32 = GLOBAL_LOAD_DWORD %15, 0, 0, implicit $exec :: (load (s32) from %ir.p2, addrspace 1)
    %17:vgpr_32 = GLOBAL_LOAD_UBYTE %14, 0, 0, implicit $exec :: (load (s8) from %ir.p3, addrspace 1)
    %18:vgpr_32 = GLOBAL_LOAD_UBYTE %14, 1, 0, implicit $exec :: (load (s8) from %ir.p3 + 1, addrspace 1)
    %19:vgpr_32 = V_LSHL_OR_B32_e64 %18, 8, %17, implicit $exec
    %20:vgpr_32 = GLOBAL_LOAD_UBYTE %14, 2, 0, implicit $exec :: (load (s8) from %ir.p3 + 2, addrspace 1)
    %21:vgpr_32 = GLOBAL_LOAD_UBYTE %14, 3, 0, implicit $exec :: (load (s8) from %ir.p3 + 3, addrspace 1)
    %22:vgpr_32 = V_LSHL_OR_B32_e64 %21, 8, %20, implicit $exec
    %23:vgpr_32 = V_LSHL_OR_B32_e64 %22, 16, %19, implicit $exec
    %24:vgpr_32 = GLOBAL_LOAD_DWORD %13, 0, 0, implicit $exec :: (load (s32) from %ir.p4, addrspace 1)
    %25:vgpr_32 = V_ADD_U32_e64 %24, %0, 0, implicit $exec
    GLOBAL_STORE_DWORD %15, %25, 0, 0, implicit $exec :: (store (s32) into %ir.p2, addrspace 1)
    %26:vgpr_32 = V_MUL_LO_U32_e64 %24, %25, implicit $exec
    GLOBAL_STORE_DWORD %14, %26, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %27:vgpr_32 = V_SUB_U32_e64 %26, %25, 0, implicit $exec
    %28:vgpr_32 = V_MUL_LO_U32_e64 %27, %0, implicit $exec
    GLOBAL_STORE_DWORD %13, %28, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    %29:vgpr_32 = V_MOV_B32_e32 100, implicit $exec
    %30:sreg_32 = S_MOV_B32 0
  
  bb.1:
    successors: %bb.2(0x04000000), %bb.1(0x7c000000)
  
    %31:sreg_32 = PHI %30, %bb.0, %32, %bb.1
    %33:vgpr_32 = PHI %29, %bb.0, %34, %bb.1
    %35:sreg_32 = PHI %30, %bb.0, %36, %bb.1
    %37:sreg_32_xm0 = S_ASHR_I32 %35, 31, implicit-def dead $scc
    %38:sreg_64 = REG_SEQUENCE %35, %subreg.sub0, %37, %subreg.sub1
    %39:sreg_64 = nsw S_LSHL_B64 %38, 2, implicit-def dead $scc
    %40:vgpr_32, %41:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %12.sub0, %39.sub0, 0, implicit $exec
    %42:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %39.sub1, %12.sub1, %41, 0, implicit $exec
    %43:vreg_64 = REG_SEQUENCE %40, %subreg.sub0, %42, %subreg.sub1
    %44:vgpr_32 = GLOBAL_LOAD_UBYTE %43, 0, 0, implicit $exec :: (load (s8) from %ir.gep, addrspace 1)
    %45:vgpr_32 = GLOBAL_LOAD_UBYTE %43, 1, 0, implicit $exec :: (load (s8) from %ir.gep + 1, addrspace 1)
    %46:vgpr_32 = V_LSHL_OR_B32_e64 %45, 8, %44, implicit $exec
    %47:vgpr_32 = GLOBAL_LOAD_UBYTE %43, 2, 0, implicit $exec :: (load (s8) from %ir.gep + 2, addrspace 1)
    %48:vgpr_32 = GLOBAL_LOAD_UBYTE %43, 3, 0, implicit $exec :: (load (s8) from %ir.gep + 3, addrspace 1)
    %49:vgpr_32 = V_LSHL_OR_B32_e64 %48, 8, %47, implicit $exec
    %50:vgpr_32 = V_LSHL_OR_B32_e64 %49, 16, %46, implicit $exec
    %34:vgpr_32 = V_ADD_U32_e64 %35, %50, 0, implicit $exec
    %36:sreg_32 = S_ADD_I32 %35, 1, implicit-def dead $scc
    %51:sreg_32 = V_CMP_GE_U32_e64 %36, %0, implicit $exec
    %32:sreg_32 = SI_IF_BREAK %51, %31, implicit-def dead $scc
    SI_LOOP %32, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    SI_END_CF %32, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %52:vreg_64 = REG_SEQUENCE %23, %subreg.sub0, undef %53:vgpr_32, %subreg.sub1
    %54:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %16, %33, %52, 0, implicit $exec
    GLOBAL_STORE_DWORD %11, %54.sub0, 0, 0, implicit $exec :: (store (s32) into %ir.p5, addrspace 1)
    S_ENDPGM 0
...


