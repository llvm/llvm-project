# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s
--- |
  define amdgpu_ps void @test(ptr addrspace(1) %gep, ptr addrspace(1) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p5) {
  ret void
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9, $vgpr10
  
    %20:vgpr_32 = COPY $vgpr10
    %19:vgpr_32 = COPY $vgpr9
    %18:vgpr_32 = COPY $vgpr8
    %17:vgpr_32 = COPY $vgpr7
    %16:vgpr_32 = COPY $vgpr6
    %15:vgpr_32 = COPY $vgpr5
    %14:vgpr_32 = COPY $vgpr4
    %13:vgpr_32 = COPY $vgpr3
    %12:vgpr_32 = COPY $vgpr2
    %11:vgpr_32 = COPY $vgpr1
    %10:vgpr_32 = COPY $vgpr0
    %92:vreg_64 = REG_SEQUENCE %18, %subreg.sub0, %19, %subreg.sub1
    %91:vreg_64 = REG_SEQUENCE %10, %subreg.sub0, %11, %subreg.sub1
    %90:vreg_64 = REG_SEQUENCE %16, %subreg.sub0, %17, %subreg.sub1
    %89:vreg_64 = REG_SEQUENCE %14, %subreg.sub0, %15, %subreg.sub1
    %88:vreg_64 = REG_SEQUENCE %12, %subreg.sub0, %13, %subreg.sub1
    %0:vgpr_32 = GLOBAL_LOAD_DWORD %88, 0, 0, implicit $exec :: (load (s32) from %ir.p2, addrspace 1)
    %31:vgpr_32 = GLOBAL_LOAD_UBYTE %89, 0, 0, implicit $exec :: (load (s8) from %ir.p3, addrspace 1)
    %33:vgpr_32 = GLOBAL_LOAD_UBYTE %89, 1, 0, implicit $exec :: (load (s8) from %ir.p3 + 1, addrspace 1)
    %36:vgpr_32 = V_LSHL_OR_B32_e64 %33, 8, %31, implicit $exec
    %37:vgpr_32 = GLOBAL_LOAD_UBYTE %89, 2, 0, implicit $exec :: (load (s8) from %ir.p3 + 2, addrspace 1)
    %39:vgpr_32 = GLOBAL_LOAD_UBYTE %89, 3, 0, implicit $exec :: (load (s8) from %ir.p3 + 3, addrspace 1)
    %41:vgpr_32 = V_LSHL_OR_B32_e64 %39, 8, %37, implicit $exec
    %1:vgpr_32 = V_LSHL_OR_B32_e64 %41, 16, %36, implicit $exec
    %43:vgpr_32 = GLOBAL_LOAD_DWORD %90, 0, 0, implicit $exec :: (load (s32) from %ir.p4, addrspace 1)
    %45:vgpr_32 = V_ADD_U32_e64 %43, %20, 0, implicit $exec
    GLOBAL_STORE_DWORD %88, %45, 0, 0, implicit $exec :: (store (s32) into %ir.p2, addrspace 1)
    %47:vgpr_32 = V_MUL_LO_U32_e64 %43, %45, implicit $exec
    GLOBAL_STORE_DWORD %89, %47, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %49:vgpr_32 = V_SUB_U32_e64 %47, %45, 0, implicit $exec
    %50:vgpr_32 = V_MUL_LO_U32_e64 %49, %20, implicit $exec
    GLOBAL_STORE_DWORD %90, %50, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    %24:vgpr_32 = V_MOV_B32_e32 100, implicit $exec
    %23:sreg_32 = S_MOV_B32 0
  
  bb.1:
    successors: %bb.2(0x04000000), %bb.1(0x7c000000)
  
    %2:sreg_32 = PHI %23, %bb.0, %7, %bb.1
    %3:vgpr_32 = PHI %24, %bb.0, %5, %bb.1
    %4:sreg_32 = PHI %23, %bb.0, %6, %bb.1
    %52:sreg_32_xm0 = S_ASHR_I32 %4, 31, implicit-def dead $scc
    %54:sreg_64 = REG_SEQUENCE %4, %subreg.sub0, %52, %subreg.sub1
    %56:sreg_64 = nsw S_LSHL_B64 %54, 2, implicit-def dead $scc
    %93:vgpr_32, %95:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %91.sub0, %56.sub0, 0, implicit $exec
    %94:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %56.sub1, %91.sub1, %95, 0, implicit $exec
    %57:vreg_64 = REG_SEQUENCE %93, %subreg.sub0, %94, %subreg.sub1
    %58:vgpr_32 = GLOBAL_LOAD_UBYTE %57, 0, 0, implicit $exec :: (load (s8) from %ir.gep, addrspace 1)
    %59:vgpr_32 = GLOBAL_LOAD_UBYTE %57, 1, 0, implicit $exec :: (load (s8) from %ir.gep + 1, addrspace 1)
    %61:vgpr_32 = V_LSHL_OR_B32_e64 %59, 8, %58, implicit $exec
    %62:vgpr_32 = GLOBAL_LOAD_UBYTE %57, 2, 0, implicit $exec :: (load (s8) from %ir.gep + 2, addrspace 1)
    %63:vgpr_32 = GLOBAL_LOAD_UBYTE %57, 3, 0, implicit $exec :: (load (s8) from %ir.gep + 3, addrspace 1)
    %64:vgpr_32 = V_LSHL_OR_B32_e64 %63, 8, %62, implicit $exec
    %66:vgpr_32 = V_LSHL_OR_B32_e64 %64, 16, %61, implicit $exec
    %5:vgpr_32 = V_ADD_U32_e64 %4, %66, 0, implicit $exec
    %6:sreg_32 = S_ADD_I32 %4, 1, implicit-def dead $scc
    %68:sreg_32 = V_CMP_GE_U32_e64 %6, %20, implicit $exec
    %7:sreg_32 = SI_IF_BREAK %68, %2, implicit-def dead $scc
    SI_LOOP %7, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    SI_END_CF %7, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %86:vreg_64 = REG_SEQUENCE %1, %subreg.sub0, undef %87:vgpr_32, %subreg.sub1
    %72:vreg_64, $sgpr_null = V_MAD_U64_U32_e64 %0, %3, %86, 0, implicit $exec
    GLOBAL_STORE_DWORD %92, %72.sub0, 0, 0, implicit $exec :: (store (s32) into %ir.p5, addrspace 1)
    S_ENDPGM 0
...

