# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-ML-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-analysis \
# RUN:     -amdgpu-next-use-analysis-compatibility-mode=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=%t.json \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s && FileCheck --input-file=%t.json --check-prefix=CHECK-GX-JSON %s
--- |
  define amdgpu_ps i32 @test(ptr addrspace(1) %gep1, ptr addrspace(1) %gep2, ptr addrspace(1) %p1, ptr addrspace(1) %p3, ptr addrspace(1) %p4) {
  ret i32 0
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9
  
    %42:vgpr_32 = COPY $vgpr9
    %41:vgpr_32 = COPY $vgpr8
    %40:vgpr_32 = COPY $vgpr7
    %39:vgpr_32 = COPY $vgpr6
    %38:vgpr_32 = COPY $vgpr5
    %37:vgpr_32 = COPY $vgpr4
    %36:vgpr_32 = COPY $vgpr3
    %35:vgpr_32 = COPY $vgpr2
    %34:vgpr_32 = COPY $vgpr1
    %33:vgpr_32 = COPY $vgpr0
    %107:vreg_64 = REG_SEQUENCE %37, %subreg.sub0, %38, %subreg.sub1
    %106:vreg_64 = REG_SEQUENCE %35, %subreg.sub0, %36, %subreg.sub1
    %105:vreg_64 = REG_SEQUENCE %33, %subreg.sub0, %34, %subreg.sub1
    %104:vreg_64 = REG_SEQUENCE %39, %subreg.sub0, %40, %subreg.sub1
    %53:vgpr_32 = GLOBAL_LOAD_USHORT %104, 0, 0, implicit $exec :: (load (s16) from %ir.p4, addrspace 1)
    %55:vgpr_32 = GLOBAL_LOAD_USHORT %104, 2, 0, implicit $exec :: (load (s16) from %ir.p4 + 2, addrspace 1)
    %0:vgpr_32 = V_LSHL_OR_B32_e64 %55, 16, %53, implicit $exec
    %58:vgpr_32 = GLOBAL_LOAD_UBYTE %105, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %60:vgpr_32 = GLOBAL_LOAD_UBYTE %105, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %63:vgpr_32 = V_LSHL_OR_B32_e64 %60, 8, %58, implicit $exec
    %64:vgpr_32 = GLOBAL_LOAD_UBYTE %105, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %66:vgpr_32 = GLOBAL_LOAD_UBYTE %105, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %68:vgpr_32 = V_LSHL_OR_B32_e64 %66, 8, %64, implicit $exec
    %1:vgpr_32 = V_LSHL_OR_B32_e64 %68, 16, %63, implicit $exec
    %48:vgpr_32 = V_MOV_B32_e32 100, implicit $exec
    %2:vgpr_32 = V_ADD_U32_e64 100, %1, 0, implicit $exec
    GLOBAL_STORE_DWORD %104, %2, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    %47:sreg_32 = S_MOV_B32 1
    %46:sreg_32 = S_MOV_B32 0
  
  bb.1:
    successors: %bb.2(0x04000000), %bb.1(0x7c000000)
  
    %3:sreg_32 = PHI %46, %bb.0, %15, %bb.1
    %4:sreg_32 = PHI %46, %bb.0, %13, %bb.1
    %5:sreg_32 = PHI %47, %bb.0, %12, %bb.1
    %6:vgpr_32 = PHI %1, %bb.0, %10, %bb.1
    %7:vgpr_32 = PHI %48, %bb.0, %11, %bb.1
    %8:vgpr_32 = PHI %1, %bb.0, %14, %bb.1
    %71:sreg_32 = S_ADD_I32 %5, -1, implicit-def dead $scc
    %72:sreg_32_xm0 = S_ASHR_I32 %71, 31, implicit-def dead $scc
    %74:sreg_64 = REG_SEQUENCE %71, %subreg.sub0, %72, %subreg.sub1
    %76:sreg_64 = nsw S_LSHL_B64 %74, 2, implicit-def dead $scc
    %109:vgpr_32, %111:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %106.sub0, %76.sub0, 0, implicit $exec
    %110:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %76.sub1, %106.sub1, %111, 0, implicit $exec
    %77:vreg_64 = REG_SEQUENCE %109, %subreg.sub0, %110, %subreg.sub1
    %9:vgpr_32 = GLOBAL_LOAD_DWORD %77, 0, 0, implicit $exec :: (load (s32) from %ir.gep1, addrspace 1)
    %10:vgpr_32 = V_ADD_U32_e64 %5, %9, 0, implicit $exec
    %11:vgpr_32 = V_MUL_LO_U32_e64 %9, %5, implicit $exec
    GLOBAL_STORE_SHORT_D16_HI %105, %11, 2, 0, implicit $exec :: (store (s16) into %ir.p1 + 2, addrspace 1)
    GLOBAL_STORE_SHORT %105, %11, 0, 0, implicit $exec :: (store (s16) into %ir.p1, addrspace 1)
    %117:vgpr_32, %119:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %107.sub0, %76.sub0, 0, implicit $exec
    %118:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %76.sub1, %107.sub1, %119, 0, implicit $exec
    %78:vreg_64 = REG_SEQUENCE %117, %subreg.sub0, %118, %subreg.sub1
    %79:vgpr_32 = GLOBAL_LOAD_USHORT %78, 0, 0, implicit $exec :: (load (s16) from %ir.gep2, addrspace 1)
    %80:vgpr_32 = GLOBAL_LOAD_USHORT %78, 2, 0, implicit $exec :: (load (s16) from %ir.gep2 + 2, addrspace 1)
    %82:vgpr_32 = V_LSHL_OR_B32_e64 %80, 16, %79, implicit $exec
    %12:sreg_32 = S_ADD_I32 %5, 1, implicit-def dead $scc
    %13:sreg_32 = S_ADD_I32 %4, -1, implicit-def dead $scc
    %14:vgpr_32 = V_ADD_U32_e64 %4, %82, 0, implicit $exec
    %84:sreg_32 = V_CMP_GE_U32_e64 %5, %41, implicit $exec
    %15:sreg_32 = SI_IF_BREAK %84, %3, implicit-def dead $scc
    %108:vgpr_32 = COPY %12, implicit $exec
    SI_LOOP %15, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    successors: %bb.3(0x80000000)
  
    SI_END_CF %15, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %87:vgpr_32 = V_ADD_U32_e64 -2, %108, 0, implicit $exec
    %23:vgpr_32 = V_MUL_LO_U32_e64 %11, %87, implicit $exec
    %24:vgpr_32 = V_MUL_LO_U32_e64 100, %6, implicit $exec
    %89:vgpr_32 = V_MUL_LO_U32_e64 %24, %0, implicit $exec
    GLOBAL_STORE_DWORD %107, %89, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %85:sreg_32 = S_MOV_B32 0
  
  bb.3:
    successors: %bb.4(0x04000000), %bb.3(0x7c000000)
  
    %25:sreg_32 = PHI %85, %bb.2, %29, %bb.3
    %26:vgpr_32 = PHI %0, %bb.2, %28, %bb.3
    %27:vgpr_32 = PHI %8, %bb.2, %23, %bb.3
    %28:vgpr_32 = V_ADD_U32_e64 2, %26, 0, implicit $exec
    %91:sreg_32 = V_CMP_GE_U32_e64 %28, %42, implicit $exec
    %29:sreg_32 = SI_IF_BREAK %91, %25, implicit-def dead $scc
    SI_LOOP %29, %bb.3, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.4:
    SI_END_CF %29, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    GLOBAL_STORE_DWORD %107, %27, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %92:vgpr_32 = V_ADD_U32_e64 %27, %28, 0, implicit $exec
    %93:vgpr_32 = V_ADD3_U32_e64 %92, %7, %24, implicit $exec
    %94:vgpr_32 = V_ADD3_U32_e64 %93, %9, %2, implicit $exec
    %95:sreg_32_xm0 = V_READFIRSTLANE_B32 %94, implicit $exec
    $sgpr0 = COPY %95
    SI_RETURN_TO_EPILOG killed $sgpr0
...

