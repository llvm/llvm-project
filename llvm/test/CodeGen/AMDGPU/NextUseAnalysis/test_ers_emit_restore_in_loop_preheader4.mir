# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

--- |
  define amdgpu_ps i32 @test(ptr addrspace(1) %gep1, ptr addrspace(1) %gep2, ptr addrspace(1) %p1, ptr addrspace(1) %p3, ptr addrspace(1) %p4) {
  ret i32 0
  }
...
---
name:            test
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.1(0x80000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4, $vgpr5, $vgpr6, $vgpr7, $vgpr8, $vgpr9
  
    %0:vgpr_32 = COPY $vgpr9
    %1:vgpr_32 = COPY $vgpr8
    %2:vgpr_32 = COPY $vgpr7
    %3:vgpr_32 = COPY $vgpr6
    %4:vgpr_32 = COPY $vgpr5
    %5:vgpr_32 = COPY $vgpr4
    %6:vgpr_32 = COPY $vgpr3
    %7:vgpr_32 = COPY $vgpr2
    %8:vgpr_32 = COPY $vgpr1
    %9:vgpr_32 = COPY $vgpr0
    %10:vreg_64 = REG_SEQUENCE %5, %subreg.sub0, %4, %subreg.sub1
    %11:vreg_64 = REG_SEQUENCE %7, %subreg.sub0, %6, %subreg.sub1
    %12:vreg_64 = REG_SEQUENCE %9, %subreg.sub0, %8, %subreg.sub1
    %13:vreg_64 = REG_SEQUENCE %3, %subreg.sub0, %2, %subreg.sub1
    %14:vgpr_32 = GLOBAL_LOAD_USHORT %13, 0, 0, implicit $exec :: (load (s16) from %ir.p4, addrspace 1)
    %15:vgpr_32 = GLOBAL_LOAD_USHORT %13, 2, 0, implicit $exec :: (load (s16) from %ir.p4 + 2, addrspace 1)
    %16:vgpr_32 = V_LSHL_OR_B32_e64 %15, 16, %14, implicit $exec
    %17:vgpr_32 = GLOBAL_LOAD_UBYTE %12, 0, 0, implicit $exec :: (load (s8) from %ir.p1, addrspace 1)
    %18:vgpr_32 = GLOBAL_LOAD_UBYTE %12, 1, 0, implicit $exec :: (load (s8) from %ir.p1 + 1, addrspace 1)
    %19:vgpr_32 = V_LSHL_OR_B32_e64 %18, 8, %17, implicit $exec
    %20:vgpr_32 = GLOBAL_LOAD_UBYTE %12, 2, 0, implicit $exec :: (load (s8) from %ir.p1 + 2, addrspace 1)
    %21:vgpr_32 = GLOBAL_LOAD_UBYTE %12, 3, 0, implicit $exec :: (load (s8) from %ir.p1 + 3, addrspace 1)
    %22:vgpr_32 = V_LSHL_OR_B32_e64 %21, 8, %20, implicit $exec
    %23:vgpr_32 = V_LSHL_OR_B32_e64 %22, 16, %19, implicit $exec
    %24:vgpr_32 = V_MOV_B32_e32 100, implicit $exec
    %25:vgpr_32 = V_ADD_U32_e64 100, %23, 0, implicit $exec
    GLOBAL_STORE_DWORD %13, %25, 0, 0, implicit $exec :: (store (s32) into %ir.p4, addrspace 1)
    %26:sreg_32 = S_MOV_B32 1
    %27:sreg_32 = S_MOV_B32 0
  
  bb.1:
    successors: %bb.2(0x04000000), %bb.1(0x7c000000)
  
    %28:sreg_32 = PHI %27, %bb.0, %29, %bb.1
    %30:sreg_32 = PHI %27, %bb.0, %31, %bb.1
    %32:sreg_32 = PHI %26, %bb.0, %33, %bb.1
    %34:vgpr_32 = PHI %23, %bb.0, %35, %bb.1
    %36:vgpr_32 = PHI %24, %bb.0, %37, %bb.1
    %38:vgpr_32 = PHI %23, %bb.0, %39, %bb.1
    %40:sreg_32 = S_ADD_I32 %32, -1, implicit-def dead $scc
    %41:sreg_32_xm0 = S_ASHR_I32 %40, 31, implicit-def dead $scc
    %42:sreg_64 = REG_SEQUENCE %40, %subreg.sub0, %41, %subreg.sub1
    %43:sreg_64 = nsw S_LSHL_B64 %42, 2, implicit-def dead $scc
    %44:vgpr_32, %45:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %11.sub0, %43.sub0, 0, implicit $exec
    %46:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %43.sub1, %11.sub1, %45, 0, implicit $exec
    %47:vreg_64 = REG_SEQUENCE %44, %subreg.sub0, %46, %subreg.sub1
    %48:vgpr_32 = GLOBAL_LOAD_DWORD %47, 0, 0, implicit $exec :: (load (s32) from %ir.gep1, addrspace 1)
    %35:vgpr_32 = V_ADD_U32_e64 %32, %48, 0, implicit $exec
    %37:vgpr_32 = V_MUL_LO_U32_e64 %48, %32, implicit $exec
    GLOBAL_STORE_SHORT_D16_HI %12, %37, 2, 0, implicit $exec :: (store (s16) into %ir.p1 + 2, addrspace 1)
    GLOBAL_STORE_SHORT %12, %37, 0, 0, implicit $exec :: (store (s16) into %ir.p1, addrspace 1)
    %49:vgpr_32, %50:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %10.sub0, %43.sub0, 0, implicit $exec
    %51:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %43.sub1, %10.sub1, %50, 0, implicit $exec
    %52:vreg_64 = REG_SEQUENCE %49, %subreg.sub0, %51, %subreg.sub1
    %53:vgpr_32 = GLOBAL_LOAD_USHORT %52, 0, 0, implicit $exec :: (load (s16) from %ir.gep2, addrspace 1)
    %54:vgpr_32 = GLOBAL_LOAD_USHORT %52, 2, 0, implicit $exec :: (load (s16) from %ir.gep2 + 2, addrspace 1)
    %55:vgpr_32 = V_LSHL_OR_B32_e64 %54, 16, %53, implicit $exec
    %33:sreg_32 = S_ADD_I32 %32, 1, implicit-def dead $scc
    %31:sreg_32 = S_ADD_I32 %30, -1, implicit-def dead $scc
    %39:vgpr_32 = V_ADD_U32_e64 %30, %55, 0, implicit $exec
    %56:sreg_32 = V_CMP_GE_U32_e64 %32, %1, implicit $exec
    %29:sreg_32 = SI_IF_BREAK %56, %28, implicit-def dead $scc
    %57:vgpr_32 = COPY %33, implicit $exec
    SI_LOOP %29, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    successors: %bb.3(0x80000000)
  
    SI_END_CF %29, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %58:vgpr_32 = V_ADD_U32_e64 -2, %57, 0, implicit $exec
    %59:vgpr_32 = V_MUL_LO_U32_e64 %37, %58, implicit $exec
    %60:vgpr_32 = V_MUL_LO_U32_e64 100, %34, implicit $exec
    %61:vgpr_32 = V_MUL_LO_U32_e64 %60, %16, implicit $exec
    GLOBAL_STORE_DWORD %10, %61, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %62:sreg_32 = S_MOV_B32 0
  
  bb.3:
    successors: %bb.4(0x04000000), %bb.3(0x7c000000)
  
    %63:sreg_32 = PHI %62, %bb.2, %64, %bb.3
    %65:vgpr_32 = PHI %16, %bb.2, %66, %bb.3
    %67:vgpr_32 = PHI %38, %bb.2, %59, %bb.3
    %66:vgpr_32 = V_ADD_U32_e64 2, %65, 0, implicit $exec
    %68:sreg_32 = V_CMP_GE_U32_e64 %66, %0, implicit $exec
    %64:sreg_32 = SI_IF_BREAK %68, %63, implicit-def dead $scc
    SI_LOOP %64, %bb.3, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.4
  
  bb.4:
    SI_END_CF %64, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    GLOBAL_STORE_DWORD %10, %67, 0, 0, implicit $exec :: (store (s32) into %ir.p3, addrspace 1)
    %69:vgpr_32 = V_ADD_U32_e64 %67, %66, 0, implicit $exec
    %70:vgpr_32 = V_ADD3_U32_e64 %69, %36, %60, implicit $exec
    %71:vgpr_32 = V_ADD3_U32_e64 %70, %48, %25, implicit $exec
    %72:sreg_32_xm0 = V_READFIRSTLANE_B32 %71, implicit $exec
    $sgpr0 = COPY %72
    SI_RETURN_TO_EPILOG killed $sgpr0
...


