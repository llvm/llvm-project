# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=graphics \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-GX-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     -run-pass=amdgpu-next-use-printer \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

# RUN: llc -mtriple=amdgcn -mcpu=gfx1200 \
# RUN:     "-passes=require<amdgpu-next-use-analysis>,print<amdgpu-next-use-analysis>" \
# RUN:     -amdgpu-next-use-analysis-config=compute \
# RUN:     -amdgpu-next-use-analysis-dump-distance-as-json=- \
# RUN:     -amdgpu-next-use-analysis-dump-distance-verbose \
# RUN:     -filetype=null \
# RUN:     %s | FileCheck --check-prefix=CHECK-CP-JSON %s

---
name:            test1
tracksRegLiveness: true
body:             |
  bb.0:
    successors: %bb.3(0x40000000), %bb.1(0x40000000)
    liveins: $vgpr0, $vgpr1, $vgpr2, $vgpr3, $vgpr4
  
    %0:vgpr_32 = COPY $vgpr4
    %1:vgpr_32 = COPY $vgpr3
    %2:vgpr_32 = COPY $vgpr2
    %3:vgpr_32 = COPY $vgpr1
    %4:vgpr_32 = COPY $vgpr0
    %5:vgpr_32 = V_AND_B32_e64 1, %2, implicit $exec
    %6:sreg_32 = V_CMP_NE_U32_e64 1, %5, implicit $exec
    %7:sreg_32 = SI_IF %6, %bb.1, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.3
  
  bb.1:
    successors: %bb.2(0x40000000), %bb.4(0x40000000)
  
    %8:vreg_64 = PHI undef %9:vreg_64, %bb.0, %10, %bb.3
    %11:vgpr_32 = PHI %4, %bb.0, undef %12:vgpr_32, %bb.3
    %13:sreg_32 = SI_ELSE %7, %bb.4, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    S_BRANCH %bb.2
  
  bb.2:
    successors: %bb.4(0x80000000)
  
    %14:vgpr_32 = DS_READ_U8_gfx9 %11, 0, 0, implicit $exec
    %15:vgpr_32 = DS_READ_U8_gfx9 %11, 1, 0, implicit $exec
    %16:vgpr_32 = DS_READ_U8_gfx9 %11, 2, 0, implicit $exec
    %17:vgpr_32 = DS_READ_U8_gfx9 %11, 3, 0, implicit $exec
    %18:vgpr_32 = DS_READ_U8_gfx9 %11, 4, 0, implicit $exec
    %19:vgpr_32 = DS_READ_U8_gfx9 %11, 5, 0, implicit $exec
    %20:vgpr_32 = DS_READ_U8_gfx9 %11, 6, 0, implicit $exec
    %21:vgpr_32 = DS_READ_U8_gfx9 %11, 7, 0, implicit $exec
    %22:vgpr_32 = V_LSHL_OR_B32_e64 %19, 8, %18, implicit $exec
    %23:vgpr_32 = V_LSHL_OR_B32_e64 %21, 8, %20, implicit $exec
    %24:vgpr_32 = V_LSHL_OR_B32_e64 %23, 16, %22, implicit $exec
    %25:vgpr_32 = V_LSHL_OR_B32_e64 %15, 8, %14, implicit $exec
    %26:vgpr_32 = V_LSHL_OR_B32_e64 %17, 8, %16, implicit $exec
    %27:vgpr_32 = V_LSHL_OR_B32_e64 %26, 16, %25, implicit $exec
    %28:vreg_64 = REG_SEQUENCE %27, %subreg.sub0, %24, %subreg.sub1
    %29:vreg_64 = COPY %28
    S_BRANCH %bb.4
  
  bb.3:
    successors: %bb.1(0x80000000)
  
    %30:vgpr_32 = DS_READ_U8_gfx9 %3, 0, 0, implicit $exec
    %31:vgpr_32 = DS_READ_U8_gfx9 %3, 1, 0, implicit $exec
    %32:vgpr_32 = DS_READ_U8_gfx9 %3, 2, 0, implicit $exec
    %33:vgpr_32 = DS_READ_U8_gfx9 %3, 3, 0, implicit $exec
    %34:vgpr_32 = DS_READ_U8_gfx9 %3, 4, 0, implicit $exec
    %35:vgpr_32 = DS_READ_U8_gfx9 %3, 5, 0, implicit $exec
    %36:vgpr_32 = DS_READ_U8_gfx9 %3, 6, 0, implicit $exec
    %37:vgpr_32 = DS_READ_U8_gfx9 %3, 7, 0, implicit $exec
    %38:vgpr_32 = V_LSHL_OR_B32_e64 %35, 8, %34, implicit $exec
    %39:vgpr_32 = V_LSHL_OR_B32_e64 %37, 8, %36, implicit $exec
    %40:vgpr_32 = V_LSHL_OR_B32_e64 %39, 16, %38, implicit $exec
    %41:vgpr_32 = V_LSHL_OR_B32_e64 %31, 8, %30, implicit $exec
    %42:vgpr_32 = V_LSHL_OR_B32_e64 %33, 8, %32, implicit $exec
    %43:vgpr_32 = V_LSHL_OR_B32_e64 %42, 16, %41, implicit $exec
    %44:vreg_64 = REG_SEQUENCE %43, %subreg.sub0, %40, %subreg.sub1
    %10:vreg_64 = COPY %44
    S_BRANCH %bb.1
  
  bb.4:
    %45:vreg_64 = PHI %8, %bb.1, %29, %bb.2
    SI_END_CF %13, implicit-def dead $exec, implicit-def dead $scc, implicit $exec
    %46:vgpr_32, %47:sreg_32_xm0_xexec = V_ADD_CO_U32_e64 %45.sub0, %1, 0, implicit $exec
    %48:vgpr_32, dead $sgpr_null = V_ADDC_U32_e64 %45.sub1, %0, %47, 0, implicit $exec
    %49:sreg_32_xm0 = V_READFIRSTLANE_B32 %46, implicit $exec
    %50:sreg_32_xm0 = V_READFIRSTLANE_B32 %48, implicit $exec
    $sgpr0 = COPY %49
    $sgpr1 = COPY %50
    SI_RETURN_TO_EPILOG killed $sgpr0, killed $sgpr1
...


