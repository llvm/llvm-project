  @array7 = global [5 x i32] zeroinitializer, align 4
  @array8 = global [5 x i32] zeroinitializer, align 4
  @array9 = global [5 x i32] zeroinitializer, align 4
  
  define amdgpu_ps void @test(ptr addrspace(1) %arrayidx1, ptr addrspace(1) %arrayidx11, ptr addrspace(1) %arrayidx1111, ptr addrspace(1) %arrayidx2, ptr addrspace(1) %arrayidx3, ptr addrspace(1) %arrayidx33, ptr addrspace(1) %arrayidx444, ptr addrspace(1) %arrayidx5, ptr addrspace(1) %gep1, ptr addrspace(1) %gep2, ptr addrspace(1) %gep3, ptr addrspace(1) %gep4, ptr addrspace(1) %p1, ptr addrspace(3) %p2, ptr addrspace(1) %p3, ptr addrspace(1) %p4, ptr addrspace(1) %p6, ptr addrspace(1) %p7) {
  ret void
  }
...
