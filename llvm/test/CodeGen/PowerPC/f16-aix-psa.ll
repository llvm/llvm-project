; P9-AIX-64-NEXT:    std 10, 104(1)
; P9-AIX-64-NEXT:    std 3, -8(1)
; P9-AIX-64-NEXT:    addi 3, 1, 56
; P9-AIX-64-NEXT:    lxsihzx 1, 0, 3
