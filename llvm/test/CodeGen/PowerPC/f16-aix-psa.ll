; P9-AIX-64:       # %bb.0: # %entry
; P9-AIX-64-NEXT:    addi 3, 1, 58
; P9-AIX-64-NEXT:    std 4, 56(1)
; P9-AIX-64-NEXT:    std 5, 64(1)
; P9-AIX-64-NEXT:    std 6, 72(1)
; P9-AIX-64-NEXT:    std 7, 80(1)
; P9-AIX-64-NEXT:    std 8, 88(1)
