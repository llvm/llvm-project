; CHECK-NEXT:    addi 3, 3, .LCPI0_0@toc@l
; CHECK-NEXT:    xvcvsxwsp 2, 35
; CHECK-NEXT:    lxvd2x 1, 0, 3
; CHECK-NEXT:    xxspltw 0, 0, 0
; CHECK-NEXT:    xvdivsp 0, 2, 0
