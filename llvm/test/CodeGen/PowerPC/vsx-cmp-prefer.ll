; NOTE: Assertions have been autogenerated by utils/update_llc_test_checks.py
; RUN: llc -verify-machineinstrs -mtriple=powerpc64le-unknown-linux-gnu \
; RUN:   -mcpu=pwr8 < %s | FileCheck %s

; Test that VSX scalar compare instructions are preferred over FPU compares
; when register pressure forces use of VSX registers (VSR32-VSR63).

define signext i32 @test_f64_lt(double %a, double %b) {
; CHECK-LABEL: test_f64_lt:
; CHECK:       # %bb.0:
; CHECK:       #APP
; CHECK:       #NO_APP
; CHECK:       xscmpudp
; CHECK-NOT:   fcmpu
; CHECK:       blr
entry:
  ; Clobber all 32 FP registers to force use of VSX registers
  call void asm sideeffect "", "~{f0},~{f1},~{f2},~{f3},~{f4},~{f5},~{f6},~{f7},~{f8},~{f9},~{f10},~{f11},~{f12},~{f13},~{f14},~{f15},~{f16},~{f17},~{f18},~{f19},~{f20},~{f21},~{f22},~{f23},~{f24},~{f25},~{f26},~{f27},~{f28},~{f29},~{f30},~{f31}"() nounwind
  %cmp = fcmp olt double %a, %b
  %cond = select i1 %cmp, i32 17, i32 97
  ret i32 %cond
}
