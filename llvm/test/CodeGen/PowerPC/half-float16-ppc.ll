; P8-AIX-32-NEXT:    stfd 29, 56(1) # 8-byte Folded Spill
; P8-AIX-32-NEXT:    stfd 31, 72(1) # 8-byte Folded Spill
; P8-AIX-32-NEXT:    fmr 31, 3
; P8-AIX-32-NEXT:    bl .__extendhfsf2[PR]
; P8-AIX-32-NEXT:    nop
