; P8-AIX-32-NEXT:    fmr 1, 30
; P8-AIX-32-NEXT:    bl .__extendhfsf2[PR]
; P8-AIX-32-NEXT:    nop
; P8-AIX-32-NEXT:    xsaddsp 1, 1, 29
; P8-AIX-32-NEXT:    bl .__truncsfhf2[PR]
; P8-AIX-32-NEXT:    nop
