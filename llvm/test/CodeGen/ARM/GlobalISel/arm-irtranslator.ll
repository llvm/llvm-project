define void @test_load_store_struct(ptr %addr) {
; Make sure the IRTranslator doesn't use an unnecessarily large GEP index type
; when breaking up loads and stores of aggregates.
  ; CHECK-LABEL: name: test_load_store_struct
  ; CHECK: bb.1 (%ir-block.0):
  ; CHECK-NEXT:   liveins: $r0
  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT:   [[COPY:%[0-9]+]]:_(p0) = COPY $r0
  ; CHECK-NEXT:   [[LOAD:%[0-9]+]]:_(i32) = G_LOAD [[COPY]](p0) :: (load (i32) from %ir.addr)
  ; CHECK-NEXT:   [[C:%[0-9]+]]:_(i32) = G_CONSTANT i32 4
  ; CHECK-NEXT:   [[PTR_ADD:%[0-9]+]]:_(p0) = nuw inbounds G_PTR_ADD [[COPY]], [[C]](i32)
  ; CHECK-NEXT:   [[LOAD1:%[0-9]+]]:_(i32) = G_LOAD [[PTR_ADD]](p0) :: (load (i32) from %ir.addr + 4)
  ; CHECK-NEXT:   G_STORE [[LOAD]](i32), [[COPY]](p0) :: (store (i32) into %ir.addr)
  ; CHECK-NEXT:   [[COPY1:%[0-9]+]]:_(p0) = COPY [[PTR_ADD]](p0)
  ; CHECK-NEXT:   G_STORE [[LOAD1]](i32), [[COPY1]](p0) :: (store (i32) into %ir.addr + 4)
  ; CHECK-NEXT:   BX_RET 14 /* CC::al */, $noreg
  %val = load {i32, i32}, ptr %addr, align 4
  store {i32, i32} %val, ptr %addr, align 4
  ret void
}
