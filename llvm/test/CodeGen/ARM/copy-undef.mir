# RUN: llc -o - %s -mtriple=armv7-- -run-pass=register-coalescer | FileCheck %s

# Make sure we don't crash on this input

---
---
name: copy_undef_propogate
tracksRegLiveness: true
body:             |
  bb.0.entry:
    liveins: $r0
  
    %4:gpr = COPY killed $r0
    %7:dpr = VSETLNi32 undef %7, killed %4, 0, 14 /* CC::al */, $noreg
    undef %9.dsub_0:qpr = COPY undef %10:dpr
    %9.dsub_1:qpr = COPY killed %7
    %12:dpr = COPY %9.dsub_0
...
