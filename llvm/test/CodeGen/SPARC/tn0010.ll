; RUN: llc < %s -mtriple=sparc -mattr=fix-tn0010 | FileCheck %s

define i32 @empty_bb() {
; CHECK-LABEL: empty_bb:
; CHECK:         .cfi_startproc
; CHECK-NEXT:  ! %bb.0:
  unreachable
}

define i32 @simulator_kernel() {
; CHECK-LABEL: simulator_kernel:
; CHECK:         .cfi_startproc
; CHECK-NEXT:  ! %bb.0: ! %entry
; CHECK-NEXT:    jmp %g0
; CHECK-NEXT:    ld [%g0], %o0
; CHECK-NEXT:  .LBB1_1: ! %dispatch
; CHECK-NEXT:    ! =>This Inner Loop Header: Depth=1
; CHECK-NEXT:    jmp %g0
; CHECK-NEXT:    nop
; CHECK-NEXT:  .LBB1_2: ! %store_block
; CHECK-NEXT:    ! =>This Inner Loop Header: Depth=1
; CHECK-NEXT:    jmp %g0
; CHECK-NEXT:    st %o0, [%g0]
entry:
  %v = load i32, ptr null, align 4
  br label %dispatch

dispatch:
  br label %indirectgoto

store_block:
  store i32 %v, ptr null, align 4
  br label %indirectgoto

indirectgoto:
  indirectbr ptr null, [label %dispatch, label %store_block]
}
