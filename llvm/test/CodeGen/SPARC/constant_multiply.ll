; Non-constant multiply should still use the libcall.
define i32 @mul_variable(i32 %a, i32 %b) nounwind {
; CHECK-LABEL: mul_variable:
; CHECK:       ! %bb.0:
; CHECK-NEXT:    save %sp, -96, %sp
; CHECK-NEXT:    mov %i1, %o1
; CHECK-NEXT:    call .umul
; CHECK-NEXT:    mov %i0, %o0
; CHECK-NEXT:    ret
; CHECK-NEXT:    restore %g0, %o0, %o0
  %1 = mul i32 %a, %b
  ret i32 %1
}
