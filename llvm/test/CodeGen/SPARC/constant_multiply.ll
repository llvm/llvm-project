; RUN: llc -mtriple=sparc -mattr=+soft-mul-div < %s | FileCheck %s

; Test mul-by-constant expansion for SparcV7 (no hardware multiply).

define i32 @mul_by_3(i32 %a) nounwind {
; CHECK-LABEL: mul_by_3:
; CHECK:       ! %bb.0:
; CHECK-NEXT:    sll %o0, 1, %o1
; CHECK-NEXT:    retl
; CHECK-NEXT:    add %o1, %o0, %o0
  %1 = mul i32 %a, 3
  ret i32 %1
}

