; CHECK-LABEL: test_load_cache_hint_with_l2_eviction(
; CHECK:    mov.b64 %rd2, 12345;
; CHECK:    ld.global.L2::evict_last.L2::cache_hint.b32 %r1, [%rd1], %rd2;
  %v = load i32, ptr addrspace(1) %p, !mem.cache_hint !17
  ret i32 %v
}

