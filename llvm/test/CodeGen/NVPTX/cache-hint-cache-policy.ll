; CHECK:    mov.b64 %rd2, 12345;
; CHECK:    ld.global.L1::evict_first.L2::cache_hint.b32 %r1, [%rd1], %rd2;
  %v = load i32, ptr addrspace(1) %p, !mem.cache_hint !16
  ret i32 %v
}

; L2::cache_hint + L2 eviction: both qualifiers should be emitted
