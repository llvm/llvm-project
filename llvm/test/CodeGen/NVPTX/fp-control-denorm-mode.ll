; Verify that denorm.in=zero/denorm.out=zero bundle operands emit .ftz on
; f16/f32 ops and that f64 is unaffected.

target triple = "nvptx64-nvidia-cuda"

declare float @llvm.fadd.f32(float, float)
declare double @llvm.fadd.f64(double, double)
declare half @llvm.fadd.f16(half, half)
declare float @llvm.fsub.f32(float, float)
declare half @llvm.fsub.f16(half, half)
declare float @llvm.fmul.f32(float, float)
declare half @llvm.fmul.f16(half, half)
declare float @llvm.fma.f32(float, float, float)
declare half @llvm.fma.f16(half, half, half)
declare float @llvm.sqrt.f32(float)
declare float @llvm.fabs.f32(float)
declare half @llvm.fabs.f16(half)
declare float @llvm.fpext.f32.f16(half)

; ---- fadd f32: no bundle, ftz bundle ----

define float @fadd_f32_no_bundle(float %a, float %b) {
; CHECK-LABEL: fadd_f32_no_bundle(
; CHECK:       {
; CHECK-NEXT:    .reg .b32 %r<4>;
; CHECK-EMPTY:
; CHECK-NEXT:  // %bb.0:
; CHECK-NEXT:    ld.param.b32 %r1, [fadd_f32_no_bundle_param_0];
; CHECK-NEXT:    ld.param.b32 %r2, [fadd_f32_no_bundle_param_1];
; CHECK-NEXT:    add.rn.f32 %r3, %r1, %r2;
; CHECK-NEXT:    st.param.b32 [func_retval0], %r3;
; CHECK-NEXT:    ret;
  %r = call float @llvm.fadd.f32(float %a, float %b)
  ret float %r
}

define float @fadd_f32_ftz(float %a, float %b) {
; CHECK-LABEL: fadd_f32_ftz(
; CHECK:       {
; CHECK-NEXT:    .reg .b32 %r<4>;
; CHECK-EMPTY:
; CHECK-NEXT:  // %bb.0:
; CHECK-NEXT:    ld.param.b32 %r1, [fadd_f32_ftz_param_0];
; CHECK-NEXT:    ld.param.b32 %r2, [fadd_f32_ftz_param_1];
; CHECK-NEXT:    add.rn.ftz.f32 %r3, %r1, %r2;
; CHECK-NEXT:    st.param.b32 [func_retval0], %r3;
; CHECK-NEXT:    ret;
  %r = call float @llvm.fadd.f32(float %a, float %b)
       [ "fp.control"(metadata !"denorm.in=zero", metadata !"denorm.out=zero") ]
