; ---- fpext f16->f32: partial and full denorm bundles ----
; For type-converting instructions (fpext), the widening cvt uses OR logic:
; either denorm.in=zero or denorm.out=zero alone is sufficient to emit .ftz,
; because -denormal-fp-math-f32=preserve-sign only sets the F32-specific flag
; (affecting the output side) and must still produce cvt.ftz.f32.f16.

define float @fpext_f16_to_f32_denorm_in_only(half %a) {
; CHECK-LABEL: fpext_f16_to_f32_denorm_in_only(
; CHECK:       {
; CHECK-NEXT:    .reg .b16 %rs<2>;
; CHECK-NEXT:    .reg .b32 %r<2>;
; CHECK-EMPTY:
; CHECK-NEXT:  // %bb.0:
; CHECK-NEXT:    ld.param.b16 %rs1, [fpext_f16_to_f32_denorm_in_only_param_0];
; CHECK-NEXT:    cvt.ftz.f32.f16 %r1, %rs1;
; CHECK-NEXT:    st.param.b32 [func_retval0], %r1;
; CHECK-NEXT:    ret;
  %r = call float @llvm.fpext.f32.f16(half %a)
       [ "fp.control"(metadata !"denorm.in=zero") ]
