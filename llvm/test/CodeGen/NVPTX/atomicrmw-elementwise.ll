define <2 x float> @fadd_v2f32_elementwise(ptr %addr, <2 x float> %val) {
; CHECK-LABEL: fadd_v2f32_elementwise(
; CHECK:       {
; CHECK-NEXT:    .reg .b32 %r<5>;
