  ; CHECK-NEXT: {{  $}}
  ; CHECK-NEXT: bb.4:
  ; CHECK-NEXT:   Return
  bb.0:
    successors: %bb.1, %bb.4

    %0:b32 = IMPLICIT_DEF
    %1:b32 = IMPLICIT_DEF
    %2:b1 = SETP_i32rr %0, %1, 0
    CBranch %2, %bb.4, 0
    GOTO %bb.1

  bb.1:
    successors: %bb.2, %bb.4

    %3:b1 = SETP_i32rr %0, %1, 1
    CBranch %3, %bb.4, 0
    GOTO %bb.2

  bb.2:
    successors: %bb.3, %bb.4

    CBranch %3, %bb.4, 0
    CBranch %3, %bb.4, 0
    GOTO %bb.3

  bb.3:
