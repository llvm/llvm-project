;           │normal                   │exception
;           v                         v
;    inner.catch.original      inner.catch.original
;           │
;           v
;   ┌────────────────────────────┐
;   │ bb7 loop header            │◄──────────────┐
;   │ try {                      │               │
;   │   call foo                 │               │
;   │ }                          │               │
;   └───────┬─────────────┬──────┘               │
