entry:
  invoke void @foo()
          to label %exit unwind label %outer.dispatch

exit:
  unreachable

outer.dispatch:
  %outer = catchswitch within none [label %outer.catch] unwind label %inner.dispatch

outer.catch:
  %outer.pad = catchpad within %outer [ptr null]
  invoke void @foo() [ "funclet"(token %outer.pad) ]
          to label %outer.cont unwind label %inner.dispatch

outer.cont:
  catchret from %outer.pad to label %bb7

inner.dispatch:
  %inner = catchswitch within none [label %inner.catch] unwind to caller

inner.catch:
  %inner.pad = catchpad within %inner [ptr null]
  catchret from %inner.pad to label %bb7

