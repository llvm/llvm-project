; RUN: llc < %s -mtriple=wasm32-unknown-unknown -wasm-enable-eh -exception-model=wasm -mattr=+exception-handling -verify-machineinstrs | FileCheck %s

; Test irreducible CFG handling when one of the loop entries is an EH pad.
;
; The normal irreducible-CFG fix routes entries through a dispatch block.
; That is not valid for EH pad entries, because exceptional successors must
; target EH pads directly.
;
; These tests use verifier-valid funclet EH IR:
; - invoke unwind targets are catchswitch blocks, not catchpad blocks.
; - invokes inside catchpads have funclet bundles.
; - unwind edges out of a catchpad use the same unwind destination as the
;   parent catchswitch.

target datalayout = "e-m:e-p:32:32-i64:64-n32:64-S128"
target triple = "wasm32-unknown-unknown"

@g = external global i32

declare void @foo()
declare void @bar(ptr)
declare ptr @llvm.wasm.get.exception(token)
declare i32 @__gxx_wasm_personality_v0(...)

