; CHECK-NEXT:    .local i32
; CHECK-NEXT:  # %bb.0: # %entry
; CHECK-NEXT:    global.get __stack_pointer
; CHECK-NEXT:    local.set 0
; CHECK-NEXT:    block
; CHECK-NEXT:    try
; CHECK-NEXT:    try
; CHECK-NEXT:  .Ltmp0: # EH_LABEL
; CHECK-NEXT:    call foo
; CHECK-NEXT:  .Ltmp1: # EH_LABEL
; CHECK-NEXT:    br 2 # 2: down to label0
; CHECK-NEXT:  .LBB0_1: # %outer.catch
; CHECK-NEXT:  .Ltmp2: # EH_LABEL
; CHECK-NEXT:  .Ltmp3: # EH_LABEL
; CHECK-NEXT:    catch_all # catch2:
; CHECK-NEXT:    local.get 0
; CHECK-NEXT:    global.set __stack_pointer
; CHECK-NEXT:    call foo
; CHECK-NEXT:  .Ltmp4: # EH_LABEL
; CHECK-NEXT:  # %bb.2: # %outer.cont
; CHECK-NEXT:  .LBB0_3: # %inner.catch
; CHECK-NEXT:    end_try # label2:
; CHECK-NEXT:  .Ltmp5: # EH_LABEL
; CHECK-NEXT:    catch_all # catch1:
; CHECK-NEXT:    local.get 0
; CHECK-NEXT:    global.set __stack_pointer
; CHECK-NEXT:  .LBB0_4: # %bb7
; CHECK-NEXT:    # =>This Inner Loop Header: Depth=1
; CHECK-NEXT:    end_try # label1:
; CHECK-NEXT:    loop # label3:
; CHECK-NEXT:    try
; CHECK-NEXT:  .Ltmp6: # EH_LABEL
; CHECK-NEXT:    call foo
; CHECK-NEXT:  .Ltmp7: # EH_LABEL
; CHECK-NEXT:  .LBB0_5: # %inner.catch
; CHECK-NEXT:    # in Loop: Header=BB0_4 Depth=1
; CHECK-NEXT:  .Ltmp8: # EH_LABEL
