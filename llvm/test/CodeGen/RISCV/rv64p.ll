; CHECK-NEXT:    sd a1, 0(a3)
; CHECK-NEXT:    ret
  %aext = sext i32 %a to i64
  %bext = sext i32 %b to i64
  %mul = mul i64 %aext, %bext
  %result = add i64 %c, %mul
  store i64 %mul, ptr %out
  ret i64 %result
}
