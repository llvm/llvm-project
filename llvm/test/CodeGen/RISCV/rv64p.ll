; Test bitwise merge: (mask & b) | (~mask & a)
define i64 @merge_i64(i64 %mask, i64 %a, i64 %b) nounwind {
; CHECK-LABEL: merge_i64:
; CHECK:       # %bb.0:
; CHECK-NEXT:    merge a0, a1, a2
