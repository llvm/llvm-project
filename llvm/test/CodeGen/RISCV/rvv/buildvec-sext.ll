  %e0 = extractelement <8 x i16> %x, i32 0
  %e1 = extractelement <8 x i16> %x, i32 1
  %e2 = extractelement <8 x i16> %x, i32 2
  %e3 = extractelement <8 x i16> %x, i32 3
  %s0 = zext i16 %e0 to i32
