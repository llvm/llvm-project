; Mixed sign and zero extends must not combine (semantics differ for negative
; inputs).
define <4 x i32> @buildvec_mixed_sext_zext_v4(<8 x i16> %x) {
; CHECK-LABEL: buildvec_mixed_sext_zext_v4:
; CHECK:       # %bb.0:
; CHECK-NEXT:    vsetivli zero, 1, e16, m1, ta, ma
; CHECK-NEXT:    vmv.x.s a0, v8
; CHECK-NEXT:    vslidedown.vi v9, v8, 1
; CHECK-NEXT:    vmv.x.s a1, v9
; CHECK-NEXT:    vslidedown.vi v9, v8, 2
; CHECK-NEXT:    vslidedown.vi v8, v8, 3
; CHECK-NEXT:    lui a2, 16
; CHECK-NEXT:    vmv.x.s a3, v9
; CHECK-NEXT:    vmv.x.s a4, v8
; CHECK-NEXT:    addi a2, a2, -1
; CHECK-NEXT:    and a1, a1, a2
; CHECK-NEXT:    and a2, a4, a2
; CHECK-NEXT:    vsetivli zero, 4, e32, m1, ta, ma
; CHECK-NEXT:    vmv.v.x v8, a0
; CHECK-NEXT:    vslide1down.vx v8, v8, a1
; CHECK-NEXT:    vslide1down.vx v8, v8, a3
; CHECK-NEXT:    vslide1down.vx v8, v8, a2
; CHECK-NEXT:    ret
  %e0 = extractelement <8 x i16> %x, i32 0
  %e1 = extractelement <8 x i16> %x, i32 1
  %e2 = extractelement <8 x i16> %x, i32 2
  %e3 = extractelement <8 x i16> %x, i32 3
  %s0 = sext i16 %e0 to i32
  %s1 = zext i16 %e1 to i32
  %s2 = sext i16 %e2 to i32
  %s3 = zext i16 %e3 to i32
  %v0 = insertelement <4 x i32> undef, i32 %s0, i32 0
  %v1 = insertelement <4 x i32> %v0, i32 %s1, i32 1
  %v2 = insertelement <4 x i32> %v1, i32 %s2, i32 2
  %v3 = insertelement <4 x i32> %v2, i32 %s3, i32 3
  ret <4 x i32> %v3
}
