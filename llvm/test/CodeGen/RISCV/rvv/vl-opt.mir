    %y:vr = PseudoRI_VZIP2A_VV_M1 $noreg, %x, %x, -1, 5 /* e32 */, 0 /* tu, mu */
    %z:vr = PseudoVADD_VV_M1 $noreg, %y, $noreg, 1, 5 /* e32 */, 0 /* tu, mu */
    $v8 = COPY %z
...
