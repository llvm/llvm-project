# NOTE: Assertions have been autogenerated by utils/update_mir_test_checks.py
# RUN: llc -mtriple=riscv64 -mattr=+a,+zabha -run-pass=instruction-select %s -o - | FileCheck %s

---
name:            atomicrmw_and_i8_monotonic
legalized:       true
regBankSelected: true
tracksRegLiveness: true
body:             |
  bb.0.entry:
    liveins: $x10, $x11

    ; CHECK-LABEL: name: atomicrmw_and_i8_monotonic
    ; CHECK: liveins: $x10, $x11
    ; CHECK-NEXT: {{  $}}
    ; CHECK-NEXT: [[COPY:%[0-9]+]]:gpr = COPY $x10
    ; CHECK-NEXT: [[COPY1:%[0-9]+]]:gpr = COPY $x11
    ; CHECK-NEXT: [[AMOAND_B:%[0-9]+]]:gpr = AMOAND_B [[COPY1]], [[COPY]] :: (load store monotonic (s8))
    ; CHECK-NEXT: $x10 = COPY [[AMOAND_B]]
    ; CHECK-NEXT: PseudoRET implicit $x10
    %0:gprb(p0) = COPY $x10
    %1:gprb(s64) = COPY $x11
    %2:gprb(s64) = G_ATOMICRMW_AND %0(p0), %1 :: (load store monotonic (s8))
    $x10 = COPY %2(s64)
    PseudoRET implicit $x10
...
