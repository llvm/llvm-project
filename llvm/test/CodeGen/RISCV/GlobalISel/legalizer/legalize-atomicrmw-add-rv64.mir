    %0:gprb(p0) = COPY $x10
    %1:gprb(s32) = G_CONSTANT i32 1
    %2:gprb(s32) = G_ATOMICRMW_ADD %0, %1 :: (load store monotonic (s32))
    %3:gprb(s64) = G_ANYEXT %2(s32)
    $x10 = COPY %3(s64)
    PseudoRET implicit $x10
...
