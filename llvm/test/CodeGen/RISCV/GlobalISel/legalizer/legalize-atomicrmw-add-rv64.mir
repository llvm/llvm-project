    ; CHECK-NEXT: [[ATOMICRMW_ADD:%[0-9]+]]:gprb(s32) = G_ATOMICRMW_ADD [[COPY]](p0), [[TRUNC]] :: (load store monotonic (s32))
    ; CHECK-NEXT: [[ANYEXT:%[0-9]+]]:gprb(s64) = G_ANYEXT [[ATOMICRMW_ADD]](s32)
    ; CHECK-NEXT: $x10 = COPY [[ANYEXT]](s64)
