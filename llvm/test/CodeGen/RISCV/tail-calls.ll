; CHECK-CF-RV64-LARGE-LABEL: duplicate_returns:
; CHECK-CF-RV64-LARGE:       # %bb.0: # %entry
; CHECK-CF-RV64-LARGE-NEXT:    lpad 0
; CHECK-CF-RV64-LARGE-NEXT:    sext.w a0, a0
; CHECK-CF-RV64-LARGE-NEXT:    beqz a0, .LBB14_4
