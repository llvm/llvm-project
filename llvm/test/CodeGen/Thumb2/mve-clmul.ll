  %a.ext = zext <1 x i64> %a to <1 x i128>
  %b.ext = zext <1 x i64> %b to <1 x i128>
  %clmul = call <1 x i128> @llvm.clmul.v1i128(<1 x i128> %a.ext, <1 x i128> %b.ext)
