# RUN: not llc -mtriple=x86_64 -run-pass=none -filetype=null %s 2>&1 | FileCheck %s
# REQUIRES: x86-registered-target

# Test parsing error for tiedto constraint with invalid operand number.

# CHECK: [[@LINE+5]]:{{[0-9]+}}: invalid operand number in tiedto constraint
---
name: foo
body: |
  bb.0:
    INLINEASM &"", attdialect, regdef:GR32, reguse tiedto:$abc
...
