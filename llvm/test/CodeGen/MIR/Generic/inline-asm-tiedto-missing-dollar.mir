# RUN: not llc -run-pass=none -filetype=null %s 2>&1 | FileCheck %s

# Test parsing error for tiedto constraint without $ prefix.

# CHECK: [[@LINE+5]]:{{[0-9]+}}: expected '$N' operand number after 'tiedto:'
---
name: foo
body: |
  bb.0:
    INLINEASM &"", 0 /* attdialect */, regdef:GR32, reguse tiedto:0
...
