  bb.0.entry:
    successors: %bb.1(0x80000000)
    liveins: $edi, $xmm0

    renamable $xmm1 = MOVAPSrm $rip, 1, $noreg, %const.0, $noreg :: (load (s128) from constant-pool)
    renamable $xmm1 = PCMPGTBrr killed renamable $xmm1, killed renamable $xmm0
    renamable $xmm0 = V_SET0
    renamable $xmm2 = MOVAPSrm $rip, 1, $noreg, %const.1, $noreg :: (load (s128) from constant-pool)

  bb.1:
    successors: %bb.3(0x40000000), %bb.2(0x40000000)
