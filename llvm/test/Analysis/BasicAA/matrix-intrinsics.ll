; CHECK-NEXT:    call void @llvm.matrix.column.major.store.v8f64.i64(<8 x double> [[L]], ptr [[P]], i64 8, i1 false, i32 4, i32 2)
; CHECK-NEXT:    [[S:%.*]] = fadd <8 x double> [[L]], [[L]]
; CHECK-NEXT:    ret <8 x double> [[S]]
;
entry:
