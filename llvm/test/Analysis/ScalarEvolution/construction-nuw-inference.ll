;; Negative case: no inner guard, BTC unknown. Helper cannot prove anything;
;; AddRec stays without <nuw>.
define void @no_inner_guard(i32 %N) mustprogress {
; CHECK-LABEL: 'no_inner_guard'
; CHECK-NEXT:  Classifying expressions for: @no_inner_guard
; CHECK-NEXT:    %iv = phi i32 [ %iv.next, %for.body ], [ 0, %entry ]
; CHECK-NEXT:    --> {0,+,2}<nuw><%for.body> U: [0,-3) S: [-2147483648,2147483647) Exits: (2 * ((-1 + (2 umax %N)) /u 2))<nuw> LoopDispositions: { %for.body: Computable }
; CHECK-NEXT:    %iv.next = add i32 %iv, 2
; CHECK-NEXT:    --> {2,+,2}<nuw><%for.body> U: [2,-1) S: [-2147483648,2147483647) Exits: (2 + (2 * ((-1 + (2 umax %N)) /u 2))<nuw>) LoopDispositions: { %for.body: Computable }
; CHECK-NEXT:  Determining loop execution counts for: @no_inner_guard
; CHECK-NEXT:  Loop %for.body: backedge-taken count is ((-1 + (2 umax %N)) /u 2)
; CHECK-NEXT:  Loop %for.body: constant max backedge-taken count is i32 2147483646
; CHECK-NEXT:  Loop %for.body: symbolic max backedge-taken count is ((-1 + (2 umax %N)) /u 2)
; CHECK-NEXT:  Loop %for.body: Trip multiple is 1
;
entry:
  br label %for.body

for.body:
  %iv = phi i32 [ %iv.next, %for.body ], [ 0, %entry ]
  %iv.next = add i32 %iv, 2
  %cmp = icmp ult i32 %iv.next, %N
