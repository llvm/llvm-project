; CHECK-NEXT:    store i32 [[IDX]], ptr [[LOC]], align 4
; CHECK-NEXT:    [[IDX_DEC]] = add nuw i32 [[IDX]], 1
; CHECK-NEXT:    [[COND:%.*]] = icmp slt i32 [[X]], [[Y]]
