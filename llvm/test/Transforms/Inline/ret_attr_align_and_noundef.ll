; CHECK:       bb1:
; CHECK-NEXT:    [[R1:%.*]] = call range(i8 0, 20) i8 @val8()
; CHECK-NEXT:    ret i8 [[R1]]
; CHECK:       bb2:
; CHECK-NEXT:    [[R2:%.*]] = call range(i8 10, 30) i8 @val8()
; CHECK-NEXT:    ret i8 [[R2]]
