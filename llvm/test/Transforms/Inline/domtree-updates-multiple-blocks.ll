; Verify that the DominatorTree is successfully updated and preserved in a valid state
; by the internalized batch pass without forcing a full invalidation fallback cycle.
; CHECK: Running pass: InlinerPass
; CHECK-NOT: Invalidating analysis: DominatorTreeAnalysis
; CHECK: Running pass: DominatorTreeVerifierPass

define internal i32 @callee_simple_cfg(i1 %cond, i32 %val) alwaysinline {
entry:
  br i1 %cond, label %then, label %else

then:
  %res1 = add i32 %val, 10
  br label %return

else:
  %res2 = sub i32 %val, 5
  br label %return

return:
  %res = phi i32 [ %res1, %then ], [ %res2, %else ]
  ret i32 %res
}

define i32 @caller_invoke_site(i1 %cond, i32 %val) personality ptr @__gxx_personality_v0 {
; CHECK-LABEL: define i32 @caller_invoke_site(
; CHECK-SAME: i1 [[COND:%.*]], i32 [[VAL:%.*]]) personality ptr @__gxx_personality_v0 {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    br i1 [[COND]], label %[[THEN_I:.*]], label %[[ELSE_I:.*]]
; CHECK:       [[THEN_I]]:
; CHECK-NEXT:    [[RES1_I:%.*]] = add i32 [[VAL]], 10
; CHECK-NEXT:    br label %[[CALLEE_SIMPLE_CFG_EXIT:.*]]
; CHECK:       [[ELSE_I]]:
; CHECK-NEXT:    [[RES2_I:%.*]] = sub i32 [[VAL]], 5
; CHECK-NEXT:    br label %[[CALLEE_SIMPLE_CFG_EXIT]]
; CHECK:       [[CALLEE_SIMPLE_CFG_EXIT]]:
; CHECK-NEXT:    [[RES_I:%.*]] = phi i32 [ [[RES1_I]], %[[THEN_I]] ], [ [[RES2_I]], %[[ELSE_I]] ]
; CHECK-NEXT:    br label %[[NORMAL:.*]]
; CHECK:       [[NORMAL]]:
; CHECK-NEXT:    ret i32 [[RES_I]]
; CHECK:       [[LPAD:.*:]]
; CHECK-NEXT:    [[LP:%.*]] = landingpad { ptr, i32 }
; CHECK-NEXT:            cleanup
; CHECK-NEXT:    ret i32 0
;
entry:
  %res = invoke i32 @callee_simple_cfg(i1 %cond, i32 %val)
  to label %normal unwind label %lpad

normal:
  ret i32 %res

lpad:
  %lp = landingpad { ptr, i32 }
  cleanup
  ret i32 0
}

declare i32 @__gxx_personality_v0(...)
