; CHECK-NEXT:    [[TMP12:%.*]] = cmpxchg ptr addrspace(1) [[HI_PTR]], i128 [[TMP11]], i128 [[TMP10]] syncscope("block") monotonic monotonic, align 16
; CHECK-NEXT:    [[SUCCESS5:%.*]] = extractvalue { i128, i1 } [[TMP12]], 1
