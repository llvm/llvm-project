; CHECK-NEXT:    [[SIN:%.*]] = extractvalue { <4 x float>, <4 x float> } [[SINCOS]], 0
; CHECK-NEXT:    [[COS:%.*]] = extractvalue { <4 x float>, <4 x float> } [[SINCOS]], 1
; CHECK-NEXT:    [[RES:%.*]] = fadd <4 x float> [[SIN]], [[COS]]
