; shl(fshr(a, b, C), C) -> and(b, -1 << C)
define i32 @shl_fshr_c8(i32 %a, i32 %b) {
; CHECK-LABEL: @shl_fshr_c8(
; CHECK-NEXT:    [[SHL:%.*]] = and i32 [[B:%.*]], -256
; CHECK-NEXT:    ret i32 [[SHL]]
;
  %fshr = call i32 @llvm.fshr.i32(i32 %a, i32 %b, i32 8)
  %shl = shl i32 %fshr, 8
  ret i32 %shl
}

; shl(fshl(a, b, BW-C), C) -> and(b, -1 << C)
; fshl(a, b, 24) == fshr(a, b, 8) for i32
define i32 @shl_fshl_c8(i32 %a, i32 %b) {
; CHECK-LABEL: @shl_fshl_c8(
