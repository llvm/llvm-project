; CHECK-NEXT:    call void @use32(i32 [[T0]])
; CHECK-NEXT:    [[T1:%.*]] = sub i32 0, [[X]]
; CHECK-NEXT:    call void @use32(i32 [[T1]])
; CHECK-NEXT:    [[T2:%.*]] = sub i32 [[Y]], [[X]]
; CHECK-NEXT:    ret i32 [[T2]]
;
