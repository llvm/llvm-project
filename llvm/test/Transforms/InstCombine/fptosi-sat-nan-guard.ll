; Fold select (fcmp uno/ord X, 0), 0, (fptosi/fptoui X) -> fptosi.sat/fptoui.sat(X)
; fptosi.sat returns 0 for NaN, matching the select's behavior.
; Also fold when the conversion result is AND-masked.

;; Positive tests

define i32 @nan_guard_fptosi_uno_f32(float %x) {
; CHECK-LABEL: @nan_guard_fptosi_uno_f32(
; CHECK-NEXT:    [[SEL:%.*]] = call i32 @llvm.fptosi.sat.i32.f32(float [[X:%.*]])
; CHECK-NEXT:    ret i32 [[SEL]]
;
  %cmp = fcmp uno float %x, 0.000000e+00
  %conv = fptosi float %x to i32
  %sel = select i1 %cmp, i32 0, i32 %conv
  ret i32 %sel
}

