; fptosi has multiple uses -- fold should still fire (replaces fcmp+select
; with fptosi.sat, net reduction even though original fptosi stays).
define i32 @nan_guard_fptosi_multi_use(float %x, ptr %p) {
; CHECK-LABEL: @nan_guard_fptosi_multi_use(
; CHECK-NEXT:    [[CONV:%.*]] = fptosi float [[X:%.*]] to i32
; CHECK-NEXT:    store i32 [[CONV]], ptr [[P:%.*]], align 4
; CHECK-NEXT:    [[SEL:%.*]] = call i32 @llvm.fptosi.sat.i32.f32(float [[X]])
; CHECK-NEXT:    ret i32 [[SEL]]
;
  %cmp = fcmp uno float %x, 0.000000e+00
  %conv = fptosi float %x to i32
  store i32 %conv, ptr %p
  %sel = select i1 %cmp, i32 0, i32 %conv
  ret i32 %sel
}

; AND has multiple uses -- fold should still fire (same reasoning).
define i32 @nan_guard_and_multi_use(float %x, ptr %p) {
; CHECK-LABEL: @nan_guard_and_multi_use(
; CHECK-NEXT:    [[CONV:%.*]] = fptosi float [[X:%.*]] to i32
; CHECK-NEXT:    [[AND:%.*]] = and i32 [[CONV]], 3
; CHECK-NEXT:    store i32 [[AND]], ptr [[P:%.*]], align 4
; CHECK-NEXT:    [[TMP1:%.*]] = call i32 @llvm.fptosi.sat.i32.f32(float [[X]])
; CHECK-NEXT:    [[SEL:%.*]] = and i32 [[TMP1]], 3
; CHECK-NEXT:    ret i32 [[SEL]]
;
  %cmp = fcmp uno float %x, 0.000000e+00
  %conv = fptosi float %x to i32
  %and = and i32 %conv, 3
  store i32 %and, ptr %p
  %sel = select i1 %cmp, i32 0, i32 %and
  ret i32 %sel
}

