; RUN: opt -mtriple=amdgcn-amd-amdhsa -mcpu=gfx900 -passes=instcombine -S < %s | FileCheck %s --check-prefixes=GFX9

; Wave64 shuffle patterns. The index must be the full wave64 thread ID,
; mbcnt.hi(-1, mbcnt.lo(-1, 0)); using mbcnt.lo alone would only yield
; lane & 0x1F and is not a wave-wide permutation.

declare i32 @llvm.amdgcn.mbcnt.lo(i32, i32)
declare i32 @llvm.amdgcn.mbcnt.hi(i32, i32)
declare i32 @llvm.amdgcn.wave.shuffle.i32(i32, i32)

; Identity: every lane reads itself, folded to the source value.
define i32 @test_identity_w64(i32 %val) {
; GFX11-W64-LABEL: @test_identity_w64(
; GFX11-W64-NEXT:    ret i32 [[VAL:%.*]]
;
; GFX9-LABEL: @test_identity_w64(
; GFX9-NEXT:    ret i32 [[VAL:%.*]]
;
  %lo = call i32 @llvm.amdgcn.mbcnt.lo(i32 -1, i32 0)
  %lane = call i32 @llvm.amdgcn.mbcnt.hi(i32 -1, i32 %lo)
  %result = call i32 @llvm.amdgcn.wave.shuffle.i32(i32 %val, i32 %lane)
  ret i32 %result
}

; Quad perm: lane ^ 1 swaps adjacent pairs.
define i32 @test_quad_perm_xor1_w64(i32 %val) {
; GFX11-W64-LABEL: @test_quad_perm_xor1_w64(
; GFX11-W64-NEXT:    [[RESULT:%.*]] = call i32 @llvm.amdgcn.update.dpp.i32(i32 poison, i32 [[VAL:%.*]], i32 177, i32 15, i32 15, i1 true)
; GFX11-W64-NEXT:    ret i32 [[RESULT]]
;
; GFX9-LABEL: @test_quad_perm_xor1_w64(
; GFX9-NEXT:    [[RESULT:%.*]] = call i32 @llvm.amdgcn.update.dpp.i32(i32 poison, i32 [[VAL:%.*]], i32 177, i32 15, i32 15, i1 true)
; GFX9-NEXT:    ret i32 [[RESULT]]
;
  %lo = call i32 @llvm.amdgcn.mbcnt.lo(i32 -1, i32 0)
  %lane = call i32 @llvm.amdgcn.mbcnt.hi(i32 -1, i32 %lo)
  %idx = xor i32 %lane, 1
  %result = call i32 @llvm.amdgcn.wave.shuffle.i32(i32 %val, i32 %idx)
  ret i32 %result
}

