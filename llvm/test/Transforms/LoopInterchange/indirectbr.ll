; RUN: opt < %s -passes=loop-interchange -loop-interchange-profitabilities=ignore -S | FileCheck %s

; When transforming loops, loop-interchange will insert new prehader blocks for
; the outer/inner loop, but in this case it will fail due to their predecessor
; blocks contain indirectbr instructions. Therefore we canoot interchange the
; loops.
;
define void @indirect0(ptr %A) {
; CHECK-LABEL: define void @indirect0(
; CHECK-SAME: ptr [[A:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    indirectbr ptr blockaddress(@indirect0, %[[OUTER_HEADER:.*]]), [label %[[OUTER_HEADER]]]
; CHECK:       [[OUTER_HEADER]]:
; CHECK-NEXT:    [[I:%.*]] = phi i64 [ 0, %[[ENTRY]] ], [ [[I_INC:%.*]], %[[OUTER_LATCH:.*]] ]
; CHECK-NEXT:    indirectbr ptr blockaddress(@indirect0, %[[INNER:.*]]), [label %[[INNER]]]
; CHECK:       [[INNER]]:
; CHECK-NEXT:    [[J:%.*]] = phi i64 [ 0, %[[OUTER_HEADER]] ], [ [[J_INC:%.*]], %[[INNER]] ]
; CHECK-NEXT:    [[GEP:%.*]] = getelementptr inbounds [4 x i8], ptr [[A]], i64 [[J]], i64 [[I]]
; CHECK-NEXT:    store i8 0, ptr [[GEP]], align 1
; CHECK-NEXT:    [[J_INC]] = add i64 [[J]], 1
; CHECK-NEXT:    [[EC_J:%.*]] = icmp eq i64 [[J_INC]], 4
; CHECK-NEXT:    br i1 [[EC_J]], label %[[OUTER_LATCH]], label %[[INNER]]
; CHECK:       [[OUTER_LATCH]]:
; CHECK-NEXT:    [[I_INC]] = add i64 [[I]], 1
; CHECK-NEXT:    [[EC_I:%.*]] = icmp eq i64 [[I_INC]], 4
; CHECK-NEXT:    br i1 [[EC_I]], label %[[EXIT:.*]], label %[[OUTER_HEADER]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    ret void
;
entry:
  indirectbr ptr blockaddress(@indirect0, %outer.header), [ label %outer.header ]

outer.header:
  %i = phi i64 [ 0, %entry ], [ %i.inc, %outer.latch ]
  indirectbr ptr blockaddress(@indirect0, %inner), [ label %inner ]

inner:
  %j = phi i64 [ 0, %outer.header ], [ %j.inc, %inner ]
  %gep = getelementptr inbounds [4 x i8], ptr %A, i64 %j, i64 %i
  store i8 0, ptr %gep
  %j.inc = add i64 %j, 1
  %ec.j = icmp eq i64 %j.inc, 4
  br i1 %ec.j, label %outer.latch, label %inner

outer.latch:
  %i.inc = add i64 %i, 1
  %ec.i = icmp eq i64 %i.inc, 4
  br i1 %ec.i, label %exit, label %outer.header

exit:
  ret void
}

; This is semantically equivalent to the above case, but the outer loop header
; uses a br instruction so theoretically we can perform loop interchange.
; However, we now check the presence of indirectbr instrucction conservatively
; and reject these loops as well.
;
define void @indirect1(ptr %A) {
; CHECK-LABEL: define void @indirect1(
; CHECK-SAME: ptr [[A:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    br label %[[OUTER_HEADER:.*]]
; CHECK:       [[OUTER_HEADER]]:
; CHECK-NEXT:    [[I:%.*]] = phi i64 [ 0, %[[ENTRY]] ], [ [[I_INC:%.*]], %[[OUTER_LATCH:.*]] ]
; CHECK-NEXT:    br label %[[INNER_HEADER:.*]]
; CHECK:       [[INNER_HEADER]]:
; CHECK-NEXT:    [[J:%.*]] = phi i64 [ 0, %[[OUTER_HEADER]] ], [ [[J_INC:%.*]], %[[INNER_LATCH:.*]] ]
; CHECK-NEXT:    indirectbr ptr blockaddress(@indirect1, %[[INNER_BODY:.*]]), [label %[[INNER_BODY]]]
; CHECK:       [[INNER_BODY]]:
; CHECK-NEXT:    [[GEP:%.*]] = getelementptr inbounds [4 x i8], ptr [[A]], i64 [[J]], i64 [[I]]
; CHECK-NEXT:    store i8 0, ptr [[GEP]], align 1
; CHECK-NEXT:    indirectbr ptr blockaddress(@indirect1, %[[INNER_LATCH]]), [label %[[INNER_LATCH]]]
; CHECK:       [[INNER_LATCH]]:
; CHECK-NEXT:    [[J_INC]] = add i64 [[J]], 1
; CHECK-NEXT:    [[EC_J:%.*]] = icmp eq i64 [[J_INC]], 4
; CHECK-NEXT:    br i1 [[EC_J]], label %[[OUTER_LATCH]], label %[[INNER_HEADER]]
; CHECK:       [[OUTER_LATCH]]:
; CHECK-NEXT:    [[I_INC]] = add i64 [[I]], 1
; CHECK-NEXT:    [[EC_I:%.*]] = icmp eq i64 [[I_INC]], 4
; CHECK-NEXT:    br i1 [[EC_I]], label %[[EXIT:.*]], label %[[OUTER_HEADER]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    ret void
;
entry:
  br label %outer.header

outer.header:
  %i = phi i64 [ 0, %entry ], [ %i.inc, %outer.latch ]
  br label %inner.header

inner.header:
  %j = phi i64 [ 0, %outer.header ], [ %j.inc, %inner.latch ]
  indirectbr ptr blockaddress(@indirect1, %inner.body), [ label %inner.body ]

inner.body:
  %gep = getelementptr inbounds [4 x i8], ptr %A, i64 %j, i64 %i
  store i8 0, ptr %gep
  indirectbr ptr blockaddress(@indirect1, %inner.latch), [ label %inner.latch ]

inner.latch:
  %j.inc = add i64 %j, 1
  %ec.j = icmp eq i64 %j.inc, 4
  br i1 %ec.j, label %outer.latch, label %inner.header

outer.latch:
  %i.inc = add i64 %i, 1
  %ec.i = icmp eq i64 %i.inc, 4
  br i1 %ec.i, label %exit, label %outer.header

exit:
  ret void
}
