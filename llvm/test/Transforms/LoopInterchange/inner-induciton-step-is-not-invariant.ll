; NOTE: Assertions have been autogenerated by utils/update_test_checks.py UTC_ARGS: --version 6
; RUN: opt < %s -passes=loop-interchange -loop-interchange-profitabilities=ignore -S | FileCheck %s

; When the inner loop has induction variables whose step recurrence values are
; not loop-invariant with respect to the outer loop, it is generally not safe
; to interchange the loops. These tests check that we don't perform
; loop-interchange in such cases.

; for (i = 1; i < 8; i++)
;   for (j = 0, k = 0; k < 16 + i; j++, k += i)
;     A[8*j + i] += 1;
;
define void @step_of_k_is_i_0(ptr %A) {
; CHECK-LABEL: define void @step_of_k_is_i_0(
; CHECK-SAME: ptr [[A:%.*]]) {
; CHECK-NEXT:  [[OUTER_HEADER:.*]]:
; CHECK-NEXT:    br label %[[INNER1:.*]]
; CHECK:       [[INNER1]]:
; CHECK-NEXT:    [[I:%.*]] = phi i64 [ 1, %[[OUTER_HEADER]] ], [ [[I_NEXT:%.*]], %[[OUTER_LATCH:.*]] ]
; CHECK-NEXT:    br label %[[OUTER_HEADER_PREHEADER:.*]]
; CHECK:       [[OUTER_HEADER_PREHEADER]]:
; CHECK-NEXT:    [[J:%.*]] = phi i64 [ 0, %[[INNER1]] ], [ [[J_NEXT:%.*]], %[[OUTER_HEADER_PREHEADER]] ]
; CHECK-NEXT:    [[K:%.*]] = phi i64 [ 0, %[[INNER1]] ], [ [[K_NEXT:%.*]], %[[OUTER_HEADER_PREHEADER]] ]
; CHECK-NEXT:    [[GEP:%.*]] = getelementptr [8 x i8], ptr [[A]], i64 [[J]], i64 [[I]]
; CHECK-NEXT:    [[OLD:%.*]] = load i8, ptr [[GEP]], align 1
; CHECK-NEXT:    [[NEW:%.*]] = add i8 [[OLD]], 1
; CHECK-NEXT:    store i8 [[NEW]], ptr [[GEP]], align 1
; CHECK-NEXT:    [[J_NEXT]] = add i64 [[J]], 1
; CHECK-NEXT:    [[K_NEXT]] = add i64 [[K]], [[I]]
; CHECK-NEXT:    [[TMP2:%.*]] = icmp slt i64 [[K]], 16
; CHECK-NEXT:    br i1 [[TMP2]], label %[[OUTER_HEADER_PREHEADER]], label %[[OUTER_LATCH]]
; CHECK:       [[OUTER_LATCH]]:
; CHECK-NEXT:    [[I_NEXT]] = add i64 [[I]], 1
; CHECK-NEXT:    [[CMP_I:%.*]] = icmp slt i64 [[I_NEXT]], 8
; CHECK-NEXT:    br i1 [[CMP_I]], label %[[INNER1]], label %[[EXIT:.*]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    ret void
;
entry:
  br label %outer.header

outer.header:
  %i = phi i64 [ 1, %entry ], [ %i.next, %outer.latch ]
  br label %inner

inner:
  %j = phi i64 [ 0, %outer.header ], [ %j.next, %inner ]
  %k = phi i64 [ 0, %outer.header ], [ %k.next, %inner ]
  %gep = getelementptr [8 x i8], ptr %A, i64 %j, i64 %i
  %old = load i8, ptr %gep
  %new = add i8 %old, 1
  store i8 %new, ptr %gep
  %j.next = add i64 %j, 1
  %k.next = add i64 %k, %i
  %ec.inner.not = icmp slt i64 %k, 16
  br i1 %ec.inner.not, label %inner, label %outer.latch

outer.latch:
  %i.next = add i64 %i, 1
  %cmp.i = icmp slt i64 %i.next, 8
  br i1 %cmp.i, label %outer.header, label %exit

exit:
  ret void
}

