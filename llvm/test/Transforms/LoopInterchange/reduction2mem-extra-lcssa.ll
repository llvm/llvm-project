; RUN:   | FileCheck -check-prefix=IR %s
; RUN: FileCheck --input-file=%t %s

; CHECK: --- !Missed
; CHECK-NEXT: Pass:            loop-interchange
; CHECK-NEXT: Name:            UnsupportedExitPHI
; CHECK-NEXT: Function:        reduction_lcssa_with_non_phi_user
; CHECK-NEXT: Args:
