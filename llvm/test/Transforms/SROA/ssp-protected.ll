; NOTE: Assertions have been autogenerated by utils/update_test_checks.py UTC_ARGS: --version 5
; RUN: opt -passes=sroa -S < %s | FileCheck %s
;
; SROA should be allowed to run on allocas with llvm.ssp.protected uses.
; When SROA can promote or slice an alloca, it deletes llvm.ssp.protected as a
; dead use. When the alloca escapes (SROA aborts), the intrinsic is preserved
; for the StackProtector pass.

declare void @llvm.ssp.protected(ptr nocapture) nofree nosync nounwind memory(none)
declare void @escape(ptr)

; SROA promotes a scalar alloca: ssp.protected is removed as a dead use.
define void @promote_scalar() ssp {
; CHECK-LABEL: define void @promote_scalar(
; CHECK-NOT:     alloca
; CHECK-NOT:     @llvm.ssp.protected
  %x = alloca i8, align 1
  call void @llvm.ssp.protected(ptr %x)
  store i8 42, ptr %x
  %v = load i8, ptr %x
  ret void
}

; An escaped array alloca: SROA cannot rewrite it, so ssp.protected is preserved.
define void @escaped_array_preserves_intrinsic() ssp {
; CHECK-LABEL: define void @escaped_array_preserves_intrinsic(
; CHECK:         %arr = alloca [8 x i8]
; CHECK:         call void @llvm.ssp.protected(ptr %arr)
; CHECK:         call void @escape(ptr %arr)
  %arr = alloca [8 x i8], align 1
  call void @llvm.ssp.protected(ptr %arr)
  call void @escape(ptr %arr)
  ret void
}
