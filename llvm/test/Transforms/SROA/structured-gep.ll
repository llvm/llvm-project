; NOTE: Assertions have been autogenerated by utils/update_test_checks.py
; RUN: opt < %s -passes='sroa' -S | FileCheck %s

target datalayout = "e-m:e-p:64:64-i64:64-f80:128-n8:16:32:64-S128"
target triple = "x86_64-unknown-linux-gnu"

declare ptr @llvm.structured.gep.p0(ptr, ...)

%struct.S = type { i32, float }

define float @test_struct() {
; CHECK-LABEL: @test_struct(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    ret float 2.000000e+00
;
entry:
  %alloca = alloca %struct.S, align 4
  %gep0 = call ptr (ptr, ...) @llvm.structured.gep.p0(ptr elementtype(%struct.S) %alloca, i32 0)
  store i32 1, ptr %gep0, align 4
  %gep1 = call ptr (ptr, ...) @llvm.structured.gep.p0(ptr elementtype(%struct.S) %alloca, i32 1)
  store float 2.0, ptr %gep1, align 4
  %val = load float, ptr %gep1, align 4
  ret float %val
}

define float @test_struct_extern(ptr %memory) {
; CHECK-LABEL: @test_struct_extern(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    [[GEP1:%.*]] = call ptr (ptr, ...) @llvm.structured.gep.p0(ptr elementtype([[STRUCT_S:%.*]]) [[MEMORY:%.*]], i32 1)
; CHECK-NEXT:    store float 2.000000e+00, ptr [[GEP1]], align 4
; CHECK-NEXT:    [[VAL:%.*]] = load float, ptr [[GEP1]], align 4
; CHECK-NEXT:    ret float [[VAL]]
;
entry:
  %gep1 = call ptr (ptr, ...) @llvm.structured.gep.p0(ptr elementtype(%struct.S) %memory, i32 1)
  store float 2.0, ptr %gep1, align 4
  %val = load float, ptr %gep1, align 4
  ret float %val
}

define i16 @test_array() {
; CHECK-LABEL: @test_array(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    [[TMP0:%.*]] = bitcast float 0.000000e+00 to i32
; CHECK-NEXT:    [[A_SROA_0_2_EXTRACT_SHIFT:%.*]] = lshr i32 [[TMP0]], 16
; CHECK-NEXT:    [[A_SROA_0_2_EXTRACT_TRUNC:%.*]] = trunc i32 [[A_SROA_0_2_EXTRACT_SHIFT]] to i16
; CHECK-NEXT:    ret i16 [[A_SROA_0_2_EXTRACT_TRUNC]]
entry:
  %a = alloca [4 x i8], align 1
  store float 0.0, ptr %a, align 4
  %ptr = call ptr (ptr, ...) @llvm.structured.gep.p0(ptr elementtype([4 x i8]) %a, i32 2)
  %val = load i16, ptr %ptr, align 2
  ret i16 %val
}

