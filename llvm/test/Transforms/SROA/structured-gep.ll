; CHECK-NEXT:    [[PTR:%.*]] = call ptr (ptr, ...) @llvm.structured.gep.p0(ptr elementtype([10 x i32]) [[A]], i32 [[IDX:%.*]])
; CHECK-NEXT:    store i32 42, ptr [[PTR]], align 4
; CHECK-NEXT:    [[VAL:%.*]] = load i32, ptr [[PTR]], align 4
; CHECK-NEXT:    ret i32 [[VAL]]
;
entry:
