; CHECK-LABEL: @fold_swapped_dominated_compare(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    [[BOUND2:%.*]] = getelementptr i64, ptr [[BASE2:%.*]], i64 [[N:%.*]]
; CHECK-NEXT:    br label [[LOOP:%.*]]
