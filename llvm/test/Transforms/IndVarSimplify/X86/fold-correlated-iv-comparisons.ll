; CHECK-NEXT:    br i1 [[CMP_EXIT]], label [[CHECK:%.*]], label [[BODY:%.*]]
; CHECK:       check:
; CHECK-NEXT:    [[SEL:%.*]] = select i1 false, i1 true, i1 false
; CHECK-NEXT:    br i1 [[SEL]], label [[BODY]], label [[EXIT:%.*]]
; CHECK:       body:
