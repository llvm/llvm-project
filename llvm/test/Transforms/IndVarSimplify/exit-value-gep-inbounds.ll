; CHECK-NEXT:    [[TMP0:%.*]] = shl i64 [[N]], 1
; CHECK-NEXT:    [[TMP1:%.*]] = add i64 [[N]], -1
; CHECK-NEXT:    [[TMP2:%.*]] = zext i64 [[TMP1]] to i65
; CHECK-NEXT:    [[TMP3:%.*]] = add i64 [[N]], -2
; CHECK-NEXT:    [[TMP4:%.*]] = zext i64 [[TMP3]] to i65
