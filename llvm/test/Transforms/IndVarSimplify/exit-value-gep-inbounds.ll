; Non-affine (polynomial) recurrence.
define ptr @polynomial_addrec_inbounds(ptr %p, i64 %n) {
; CHECK-LABEL: define ptr @polynomial_addrec_inbounds(
; CHECK-SAME: ptr [[P:%.*]], i64 [[N:%.*]]) {
