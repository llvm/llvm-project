; NOTE: Assertions have been autogenerated by utils/update_test_checks.py
; RUN: opt < %s -passes=indvars -indvars-predicate-loops=1 -S | FileCheck %s

; The inner loop's max BTC is unknown and it is not mustprogress, so the
; helper bails and predication of the outer exit is skipped.
define void @infinite_subloop_skips_predication() {
; CHECK-LABEL: @infinite_subloop_skips_predication(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    br label [[OUTER_HEADER:%.*]]
; CHECK:       outer.header:
; CHECK-NEXT:    [[IV:%.*]] = phi i8 [ 0, [[ENTRY:%.*]] ], [ [[IV_NEXT:%.*]], [[OUTER_LATCH:%.*]] ]
; CHECK-NEXT:    br label [[INNER_HEADER:%.*]]
; CHECK:       exit:
; CHECK-NEXT:    ret void
; CHECK:       inner.header:
; CHECK-NEXT:    [[INNER_COND:%.*]] = icmp eq i8 [[IV]], 1
; CHECK-NEXT:    br i1 [[INNER_COND]], label [[INNER_HEADER]], label [[OUTER_LATCH]]
; CHECK:       outer.latch:
; CHECK-NEXT:    [[IV_NEXT]] = add nuw i8 [[IV]], 1
; CHECK-NEXT:    [[OUTER_COND:%.*]] = icmp eq i8 [[IV_NEXT]], -1
; CHECK-NEXT:    br i1 [[OUTER_COND]], label [[EXIT:%.*]], label [[OUTER_HEADER]]
;
entry:
  br label %outer.header

outer.header:
  %iv = phi i8 [ 0, %entry ], [ %iv.next, %outer.latch ]
  br label %inner.header

exit:
  ret void

inner.header:
  %inner.cond = icmp eq i8 %iv, 1
  br i1 %inner.cond, label %inner.header, label %outer.latch

outer.latch:
  %iv.next = add nuw i8 %iv, 1
  %outer.cond = icmp eq i8 %iv.next, -1
  br i1 %outer.cond, label %exit, label %outer.header
}

; Tagging the inner loop !llvm.loop.mustprogress short-circuits the helper
; without consulting SCEV, so predication of the outer exit fires as usual.
; (The metadata is the test input asserting termination; IndVarSimplify
; trusts the tag without verification, so the inner loop's actual
; non-termination when iv == 0 is irrelevant to the optimizer's choice.)
define void @mustprogress_subloop_still_predicated() {
; CHECK-LABEL: @mustprogress_subloop_still_predicated(
; CHECK-NEXT:  entry:
; CHECK-NEXT:    br label [[OUTER_HEADER:%.*]]
; CHECK:       outer.header:
; CHECK-NEXT:    [[IV:%.*]] = phi i8 [ 0, [[ENTRY:%.*]] ], [ [[IV_NEXT:%.*]], [[OUTER_LATCH:%.*]] ]
; CHECK-NEXT:    br label [[INNER_HEADER:%.*]]
; CHECK:       exit:
; CHECK-NEXT:    ret void
; CHECK:       inner.header:
; CHECK-NEXT:    [[INNER_COND:%.*]] = icmp eq i8 [[IV]], 1
; CHECK-NEXT:    br i1 [[INNER_COND]], label [[INNER_HEADER]], label [[OUTER_LATCH]], !llvm.loop [[LOOP0:![0-9]+]]
; CHECK:       outer.latch:
; CHECK-NEXT:    [[IV_NEXT]] = add nuw i8 [[IV]], 1
; CHECK-NEXT:    br i1 true, label [[EXIT:%.*]], label [[OUTER_HEADER]]
;
entry:
  br label %outer.header

outer.header:
  %iv = phi i8 [ 0, %entry ], [ %iv.next, %outer.latch ]
  br label %inner.header

exit:
  ret void

inner.header:
  %inner.cond = icmp eq i8 %iv, 1
  br i1 %inner.cond, label %inner.header, label %outer.latch, !llvm.loop !0

outer.latch:
  %iv.next = add nuw i8 %iv, 1
  %outer.cond = icmp eq i8 %iv.next, -1
  br i1 %outer.cond, label %exit, label %outer.header
}

!0 = distinct !{!0, !1}
!1 = !{!"llvm.loop.mustprogress"}
