; CHECK-NEXT:    call void @llvm.assume(i1 true) [ "dereferenceable"(ptr [[ARG1]], i64 1) ]
; CHECK-NEXT:    br label %[[BB2]]
; CHECK:       [[BB4]]:
; CHECK-NEXT:    br label %[[BB2]]
;
; DROP-DEREF-LABEL: define ptr @test_dup_ptr_used_elsewhere(
