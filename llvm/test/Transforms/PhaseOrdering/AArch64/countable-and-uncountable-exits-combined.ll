; RUN: opt -passes="default<O3>" -S %s | FileCheck %s

target triple = "aarch64"

; Test derived from the following C code. We see the two exit conditions merged
; into one before reaching LoopVectorize.
;
; int c[10000];
; int src[10000];
; int dst[10000];
;
; void foo() {
;   for (int i=0; i<10000; ++i) {
;     dst[i] = src[i] + 42;
;     if (c[i])
;       break;
;   }
; }

@src = global [10000 x i32] zeroinitializer, align 4
@dst = global [10000 x i32] zeroinitializer, align 4
@c = global [10000 x i32] zeroinitializer, align 4

define void @foo() #0 {
; CHECK-LABEL: define void @foo(
; CHECK-SAME: ) local_unnamed_addr #[[ATTR0:[0-9]+]] {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    br label %[[FOR_BODY:.*]]
; CHECK:       [[FOR_BODY]]:
; CHECK-NEXT:    [[INDVARS_IV:%.*]] = phi i64 [ 0, %[[ENTRY]] ], [ [[INDVARS_IV_NEXT:%.*]], %[[FOR_BODY]] ]
; CHECK-NEXT:    [[ARRAYIDX:%.*]] = getelementptr inbounds nuw [4 x i8], ptr @src, i64 [[INDVARS_IV]]
; CHECK-NEXT:    [[SRC_PTR:%.*]] = load i32, ptr [[ARRAYIDX]], align 4
; CHECK-NEXT:    [[ADD:%.*]] = add nsw i32 [[SRC_PTR]], 42
; CHECK-NEXT:    [[DST_PTR:%.*]] = getelementptr inbounds nuw [4 x i8], ptr @dst, i64 [[INDVARS_IV]]
; CHECK-NEXT:    store i32 [[ADD]], ptr [[DST_PTR]], align 4
; CHECK-NEXT:    [[EE_PTR:%.*]] = getelementptr inbounds nuw [4 x i8], ptr @c, i64 [[INDVARS_IV]]
; CHECK-NEXT:    [[EE_VAL:%.*]] = load i32, ptr [[EE_PTR]], align 4
; CHECK-NEXT:    [[EE_COND:%.*]] = icmp ne i32 [[EE_VAL]], 0
; CHECK-NEXT:    [[INDVARS_IV_NEXT]] = add nuw nsw i64 [[INDVARS_IV]], 1
; CHECK-NEXT:    [[EXITCOND_NOT:%.*]] = icmp eq i64 [[INDVARS_IV_NEXT]], 10000
; CHECK-NEXT:    [[OR_COND:%.*]] = select i1 [[EE_COND]], i1 true, i1 [[EXITCOND_NOT]]
; CHECK-NEXT:    br i1 [[OR_COND]], label %[[EXIT:.*]], label %[[FOR_BODY]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    ret void
;
entry:
  br label %for.cond

for.cond:
  %iv = phi i32 [ 0, %entry ], [ %inc, %for.inc ]
  %counted.cmp = icmp samesign ult i32 %iv, 10000
  br i1 %counted.cmp, label %for.body, label %exit

for.body:
  %idxprom = zext nneg i32 %iv to i64
  %arrayidx = getelementptr inbounds nuw [4 x i8], ptr @src, i64 %idxprom
  %src.ptr = load i32, ptr %arrayidx, align 4
  %add = add nsw i32 %src.ptr, 42
  %dst.ptr = getelementptr inbounds nuw [4 x i8], ptr @dst, i64 %idxprom
  store i32 %add, ptr %dst.ptr, align 4
  %ee.ptr = getelementptr inbounds nuw [4 x i8], ptr @c, i64 %idxprom
  %ee.val = load i32, ptr %ee.ptr, align 4
  %ee.cond = icmp eq i32 %ee.val, 0
  br i1 %ee.cond, label %for.inc, label %exit

for.inc:
  %inc = add nuw nsw i32 %iv, 1
  br label %for.cond

exit:
  ret void
}

attributes #0 = { nounwind "target-features"="+sve2" }
