; Test stolen from a miscompile from an old attempt at recognizing memcmp idioms in loops,
; before it was reverted. https://bugs.llvm.org/show_bug.cgi?id=43206
;
; bool do_check(void) {
;   for (int i = 0; i < 100; i++)
;       for (int j = 0; j < 100; j++)
;         if (arr2[i][j] != arr1[i])
;           return false;
;   return true;
; };
;
; The loads proceed differently here - arr1[i] changes once per outer loop,
; while arr2[i][j] changes both in inner loop, and in outer loop. Thus, this tests
; that our usage of SCEV is properly scoped to the loop we are analyzing.
@arr2 = global [100 x [100 x i8]] zeroinitializer, align 16
@arr1 = global [100 x i8] zeroinitializer, align 16
define i1 @no_idiom_different_loops() {
; CHECK-LABEL: define i1 @no_idiom_different_loops() {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    br label %[[FOR_COND1_PREHEADER:.*]]
; CHECK:       [[FOR_COND1_PREHEADER]]:
; CHECK-NEXT:    [[I_028:%.*]] = phi i32 [ 0, %[[ENTRY]] ], [ [[INC13:%.*]], %[[FOR_INC12:.*]] ]
; CHECK-NEXT:    [[IDXPROM:%.*]] = zext nneg i32 [[I_028]] to i64
; CHECK-NEXT:    [[ARRAYIDX:%.*]] = getelementptr inbounds nuw [100 x i8], ptr @arr2, i64 [[IDXPROM]]
; CHECK-NEXT:    [[ARRAYIDX8:%.*]] = getelementptr inbounds nuw i8, ptr @arr1, i64 [[IDXPROM]]
; CHECK-NEXT:    [[TMP0:%.*]] = load i8, ptr [[ARRAYIDX8]], align 1
; CHECK-NEXT:    br label %[[FOR_BODY4:.*]]
; CHECK:       [[FOR_COND1:.*]]:
; CHECK-NEXT:    [[INC:%.*]] = add nuw nsw i32 [[J_027:%.*]], 1
; CHECK-NEXT:    [[CMP2:%.*]] = icmp samesign ugt i32 [[J_027]], 98
; CHECK-NEXT:    br i1 [[CMP2]], label %[[FOR_INC12]], label %[[FOR_BODY4]]
; CHECK:       [[FOR_BODY4]]:
; CHECK-NEXT:    [[J_027]] = phi i32 [ 0, %[[FOR_COND1_PREHEADER]] ], [ [[INC]], %[[FOR_COND1]] ]
; CHECK-NEXT:    [[IDXPROM5:%.*]] = zext nneg i32 [[J_027]] to i64
; CHECK-NEXT:    [[ARRAYIDX6:%.*]] = getelementptr inbounds nuw i8, ptr [[ARRAYIDX]], i64 [[IDXPROM5]]
; CHECK-NEXT:    [[TMP1:%.*]] = load i8, ptr [[ARRAYIDX6]], align 1
; CHECK-NEXT:    [[CMP10_NOT:%.*]] = icmp eq i8 [[TMP1]], [[TMP0]]
; CHECK-NEXT:    br i1 [[CMP10_NOT]], label %[[FOR_COND1]], label %[[CLEANUP14_LOOPEXIT:.*]]
; CHECK:       [[FOR_INC12]]:
; CHECK-NEXT:    [[CMP10_NOT_LCSSA31:%.*]] = phi i1 [ [[CMP10_NOT]], %[[FOR_COND1]] ]
; CHECK-NEXT:    [[INC13]] = add nuw nsw i32 [[I_028]], 1
; CHECK-NEXT:    [[CMP:%.*]] = icmp samesign ugt i32 [[I_028]], 98
; CHECK-NEXT:    br i1 [[CMP]], label %[[CLEANUP14_LOOPEXIT30:.*]], label %[[FOR_COND1_PREHEADER]]
; CHECK:       [[CLEANUP14_LOOPEXIT]]:
; CHECK-NEXT:    [[CMP10_NOT_LCSSA:%.*]] = phi i1 [ [[CMP10_NOT]], %[[FOR_BODY4]] ]
; CHECK-NEXT:    br label %[[CLEANUP14:.*]]
; CHECK:       [[CLEANUP14_LOOPEXIT30]]:
; CHECK-NEXT:    [[CMP10_NOT_LCSSA31_LCSSA:%.*]] = phi i1 [ [[CMP10_NOT_LCSSA31]], %[[FOR_INC12]] ]
; CHECK-NEXT:    br label %[[CLEANUP14]]
; CHECK:       [[CLEANUP14]]:
; CHECK-NEXT:    [[CMP10_NOT32:%.*]] = phi i1 [ [[CMP10_NOT_LCSSA31_LCSSA]], %[[CLEANUP14_LOOPEXIT30]] ], [ [[CMP10_NOT_LCSSA]], %[[CLEANUP14_LOOPEXIT]] ]
; CHECK-NEXT:    ret i1 [[CMP10_NOT32]]
;
entry:
  br label %for.cond1.preheader

for.cond1.preheader:                              ; preds = %entry, %for.inc12
  %i.028 = phi i32 [ 0, %entry ], [ %inc13, %for.inc12 ]
  %idxprom = zext nneg i32 %i.028 to i64
  %arrayidx = getelementptr inbounds nuw [100 x i8], ptr @arr2, i64 %idxprom
  %arrayidx8 = getelementptr inbounds nuw i8, ptr @arr1, i64 %idxprom
  %0 = load i8, ptr %arrayidx8, align 1
  br label %for.body4

for.cond1:                                        ; preds = %for.body4
  %inc = add nuw nsw i32 %j.027, 1
  %cmp2 = icmp samesign ugt i32 %j.027, 98
