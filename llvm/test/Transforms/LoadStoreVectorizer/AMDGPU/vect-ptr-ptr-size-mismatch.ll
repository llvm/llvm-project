; Size mismatch between the 32 bit pointer in address space 5 and 64 bit
; pointer in address space 0 it was cast to caused below test to crash.
; The p5:32:32 portion of the data layout is critical for the test.

define void @cast_to_ptr() {
; CHECK-LABEL: define void @cast_to_ptr() {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[ASCAST:%.*]] = addrspacecast ptr addrspace(5) null to ptr
; CHECK-NEXT:    [[TMP4:%.*]] = icmp eq i32 poison, 0
; CHECK-NEXT:    [[TMP6:%.*]] = select i1 false, ptr poison, ptr poison
; CHECK-NEXT:    [[TMP7:%.*]] = select i1 [[TMP4]], ptr null, ptr [[TMP6]]
; CHECK-NEXT:    [[TMP9:%.*]] = select i1 [[TMP4]], ptr [[ASCAST]], ptr null
; CHECK-NEXT:    store ptr poison, ptr [[TMP9]], align 8
; CHECK-NEXT:    store ptr poison, ptr [[TMP7]], align 8
; CHECK-NEXT:    unreachable
;
entry:
  %ascast = addrspacecast ptr addrspace(5) zeroinitializer to ptr
  %tmp4 = icmp eq i32 poison, 0
  %tmp6 = select i1 false, ptr poison, ptr poison
  %tmp7 = select i1 %tmp4, ptr null, ptr %tmp6
  %tmp9 = select i1 %tmp4, ptr %ascast, ptr null
  store ptr poison, ptr %tmp9, align 8
  store ptr poison, ptr %tmp7, align 8
  unreachable
}

