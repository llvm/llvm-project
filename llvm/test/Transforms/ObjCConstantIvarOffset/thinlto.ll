; Test multi-level hierarchy with cascading slide across three levels
; in a single merged module.
;
; Hierarchy:
;   NSObject
;     `- Base
;          int a;                        // a at offset 8
;          `- Middle
;               int b;                   // b at offset 12
;               int hidden;              // hidden at offset 16 (extension)
;               `- Leaf
;                    int c;              // c compiled at 16, slid to 20
;
; --- FullLTO path ---
; RUN: rm -rf %t && split-file %s %t
; RUN: opt -passes=objc-constant-ivar-offset -S %t/body.ll | FileCheck %s --check-prefixes=MIDDLE,LEAF
;
; MIDDLE: @"OBJC_IVAR_$_Base.a" = {{.*}}constant i64 8
; MIDDLE: @"OBJC_IVAR_$_Middle.b" = {{.*}}constant i64 12
; MIDDLE: @"OBJC_IVAR_$_Middle.hidden" = {{.*}}constant i64 16
; LEAF: @"OBJC_IVAR_$_Leaf.c" = {{.*}}constant i64 20
; LEAF: @"_OBJC_CLASS_RO_$_Leaf" = internal global %struct._class_ro_t { i32 0, i32 20, i32 24,
;
; --- ThinLTO path ---
; RUN: opt -module-summary %t/middle.ll -o %t/middle.bc
; RUN: opt -module-summary %t/leaf.ll -o %t/leaf.bc
; RUN: llvm-lto2 run %t/middle.bc %t/leaf.bc -save-temps -o %t/out \
; RUN:   -r=%t/middle.bc,_OBJC_CLASS_$_Base,plx \
; RUN:   -r=%t/middle.bc,_OBJC_CLASS_$_Middle,plx \
; RUN:   -r=%t/middle.bc,_OBJC_CLASS_$_NSObject, \
; RUN:   -r=%t/middle.bc,_OBJC_METACLASS_$_Base,plx \
; RUN:   -r=%t/middle.bc,_OBJC_METACLASS_$_Middle,plx \
; RUN:   -r=%t/middle.bc,_OBJC_METACLASS_$_NSObject, \
; RUN:   -r=%t/middle.bc,_OBJC_IVAR_$_Base.a,plx \
; RUN:   -r=%t/middle.bc,_OBJC_IVAR_$_Middle.b,plx \
; RUN:   -r=%t/middle.bc,_OBJC_IVAR_$_Middle.hidden,plx \
; RUN:   -r=%t/middle.bc,__objc_empty_cache, \
; RUN:   -r=%t/leaf.bc,_OBJC_CLASS_$_Leaf,plx \
; RUN:   -r=%t/leaf.bc,_OBJC_CLASS_$_Middle, \
; RUN:   -r=%t/leaf.bc,_OBJC_METACLASS_$_Leaf,plx \
; RUN:   -r=%t/leaf.bc,_OBJC_METACLASS_$_NSObject, \
; RUN:   -r=%t/leaf.bc,_OBJC_METACLASS_$_Middle, \
; RUN:   -r=%t/leaf.bc,_OBJC_IVAR_$_Leaf.c,plx \
; RUN:   -r=%t/leaf.bc,__objc_empty_cache,
; RUN: llvm-dis %t/out.1.4.opt.bc -o - | FileCheck %s --check-prefix=MIDDLE
; RUN: llvm-dis %t/out.2.4.opt.bc -o - | FileCheck %s --check-prefix=LEAF

; Segments:
;   middle.m / leaf.m - ingredients (requires Darwin SDK to regenerate)
;   gen               - refresher
;   body.ll           - merged module (llvm-link of middle+leaf), used by FullLTO path
;   middle.ll / leaf.ll - per-module IR, used by ThinLTO path

;--- middle.m
#import <objc/NSObject.h>
@interface Base : NSObject { int a; } @end
@interface Middle : Base { int b; } @end
@interface Middle () { int hidden; } @end
@implementation Base @end
@implementation Middle @end

;--- leaf.m
#import <objc/NSObject.h>
@interface Base : NSObject { int a; } @end
@interface Middle : Base { int b; } @end
@interface Leaf : Middle { int c; } @end
@implementation Leaf @end

;--- gen
clang -target x86_64-apple-macosx10.15 -fobjc-runtime=macosx-10.15 -S -emit-llvm -isysroot $(xcrun --show-sdk-path) middle.m -o middle.ll
clang -target x86_64-apple-macosx10.15 -fobjc-runtime=macosx-10.15 -S -emit-llvm -isysroot $(xcrun --show-sdk-path) leaf.m -o leaf.ll
llvm-link middle.ll leaf.ll -S -o -
# body.ll is auto-generated by linking middle.ll and leaf.ll
