; not handled properly and instead ended up in an infinite loop.
define void @bug36015(i32 %cmp0, i32 %count) {
; CHECK-LABEL: define void @bug36015(
; CHECK-SAME: i32 [[CMP0:%.*]], i32 [[COUNT:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    br label %[[LOOP_OUTER:.*]]
