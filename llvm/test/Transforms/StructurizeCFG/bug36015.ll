; CHECK-NEXT:    [[CTR_LOOP_OUTER:%.*]] = phi i32 [ 0, %[[ENTRY]] ], [ [[TMP3:%.*]], %[[FLOW2:.*]] ]
; CHECK-NEXT:    call void @foo(i32 0)
; CHECK-NEXT:    br label %[[LOOP_INNER:.*]]
; CHECK:       [[LOOP_INNER]]:
; CHECK-NEXT:    [[CTR_LOOP_INNER:%.*]] = phi i32 [ [[CTR_LOOP_OUTER]], %[[LOOP_OUTER]] ], [ [[TMP0:%.*]], %[[FLOW:.*]] ]
; CHECK-NEXT:    call void @foo(i32 1)
; CHECK-NEXT:    [[COND_INNER:%.*]] = icmp eq i32 [[CMP0]], [[CTR_LOOP_INNER]]
; CHECK-NEXT:    br i1 [[COND_INNER]], label %[[IF:.*]], label %[[FLOW]]
; CHECK:       [[IF]]:
; CHECK-NEXT:    [[CTR_IF:%.*]] = add i32 [[CTR_LOOP_INNER]], 1
; CHECK-NEXT:    call void @foo(i32 2)
; CHECK-NEXT:    [[COND_IF:%.*]] = icmp sge i32 [[CTR_IF]], [[COUNT]]
; CHECK-NEXT:    br label %[[FLOW]]
; CHECK:       [[FLOW]]:
; CHECK-NEXT:    [[TMP0]] = phi i32 [ [[CTR_IF]], %[[IF]] ], [ undef, %[[LOOP_INNER]] ]
; CHECK-NEXT:    [[TMP1:%.*]] = phi i1 [ [[COND_IF]], %[[IF]] ], [ true, %[[LOOP_INNER]] ]
; CHECK-NEXT:    [[TMP2:%.*]] = phi i1 [ false, %[[IF]] ], [ true, %[[LOOP_INNER]] ]
; CHECK-NEXT:    br i1 [[TMP1]], label %[[FLOW1:.*]], label %[[LOOP_INNER]]
; CHECK:       [[FLOW1]]:
; CHECK-NEXT:    br i1 [[TMP2]], label %[[ELSE:.*]], label %[[FLOW2]]
; CHECK:       [[ELSE]]:
; CHECK-NEXT:    [[CTR_ELSE:%.*]] = add i32 [[CTR_LOOP_INNER]], 1
