; CHECK-NEXT:    [[TMP3:%.*]] = phi i1 [ [[C_INV]], %[[T0]] ], [ [[TMP1]], %[[FLOW5]] ]
; CHECK-NEXT:    br i1 [[TMP3]], label %[[T1:.*]], label %[[FLOW7:.*]]
; CHECK:       [[T1]]:
; CHECK-NEXT:    br label %[[FLOW7]]
; CHECK:       [[FLOW8:.*]]:
; CHECK-NEXT:    [[TMP4:%.*]] = phi i1 [ false, %[[T2:.*]] ], [ [[TMP8:%.*]], %[[FLOW7]] ]
; CHECK-NEXT:    br i1 [[TMP4]], label %[[T1A:.*]], label %[[FLOW9]]
; CHECK:       [[T1A]]:
; CHECK-NEXT:    br label %[[FLOW9]]
; CHECK:       [[FLOW7]]:
; CHECK-NEXT:    [[TMP5]] = phi i1 [ false, %[[T1]] ], [ [[TMP6]], %[[FLOW6]] ]
; CHECK-NEXT:    [[TMP8]] = phi i1 [ true, %[[T1]] ], [ false, %[[FLOW6]] ]
; CHECK-NEXT:    [[TMP7:%.*]] = phi i1 [ [[D_INV]], %[[T1]] ], [ [[TMP0]], %[[FLOW6]] ]
; CHECK-NEXT:    br i1 [[TMP7]], label %[[T2]], label %[[FLOW8]]
; CHECK:       [[T2]]:
; CHECK-NEXT:    br label %[[FLOW8]]
; CHECK:       [[FLOW]]:
; CHECK-NEXT:    [[ISLAND_SEL:%.*]] = phi i1 [ true, %[[ENTRY_TARGET_T0]] ], [ false, %[[ENTRY_TARGET_T1]] ], [ false, %[[ENTRY_TARGET_T2]] ]
; CHECK-NEXT:    [[ISLAND_SEL1]] = phi i1 [ false, %[[ENTRY_TARGET_T0]] ], [ true, %[[ENTRY_TARGET_T1]] ], [ false, %[[ENTRY_TARGET_T2]] ]
