; CHECK-NEXT:    call void @llvm.amdgcn.unreachable()
; CHECK-NEXT:    br label %[[EXIT:.*]]
; CHECK:       [[CONT]]:
; CHECK-NEXT:    br label %[[FLOW:.*]]
; CHECK:       [[FLOW]]:
; CHECK-NEXT:    br label %[[EXIT]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    ret void
;
