; CHECK:       [[FLOW:.*]]:
; CHECK-NEXT:    [[ISLAND_SEL:%.*]] = phi i1 [ true, %[[CB_TARGET_CB]] ], [ false, %[[CB_TARGET_RET]] ]
; CHECK-NEXT:    [[ISLAND_SEL_INV:%.*]] = xor i1 [[ISLAND_SEL]], true
; CHECK-NEXT:    br i1 [[ISLAND_SEL_INV]], label %[[RET:.*]], label %[[CB]]
