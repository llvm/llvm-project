; CHECK-NEXT:    br label %[[CB:.*]]
; CHECK:       [[FLOW4]]:
; CHECK-NEXT:    [[TMP2:%.*]] = phi i1 [ [[ISLAND_SEL:%.*]], %[[FLOW2:.*]] ], [ true, %[[INNER]] ]
; CHECK-NEXT:    [[TMP0:%.*]] = phi i1 [ [[ISLAND_SEL_INV:%.*]], %[[FLOW2]] ], [ true, %[[INNER]] ]
; CHECK-NEXT:    br i1 [[TMP0]], label %[[FLOW5:.*]], label %[[INNER]]
; CHECK:       [[CB]]:
; CHECK-NEXT:    callbr void asm "", "!i"()
