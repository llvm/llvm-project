; CHECK:       [[FLOW5:.*]]:
; CHECK-NEXT:    [[TMP0:%.*]] = phi i1 [ true, %[[FLOW3:.*]] ], [ false, %[[FLOW:.*]] ]
; CHECK-NEXT:    [[TMP1:%.*]] = phi i1 [ [[ISLAND_SEL1:%.*]], %[[FLOW3]] ], [ false, %[[FLOW]] ]
