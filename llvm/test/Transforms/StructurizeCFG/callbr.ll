; CHECK:       [[ENTRY_TARGET_T0]]:
; CHECK-NEXT:    br label %[[FLOW]]
; CHECK:       [[ENTRY_TARGET_T1]]:
; CHECK-NEXT:    br label %[[FLOW]]
; CHECK:       [[ENTRY_TARGET_T2]]:
; CHECK-NEXT:    br label %[[FLOW]]
