; intrinsic callbr (kill) that is the latch of a loop.
define void @callbr_kill_in_loop(i1 %c, i1 %d) {
; CHECK-LABEL: define void @callbr_kill_in_loop(
; CHECK-SAME: i1 [[C:%.*]], i1 [[D:%.*]]) {
