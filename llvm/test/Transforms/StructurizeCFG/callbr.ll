; ===== Data flow across the island (return value / phis) =====

; A PHI in the join consumes the callbr return value across the bypass.
define i32 @callbr_phi_uses_return_value(i1 %c) {
; CHECK-LABEL: define i32 @callbr_phi_uses_return_value(
; CHECK-SAME: i1 [[C:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[V:%.*]] = callbr i32 asm "", "=r,!i"()
; CHECK-NEXT:            to label %[[FT:.*]] [label %[[IND:.*]]]
; CHECK:       [[FT]]:
; CHECK-NEXT:    br label %[[FLOW:.*]]
; CHECK:       [[IND]]:
; CHECK-NEXT:    br label %[[FLOW]]
; CHECK:       [[FLOW]]:
; CHECK-NEXT:    [[ISLAND_SEL:%.*]] = phi i1 [ true, %[[FT]] ], [ false, %[[IND]] ]
; CHECK-NEXT:    [[ISLAND_SEL_INV:%.*]] = xor i1 [[ISLAND_SEL]], true
; CHECK-NEXT:    br i1 [[ISLAND_SEL_INV]], label %[[FLOW1:.*]], label %[[JOIN:.*]]
; CHECK:       [[FLOW1]]:
; CHECK-NEXT:    br label %[[JOIN]]
; CHECK:       [[JOIN]]:
; CHECK-NEXT:    [[P:%.*]] = phi i32 [ [[V]], %[[FLOW]] ], [ 0, %[[FLOW1]] ]
; CHECK-NEXT:    ret i32 [[P]]
