; CHECK-NEXT:    br label %[[FLOW2]]
;
entry:
  br label %outer
outer:
  br label %inner
inner:
  br i1 %c, label %cb, label %inner.exit
cb:
  callbr void asm "", "!i"() to label %inner [label %outer]
inner.exit:
  br i1 %d, label %outer, label %exit
exit:
