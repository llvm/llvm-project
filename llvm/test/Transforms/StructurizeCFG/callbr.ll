; ===== Loops =====

; The callbr fallthrough edge loops back to the callbr block.
define void @callbr_self_loop_fallthrough(i1 %c) {
; CHECK-LABEL: define void @callbr_self_loop_fallthrough(
; CHECK-SAME: i1 [[C:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    br label %[[CB:.*]]
