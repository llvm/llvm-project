; NOTE: Assertions have been autogenerated by utils/update_test_checks.py
; RUN: opt < %s -passes=aggressive-instcombine -S | FileCheck %s

; Issue #202112: TruncInstCombine bailed when an expression-graph leaf was an
; Argument rather than a Constant or Instruction. The K&R-style rotl below is
; the minimal repro: clang lowers a u8 K&R parameter to an i16 %x because of
; default argument promotion, so the expression bottoms out at an Argument and
; the pre-patch graph builder refused to narrow it.

define zeroext i8 @rotl_kr(i16 noundef %x) {
; CHECK-LABEL: @rotl_kr(
; CHECK-NEXT:    [[X_TRUNC:%.*]] = trunc i16 [[X:%.*]] to i8
; CHECK-NEXT:    [[M:%.*]] = and i8 [[X_TRUNC]], -1
; CHECK-NEXT:    [[S:%.*]] = shl i8 [[M]], 1
; CHECK-NEXT:    [[R:%.*]] = lshr i8 [[M]], 7
; CHECK-NEXT:    [[O:%.*]] = or i8 [[S]], [[R]]
; CHECK-NEXT:    ret i8 [[O]]
;
  %m = and i16 %x, 255
  %s = shl nuw nsw i16 %m, 1
  %r = lshr i16 %m, 7
  %o = or disjoint i16 %s, %r
  %t = trunc i16 %o to i8
  ret i8 %t
}

; Trivial case: trunc directly off an Argument with no in-graph instructions.
; The patch deliberately bails here — narrowing would only move the trunc to
; the function entry without eliminating any work, and that's not a real win.

define i8 @trunc_arg_only(i16 %x) {
; CHECK-LABEL: @trunc_arg_only(
; CHECK-NEXT:    [[T:%.*]] = trunc i16 [[X:%.*]] to i8
; CHECK-NEXT:    ret i8 [[T]]
;
  %t = trunc i16 %x to i8
  ret i8 %t
}

; Longer chain rooted at the Argument: leading mask establishes KnownBits low
; byte; subsequent shifts/xor/or narrow uniformly. Mirrors the shape of the
; AES inverse-Sbox helper from the bug report.

define zeroext i8 @arg_chain_kr(i16 noundef %x) {
; CHECK-LABEL: @arg_chain_kr(
; CHECK-NEXT:    [[X_TRUNC:%.*]] = trunc i16 [[X:%.*]] to i8
; CHECK-NEXT:    [[M:%.*]] = and i8 [[X_TRUNC]], -1
; CHECK-NEXT:    [[A:%.*]] = shl i8 [[M]], 1
; CHECK-NEXT:    [[B:%.*]] = lshr i8 [[M]], 7
; CHECK-NEXT:    [[C:%.*]] = or i8 [[A]], [[B]]
; CHECK-NEXT:    [[D:%.*]] = xor i8 [[C]], 99
; CHECK-NEXT:    ret i8 [[D]]
;
  %m = and i16 %x, 255
  %a = shl i16 %m, 1
  %b = lshr i16 %m, 7
  %c = or i16 %a, %b
  %d = xor i16 %c, 99
  %t = trunc i16 %d to i8
  ret i8 %t
}

; Negative: shift amount equals narrow bitwidth — must NOT narrow, the
; existing shift-amount KnownBits gate still rules even with an Argument leaf.

define i8 @arg_shl_8_negative(i16 %x) {
; CHECK-LABEL: @arg_shl_8_negative(
; CHECK-NEXT:    [[S:%.*]] = shl i16 [[X:%.*]], 8
; CHECK-NEXT:    [[T:%.*]] = trunc i16 [[S]] to i8
; CHECK-NEXT:    ret i8 [[T]]
;
  %s = shl i16 %x, 8
  %t = trunc i16 %s to i8
  ret i8 %t
}

; Negative: KnownBits at the lshr's LHS allow the high byte to be set
; (the AND mask comes AFTER the shifts), so narrowing would change the
; result of the lshr. The pass must leave this alone.

define zeroext i8 @arg_no_leading_mask_negative(i16 noundef %x) {
; CHECK-LABEL: @arg_no_leading_mask_negative(
; CHECK-NEXT:    [[Y0:%.*]] = xor i16 [[X:%.*]], 99
; CHECK-NEXT:    [[Y0_SHL:%.*]] = shl i16 [[Y0]], 1
; CHECK-NEXT:    [[Y0_LSHR:%.*]] = lshr i16 [[Y0]], 7
; CHECK-NEXT:    [[Y0_ROT:%.*]] = or i16 [[Y0_SHL]], [[Y0_LSHR]]
; CHECK-NEXT:    [[SB:%.*]] = and i16 [[Y0_ROT]], 255
; CHECK-NEXT:    [[T:%.*]] = trunc i16 [[SB]] to i8
; CHECK-NEXT:    ret i8 [[T]]
;
  %y0 = xor i16 %x, 99
  %y0.shl = shl i16 %y0, 1
  %y0.lshr = lshr i16 %y0, 7
  %y0.rot = or i16 %y0.shl, %y0.lshr
  %sb = and i16 %y0.rot, 255
  %t = trunc i16 %sb to i8
  ret i8 %t
}
