; NOTE: Assertions have been autogenerated by utils/update_test_checks.py UTC_ARGS: --check-attributes --version 6
; Tests for the BFS-based "same-block fast path" inside
; AAPointerInfoImpl::forallInterferingAccesses, used to skip
; AA::isPotentiallyReachable calls when answering reachability between
; an instruction I and a candidate access Acc.
;
; forallInterferingAccesses asks, for each candidate access Acc, two
; reachability questions:
;
;   * forward  ("can I reach Acc?")    governs whether Acc is a
;                                       potentially-interfering write
;                                       w.r.t. I (read direction).
;   * backward ("can Acc reach I?")    governs whether Acc is a
;                                       potentially-interfering read
;                                       w.r.t. I (write direction).
;
; The optimization runs a per-Scope batch BFS and then, for same-block
; pairs (I and Acc in the same basic block), uses an exact-must-write
; barrier scan between them ("does any ExclusionSet instruction sit
; between I and Acc?") instead of an isPotentiallyReachable call. The
; barrier scan is sound as a negative filter when "BFSSafe" holds -
; currently an alloca in a norecurse function: in that case there is
; no inter-procedural re-entry path that could reach the access while
; bypassing the in-block barrier, so a barrier between I and Acc
; proves non-reachability without isPotentiallyReachable.
;
; The same-block fast path is implemented as two parallel branches
; gated on BFSSafe. The first three tests exercise the BFSSafe branch
; (alloca in a norecurse function); the last two exercise the
; non-BFSSafe branch (alloca in a self-recursive function, so
; norecurse is not derived and BFSSafe is false). Each test pins down
; an end-to-end optimization outcome that succeeds only when same-block
; reachability resolution gives the right answer for every (I, Acc)
; pair AAPointerInfo asks about.
;
; BFSSafe case:
;   * same_block_read              - read direction: a load with two
;                                     prior same-block writes, the
;                                     first of which is killed by an
;                                     in-block must-write barrier. The
;                                     load must fold to the barrier's
;                                     value.
;   * same_block_write             - write direction: a chain of three
;                                     same-block stores with a downstream
;                                     load. The earlier stores must be
;                                     recognized as killed and the load
;                                     must fold to the latest store's
;                                     value.
;   * barrier_between_two_loads    - two same-block loads separated by
;                                     a must-write barrier. Both loads
;                                     must fold: the first to the
;                                     upstream init value, the second
;                                     to the barrier's value.
;
; Non-BFSSafe case:
;   * nonbfssafe_read              - read-direction analogue of
;                                     same_block_read, in a self-
;                                     recursive function so BFSSafe is
;                                     false. The non-BFSSafe branch's
;                                     same-block barrier scan must
;                                     resolve the (Acc=upstream-write,
;                                     I=load) backward query for the
;                                     load to fold.
;   * nonbfssafe_write             - write-direction analogue of
;                                     same_block_write, in a self-
;                                     recursive function. The
;                                     non-BFSSafe branch's same-block
;                                     barrier scan must rule out the
;                                     killed upstream stores so the
;                                     load folds to the latest store's
;                                     value.
;
; RUN: opt -aa-pipeline=basic-aa -passes=attributor -attributor-manifest-internal -attributor-annotate-decl-cs -S < %s | FileCheck %s --check-prefixes=CHECK,TUNIT
; RUN: opt -aa-pipeline=basic-aa -passes=attributor-cgscc -attributor-manifest-internal -attributor-annotate-decl-cs -S < %s | FileCheck %s --check-prefixes=CHECK,CGSCC

; ------------------------------------------------------------------
; same_block_read - read direction.
;
; AAPointerInfo asks, for the load `%v`, whether the upstream `store
; i32 1` interferes with `%v`. Take I = the load `%v`, Acc = the
; upstream `store i32 1`.
;
; The forward direction's same-block fast path is gated on
; I.comesBefore(Acc). Here Acc is upstream of I, so I.comesBefore(Acc)
; is false; the fast path does not fire and the call falls through to
; AA::isPotentiallyReachable.
;
; The backward direction's same-block fast path is gated on
; Acc.comesBefore(I). That holds, so the fast path fires: it scans
; ExcludedBlockInsts for any ExclI with Acc.comesBefore(ExclI) and
; ExclI.comesBefore(I). The barrier `store i32 99` satisfies both, so
; the scan declares Acc to be killed before reaching I.
;
; With both directions resolved, %v folds to 99.
define i32 @same_block_read() norecurse nounwind {
; CHECK: Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
; CHECK-LABEL: define noundef i32 @same_block_read(
; CHECK-SAME: ) #[[ATTR0:[0-9]+]] {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    ret i32 99
;
entry:
  %p = alloca i32, align 4
  store i32 1, ptr %p, align 4
  store i32 99, ptr %p, align 4
  %v = load i32, ptr %p, align 4
  ret i32 %v
}

; ------------------------------------------------------------------
; same_block_write - write direction.
;
; A chain of three same-block stores followed by a load. AAPointerInfo
; asks, for each candidate Acc, whether it interferes with the load
; `%v`. Take I = the load `%v` for the discussion below; Acc ranges
; over the three stores.
;
; The forward direction's same-block fast path is gated on
; I.comesBefore(Acc). All three stores are upstream of I, so this is
; always false here and the fast path's forward branch never fires.
;
; The backward direction is gated on Acc.comesBefore(I) and is the
; relevant one. For Acc = `store i32 5`: the scan finds `store i32 7`
; with Acc.comesBefore(store7) and store7.comesBefore(I) -- Acc is
; killed before reaching I. For Acc = `store i32 7`: the scan finds
; `store i32 %x` with Acc.comesBefore(storeX) and storeX.comesBefore(I)
; -- Acc is killed before reaching I. Only `store i32 %x` survives as
; a real interferer, and it is also the dominating must-write feeding
; %v, so %v folds to %x.
define i32 @same_block_write(i32 %x) norecurse nounwind {
; CHECK: Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
; CHECK-LABEL: define i32 @same_block_write(
; CHECK-SAME: i32 returned [[X:%.*]]) #[[ATTR0]] {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[P:%.*]] = alloca i32, align 4
; CHECK-NEXT:    store i32 [[X]], ptr [[P]], align 4
; CHECK-NEXT:    ret i32 [[X]]
;
entry:
  %p = alloca i32, align 4
  store i32 5, ptr %p, align 4
  store i32 7, ptr %p, align 4
  store i32 %x, ptr %p, align 4
  %v = load i32, ptr %p, align 4
  ret i32 %v
}

; ------------------------------------------------------------------
; barrier_between_two_loads - barrier sitting between two same-block
; accesses, both of which AAPointerInfo must resolve correctly.
;
; AAPointerInfo asks reachability questions for each load
; independently, so each load takes its turn as I.
;
; First, take I = `%v0` and Acc = the upstream `store i32 7` and the
; downstream barrier `store i32 42`, in turn:
;   - For Acc = `store i32 7` (upstream of I): I.comesBefore(Acc) is
;     false and Acc.comesBefore(I) is true; the backward fast path
;     scans for a barrier between Acc and I but finds none in
;     ExcludedBlockInsts -- the only ExclI is `store i32 42`, which
;     fails Acc.comesBefore(ExclI) && ExclI.comesBefore(I) since the
;     barrier comes after I. Falls through to isPotentiallyReachable,
;     which gives the correct answer that `store i32 7` reaches I.
;     `store i32 7` is therefore the dominating must-write feeding
;     %v0; the load folds to 7.
;   - For Acc = `store i32 42` (downstream of I): I.comesBefore(Acc)
;     is true; the forward fast path scans for a barrier between I and
;     Acc. The only candidate ExclI is `store i32 42` itself, which
;     fails I.comesBefore(ExclI) && ExclI.comesBefore(Acc) (ExclI ==
;     Acc, not strictly before). Falls through to
;     isPotentiallyReachable, which correctly says the barrier does
;     not interfere with %v0.
;
; Second, take I = `%v1`. The reasoning is the symmetric of
; same_block_read: the upstream `store i32 7` is killed by the barrier
; `store i32 42` (backward fast path with the barrier between Acc and
; I), and `store i32 42` is the dominating must-write feeding %v1.
; The load folds to 42.
;
; The function reduces to `ret i32 49`.
define i32 @barrier_between_two_loads() norecurse nounwind {
; CHECK: Function Attrs: mustprogress nofree norecurse nosync nounwind willreturn memory(none)
; CHECK-LABEL: define noundef i32 @barrier_between_two_loads(
; CHECK-SAME: ) #[[ATTR0]] {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    ret i32 49
;
entry:
  %p = alloca i32, align 4
  store i32 7, ptr %p, align 4
  %v0 = load i32, ptr %p, align 4
  store i32 42, ptr %p, align 4
  %v1 = load i32, ptr %p, align 4
  %sum = add i32 %v0, %v1
  ret i32 %sum
}

; ==================================================================
; Non-BFSSafe case (alloca in a self-recursive function, so
; norecurse is not derived and BFSSafe is false). These tests exercise
; the "else" branch of the same-block fast path.
;
; Note that outside the I.comesBefore(Acc)/Acc.comesBefore(I) cases
; the same-block fast path falls through to
; AA::isPotentiallyReachable. In the non-BFSSafe case
; isPotentiallyReachable does NOT have an IsLiveInCalleeCB to
; short-circuit it, so it conservatively considers re-entry paths and
; can answer "reachable" where the BFSSafe case would short-circuit
; "not reachable". This is why the non-BFSSafe analogue of
; barrier_between_two_loads does NOT fold cleanly (the first load is
; preserved by the isPotentiallyReachable fallback's correct answer
; that recursion can clobber %p between invocations) and is therefore
; not included as a test here.
; ==================================================================

declare void @sink(i32)

; ------------------------------------------------------------------
; nonbfssafe_read - read direction in the non-BFSSafe case.
;
; Same compute-block shape as same_block_read, wrapped in a
; self-recursive function. Take I = the load `%v` and Acc = the
; upstream `store i32 1`. The relevant query is the backward one,
; gated on Acc.comesBefore(I), which holds. The non-BFSSafe branch's
; same-block barrier scan finds `store i32 99` with
; Acc.comesBefore(store99) && store99.comesBefore(I), so it declares
; Acc killed before reaching I. The load folds to 99.
define i32 @nonbfssafe_read(i32 %n) nounwind {
; CHECK: Function Attrs: nounwind
; CHECK-LABEL: define noundef i32 @nonbfssafe_read(
; CHECK-SAME: i32 [[N:%.*]]) #[[ATTR1:[0-9]+]] {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[CMP:%.*]] = icmp sgt i32 [[N]], 0
; CHECK-NEXT:    br i1 [[CMP]], label %[[RECURSE:.*]], label %[[COMPUTE:.*]]
; CHECK:       [[RECURSE]]:
; CHECK-NEXT:    [[NM1:%.*]] = sub i32 [[N]], 1
; CHECK-NEXT:    [[R:%.*]] = call noundef i32 @nonbfssafe_read(i32 [[NM1]]) #[[ATTR1]]
; CHECK-NEXT:    call void @sink(i32 noundef 99)
; CHECK-NEXT:    br label %[[COMPUTE]]
; CHECK:       [[COMPUTE]]:
; CHECK-NEXT:    ret i32 99
;
entry:
  %p = alloca i32, align 4
  %cmp = icmp sgt i32 %n, 0
  br i1 %cmp, label %recurse, label %compute

recurse:
  %nm1 = sub i32 %n, 1
  %r = call i32 @nonbfssafe_read(i32 %nm1)
  call void @sink(i32 %r)
  br label %compute

compute:
  store i32 1, ptr %p, align 4
  store i32 99, ptr %p, align 4
  %v = load i32, ptr %p, align 4
  ret i32 %v
}

; ------------------------------------------------------------------
; nonbfssafe_write - write direction in the non-BFSSafe case.
;
; Same compute-block shape as same_block_write, wrapped in a
; self-recursive function. Take I = the load `%v`; Acc ranges over the
; three stores. The backward fast path (gated on Acc.comesBefore(I))
; fires for the two upstream stores: for Acc = `store i32 5`, the
; non-BFSSafe branch's same-block barrier scan finds `store i32 7`
; satisfying Acc.comesBefore(store7) && store7.comesBefore(I); for
; Acc = `store i32 7`, the scan finds `store i32 %x` similarly. Both
; upstream stores are killed before reaching I. Only `store i32 %x`
; survives as a real interferer, and it is the dominating must-write
; feeding %v, so the load folds to %x.
define i32 @nonbfssafe_write(i32 %n, i32 %x) nounwind {
; CHECK: Function Attrs: nounwind
; CHECK-LABEL: define i32 @nonbfssafe_write(
; CHECK-SAME: i32 [[N:%.*]], i32 returned [[X:%.*]]) #[[ATTR1]] {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[P:%.*]] = alloca i32, align 4
; CHECK-NEXT:    [[CMP:%.*]] = icmp sgt i32 [[N]], 0
; CHECK-NEXT:    br i1 [[CMP]], label %[[RECURSE:.*]], label %[[COMPUTE:.*]]
; CHECK:       [[RECURSE]]:
; CHECK-NEXT:    [[NM1:%.*]] = sub i32 [[N]], 1
; CHECK-NEXT:    [[R:%.*]] = call i32 @nonbfssafe_write(i32 [[NM1]], i32 [[X]]) #[[ATTR1]]
; CHECK-NEXT:    call void @sink(i32 [[X]])
; CHECK-NEXT:    br label %[[COMPUTE]]
; CHECK:       [[COMPUTE]]:
; CHECK-NEXT:    store i32 [[X]], ptr [[P]], align 4
; CHECK-NEXT:    ret i32 [[X]]
;
entry:
  %p = alloca i32, align 4
  %cmp = icmp sgt i32 %n, 0
  br i1 %cmp, label %recurse, label %compute

recurse:
  %nm1 = sub i32 %n, 1
  %r = call i32 @nonbfssafe_write(i32 %nm1, i32 %x)
  call void @sink(i32 %r)
  br label %compute

compute:
  store i32 5, ptr %p, align 4
  store i32 7, ptr %p, align 4
  store i32 %x, ptr %p, align 4
  %v = load i32, ptr %p, align 4
  ret i32 %v
}
