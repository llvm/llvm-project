; CHECK-NEXT:    [[TMP2:%.*]] = add i32 [[TMP1]], -1
; CHECK-NEXT:    [[TMP3:%.*]] = sub i32 [[TMP2]], [[LSR_IV_NEXT_LCSSA]]
; CHECK-NEXT:    ret i32 [[TMP3]]
;

entry:
  br label %loop

loop:                                           ; preds = %loop, %entry
