; CHECK-NEXT:    ret { i32, i32 } [[RES]]
;
  %res = call { i32, i32 } @callee(ptr %p)
  ret { i32, i32 } %res
}

define internal { i32, i32 } @callee(ptr %p) {
; CHECK-LABEL: define internal { i32, i32 } @callee(
; CHECK-SAME: { i32, i32 } [[P_0_VAL:%.*]]) {
; CHECK-NEXT:    ret { i32, i32 } [[P_0_VAL]]
;
  %res = load { i32, i32 }, ptr %p
  ret { i32, i32 } %res
}
