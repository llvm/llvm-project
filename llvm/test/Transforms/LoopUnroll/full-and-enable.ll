; Check that a loop with both llvm.loop.unroll.full and llvm.loop.unroll.enable
; metadata is fully unrolled.

define void @full_and_enable(ptr %p) {
; CHECK-LABEL: define void @full_and_enable(
; CHECK-SAME: ptr [[P:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    br label %[[LOOP:.*]]
; CHECK:       [[LOOP]]:
; CHECK-NEXT:    store i32 0, ptr [[P]], align 4
; CHECK-NEXT:    [[PTR_1:%.*]] = getelementptr inbounds i32, ptr [[P]], i64 1
; CHECK-NEXT:    store i32 0, ptr [[PTR_1]], align 4
; CHECK-NEXT:    ret void
;
entry:
  br label %loop

loop:
  %iv = phi i64 [ 0, %entry ], [ %iv.next, %loop ]
  %ptr = getelementptr inbounds i32, ptr %p, i64 %iv
  store i32 0, ptr %ptr, align 4
  %iv.next = add nuw nsw i64 %iv, 1
  %cmp = icmp eq i64 %iv.next, 2
  br i1 %cmp, label %exit, label %loop, !llvm.loop !0

exit:
  ret void
}

