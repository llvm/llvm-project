; CHECK-NEXT:    [[GEP:%.*]] = getelementptr i64, ptr [[XP]], i64 [[IV]]
; CHECK-NEXT:    [[X:%.*]] = load i64, ptr [[GEP]], align 4
; CHECK-NEXT:    [[DIV]] = udiv i64 [[X]], [[Y]]
