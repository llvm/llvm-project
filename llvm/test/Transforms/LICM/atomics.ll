; Check that we can hoist unordered loads
define i32 @test1(ptr nocapture %y) nounwind uwtable ssp {
; CHECK-LABEL: define i32 @test1(
; CHECK-SAME: ptr captures(none) [[Y:%.*]]) #[[ATTR0:[0-9]+]] {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    [[VAL:%.*]] = load atomic i32, ptr [[Y]] unordered, align 4
; CHECK-NEXT:    br label %[[LOOP:.*]]
; CHECK:       [[LOOP]]:
; CHECK-NEXT:    [[I:%.*]] = phi i32 [ [[INC:%.*]], %[[LOOP]] ], [ 0, %[[ENTRY]] ]
; CHECK-NEXT:    [[INC]] = add nsw i32 [[I]], 1
; CHECK-NEXT:    [[EXITCOND:%.*]] = icmp eq i32 [[INC]], [[VAL]]
; CHECK-NEXT:    br i1 [[EXITCOND]], label %[[END:.*]], label %[[LOOP]]
; CHECK:       [[END]]:
; CHECK-NEXT:    [[VAL_LCSSA:%.*]] = phi i32 [ [[VAL]], %[[LOOP]] ]
; CHECK-NEXT:    ret i32 [[VAL_LCSSA]]
;
entry:
  br label %loop

loop:
  %i = phi i32 [ %inc, %loop ], [ 0, %entry ]
  %val = load atomic i32, ptr %y unordered, align 4
  %inc = add nsw i32 %i, 1
  %exitcond = icmp eq i32 %inc, %val
  br i1 %exitcond, label %end, label %loop

end:
  ret i32 %val
}

; Check that we don't sink/hoist monotonic loads
; (Strictly speaking, it's not forbidden, but it's supposed to be possible to
; use monotonic for spinlock-like constructs.)
define i32 @test2(ptr nocapture %y) nounwind uwtable ssp {
; CHECK-LABEL: define i32 @test2(
; CHECK-SAME: ptr captures(none) [[Y:%.*]]) #[[ATTR0]] {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    br label %[[LOOP:.*]]
; CHECK:       [[LOOP]]:
; CHECK-NEXT:    [[VAL:%.*]] = load atomic i32, ptr [[Y]] monotonic, align 4
; CHECK-NEXT:    [[EXITCOND:%.*]] = icmp ne i32 [[VAL]], 0
; CHECK-NEXT:    br i1 [[EXITCOND]], label %[[END:.*]], label %[[LOOP]]
; CHECK:       [[END]]:
; CHECK-NEXT:    [[VAL_LCSSA:%.*]] = phi i32 [ [[VAL]], %[[LOOP]] ]
; CHECK-NEXT:    ret i32 [[VAL_LCSSA]]
;
entry:
  br label %loop

loop:
  %val = load atomic i32, ptr %y monotonic, align 4
  %exitcond = icmp ne i32 %val, 0
  br i1 %exitcond, label %end, label %loop

end:
  ret i32 %val
}

