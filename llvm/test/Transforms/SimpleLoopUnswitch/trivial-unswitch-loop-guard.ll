define void @multiple_inner_loops3(i32 %M, i32 %N, ptr %A, ptr %B) {
; CHECK-LABEL: define void @multiple_inner_loops3(
; CHECK-SAME: i32 [[M:%.*]], i32 [[N:%.*]], ptr [[A:%.*]], ptr [[B:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
