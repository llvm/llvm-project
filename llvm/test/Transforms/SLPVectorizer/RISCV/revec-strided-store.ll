; CHECK-NEXT:    store <2 x i8> zeroinitializer, ptr [[OUT1]], align 2
; CHECK-NEXT:    ret void
;
entry:
  %out1 = getelementptr i8, ptr %out0, i64 3
  store <2 x i8> zeroinitializer, ptr %out0, align 2
  store <2 x i8> zeroinitializer, ptr %out1, align 2
  ret void
}

