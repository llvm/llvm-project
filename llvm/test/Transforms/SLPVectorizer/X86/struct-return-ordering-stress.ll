; CHECK-NEXT:    [[TMP2:%.*]] = shufflevector <4 x i32> [[TMP1]], <4 x i32> poison, <4 x i32> <i32 2, i32 0, i32 3, i32 1>
; CHECK-NEXT:    [[TMP3:%.*]] = load <4 x i32>, ptr @b, align 4
; CHECK-NEXT:    [[TMP4:%.*]] = shufflevector <4 x i32> [[TMP3]], <4 x i32> poison, <4 x i32> <i32 2, i32 0, i32 3, i32 1>
; CHECK-NEXT:    [[TMP5:%.*]] = call { <4 x i32>, <4 x i1> } @llvm.sadd.with.overflow.v4i32(<4 x i32> [[TMP2]], <4 x i32> [[TMP4]])
; CHECK-NEXT:    [[TMP6:%.*]] = extractvalue { <4 x i32>, <4 x i1> } [[TMP5]], 0
; CHECK-NEXT:    store <4 x i32> [[TMP6]], ptr @r, align 4
; CHECK-NEXT:    [[TMP7:%.*]] = mul <4 x i32> [[TMP6]], splat (i32 7)
; CHECK-NEXT:    [[TMP8:%.*]] = shufflevector <4 x i32> [[TMP7]], <4 x i32> poison, <4 x i32> <i32 1, i32 3, i32 0, i32 2>
; CHECK-NEXT:    store <4 x i32> [[TMP8]], ptr @c, align 4
; CHECK-NEXT:    ret void
;
  %a0 = load i32, ptr @a, align 4
  %a1 = load i32, ptr getelementptr inbounds ([4 x i32], ptr @a, i64 0, i64 1), align 4
  %a2 = load i32, ptr getelementptr inbounds ([4 x i32], ptr @a, i64 0, i64 2), align 4
  %a3 = load i32, ptr getelementptr inbounds ([4 x i32], ptr @a, i64 0, i64 3), align 4
  %b0 = load i32, ptr @b, align 4
  %b1 = load i32, ptr getelementptr inbounds ([4 x i32], ptr @b, i64 0, i64 1), align 4
  %b2 = load i32, ptr getelementptr inbounds ([4 x i32], ptr @b, i64 0, i64 2), align 4
