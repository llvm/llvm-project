  %x3 = call {i32, i1} @llvm.sadd.with.overflow.i32(i32 %a3, i32 %b3)
  %e0 = extractvalue {i32, i1} %x0, 0
  %e1 = extractvalue {i32, i1} %x1, 0
  %e2 = extractvalue {i32, i1} %x2, 0
  %e3 = extractvalue {i32, i1} %x3, 0
  %m0 = mul i32 %e0, 7
  %m1 = mul i32 %e1, 7
  %m2 = mul i32 %e2, 7
  %m3 = mul i32 %e3, 7
  store i32 %e2, ptr @r, align 4
  store i32 %e0, ptr getelementptr inbounds ([4 x i32], ptr @r, i64 0, i64 1), align 4
