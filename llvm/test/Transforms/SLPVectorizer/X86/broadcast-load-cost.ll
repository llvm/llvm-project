; NOTE: Assertions have been autogenerated by utils/update_test_checks.py UTC_ARGS: --version 6
; RUN: opt -passes=slp-vectorizer -S -mtriple=x86_64-unknown-linux -mcpu=penryn -slp-threshold=-2 -pass-remarks-output=%t < %s | FileCheck %s
; RUN: FileCheck %s --input-file=%t --check-prefix=YAML

; Verify that the SLP cost estimator forwards the gathered scalar VL as the
; Args operand to TTI::getShuffleCost() for the final permutation produced by
; ShuffleCostEstimator::finalize(). On SSE3 the X86 SK_Broadcast lookup
; recognises a v2f64 broadcast-of-load (movddup folds the load) when any
; element of Args is a LoadInst, and reports the shuffle as free. Without
; the VL forward, Args is empty, the lookup is skipped, and the broadcast
; is charged the regular shufpd cost (1 unit), making the vectorized form
; appear less profitable.

; YAML-LABEL: --- !Passed
; YAML-NEXT: Pass:            slp-vectorizer
; YAML-NEXT: Name:            StoresVectorized
; YAML-NEXT: Function:        bcast_v2f64_load
; YAML-NEXT: Args:
; YAML-NEXT:  - String:          'Stores SLP vectorized with cost '
; YAML-NEXT:  - Cost:            '-1'

define void @bcast_v2f64_load(ptr %A, double %y, double %z, ptr %S) {
; CHECK-LABEL: define void @bcast_v2f64_load(
; CHECK-SAME: ptr [[A:%.*]], double [[Y:%.*]], double [[Z:%.*]], ptr [[S:%.*]]) #[[ATTR0:[0-9]+]] {
; CHECK-NEXT:    [[X:%.*]] = load double, ptr [[A]], align 8
; CHECK-NEXT:    [[TMP1:%.*]] = insertelement <2 x double> poison, double [[X]], i32 0
; CHECK-NEXT:    [[TMP2:%.*]] = shufflevector <2 x double> [[TMP1]], <2 x double> poison, <2 x i32> zeroinitializer
; CHECK-NEXT:    [[TMP3:%.*]] = insertelement <2 x double> poison, double [[Y]], i32 0
; CHECK-NEXT:    [[TMP4:%.*]] = insertelement <2 x double> [[TMP3]], double [[Z]], i32 1
; CHECK-NEXT:    [[TMP5:%.*]] = fmul <2 x double> [[TMP2]], [[TMP4]]
; CHECK-NEXT:    store <2 x double> [[TMP5]], ptr [[S]], align 8
; CHECK-NEXT:    ret void
;
  %x = load double, ptr %A, align 8
  %a = fmul double %x, %y
  %b = fmul double %x, %z
  %s1 = getelementptr inbounds double, ptr %S, i64 1
  store double %a, ptr %S, align 8
  store double %b, ptr %s1, align 8
  ret void
}
