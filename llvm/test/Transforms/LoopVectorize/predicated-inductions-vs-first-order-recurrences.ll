  %gep = getelementptr inbounds i64, ptr %dst, i64 %prev
  store i64 %iv, ptr %gep, align 8
  %cmp = icmp slt i64 %iv.next, %n
  br i1 %cmp, label %loop, label %exit

exit:
  %result = phi i64 [ %ext, %loop ]
  ret i64 %result
}
