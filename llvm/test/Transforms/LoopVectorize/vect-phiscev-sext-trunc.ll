  %l = load i32, ptr %B.gep
  %c = icmp eq i32 %l, 0
  br i1 %c, label %then, label %latch

then:
  %A.gep = getelementptr inbounds i32, ptr %A, i64 %iv
  store i32 0, ptr %A.gep
  br label %latch

