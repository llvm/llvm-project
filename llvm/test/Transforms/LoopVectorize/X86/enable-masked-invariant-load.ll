; CHECK-ON:       vector.ph:
; CHECK-ON-NEXT:    [[N_MOD_VF:%.*]] = urem i64 [[N]], 4
; CHECK-ON-NEXT:    [[N_VEC:%.*]] = sub i64 [[N]], [[N_MOD_VF]]
; CHECK-ON-NEXT:    br label [[VECTOR_BODY:%.*]]
; CHECK-ON:       vector.body:
