  %iv.next = sub nsw i16 %iv, 1
  %exit.cond = icmp ne i16 %iv.next, 0
  br i1 %exit.cond, label %loop, label %exit

exit:
  %lcssa.1 = phi i16 [ %res, %loop ]
  %lcssa.2 = phi i16 [ %res, %loop ]
  ret i16 %lcssa.2
}
