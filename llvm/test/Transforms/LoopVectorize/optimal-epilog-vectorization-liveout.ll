entry:
  br label %loop

loop:
  %iv = phi i64 [ 0, %entry ], [ %iv.next, %loop ]
  %iv2 = phi i32 [ %start, %entry ], [ %iv2.next, %loop ]
  %gep = getelementptr i32, ptr %dst, i64 %iv
  store i32 0, ptr %gep, align 4
  %iv.next = add nuw i64 %iv, 1
  %iv2.next = add nuw i32 %iv2, 1
