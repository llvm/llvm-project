loop:
  %iv = phi i64 [ 0, %entry ], [ %iv.next, %loop ]
  %iv.next = add i64 %iv, 1
  %l.p = load ptr, ptr %p, align 8
  %gep = getelementptr i32, ptr %l.p, i64 %iv
  %iv.trunc = trunc i64 %iv.next to i32
  store i32 %iv.trunc, ptr %gep, align 4
