; CHECK-SAME: float nofpclass(nan inf) [[X:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    ret float 0.000000e+00
;
entry:
  %d = fsub float %x, %x
  ret float %d
}

; Original reproducer from the issue.

define double @missed_selfsub_consumer(float nofpclass(nan inf) %x,
; CHECK-LABEL: define double @missed_selfsub_consumer(
; CHECK-SAME: float nofpclass(nan inf) [[X:%.*]], double [[SCALE:%.*]], double [[ACC:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[MUL:%.*]] = fmul double [[SCALE]], 0.000000e+00
