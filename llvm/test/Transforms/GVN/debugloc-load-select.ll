; MSSA-NEXT:    [[TMP2:%.*]] = load i32, ptr [[DOT]], align 4, !dbg [[DBG9:![0-9]+]]
; MSSA-NEXT:    [[CMP174_NOT473:%.*]] = icmp eq i32 [[TMP2]], 0
; MSSA-NEXT:    ret void
