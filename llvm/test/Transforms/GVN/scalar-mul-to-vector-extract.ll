; Regression test for issue #185564: reuse the existing vector fmul in a
; scalarized reduction instead of recomputing the same lane multiplication.
define i1 @issue185564(<2 x float> %v0, float %s0, <2 x float> %v1, float %s1) {
; CHECK-LABEL: define i1 @issue185564(
; CHECK-SAME: <2 x float> [[V0:%.*]], float [[S0:%.*]], <2 x float> [[V1:%.*]], float [[S1:%.*]]) {
; CHECK-NEXT:    [[E0:%.*]] = extractelement <2 x float> [[V0]], i64 1
; CHECK-NEXT:    [[E1:%.*]] = extractelement <2 x float> [[V1]], i64 1
; CHECK-NEXT:    [[V:%.*]] = fmul <2 x float> [[V0]], [[V1]]
; CHECK-NEXT:    [[LANE0:%.*]] = extractelement <2 x float> [[V]], i64 0
; CHECK-NEXT:    [[LANE1:%.*]] = extractelement <2 x float> [[V]], i64 1
; CHECK-NEXT:    [[SUM01:%.*]] = fadd float [[LANE0]], [[LANE1]]
; CHECK-NEXT:    [[TAIL:%.*]] = fmul float [[S0]], [[S1]]
; CHECK-NEXT:    [[SUM:%.*]] = fadd float [[TAIL]], [[SUM01]]
; CHECK-NEXT:    [[CMP:%.*]] = fcmp olt float [[SUM]], 0.000000e+00
; CHECK-NEXT:    ret i1 [[CMP]]
;
  %e0 = extractelement <2 x float> %v0, i64 1
  %e1 = extractelement <2 x float> %v1, i64 1
  %v = fmul <2 x float> %v0, %v1
  %lane0 = extractelement <2 x float> %v, i64 0
  %lane1mul = fmul float %e0, %e1
  %sum01 = fadd float %lane0, %lane1mul
  %tail = fmul float %s0, %s1
  %sum = fadd float %tail, %sum01
  %cmp = fcmp olt float %sum, 0.000000e+00
  ret i1 %cmp
}

