; CHECK-NEXT:    [[V:%.*]] = fmul <2 x float> [[V0]], [[V1]]
; CHECK-NEXT:    [[TMP1:%.*]] = extractelement <2 x float> [[V]], i64 0
; CHECK-NEXT:    ret float [[TMP1]]
;
  %e0 = extractelement <2 x float> %v0, i64 0
  %e1 = extractelement <2 x float> %v1, i64 0
