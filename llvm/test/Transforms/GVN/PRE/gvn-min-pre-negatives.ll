  %rhs.gep1 = getelementptr i32, ptr %a, i64 %idx.ext
  %rhs.gep2 = getelementptr i8, ptr %rhs.gep1, i64 -4
  %rhs = load i32, ptr %rhs.gep2, align 4
  %cmp = icmp slt i32 %lhs, %rhs
  %iv.next = add i64 %iv, 1
  %newidx = trunc i64 %iv.next to i32
  %idx.next = select i1 %cmp, i32 %newidx, i32 %idx.outer
  %cnt.next = add i32 %cnt, 1
  %cont = icmp ult i32 %cnt, 1
  br i1 %cont, label %loop, label %outer
}

