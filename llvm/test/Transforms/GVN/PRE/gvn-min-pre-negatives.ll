; Negative test: hoistable load is unordered-atomic. Memoizing across
; iterations would drop the per-iteration atomic semantics.
define i32 @test_atomic_hoistable_load(ptr %a) {
; CHECK-LABEL: define i32 @test_atomic_hoistable_load(
; CHECK-SAME: ptr [[A:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*]]:
; CHECK-NEXT:    br label %[[LOOP:.*]]
; CHECK:       [[LOOP]]:
; CHECK-NEXT:    [[IV:%.*]] = phi i64 [ 3, %[[ENTRY]] ], [ [[IV_NEXT:%.*]], %[[LOOP]] ]
; CHECK-NEXT:    [[CTR:%.*]] = phi i64 [ 3, %[[ENTRY]] ], [ [[CTR_NEXT:%.*]], %[[LOOP]] ]
; CHECK-NEXT:    [[IDX:%.*]] = phi i32 [ 1, %[[ENTRY]] ], [ [[IDX_NEXT:%.*]], %[[LOOP]] ]
; CHECK-NEXT:    [[IV_NEXT]] = add nsw i64 [[IV]], -1
; CHECK-NEXT:    [[LHS_GEP:%.*]] = getelementptr i32, ptr [[A]], i64 [[IV]]
; CHECK-NEXT:    [[LHS:%.*]] = load i32, ptr [[LHS_GEP]], align 4
; CHECK-NEXT:    [[IDX_EXT:%.*]] = sext i32 [[IDX]] to i64
; CHECK-NEXT:    [[RHS_GEP1:%.*]] = getelementptr i32, ptr [[A]], i64 [[IDX_EXT]]
; CHECK-NEXT:    [[RHS_GEP2:%.*]] = getelementptr i8, ptr [[RHS_GEP1]], i64 -4
; CHECK-NEXT:    [[RHS:%.*]] = load atomic i32, ptr [[RHS_GEP2]] unordered, align 4
; CHECK-NEXT:    [[CMP:%.*]] = icmp slt i32 [[LHS]], [[RHS]]
; CHECK-NEXT:    [[NEWIDX:%.*]] = trunc nsw i64 [[IV_NEXT]] to i32
; CHECK-NEXT:    [[IDX_NEXT]] = select i1 [[CMP]], i32 [[NEWIDX]], i32 [[IDX]]
; CHECK-NEXT:    [[CTR_NEXT]] = add nsw i64 [[CTR]], -1
; CHECK-NEXT:    [[CONT:%.*]] = icmp samesign ugt i64 [[CTR]], 1
; CHECK-NEXT:    br i1 [[CONT]], label %[[LOOP]], label %[[EXIT:.*]]
; CHECK:       [[EXIT]]:
; CHECK-NEXT:    ret i32 [[IDX_NEXT]]
;
entry:
  br label %loop
loop:
  %iv = phi i64 [ 3, %entry ], [ %iv.next, %loop ]
  %ctr = phi i64 [ 3, %entry ], [ %ctr.next, %loop ]
  %idx = phi i32 [ 1, %entry ], [ %idx.next, %loop ]
  %iv.next = add nsw i64 %iv, -1
  %lhs.gep = getelementptr i32, ptr %a, i64 %iv
  %lhs = load i32, ptr %lhs.gep, align 4
  %idx.ext = sext i32 %idx to i64
  %rhs.gep1 = getelementptr i32, ptr %a, i64 %idx.ext
  %rhs.gep2 = getelementptr i8, ptr %rhs.gep1, i64 -4
  %rhs = load atomic i32, ptr %rhs.gep2 unordered, align 4
  %cmp = icmp slt i32 %lhs, %rhs
  %newidx = trunc nsw i64 %iv.next to i32
  %idx.next = select i1 %cmp, i32 %newidx, i32 %idx
  %ctr.next = add nsw i64 %ctr, -1
  %cont = icmp samesign ugt i64 %ctr, 1
  br i1 %cont, label %loop, label %exit
exit:
  ret i32 %idx.next
}

