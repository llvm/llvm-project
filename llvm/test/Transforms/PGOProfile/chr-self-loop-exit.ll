; NOTE: Assertions have been autogenerated by utils/update_test_checks.py UTC_ARGS: --version 5
; Test that CHR correctly handles an exit block with a self-loop back-edge
; and unreachable predecessors when inserting trivial phi nodes.
;
; CHR (Control Height Reduction) inserts trivial phi nodes at the scope exit
; block for values defined inside the scope. When the exit block has a
; self-loop back-edge, the instruction being phi'd does not dominate that
; edge. The correct incoming value for the self-loop edge is the phi itself,
; expressing a loop-carried value. Unreachable predecessors should be
; skipped entirely.
;
; RUN: opt < %s -passes='require<profile-summary>,function(chr)' -S | FileCheck %s

target datalayout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i8:8:32-i16:16:32-i64:64-i128:128-n32:64-S128-Fn32"
target triple = "aarch64-unknown-linux-gnu"

