; CHECK-NEXT:    br i1 [[TOBOOL22_NOT_1_NONCHR]], label %[[COND_FALSE_1_NONCHR:.*]], label %[[FOR_COND23_1]], !prof [[PROF33]]
; CHECK:       [[COND_FALSE_1_NONCHR]]:
