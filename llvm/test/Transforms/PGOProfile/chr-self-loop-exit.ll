; CHECK-NEXT:    br i1 false, label %[[FOR_END43:.*]], label %[[IF_END21]]
; CHECK:       [[IF_END21]]:
; CHECK-NEXT:    [[Z_ADDR_04:%.*]] = phi i8 [ 0, %[[ENTRY]] ], [ [[TMP2:%.*]], %[[FOR_COND1_LOOPEXIT]] ]
