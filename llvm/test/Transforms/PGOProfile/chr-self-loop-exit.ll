; CHECK-NEXT:    br i1 [[TMP1]], label %[[IF_END21_SPLIT:.*]], label %[[IF_END21_SPLIT_NONCHR:.*]], !prof [[PROF31:![0-9]+]]
; CHECK:       [[IF_END21_SPLIT]]:
