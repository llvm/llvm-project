; Basic case from issue #138636: zext(i1) stored in the false-branch successor
; should be folded to 0 because the branch condition is known false there.
define void @zext_i1_false_branch(ptr writeonly %p0, i1 %cond, ptr writeonly %p1) {
; CHECK-LABEL: @zext_i1_false_branch(
; CHECK-NEXT:    [[EXT:%.*]] = zext i1 [[COND:%.*]] to i8
; CHECK-NEXT:    store i8 [[EXT]], ptr [[P0:%.*]], align 1
; CHECK-NEXT:    br i1 [[COND]], label [[TRUE:%.*]], label [[FALSE:%.*]]
; CHECK:       false:
; CHECK-NEXT:    store i8 0, ptr [[P1:%.*]], align 1
; CHECK-NEXT:    br label [[END:%.*]]
; CHECK:       true:
; CHECK-NEXT:    br label [[END]]
; CHECK:       end:
; CHECK-NEXT:    ret void
;
  %ext = zext i1 %cond to i8
  store i8 %ext, ptr %p0, align 1
  br i1 %cond, label %true, label %false

false:
  store i8 %ext, ptr %p1, align 1
  br label %end

true:
  br label %end

end:
  ret void
}

