; CHECK-NEXT:    call void @__test_paren_post_load(ptr [[PTR]], i64 [[TMP1]], i32 7, i8 0, i32 -3) #[[ATTR0]]
; CHECK-NEXT:    [[V4:%.*]] = load volatile i32, ptr [[PTR]], align 4
; CHECK-NEXT:    [[V5:%.*]] = load atomic i32, ptr [[PTR]] monotonic, align 4
; CHECK-NEXT:    [[V6:%.*]] = load atomic volatile i32, ptr [[PTR]] acquire, align 4
; CHECK-NEXT:    [[SUM1:%.*]] = add i32 [[V1]], [[V2]]
; CHECK-NEXT:    [[SUM2:%.*]] = add i32 [[SUM1]], [[V3]]
; CHECK-NEXT:    [[SUM3:%.*]] = add i32 [[SUM2]], [[V4]]
; CHECK-NEXT:    [[SUM4:%.*]] = add i32 [[SUM3]], [[V5]]
; CHECK-NEXT:    [[SUM5:%.*]] = add i32 [[SUM4]], [[V6]]
; CHECK-NEXT:    ret i32 [[SUM5]]
;
entry:
  ; Filter: (atomicity_ordering>3 || atomicity_ordering==0) && is_volatile==0

  ; Regular load: atomicity=0, volatile=0
  ; Evaluates: (0>3 || 0==0) && 0==0 = (false || true) && true = true && true = true
  ; Result: instrumented
  %v1 = load i32, ptr %ptr, align 4

  ; Atomic acquire load: atomicity=4, volatile=0
  ; Evaluates: (4>3 || 4==0) && 0==0 = (true || false) && true = true && true = true
  ; Result: instrumented
  %v2 = load atomic i32, ptr %ptr acquire, align 4

  ; Atomic seq_cst load: atomicity=7, volatile=0
  ; Evaluates: (7>3 || 7==0) && 0==0 = (true || false) && true = true && true = true
  ; Result: instrumented
  %v3 = load atomic i32, ptr %ptr seq_cst, align 4

  ; Volatile load: atomicity=0, volatile=1
  ; Evaluates: (0>3 || 0==0) && 1==0 = (false || true) && false = true && false = false
  ; Result: NOT instrumented
  %v4 = load volatile i32, ptr %ptr, align 4

  ; Atomic monotonic load: atomicity=2, volatile=0
  ; Evaluates: (2>3 || 2==0) && 0==0 = (false || false) && true = false && true = false
  ; Result: NOT instrumented
  %v5 = load atomic i32, ptr %ptr monotonic, align 4

  ; Atomic volatile acquire load: atomicity=4, volatile=1
  ; Evaluates: (4>3 || 4==0) && 1==0 = (true || false) && false = true && false = false
  ; Result: NOT instrumented
  %v6 = load atomic volatile i32, ptr %ptr acquire, align 4

  %sum1 = add i32 %v1, %v2
  %sum2 = add i32 %sum1, %v3
  %sum3 = add i32 %sum2, %v4
  %sum4 = add i32 %sum3, %v5
  %sum5 = add i32 %sum4, %v6
  ret i32 %sum5
}

