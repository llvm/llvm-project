define i32 @internal_func(i32 %x) {
; CHECK-LABEL: define i32 @internal_func(
; CHECK-SAME: i32 [[X:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[RESULT:%.*]] = add i32 [[X]], 42
; CHECK-NEXT:    ret i32 [[RESULT]]
;
entry:
  %result = add i32 %x, 42
  ret i32 %result
}

