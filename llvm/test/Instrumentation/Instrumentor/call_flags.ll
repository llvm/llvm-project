; CHECK: @__instrumentor_value_pack.4 = internal global <{ i32, i32, i64 }> <{ i32 8, i32 12, i64 100 }>
; CHECK: @__instrumentor_.str.5 = private unnamed_addr constant [19 x i8] c"llvm.memset.p0.i64\00", align 1
; CHECK: @__instrumentor_value_pack.6 = internal global <{ i32, i32, ptr, i32, i32, [7 x i8], i8, i32, i32, i64, i32, i32, [7 x i8], i1 }> <{ i32 8, i32 15, ptr null, i32 1, i32 12, [7 x i8] zeroinitializer, i8 0, i32 8, i32 12, i64 100, i32 1, i32 12, [7 x i8] zeroinitializer, i1 false }>
; CHECK: @__instrumentor_.str.7 = private unnamed_addr constant [5 x i8] c"free\00", align 1
; CHECK: @__instrumentor_deallocation_call_info = internal constant <{ ptr, i32, i32, i32 }> <{ ptr @__instrumentor_.str.3, i32 0, i32 -1, i32 -1 }>
