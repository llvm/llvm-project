entry:
  ; Test call to defined function - should have is_definition = true
  %result1 = call i32 @internal_func(i32 %a)

  ; Test call to external function - should have is_definition = false
  call void @external_func(i32 %result1, i64 %b)

  ; Test call to allocation function - should have allocation_info
  %ptr = call ptr @malloc(i64 100)

  ; Test call to intrinsic - should have intrinsic_id != 0, callee = nullptr
  call void @llvm.memset.p0.i64(ptr %ptr, i8 0, i64 100, i1 false)

  ; Test call to free function - should have deallocation_info
  call void @free(ptr %ptr)

  %result2 = zext i32 %result1 to i64
  ret i64 %result2
}

attributes #0 = { allockind("alloc,uninitialized") allocsize(0) }
attributes #1 = { allockind("free") "alloc-family"="malloc" }
