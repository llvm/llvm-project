; NOTE: Assertions have been autogenerated by utils/update_test_checks.py UTC_ARGS: --check-globals all --version 5
; RUN: opt < %s -passes=instrumentor -instrumentor-read-config-files=%S/call_flags_config.json -S | FileCheck %s

; This test checks that various CallIO flags are passed correctly:
; - callee address
; - callee_name
; - intrinsic_id (for both regular functions and intrinsics)
; - allocation_info (for allocation functions)
; - return_value (in post_call)
; - return_value_size (in post_call)
; - num_parameters
; - parameters (with replacement)
; - is_definition (different for declarations vs definitions)
; - id

target datalayout = "e-m:o-p270:32:32-p271:32:32-p272:64:64-i64:64-f80:128-n8:16:32:64-S128"

declare void @external_func(i32, i64)
declare ptr @malloc(i64) #0
declare void @free(ptr allocptr) #1
declare void @llvm.memset.p0.i64(ptr nocapture writeonly, i8, i64, i1)

