; CHECK: @__instrumentor_.str.1 = private unnamed_addr constant [14 x i8] c"external_func\00", align 1
; CHECK: @__instrumentor_value_pack.2 = internal global <{ i32, i32, [4 x i8], i32, i32, i32, i64 }> <{ i32 4, i32 12, [4 x i8] zeroinitializer, i32 0, i32 8, i32 12, i64 0 }>
