{
  "configuration": {
    "runtime_prefix": "__instrumentor_"
  },
  "instruction_pre": {
    "numeric": {
      "enabled": true,
      "filter": "(flags.nnan || flags.nsz) && !flags.ninf",
      "type_id": true,
      "size": true,
      "opcode": true,
      "left": true,
      "right": true,
      "flags": true,
      "id": true
    }
  },
  "instruction_post": {
    "numeric": {
      "enabled": true,
      "filter": "flags == 0b11100",
      "type_id": true,
      "size": true,
      "opcode": true,
      "left": true,
      "right": true,
      "flags": true,
      "id": true
    }
  }
}
