; Test cast instruction instrumentation with opcode filtering.
; This test verifies that the filter on the opcode works to pick a single
; cast type (PtrToInt with opcode 48) out of many cast instructions.
; Only ptrtoint instructions should be instrumented, while other casts
; like inttoptr, trunc, zext, fptoui, etc. should be left uninstrumented.
;
; RUN: opt < %s -passes=instrumentor -instrumentor-read-config-files=%S/cast_filter_config.json -S | FileCheck %s


define void @test_filter_only_ptrtoint(ptr noundef %p1, i64 noundef %i1, i32 noundef %i2, float noundef %f1) {
; CHECK-LABEL: define void @test_filter_only_ptrtoint(
; CHECK-SAME: ptr noundef [[P1:%.*]], i64 noundef [[I1:%.*]], i32 noundef [[I2:%.*]], float noundef [[F1:%.*]]) {
; CHECK-NEXT:  [[ENTRY:.*:]]
; CHECK-NEXT:    [[TMP0:%.*]] = ptrtoint ptr [[P1]] to i64
; CHECK-NEXT:    call void @__instrumentor_pre_cast(i64 [[TMP0]], i32 48) #[[ATTR0:[0-9]+]]
; CHECK-NEXT:    [[A1:%.*]] = ptrtoint ptr [[P1]] to i64
; CHECK-NEXT:    [[TMP1:%.*]] = call i64 @__instrumentor_post_cast(i64 [[TMP0]], i64 [[A1]], i32 48) #[[ATTR0]]
; CHECK-NEXT:    [[P2:%.*]] = inttoptr i64 [[I1]] to ptr
; CHECK-NEXT:    [[TMP2:%.*]] = ptrtoint ptr [[P2]] to i64
; CHECK-NEXT:    [[T1:%.*]] = trunc i64 [[I1]] to i32
; CHECK-NEXT:    [[TMP3:%.*]] = zext i32 [[T1]] to i64
; CHECK-NEXT:    [[Z1:%.*]] = zext i32 [[I2]] to i64
; CHECK-NEXT:    [[FU:%.*]] = fptoui float [[F1]] to i32
; CHECK-NEXT:    [[TMP4:%.*]] = zext i32 [[FU]] to i64
; CHECK-NEXT:    [[FS:%.*]] = fptosi float [[F1]] to i32
; CHECK-NEXT:    [[TMP5:%.*]] = zext i32 [[FS]] to i64
; CHECK-NEXT:    call void @use_mixed(i64 [[TMP1]], ptr [[P2]], i32 [[T1]], i64 [[Z1]], i32 [[FU]], i32 [[FS]])
; CHECK-NEXT:    ret void
;
entry:
  %a1 = ptrtoint ptr %p1 to i64
  %p2 = inttoptr i64 %i1 to ptr
  %t1 = trunc i64 %i1 to i32
  %z1 = zext i32 %i2 to i64
  %fu = fptoui float %f1 to i32
  %fs = fptosi float %f1 to i32
  call void @use_mixed(i64 %a1, ptr %p2, i32 %t1, i64 %z1, i32 %fu, i32 %fs)
  ret void
}


