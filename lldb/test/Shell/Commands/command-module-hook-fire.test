# Test that module hooks fire when modules are loaded.
#
# RUN: %clang_host -g %S/Inputs/main.c -o %t
# RUN: %lldb -b -o 'file %t' \
# RUN:   -o 'target module-hook add -o "script print(\"HOOK_FIRED\")"' \
# RUN:   -o 'target modules add %t' \
# RUN:   2>&1 | FileCheck %s

# CHECK: Module hook #1 added.
# CHECK: HOOK_FIRED
