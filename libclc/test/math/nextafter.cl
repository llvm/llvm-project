// AMDGCN-NEXT:    [[TMP2:%.*]] = icmp sgt i16 [[TMP1]], -1
// AMDGCN-NEXT:    [[TMP3:%.*]] = select i1 [[TMP2]], i16 1, i16 -1
// AMDGCN-NEXT:    [[TMP4:%.*]] = add i16 [[TMP3]], [[TMP1]]
// AMDGCN-NEXT:    [[TMP5:%.*]] = bitcast i16 [[TMP4]] to half
// AMDGCN-NEXT:    [[TMP6:%.*]] = fcmp contract oeq half [[X]], 0.000000e+00
// AMDGCN-NEXT:    [[TMP7:%.*]] = fcmp ueq half [[X]], +inf
// AMDGCN-NEXT:    [[TMP8:%.*]] = select contract i1 [[TMP7]], half [[X]], half [[TMP5]]
// AMDGCN-NEXT:    [[TMP9:%.*]] = fcmp contract ogt half [[X]], 0.000000e+00
// AMDGCN-NEXT:    [[TMP10:%.*]] = bitcast half [[X]] to i16
// AMDGCN-NEXT:    [[TMP11:%.*]] = select i1 [[TMP9]], i16 -1, i16 1
// AMDGCN-NEXT:    [[TMP12:%.*]] = add i16 [[TMP11]], [[TMP10]]
// AMDGCN-NEXT:    [[TMP13:%.*]] = bitcast i16 [[TMP12]] to half
// AMDGCN-NEXT:    [[TMP14:%.*]] = select contract i1 [[TMP6]], half -5.960460e-08, half [[TMP13]]
// AMDGCN-NEXT:    [[TMP15:%.*]] = fcmp ueq half [[X]], -inf
// AMDGCN-NEXT:    [[TMP16:%.*]] = select contract i1 [[TMP15]], half [[X]], half [[TMP14]]
// AMDGCN-NEXT:    [[TMP17:%.*]] = fcmp contract olt half [[X]], [[Y]]
// AMDGCN-NEXT:    [[TMP18:%.*]] = select contract i1 [[TMP17]], half [[TMP8]], half [[Y]]
// AMDGCN-NEXT:    [[TMP19:%.*]] = fcmp contract ogt half [[X]], [[Y]]
// AMDGCN-NEXT:    [[TMP20:%.*]] = select contract i1 [[TMP19]], half [[TMP16]], half [[TMP18]]
// AMDGCN-NEXT:    [[NARROW_I_I_I:%.*]] = fcmp contract ord half [[X]], [[Y]]
// AMDGCN-NEXT:    [[TMP21:%.*]] = select contract i1 [[NARROW_I_I_I]], half [[TMP20]], half +qnan
// AMDGCN-NEXT:    ret half [[TMP21]]
//
half test_half(half x, half y) {
  return nextafter(x, y);
}

