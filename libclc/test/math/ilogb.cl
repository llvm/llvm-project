// RUN: %clang --target=%target -mcpu=%cpu -x cl -cl-std=CL3.0 -O2 -emit-llvm -S -o - %s | FileCheck %s --check-prefix=%check_prefix

#pragma OPENCL EXTENSION cl_khr_fp16 : enable

// AMDGCN-LABEL: define hidden i32 @test_half(
// AMDGCN-SAME: half noundef [[X:%.*]]) local_unnamed_addr #[[ATTR0:[0-9]+]] {
// AMDGCN-NEXT:  [[ENTRY:.*:]]
// AMDGCN-NEXT:    [[TMP0:%.*]] = tail call { half, i32 } @llvm.frexp.f16.i32(half [[X]])
// AMDGCN-NEXT:    [[TMP1:%.*]] = extractvalue { half, i32 } [[TMP0]], 1
// AMDGCN-NEXT:    [[TMP2:%.*]] = add nsw i32 [[TMP1]], -1
// AMDGCN-NEXT:    [[TMP3:%.*]] = tail call half @llvm.fabs.f16(half [[X]])
// AMDGCN-NEXT:    [[TMP4:%.*]] = fcmp one half [[TMP3]], +inf
// AMDGCN-NEXT:    [[TMP5:%.*]] = select i1 [[TMP4]], i32 [[TMP2]], i32 2147483647
// AMDGCN-NEXT:    [[TMP6:%.*]] = fcmp contract une half [[X]], 0.000000e+00
// AMDGCN-NEXT:    [[TMP7:%.*]] = select i1 [[TMP6]], i32 [[TMP5]], i32 -2147483648
// AMDGCN-NEXT:    ret i32 [[TMP7]]
//
int test_half(half x) {
  return ilogb(x);
}

