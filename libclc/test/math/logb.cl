// RUN: %clang --target=%target -mcpu=%cpu -x cl -cl-std=CL3.0 -O2 -emit-llvm -S -o - %s | FileCheck %s --check-prefix=%check_prefix

#pragma OPENCL EXTENSION cl_khr_fp16 : enable

// AMDGCN-LABEL: define hidden half @test_half(
// AMDGCN-SAME: half noundef [[X:%.*]]) local_unnamed_addr #[[ATTR0:[0-9]+]] {
// AMDGCN-NEXT:  [[ENTRY:.*:]]
// AMDGCN-NEXT:    [[TMP0:%.*]] = tail call { half, i32 } @llvm.frexp.f16.i32(half [[X]])
// AMDGCN-NEXT:    [[TMP1:%.*]] = extractvalue { half, i32 } [[TMP0]], 1
// AMDGCN-NEXT:    [[TMP2:%.*]] = add nsw i32 [[TMP1]], -1
// AMDGCN-NEXT:    [[TMP3:%.*]] = sitofp i32 [[TMP2]] to half
// AMDGCN-NEXT:    [[TMP4:%.*]] = tail call contract noundef half @llvm.fabs.f16(half [[X]])
// AMDGCN-NEXT:    [[TMP5:%.*]] = fcmp ueq half [[TMP4]], +inf
// AMDGCN-NEXT:    [[TMP6:%.*]] = select contract i1 [[TMP5]], half [[TMP4]], half [[TMP3]]
// AMDGCN-NEXT:    [[TMP7:%.*]] = fcmp contract une half [[X]], 0.000000e+00
// AMDGCN-NEXT:    [[TMP8:%.*]] = select contract i1 [[TMP7]], half [[TMP6]], half -inf
// AMDGCN-NEXT:    ret half [[TMP8]]
//
half test_half(half x) {
  return logb(x);
}

