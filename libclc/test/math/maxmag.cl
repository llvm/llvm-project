// REQUIRES: amdgpu-registered-target

// RUN: %clang --target=%target -mcpu=%cpu -x cl -cl-std=CL3.0 -O2 -emit-llvm -S -o - %s | FileCheck %s --check-prefix=%check_prefix

#pragma OPENCL EXTENSION cl_khr_fp16 : enable

// AMDGCN-LABEL: define hidden noundef half @test_half(
// AMDGCN-SAME: half noundef [[X:%.*]], half noundef [[Y:%.*]]) local_unnamed_addr #[[ATTR0:[0-9]+]] {
// AMDGCN-NEXT:  [[ENTRY:.*:]]
// AMDGCN-NEXT:    [[TMP0:%.*]] = tail call contract noundef half @llvm.fabs.f16(half [[X]])
// AMDGCN-NEXT:    [[TMP1:%.*]] = tail call contract noundef half @llvm.fabs.f16(half [[Y]])
// AMDGCN-NEXT:    [[TMP2:%.*]] = fcmp contract ogt half [[TMP0]], [[TMP1]]
// AMDGCN-NEXT:    [[TMP3:%.*]] = tail call contract noundef half @llvm.maximumnum.f16(half [[X]], half [[Y]])
// AMDGCN-NEXT:    [[TMP4:%.*]] = select contract i1 [[TMP2]], half [[X]], half [[TMP3]]
// AMDGCN-NEXT:    [[TMP5:%.*]] = fcmp contract ogt half [[TMP1]], [[TMP0]]
// AMDGCN-NEXT:    [[TMP6:%.*]] = select contract i1 [[TMP5]], half [[Y]], half [[TMP4]]
// AMDGCN-NEXT:    ret half [[TMP6]]
//
half test_half(half x, half y) {
  return maxmag(x, y);
}

