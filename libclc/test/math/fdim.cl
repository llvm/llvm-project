// AMDGCN-LABEL: define hidden noundef half @test_half(
// AMDGCN-SAME: half noundef [[X:%.*]], half noundef [[Y:%.*]]) local_unnamed_addr #[[ATTR0:[0-9]+]] {
// AMDGCN-NEXT:  [[ENTRY:.*:]]
// AMDGCN-NEXT:    [[TMP0:%.*]] = fcmp contract ugt half [[X]], [[Y]]
// AMDGCN-NEXT:    [[TMP1:%.*]] = fsub contract half [[X]], [[Y]]
// AMDGCN-NEXT:    [[TMP2:%.*]] = select contract i1 [[TMP0]], half [[TMP1]], half 0.000000e+00
// AMDGCN-NEXT:    ret half [[TMP2]]
//
half test_half(half x, half y) {
  return fdim(x, y);
}

