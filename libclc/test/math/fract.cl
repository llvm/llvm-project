// RUN: %clang --target=%target -mcpu=%cpu -x cl -cl-std=CL3.0 -O2 -emit-llvm -S -o - %s | FileCheck %s --check-prefix=%check_prefix

#pragma OPENCL EXTENSION cl_khr_fp16 : enable

// AMDGCN-LABEL: define hidden noundef half @test_half(
// AMDGCN-SAME: half noundef [[X:%.*]], ptr addrspace(1) noundef writeonly captures(none) initializes((0, 2)) [[IPTR:%.*]]) local_unnamed_addr #[[ATTR0:[0-9]+]] {
// AMDGCN-NEXT:  [[ENTRY:.*:]]
// AMDGCN-NEXT:    [[TMP0:%.*]] = tail call contract noundef half @llvm.floor.f16(half [[X]])
// AMDGCN-NEXT:    [[TMP1:%.*]] = fsub contract half [[X]], [[TMP0]]
// AMDGCN-NEXT:    [[TMP2:%.*]] = fcmp contract oge half [[TMP1]], 9.995110e-01
// AMDGCN-NEXT:    [[TMP3:%.*]] = select contract i1 [[TMP2]], half 9.995110e-01, half [[TMP1]]
// AMDGCN-NEXT:    [[TMP4:%.*]] = tail call half @llvm.fabs.f16(half [[X]])
// AMDGCN-NEXT:    [[TMP5:%.*]] = fcmp une half [[TMP4]], +inf
// AMDGCN-NEXT:    [[TMP6:%.*]] = select contract i1 [[TMP5]], half [[TMP3]], half 0.000000e+00
