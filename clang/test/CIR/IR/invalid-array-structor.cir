module {
  cir.func private @_ZN1SD1Ev(!cir.ptr<!rec_S>)
  // Static form: addr must be a pointer to an array type.
  cir.func @bad_static_dtor_not_array_ctor(%p: !cir.ptr<!cir.array<!rec_S x 10>>) {
    // expected-error@+1 {{'cir.array.dtor' op block argument pointee type must match the innermost array element type}}
