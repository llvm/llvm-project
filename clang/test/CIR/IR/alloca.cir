
// RUN: cir-opt %s --verify-roundtrip | FileCheck %s

!u64i = !cir.int<u, 64>
!u8i = !cir.int<u, 8>
!s32i = !cir.int<s, 32>
!void = !cir.void
module {
  cir.func dso_local @_Z11test_allocam(%arg0: !u64i) -> !cir.ptr<!void> {
    %0 = cir.alloca "n" align(8) init : !cir.ptr<!u64i>
    %1 = cir.alloca "__retval" align(8) : !cir.ptr<!cir.ptr<!void>>
    cir.store %arg0, %0 : !u64i, !cir.ptr<!u64i>
    %2 = cir.load align(8) %0 : !cir.ptr<!u64i>, !u64i
    // Dynamically sized alloca
    %3 = cir.alloca "bi_alloca" align(16) size(%2) : !cir.ptr<!u8i>
    %4 = cir.cast bitcast %3 : !cir.ptr<!u8i> -> !cir.ptr<!void>
    cir.store %4, %1 : !cir.ptr<!void>, !cir.ptr<!cir.ptr<!void>>
    %5 = cir.load %1 : !cir.ptr<!cir.ptr<!void>>, !cir.ptr<!void>
    cir.return %5 : !cir.ptr<!void>
  }

  // CHECK: cir.func dso_local @_Z11test_allocam(%arg0: !u64i) -> !cir.ptr<!void> {
  // CHECK:   %0 = cir.alloca "n" align(8) init : !cir.ptr<!u64i>
  // CHECK:   %1 = cir.alloca "__retval" align(8) : !cir.ptr<!cir.ptr<!void>>
  // CHECK:   cir.store %arg0, %0 : !u64i, !cir.ptr<!u64i>
  // CHECK:   %2 = cir.load align(8) %0 : !cir.ptr<!u64i>, !u64i
  // CHECK:   %3 = cir.alloca "bi_alloca" align(16) size(%2) : !cir.ptr<!u8i>
  // CHECK:   %4 = cir.cast bitcast %3 : !cir.ptr<!u8i> -> !cir.ptr<!void>
  // CHECK:   cir.store %4, %1 : !cir.ptr<!void>, !cir.ptr<!cir.ptr<!void>>
  // CHECK:   %5 = cir.load %1 : !cir.ptr<!cir.ptr<!void>>, !cir.ptr<!void>
  // CHECK:   cir.return %5 : !cir.ptr<!void>
  // CHECK: }
  // Parse tests for all flag combinations
  cir.func dso_local @test_alloca_flags() {
    // No flags
    %0 = cir.alloca "a" align(4) : !cir.ptr<!s32i>

    // init only
    %1 = cir.alloca "b" align(4) init : !cir.ptr<!s32i>

    // const only
    %2 = cir.alloca "c" align(4) const : !cir.ptr<!s32i>

    // init + const
    %3 = cir.alloca "d" align(4) init const : !cir.ptr<!s32i>

    // cleanup_dest_slot only
    %4 = cir.alloca "e" align(4) cleanup_dest_slot : !cir.ptr<!s32i>

    // all flags
    %6 = cir.alloca "f" align(4) init const cleanup_dest_slot : !cir.ptr<!s32i>

    // dynamic size, no flags
    %sz = cir.const #cir.int<4> : !u64i
    %7 = cir.alloca "h" align(16) size(%sz) : !cir.ptr<!u8i>

    // dynamic size + init
    %8 = cir.alloca "i" align(16) init size(%sz) : !cir.ptr<!u8i>

    cir.return
  }
  // CHECK-LABEL: cir.func dso_local @test_alloca_flags
  // CHECK:   cir.alloca "a" align(4) : !cir.ptr<!s32i>
  // CHECK:   cir.alloca "b" align(4) init : !cir.ptr<!s32i>
  // CHECK:   cir.alloca "c" align(4) const : !cir.ptr<!s32i>
  // CHECK:   cir.alloca "d" align(4) init const : !cir.ptr<!s32i>
  // CHECK:   cir.alloca "e" align(4) cleanup_dest_slot : !cir.ptr<!s32i>
  // CHECK:   cir.alloca "f" align(4) init const cleanup_dest_slot : !cir.ptr<!s32i>
  // CHECK:   cir.alloca "h" align(16) size(%{{.*}}) : !cir.ptr<!u8i>
  // CHECK:   cir.alloca "i" align(16) init size(%{{.*}}) : !cir.ptr<!u8i>
}
