// RUN: cir-opt %s -cir-to-llvm -o %t.mlir
// RUN: FileCheck --input-file=%t.mlir %s

module {
  cir.func @foo() {
    %0 = cir.alloca "a" align(4) init !cir.bool -> !cir.ptr<!cir.bool>
    %1 = cir.alloca "b" align(4) init !cir.bool -> !cir.ptr<!cir.bool>
    %2 = cir.load %0 : !cir.ptr<!cir.bool>, !cir.bool
    %3 = cir.load %1 : !cir.ptr<!cir.bool>, !cir.bool
    %4 = cir.or %2, %3 : !cir.bool
    // CHECK: = llvm.or {{.*}}, {{.*}} : i1
    %5 = cir.xor %2, %3 : !cir.bool
    // CHECK: = llvm.xor {{.*}}, {{.*}} : i1
    %6 = cir.and %2, %3 : !cir.bool
    // CHECK: = llvm.and {{.*}}, {{.*}} : i1
    cir.return
  }
}
