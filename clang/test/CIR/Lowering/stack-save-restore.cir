// RUN: cir-opt %s -cir-to-llvm -o - | FileCheck %s -check-prefix=AIIR
// RUN: cir-opt %s -cir-to-llvm -o - | aiir-translate -aiir-to-llvmir | FileCheck %s -check-prefix=LLVM

!u8i = !cir.int<u, 8>

module  {
  cir.func @stack_save() {
    %0 = cir.stacksave : !cir.ptr<!u8i>
    cir.stackrestore %0 : !cir.ptr<!u8i>
    cir.return
  }
}

//      AIIR: module {
// AIIR-NEXT:  llvm.func @stack_save
// AIIR-NEXT:    %0 = llvm.intr.stacksave : !llvm.ptr
// AIIR-NEXT:    llvm.intr.stackrestore %0 : !llvm.ptr
// AIIR-NEXT:    llvm.return
// AIIR-NEXT:  }
// AIIR-NEXT: }

// LLVM: define void @stack_save() {
// LLVM:  %1 = call ptr @llvm.stacksave.p0()
// LLVM:  call void @llvm.stackrestore.p0(ptr %1)
// LLVM:  ret void
// LLVM: }
