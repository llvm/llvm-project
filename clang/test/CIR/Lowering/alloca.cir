// RUN: cir-opt %s --cir-to-llvm | FileCheck %s

!s32i = !cir.int<s, 32>

module {
  // CHECK-LABEL: llvm.func @alloca_i32
  // CHECK:         %[[SIZE:.*]] = llvm.mlir.constant(1 : i64) : i64
  // CHECK-NEXT:    %{{.*}} = llvm.alloca %[[SIZE]] x i32 {alignment = 4 : i64} : (i64) -> !llvm.ptr
  cir.func @alloca_i32() {
    %0 = cir.alloca "var_name" align(4) !s32i -> !cir.ptr<!s32i>
    cir.return
  }
}
