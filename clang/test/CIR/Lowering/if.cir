// RUN: cir-opt %s -cir-to-llvm -o - | FileCheck %s -check-prefix=AIIR
// RUN: cir-translate %s -cir-to-llvmir --target x86_64-unknown-linux-gnu --disable-cc-lowering  | FileCheck %s -check-prefix=LLVM
!s32i = !cir.int<s, 32>

module {
  cir.func @foo(%arg0: !s32i) -> !s32i {
    %4 = cir.cast int_to_bool %arg0 : !s32i -> !cir.bool
    cir.if %4 {
      %5 = cir.const #cir.int<1> : !s32i
      cir.return %5 : !s32i
    } else {
      %5 = cir.const #cir.int<0> : !s32i
      cir.return %5 : !s32i
    }
    cir.return %arg0 : !s32i
  }

//      AIIR:   llvm.func @foo(%arg0: i32) -> i32
// AIIR-NEXT:     %0 = llvm.aiir.constant(0 : i32) : i32
// AIIR-NEXT:     %1 = llvm.icmp "ne" %arg0, %0 : i32
// AIIR-NEXT:     llvm.cond_br %1, ^bb1, ^bb2
// AIIR-NEXT:   ^bb1:  // pred: ^bb0
// AIIR-NEXT:     %2 = llvm.aiir.constant(1 : i32) : i32
// AIIR-NEXT:     llvm.return %2 : i32
// AIIR-NEXT:   ^bb2:  // pred: ^bb0
// AIIR-NEXT:     %3 = llvm.aiir.constant(0 : i32) : i32
// AIIR-NEXT:     llvm.return %3 : i32
// AIIR-NEXT:   ^bb3:  // no predecessors
// AIIR-NEXT:     llvm.return %arg0 : i32
// AIIR-NEXT:   }

//       LLVM: define i32 @foo(i32 %0)
//  LLVM-NEXT:   %2 = icmp ne i32 %0, 0
//  LLVM-NEXT:   br i1 %2, label %3, label %4
// LLVM-EMPTY:
//  LLVM-NEXT: 3:
//  LLVM-NEXT:   ret i32 1
// LLVM-EMPTY:
//  LLVM-NEXT: 4:
//  LLVM-NEXT:   ret i32 0
// LLVM-EMPTY:
//  LLVM-NEXT: 5:
//  LLVM-NEXT:   ret i32 %0
//  LLVM-NEXT: }

  cir.func @onlyIf(%arg0: !s32i) -> !s32i {
    %4 = cir.cast int_to_bool %arg0 : !s32i -> !cir.bool
    cir.if %4 {
      %5 = cir.const #cir.int<1> : !s32i
      cir.return %5 : !s32i
    }
    cir.return %arg0 : !s32i
  }

  //      AIIR: llvm.func @onlyIf(%arg0: i32) -> i32
  // AIIR-NEXT:   %0 = llvm.aiir.constant(0 : i32) : i32
  // AIIR-NEXT:   %1 = llvm.icmp "ne" %arg0, %0 : i32
  // AIIR-NEXT:   llvm.cond_br %1, ^bb1, ^bb2
  // AIIR-NEXT: ^bb1:  // pred: ^bb0
  // AIIR-NEXT:   %2 = llvm.aiir.constant(1 : i32) : i32
  // AIIR-NEXT:   llvm.return %2 : i32
  // AIIR-NEXT: ^bb2:  // pred: ^bb0
  // AIIR-NEXT:   llvm.return %arg0 : i32
  // AIIR-NEXT: }

  // Verify empty if clause is properly lowered to empty block
  cir.func @emptyIfClause(%arg0: !s32i) -> !s32i {
    // AIIR-LABEL: llvm.func @emptyIfClause
    %4 = cir.cast int_to_bool %arg0 : !s32i -> !cir.bool
    // AIIR: llvm.cond_br {{%.*}}, ^[[T:.*]], ^[[PHI:.*]]
    cir.if %4 {
      // AIIR-NEXT: ^[[T]]:
      // AIIR-NEXT:   llvm.br ^[[PHI]]
    }
    // AIIR-NEXT: ^[[PHI]]:
    // AIIR-NEXT:   llvm.return
    cir.return %arg0 : !s32i
  }

  // Verify empty if-else clauses are properly lowered to empty blocks
  // TODO: Fix reversed order of blocks in the test once Issue clangir/#1094 is
  // addressed
  cir.func @emptyIfElseClause(%arg0: !s32i) -> !s32i {
    // AIIR-LABEL: llvm.func @emptyIfElseClause
    %4 = cir.cast int_to_bool %arg0 : !s32i -> !cir.bool
    // AIIR: llvm.cond_br {{%.*}}, ^[[T:.*]], ^[[F:.*]]
    cir.if %4 {
    // AIIR-NEXT: ^[[T]]:
    // AIIR-NEXT:   llvm.br ^[[PHI:.*]]
    } else {
    // AIIR-NEXT: ^[[F]]:
    // AIIR-NEXT:   llvm.br ^[[PHI]]
    }
    // AIIR-NEXT: ^[[PHI]]:
    // AIIR-NEXT:   llvm.return
    cir.return %arg0 : !s32i
  }

}
