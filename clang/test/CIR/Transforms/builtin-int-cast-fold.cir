// RUN: cir-opt -cir-canonicalize -o %t.cir %s
// RUN: FileCheck --input-file=%t.cir %s

!s32i = !cir.int<s, 32>

module {
  // A round-trip cast (CIR -> builtin -> CIR back to the original type)
  // folds away, returning the original value.
  cir.func @roundtrip(%arg0: !s32i) -> !s32i {
    %0 = cir.builtin_int_cast %arg0 : !s32i -> i32
    %1 = cir.builtin_int_cast %0 : i32 -> !s32i
    cir.return %1 : !s32i
  }

  // CHECK: cir.func{{.*}} @roundtrip(%[[ARG:.+]]: !s32i) -> !s32i {
  // CHECK-NEXT:   cir.return %[[ARG]] : !s32i
  // CHECK-NEXT: }

  // A round-trip that returns to a *different* CIR type must not fold.
  cir.func @no_fold_diff_type(%arg0: i32) -> !s32i {
    %0 = cir.builtin_int_cast %arg0 : i32 -> !s32i
    cir.return %0 : !s32i
  }

  // CHECK: cir.func{{.*}} @no_fold_diff_type(%[[ARG2:.+]]: i32) -> !s32i {
  // CHECK-NEXT:   %[[CAST:.+]] = cir.builtin_int_cast %[[ARG2]] : i32 -> !s32i
  // CHECK-NEXT:   cir.return %[[CAST]] : !s32i
  // CHECK-NEXT: }
}
