void test_broadcast_shuffle(short3 s3, ushort8 us8, short16 s16) {
  (void)intel_sub_group_broadcast(s3, 1u);
  (void)intel_sub_group_broadcast(us8, 1u);
  (void)intel_sub_group_shuffle(s16, 1u);
  (void)intel_sub_group_shuffle_xor(us8, 1u);
  (void)intel_sub_group_shuffle_down(s16, s16, 1u);
  (void)intel_sub_group_shuffle_up(us8, us8, 1u);
}

