void test_broadcast_shuffle(char3 c3, uchar8 uc8, char16 c16) {
  (void)intel_sub_group_broadcast(c3, 1u);
  (void)intel_sub_group_broadcast(uc8, 1u);
  (void)intel_sub_group_shuffle(c16, 1u);
  (void)intel_sub_group_shuffle_xor(uc8, 1u);
  (void)intel_sub_group_shuffle_down(c16, c16, 1u);
  (void)intel_sub_group_shuffle_up(uc8, uc8, 1u);
}

