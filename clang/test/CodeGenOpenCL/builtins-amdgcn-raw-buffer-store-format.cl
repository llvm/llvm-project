// CHECK-NEXT:    ret void
//
void test_raw_buffer_store_format_v4f32(v4f32 vdata, __amdgpu_buffer_rsrc_t rsrc) {
  __builtin_amdgcn_raw_buffer_store_format_v4f32(vdata, rsrc,0, 0, 0);
}

