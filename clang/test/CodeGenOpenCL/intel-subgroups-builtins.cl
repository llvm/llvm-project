  intel_sub_group_block_write4(rwimg, coord, value4);
  intel_sub_group_block_write8(rwimg, coord, value8);

  intel_sub_group_block_write_ui(woimg, coord, value);
  intel_sub_group_block_write_ui4(rwimg, coord, value4);
}
