// Tests for clang-ssaf-linker command-line option validation.

// RUN: not clang-ssaf-linker 2>&1 \
// RUN:   | FileCheck %s --match-full-lines --check-prefix=NO-ARGS
// NO-ARGS:      clang-ssaf-linker{{(\.exe)?}}: Not enough positional command line arguments specified!
// NO-ARGS-NEXT: Must specify at least 1 positional argument: See: {{.*}}clang-ssaf-linker{{(\.exe)?}} --help
// NO-ARGS-NEXT: clang-ssaf-linker{{(\.exe)?}}: for the -o option: must be specified at least once!

// RUN: not clang-ssaf-linker %S/Inputs/tu-empty.json 2>&1 \
// RUN:   | FileCheck %s --match-full-lines --check-prefix=NO-OUTPUT
// NO-OUTPUT: clang-ssaf-linker{{(\.exe)?}}: for the -o option: must be specified at least once!

// RUN: not clang-ssaf-linker -o %t/output.json 2>&1 \
// RUN:   | FileCheck %s --match-full-lines --check-prefix=NO-INPUT
// NO-INPUT:      clang-ssaf-linker{{(\.exe)?}}: Not enough positional command line arguments specified!
// NO-INPUT-NEXT: Must specify at least 1 positional argument: See: {{.*}}clang-ssaf-linker{{(\.exe)?}} --help

