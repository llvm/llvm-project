  [[nodiscard]] _LIBCPP_AVAILABILITY_TE_ENVIRONMENT _LIBCPP_HIDE_FROM_ABI static text_encoding environment() {
#      if defined(_LIBCPP_WIN32API)
    return __get_locale_encoding(nullptr);
#      else
