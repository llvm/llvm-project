"""Rules for running lit tests."""

load("@bazel_skylib//lib:paths.bzl", "paths")
load("@rules_python//python:defs.bzl", _py_test = "py_test")

# Python helper that resolves a path against the .cfg file's own location.
# Injected into rendered lit.site.cfg files so that dirname substitutions
# (which lit_expand_template renders as cfg-relative paths) resolve to absolute
# runfiles paths at test runtime. Mirrors CMake's LLVM_LIT_PATH_FUNCTION from
# llvm/cmake/modules/AddLLVM.cmake.
_LIT_SITE_CFG_PATH_FUNCTION = (
    "import os\n" +
    "def path(p):\n" +
    "    if not p: return ''\n" +
    "    return os.path.abspath(os.path.join(os.path.dirname(__file__), p))\n"
)

_LIT_SITE_CFG_IN_HEADER = "# Autogenerated, do not edit.\n" + _LIT_SITE_CFG_PATH_FUNCTION

def _short_path_relpath(from_dir, to_dir):
    """Returns the relative path from from_dir to to_dir.

    Both arguments are runfiles-root-relative (short_path-style) directories.
    Any leading `..` segments that short_path uses for files in external repos
    are treated as ordinary components, so resolutions within the same repo
    (main<->main or external<->external) produce the correct relative path.
    """
    if from_dir == to_dir:
        return "."
    from_parts = [p for p in from_dir.split("/") if p]
    to_parts = [p for p in to_dir.split("/") if p]
    common = 0
    for i in range(min(len(from_parts), len(to_parts))):
        if from_parts[i] != to_parts[i]:
            break
        common += 1
    parts = [".."] * (len(from_parts) - common) + to_parts[common:]
    return "/".join(parts) if parts else "."

def _lit_expand_template_impl(ctx):
    out = ctx.outputs.out
    cfg_dir = paths.dirname(out.short_path)

    substitutions = {"@LIT_SITE_CFG_IN_HEADER@": _LIT_SITE_CFG_IN_HEADER}
    for key, value in ctx.attr.substitutions.items():
        if key in substitutions:
            fail("substitution %r conflicts with a built-in key" % key)
        substitutions[key] = value

    # dirname_anchors is a label_keyed_string_dict whose values are JSON-encoded
    # lists of placeholder strings. label_keyed_string_dict ships in stock
    # Bazel (unlike string_keyed_label_dict, which requires Bazel 9+), so the
    # macro inverts the user-facing `placeholder -> label` mapping into this
    # form before handing it to the rule.
    for anchor_target, placeholders_json in ctx.attr.dirname_anchors.items():
        files = anchor_target.files.to_list()
        if not files:
            fail("dirname_substitutions anchor %s yielded no files" %
                 anchor_target.label)

        # Each placeholder resolves to the dirname of the anchor file (via its
        # short_path); the file's content is irrelevant. A BUILD.bazel label is
        # the conventional pick because every package has one.
        anchor_dir = paths.dirname(files[0].short_path)
        rel = _short_path_relpath(cfg_dir, anchor_dir)
        rendered = "\" + path(\"%s\") + \"" % rel

        for placeholder in json.decode(placeholders_json):
            if placeholder in substitutions:
                fail("dirname substitution %r conflicts with another substitution" %
                     placeholder)

            # The upstream lit.site.cfg(.py).in templates write path-bearing
            # variables as bare string literals: `config.x = "@VAR@"`.
            # Substituting the inner placeholder with `" + path("rel") + "`
            # turns the line into `config.x = "" + path("rel") + ""`, which
            # evaluates at lit-load time to the absolute runfiles path
            # without modifying the template.
            substitutions[placeholder] = rendered

    ctx.actions.expand_template(
        template = ctx.file.template,
        output = out,
        substitutions = substitutions,
    )

    return [DefaultInfo(
        files = depset([out]),
    )]

_lit_expand_template = rule(
    implementation = _lit_expand_template_impl,
    doc = "Backing rule for the `lit_expand_template` macro; do not use directly.",
    attrs = {
        "dirname_anchors": attr.label_keyed_string_dict(
            doc = "Anchor label -> JSON-encoded list of placeholders. For " +
                  "each entry, the placeholders are replaced with a " +
                  "`path(\"rel\")` call resolving to the dirname of the " +
                  "anchor file at lit-load time. Built by the " +
                  "`lit_expand_template` macro from its " +
                  "`dirname_substitutions` argument.",
            allow_files = True,
        ),
        "out": attr.output(
            doc = "Generated lit.site.cfg(.py) file.",
            mandatory = True,
        ),
        "substitutions": attr.string_dict(
            doc = "Placeholder -> literal-string substitutions applied to " +
                  "the template. `@LIT_SITE_CFG_IN_HEADER@` is reserved.",
        ),
        "template": attr.label(
            allow_single_file = True,
            mandatory = True,
            doc = "Upstream lit.site.cfg(.py).in template to render.",
        ),
    },
)

def lit_expand_template(
        name,
        template,
        out,
        substitutions = None,
        dirname_substitutions = None,
        **kwargs):
    """Renders an upstream lit.site.cfg(.py).in template for Bazel.

    The upstream `.in` templates are kept unmodified. The macro:
    - injects a `path()` helper at the top via the `@LIT_SITE_CFG_IN_HEADER@`
      substitution slot,
    - replaces `@VAR@` placeholders listed in `substitutions` with literal
      strings, and
    - replaces each placeholder in `dirname_substitutions` with a
      `path("rel")` call that resolves at test runtime to the absolute
      runfiles path of the anchor file's directory.

    Args:
      name: target name.
      template: label of the upstream `.in` template.
      out: filename of the rendered `lit.site.cfg(.py)` to generate.
      substitutions: dict[str, str]. Placeholder -> literal substitution.
      dirname_substitutions: dict[str, label]. Placeholder -> label of a file
        whose containing directory the placeholder should resolve to. The
        label is typically a `//pkg:BUILD.bazel`; only its file's
        `short_path.dirname` is read. The macro inverts this to a
        `label_keyed_string_dict` keyed by anchor label, with JSON-encoded
        placeholder lists as values, so the rule works on Bazel versions
        without `string_keyed_label_dict`.
      **kwargs: forwarded to the underlying rule (e.g. `testonly`,
        `visibility`).
    """
    dirname_substitutions = dirname_substitutions or {}

    # Group placeholders by anchor label so the same label appears only once
    # in the label_keyed_string_dict.
    placeholders_by_anchor = {}
    for placeholder, anchor in dirname_substitutions.items():
        placeholders_by_anchor.setdefault(anchor, []).append(placeholder)
    dirname_anchors = {
        anchor: json.encode(sorted(placeholders))
        for anchor, placeholders in placeholders_by_anchor.items()
    }

    _lit_expand_template(
        name = name,
        template = template,
        out = out,
        substitutions = substitutions or {},
        dirname_anchors = dirname_anchors,
        **kwargs
    )

def lit_test(
        name,
        srcs,
        args = None,
        data = None,
        deps = None,
        py_test = _py_test,
        **kwargs):
    """Runs a single test file with LLVM's lit tool.

    Args:
      name: string. the name of the generated test target.
      srcs: label list. The files on which to run lit.
      args: string list. Additional arguments to pass to lit.
        Note that `-v` and the 'srcs' paths are added automatically.
      data: label list. Additional data dependencies of the test.
        Note that 'srcs' targets are added automatically.
      deps: label list. List of targets the test depends on.
      py_test: function. The py_test rule to use for the underlying test.
      **kwargs: additional keyword arguments.

    See https://llvm.org/docs/CommandGuide/lit.html for details on lit.
    """

    args = args or []
    data = data or []
    deps = deps or []
    py_test(
        name = name,
        srcs = [Label("//llvm:lit")],
        main = Label("//llvm:utils/lit/lit.py"),
        args = args + ["-v"] + ["$(rootpath %s)" % src for src in srcs],
        data = data + srcs,
        legacy_create_init = False,
        deps = deps + [Label("//llvm:lit")],
        **kwargs
    )
