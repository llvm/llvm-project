load("//llvm:lit_test.bzl", "lit_expand_template", "lit_test")

lit_expand_template(
    name = "lit_site_cfg",
    testonly = True,
    out = "lit.site.cfg",
    dirname_substitutions = {
        "@LLVM_BINARY_DIR@": "//llvm:BUILD.bazel",
        # //llvm/utils/lit ships no BUILD file, so anchor on a file that lives
        # there (its dirname is the lit tools dir we want).
        "@LLVM_LIT_TOOLS_DIR@": "//llvm:utils/lit/lit.py",
        "@LLVM_SOURCE_DIR@": "//llvm:BUILD.bazel",
        "@LLVM_TOOLS_DIR@": "//llvm:BUILD.bazel",
    },
    template = "lit.site.cfg.in",
)

[
    lit_test(
        name = "%s.test" % src,
        srcs = [src],
        data = [
            "check-tested-lit-timeout-ability",
            "lit.cfg",
            "lit.site.cfg",
            "//llvm:FileCheck",
            "//llvm:count",
            "//llvm:not",
            "//llvm:split-file",
        ] + glob(["Inputs/**"]),
    )
    for src in glob(
        ["**/*.py"],
        exclude = [
            "Inputs/**",
            "use-llvm-tool.py",  # TODO: debug and re-enable
        ],
    )
]
