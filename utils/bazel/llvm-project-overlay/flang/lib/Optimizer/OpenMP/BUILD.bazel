        "//flang/include/flang/Optimizer/Dialect/FIRCG:FIRCGHeaders",
        "//flang/include/flang/Optimizer/HLFIR:HLFIRHeaders",
        "//flang/include/flang/Optimizer/OpenMP:FlangOpenMPPassesIncGen",
        "//flang/include/flang/Optimizer/OpenMP:OpenMPHeaders",
        "//flang/include/flang/Optimizer/Support:FIRSupportHeaders",
        "//flang/include/flang/Optimizer/Transforms:TransformsHeaders",
        "//flang/lib/Optimizer/Analysis:FIRAnalysis",
