        "//mlir:ControlFlowDialect",
        "//mlir:DialectUtils",
        "//mlir:FuncDialect",
        "//mlir:IR",
        "//mlir:LLVMDialect",
        "//mlir:LoopLikeInterface",
        "//mlir:OpenMPDialect",
        "//mlir:OpenMPTransforms",
