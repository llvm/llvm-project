load("@rules_cc//cc:defs.bzl", "cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = [
        "layering_check",
    ],
)

licenses(["notice"])

cc_library(
    name = "flangPasses",
    srcs = glob(
        [
            "*.cpp",
            "*.h",
        ],
        allow_empty = True,
    ),
    deps = [
        "//flang:CommonHeaders",
        "//flang:SupportHeaders",
        "//flang/include/flang/Optimizer/CodeGen:CodeGenHeaders",
        "//flang/include/flang/Optimizer/Dialect:DialectHeaders",
        "//flang/include/flang/Optimizer/HLFIR:HLFIRHeaders",
        "//flang/include/flang/Optimizer/OpenACC:OpenACCHeaders",
        "//flang/include/flang/Optimizer/OpenMP:OpenMPHeaders",
        "//flang/include/flang/Optimizer/Passes:PassesHeaders",
        "//flang/include/flang/Optimizer/Transforms:TransformsHeaders",
        "//flang/lib/Optimizer/CodeGen:FIRCodeGen",
        "//flang/lib/Optimizer/HLFIR/Transforms:HLFIRTransforms",
        "//flang/lib/Optimizer/OpenACC/Transforms:FIROpenACCTransforms",
        "//flang/lib/Optimizer/OpenMP:FlangOpenMPTransforms",
        "//flang/lib/Optimizer/Transforms:FIRTransforms",
        "//flang/lib/Support:FortranSupport",
        "//llvm:Passes",
        "//llvm:Support",
        "//mlir:AllExtensions",
        "//mlir:ComplexToStandard",
        "//mlir:ConversionPasses",
        "//mlir:IR",
        "//mlir:LLVMIRTransforms",
        "//mlir:MathToFuncs",
        "//mlir:MathToLLVM",
        "//mlir:OpenMPTransforms",
        "//mlir:Pass",
        "//mlir:ReconcileUnrealizedCasts",
        "//mlir:RegisterAllDialects",
        "//mlir:SCFToControlFlow",
        "//mlir:Support",
        "//mlir:Transforms",
    ],
)
