load("@rules_cc//cc:defs.bzl", "cc_library")

package(
    default_visibility = ["//visibility:public"],
    features = [
        "layering_check",
    ],
)

licenses(["notice"])

cc_library(
    name = "FIRSupportHeaders",
    hdrs = glob(["*.h"]),
    strip_include_prefix = "/flang/include",
    deps = [
        "//flang:CommonHeaders",
        "//flang/include/flang/Optimizer/Dialect:DialectHeaders",
        "//llvm:Support",
        "//mlir:IR",
        "//mlir:Support",
    ],
)
