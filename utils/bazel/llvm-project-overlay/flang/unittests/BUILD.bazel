)

############################################################
# Evaluate -- non-gtest standalone binaries
############################################################

[
    cc_test(
        name = name,
        size = "small",
        srcs = [src],
        deps = [
            "//flang:CommonHeaders",
            "//flang:EvaluateHeaders",
            "//flang:ParserHeaders",
            "//flang:TestingHeaders",
            "//flang/lib/Testing:NonGTestTesting",
            "//llvm:Support",
        ],
    )
    for name, src in [
        ("EvaluateLeadingZeroBitCountTest", "Evaluate/leading-zero-bit-count.cpp"),
        ("EvaluateBitPopulationCountTest", "Evaluate/bit-population-count.cpp"),
        ("EvaluateUInt128Test", "Evaluate/uint128.cpp"),
    ]
]

