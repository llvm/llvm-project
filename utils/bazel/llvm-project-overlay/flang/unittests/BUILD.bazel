cc_test(
    name = "EvaluateRealTest",
    size = "small",
    srcs = [
        "Evaluate/real.cpp",
        "//flang/lib/Evaluate:host.h",
    ],
    # The real.cpp test relies on fenv.h floating-point exception trapping,
    # which requires C++ exceptions to be enabled (the runtime catches FP
    # signals).  The default flang library toolchain disables exceptions.
    copts = [
        "-fexceptions",
        "-frtti",
    ],
    deps = [
        "//flang:CommonHeaders",
        "//flang:DecimalHeaders",
        "//flang:EvaluateHeaders",
        "//flang:SemanticsHeaders",
        "//flang:TestingHeaders",
        "//flang/lib/Decimal:FortranDecimal",
        "//flang/lib/Evaluate:FortranEvaluate",
        "//flang/lib/Semantics:FortranSemantics",
        "//flang/lib/Testing:NonGTestTesting",
        "//llvm:Support",
    ],
)

cc_test(
    name = "EvaluateFoldingTest",
    size = "small",
    srcs = [
        "Evaluate/folding.cpp",
        # folding.cpp includes "../../lib/Evaluate/host.h", a private header
        # of //flang/lib/Evaluate:FortranEvaluate. Pull it into srcs here so
        # the test's own module owns it (same pattern as EvaluateRealTest).
        "//flang/lib/Evaluate:host.h",
    ],
    deps = [
        "//flang:CommonHeaders",
        "//flang:EvaluateHeaders",
        "//flang:ParserHeaders",
        "//flang:SemanticsHeaders",
        "//flang:SupportHeaders",
        "//flang:TestingHeaders",
        "//flang/lib/Evaluate:FortranEvaluate",
        "//flang/lib/Semantics:FortranSemantics",
        "//flang/lib/Support:FortranSupport",
        "//flang/lib/Testing:NonGTestTesting",
        "//llvm:Support",
    ],
)

