load("@rules_cc//cc:defs.bzl", "cc_test")

package(
    default_visibility = ["//visibility:public"],
    features = [
        "layering_check",
    ],
)

licenses(["notice"])

############################################################
# Common
############################################################

cc_test(
    name = "FlangCommonTests",
    size = "small",
    srcs = glob(["Common/*.cpp"]),
    deps = [
        "//flang:CommonHeaders",
        "//flang:SupportHeaders",
        "//flang/lib/Support:FortranSupport",
        "//llvm:Support",
        "//third-party/unittest:gtest",
        "//third-party/unittest:gtest_main",
    ],
)

