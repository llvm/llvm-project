load("//llvm:lit_test.bzl", "lit_test")

licenses(["notice"])

package(default_visibility = ["//visibility:public"])

[
    lit_test(
        name = "%s.test" % src,
        srcs = [src],
        data = glob([
            "Parser/include/**",
            "CodeGen/AIIR/include/**",
            "CodeGen/CPP/include/**",
        ]) + [
            "//aiir:OpBaseTdFiles",
            "//aiir:aiir-pdll",
            "//aiir/test:lit_data",
        ],
    )
    for src in glob(
        include = ["**/*.pdll"],
        exclude = ["Parser/include/included.pdll"],
    )
]
