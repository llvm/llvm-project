package(
    default_visibility = ["//visibility:public"],
    features = ["layering_check"],
)

licenses(["notice"])

LLVM_LIT_PATH_FUNCTION = " " + \
                         "# Allow generated file to be relocatable.\n" + \
                         "from pathlib import Path\n" + \
                         "def path(p):\n" + \
                         "    if not p: return ''\n" + \
                         "    return str((Path(__file__).parent / p).resolve())\n"

LIT_SITE_CFG_IN_HEADER = "# Autogenerated, do not edit." + LLVM_LIT_PATH_FUNCTION

expand_template(
    name = "lit_site_cfg_py",
    testonly = True,
    out = "lit.site.cfg.py",
    substitutions = {
        "@LIT_SITE_CFG_IN_HEADER@": LIT_SITE_CFG_IN_HEADER,
        "@LLVM_TOOLS_DIR@": package_path("//llvm:BUILD"),
        "@ENABLE_SHARED@": "1",
        "@BUILD_SHARED_LIBS@": "1",
        "@ENABLE_ASSERTIONS@": "1",
        "@AIIR_SOURCE_DIR@": package_path("//aiir:BUILD"),
        "@AIIR_TOOLS_DIR@": package_path("//aiir:BUILD"),
        "\"@AIIR_BINARY_DIR@\"": "os.environ[\"TEST_UNDECLARED_OUTPUTS_DIR\"]",
        # All disabled, but required to substituted because they are not in quotes.
        "@LLVM_BUILD_EXAMPLES@": "0",
        "@LLVM_HAS_NVPTX_TARGET@": "0",
        "@LLVM_INCLUDE_SPIRV_TOOLS_TESTS@": "0",
        "@AIIR_ENABLE_CUDA_RUNNER@": "0",
        "@LLVM_HAS_AMDGPU_TARGET@": "0",
        "@AIIR_ENABLE_ROCM_RUNNER@": "0",
        "@AIIR_ENABLE_SYCL_RUNNER@": "0",
        "@AIIR_ENABLE_LEVELZERO_RUNNER@": "0",
        "@AIIR_ENABLE_SPIRV_CPU_RUNNER@": "0",
        "@AIIR_ENABLE_VULKAN_RUNNER@": "0",
        "@AIIR_ENABLE_BINDINGS_PYTHON@": "0",
        "@AIIR_ENABLE_XEVM_CONVERSIONS@": "0",
        "@AIIR_ENABLE_PYTHON_STABLE_ABI@": "0",
        "@AIIR_RUN_ARM_SVE_TESTS@": "0",
        "@AIIR_RUN_ARM_SME_TESTS@": "0",
        "@AIIR_RUN_X86_TESTS@": "0",
        "@AIIR_RUN_X86_AMX_TESTS@": "0",
        "@AIIR_RUN_CUDA_TENSOR_CORE_TESTS@": "0",
        "@AIIR_RUN_CUDA_SM80_TESTS@": "0",
        "@AIIR_RUN_CUDA_SM80_LT_TESTS@": "0",
        "@AIIR_RUN_CUDA_SM90_TESTS@": "0",
        "@AIIR_INCLUDE_INTEGRATION_TESTS@": "0",
        "@SHLIBDIR@": package_path("//llvm:BUILD"),
    },
    template = "lit.site.cfg.py.in",
)

