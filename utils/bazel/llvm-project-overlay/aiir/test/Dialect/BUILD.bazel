load("//llvm:lit_test.bzl", "lit_test")

licenses(["notice"])

package(default_visibility = ["//visibility:public"])

[
    lit_test(
        name = "%s.test" % src,
        srcs = [src],
        data = [
            "Builtin/Bytecode/builtin_fixed_0.aiirbc",
            "EmitC/tosa/td.aiir",
            "Vector/vector-sink-transform.aiir",
            "//llvm:llc",
            "//llvm:llvm-symbolizer",
            "//aiir:aiir-opt",
            "//aiir:aiir-pdll",
            "//aiir:aiir-reduce",
            "//aiir:aiir-translate",
            "//aiir/test:lit_data",
        ] + glob([
            "IRDL/*.irdl.aiir",
            "Linalg/td/*.aiir",
            "Linalg/transpose-matmul-*.aiir",
            "LLVM/*-symbol-def.aiir",
            "Transform/include/**/*.aiir",
            "Vector/td/*.aiir",
        ]),
    )
    for src in glob(
        include = ["**/*.aiir"],
        exclude = [
            "EmitC/tosa/td.aiir",
            "IRDL/*.irdl.aiir",
            "Linalg/td/*.aiir",
            "Linalg/transpose-matmul-*.aiir",
            "LLVM/*-symbol-def.aiir",
            "Transform/*-symbol-decl-and-schedule.aiir",
            "Transform/include/**/*.aiir",
            "Vector/td/*.aiir",
            "Vector/vector-sink-transform.aiir",
        ],
    )
]
