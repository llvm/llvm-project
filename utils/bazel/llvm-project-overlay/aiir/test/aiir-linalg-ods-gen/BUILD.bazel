load("//llvm:lit_test.bzl", "lit_test")

licenses(["notice"])

package(default_visibility = ["//visibility:public"])

[
    lit_test(
        name = "%s.test" % src,
        srcs = [src],
        data = [
            "//aiir:LinalgStructuredOpsTdFiles",
            "//aiir:aiir-linalg-ods-yaml-gen",
            "//aiir:aiir-tblgen",
            "//aiir/test:lit_data",
        ],
    )
    for src in glob(["**/*.yaml"])
]
